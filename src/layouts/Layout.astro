---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SMMIA — Le module IA qui change tout",
  description = "En 3 mois, tu passes de zéro à freelance IA qui cartonne. 2 lives/semaine avec 5 experts. Communauté Focus."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Anti-FOUC — applique le theme avant le render
      (function() {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/logos/SMMIA-logo-transparent-v2.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link id="favicon-32" rel="icon" type="image/png" sizes="32x32" href="/images/logos/smmia-favicon-64.png" />
    <link id="favicon-192" rel="icon" type="image/png" sizes="192x192" href="/images/logos/smmia-favicon-512.png" />
    <link id="favicon-apple" rel="apple-touch-icon" sizes="180x180" href="/images/logos/smmia-favicon-180.png" />
    <link id="favicon-shortcut" rel="shortcut icon" href="/images/logos/smmia-favicon-64.png" />
    <script is:inline>
      // Swap favicon selon theme (dark/light)
      (function() {
        function setFavicon(theme) {
          var suffix = theme === 'light' ? '-light' : '';
          var map = {
            'favicon-32':       '/images/logos/smmia-favicon' + suffix + '-64.png',
            'favicon-192':      '/images/logos/smmia-favicon' + suffix + '-512.png',
            'favicon-apple':    '/images/logos/smmia-favicon' + suffix + '-180.png',
            'favicon-shortcut': '/images/logos/smmia-favicon' + suffix + '-64.png',
          };
          Object.keys(map).forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.href = map[id];
          });
        }
        try {
          var saved = localStorage.getItem('theme');
          setFavicon(saved === 'light' ? 'light' : 'dark');
        } catch(e) {}
        window.__swapFavicon = setFavicon;
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,500;1,9..144,600;1,9..144,700;1,9..144,900&family=JetBrains+Mono:wght@400;500;700&family=Archivo+Black&family=Unbounded:wght@700;800;900&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet" />
    <!-- styles imported in frontmatter -->
  </head>
  <body>
    <!-- Custom cursor -->
    <div id="cursor"></div>

    <!-- Modal images -->
    <div id="img-modal">
      <button id="modal-close">&#10005;</button>
      <img id="modal-img" src="" alt="Avis membre" />
    </div>

    <!-- Toggle thème en position fixed (coin top-right) -->
    <button id="theme-toggle" aria-label="Basculer thème clair / sombre" class="theme-toggle-fixed">
      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <style>
      .theme-toggle-fixed {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 999;
        width: 44px; height: 44px;
        border-radius: 50%;
        background: rgba(168, 85, 247, 0.14);
        border: 1.5px solid rgba(168, 85, 247, 0.55);
        color: #fff;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 4px 14px rgba(168, 85, 247, 0.25);
        transition: transform 0.3s, background 0.2s;
        padding: 0;
      }
      .theme-toggle-fixed:hover { transform: scale(1.08); background: rgba(168, 85, 247, 0.24); }
      .theme-toggle-fixed .icon-sun,
      .theme-toggle-fixed .icon-moon { position: absolute; transition: opacity 0.25s ease, transform 0.35s ease; }
      .theme-toggle-fixed .icon-moon { opacity: 1; }
      .theme-toggle-fixed .icon-sun  { opacity: 0; transform: rotate(-90deg); }
      :root[data-theme="light"] .theme-toggle-fixed .icon-sun  { opacity: 1; transform: rotate(0); }
      :root[data-theme="light"] .theme-toggle-fixed .icon-moon { opacity: 0; transform: rotate(90deg); }
      :root[data-theme="light"] .theme-toggle-fixed { color: #5B21B6; background: rgba(168, 85, 247, 0.1); border-color: rgba(124, 58, 237, 0.5); }
    </style>
    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch(e) {}
        if (typeof window.__swapFavicon === 'function') window.__swapFavicon(next);
      });
    </script>
    <slot />

    <script>
      // Custom cursor — uniquement sur desktop avec souris fine (skip mobile / touch)
      const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
      const cursor = document.getElementById('cursor');

      if (hasFinePointer && cursor) {
        let mouseX = -100, mouseY = -100;
        let curX = -100, curY = -100;
        let rafId = 0;
        let isMoving = false;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          if (!isMoving) {
            isMoving = true;
            animateCursor();
          }
        }, { passive: true });

        function animateCursor() {
          const lerp = 0.18;
          curX += (mouseX - curX) * lerp;
          curY += (mouseY - curY) * lerp;
          cursor.style.transform = `translate3d(${curX}px, ${curY}px, 0)`;
          // Stop le rAF quand le curseur est quasi-stable (économise CPU)
          if (Math.abs(mouseX - curX) < 0.5 && Math.abs(mouseY - curY) < 0.5) {
            isMoving = false;
            return;
          }
          rafId = requestAnimationFrame(animateCursor);
        }

        // Hover effect
        document.querySelectorAll('a, button, .btn-pill, .avis-card, .intervenant-card, .faq-item').forEach(el => {
          el.addEventListener('mouseenter', () => cursor.classList.add('hovering'));
          el.addEventListener('mouseleave', () => cursor.classList.remove('hovering'));
        });
      } else if (cursor) {
        cursor.style.display = 'none';
      }

      // Scroll animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.dataset.delay || '0';
            setTimeout(() => {
              el.classList.add('visible');
            }, parseFloat(delay) * 1000);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

      // Count-up
      function countUp(el: HTMLElement, target: number, duration: number = 1500, suffix: string = '') {
        const start = Date.now();
        const update = () => {
          const elapsed = Date.now() - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(update);
        };
        requestAnimationFrame(update);
      }

      const countObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const val = parseInt(el.dataset.countup || '0');
            const suffix = el.dataset.suffix || '';
            countUp(el, val, 1500, suffix);
            countObserver.unobserve(el);
          }
        });
      }, { threshold: 0.5 });

      document.querySelectorAll('[data-countup]').forEach(el => countObserver.observe(el as HTMLElement));

      // FAQ accordion
      document.querySelectorAll('.faq-item').forEach(item => {
        const btn = item.querySelector('.faq-btn');
        const answer = item.querySelector('.faq-answer');
        const chevron = item.querySelector('.faq-chevron');
        btn?.addEventListener('click', () => {
          const isOpen = answer?.classList.contains('open');
          document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
          document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotated'));
          if (!isOpen) {
            answer?.classList.add('open');
            chevron?.classList.add('rotated');
          }
        });
      });

      // Modal
      const modal = document.getElementById('img-modal');
      const modalImg = document.getElementById('modal-img') as HTMLImageElement;
      const modalClose = document.getElementById('modal-close');

      document.querySelectorAll('.avis-card img').forEach(img => {
        img.addEventListener('click', () => {
          if (modal && modalImg) {
            modalImg.src = (img as HTMLImageElement).src;
            modal.classList.add('active');
          }
        });
      });

      modalClose?.addEventListener('click', () => modal?.classList.remove('active'));
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('active');
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') modal?.classList.remove('active');
      });

      // Navbar scroll effect — passif + rAF-throttled
      const navbar = document.getElementById('navbar');
      let scrollRaf = 0;
      window.addEventListener('scroll', () => {
        if (scrollRaf) return;
        scrollRaf = requestAnimationFrame(() => {
          if (window.scrollY > 100) navbar?.classList.add('scrolled');
          else navbar?.classList.remove('scrolled');
          scrollRaf = 0;
        });
      }, { passive: true });

      // ═══════════════════════════════════════════════════════════════════
      // FIX CRASH CHROME STATUS_BREAKPOINT — 2026-04-21 (v2)
      // Pause animations CSS des sections hors viewport (marquees, pulses,
      // rings, spins, filter-blur halos) en togglant .in-view sur <section>.
      // CSS: les règles `section:not(.in-view) .xxx { animation-play-state: paused }`
      // arrêtent le compositor/GPU pour les sections invisibles.
      // rootMargin réduit à 0 — plus agressif — pour vraiment couper les
      // animations qui ne sont pas à l'écran pendant un scroll rapide.
      // ═══════════════════════════════════════════════════════════════════
      const sectionIO = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) e.target.classList.add('in-view');
          else e.target.classList.remove('in-view');
        });
      }, { rootMargin: '0px 0px', threshold: 0 });
      document.querySelectorAll('section').forEach((s) => sectionIO.observe(s));

      // Footer observer (pause ft-online-dot hors viewport)
      const footerEl = document.querySelector('footer');
      if (footerEl) {
        const ftIO = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) document.body.classList.add('footer-in-view');
            else document.body.classList.remove('footer-in-view');
          });
        }, { rootMargin: '0px', threshold: 0 });
        ftIO.observe(footerEl);
      }
    </script>

    <style>
      #navbar.scrolled {
        border-bottom: 1px solid rgba(168,85,247,0.3);
      }
    </style>
  </body>
</html>
