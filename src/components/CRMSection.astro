    left.appendChild(trow);left.appendChild(sub);
    const btn=document.createElement('button');btn.className='cb';btn.style.cssText='font-size:.72rem;padding:6px 12px;flex-shrink:0;';btn.textContent='▶ Voir';
    btn.addEventListener('click',e=>{e.stopPropagation();openPlayer(i);});
    row.appendChild(thumb);row.appendChild(left);row.appendChild(btn);
    c.appendChild(row);
  });
}
function openPlayer(i){
  rpIdx=i;rpElapsed=0;rpOn=false;clearInterval(rpTimer);
  const r=RP_DATA[i];
  hide('rp-list-view');show('rp-player-view');
  el('rp-thumb-title').textContent=r.t;
  el('rp-player-label').textContent=r.t;
  el('rp-time').textContent='0:00 / '+r.d;
  el('rp-fill').style.width='0%';
  // Background thumbnail image du live
  if(r.img){
    el('rp-thumb').style.background='linear-gradient(180deg,rgba(10,4,19,0.45),rgba(10,4,19,0.85)),url("'+r.img+'") center/cover';
  } else {
    el('rp-thumb').style.background='linear-gradient(135deg,#0a0a0a,#1a0a2e)';
  }
  el('rp-thumb').style.display='flex';
  el('rp-live').style.display='none';
  el('rp-play-icon').innerHTML='<polygon points="5 3 19 12 5 21 5 3"/>';
}
function togglePlay(){
  const r=RP_DATA[rpIdx];rpOn=!rpOn;
  if(rpOn){
    el('rp-thumb').style.display='none';
    el('rp-live').style.display='flex';
    el('rp-now').textContent=r.t.replace(/Live \d+ — /,'');
    el('rp-play-icon').innerHTML='<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>';
    rpTimer=setInterval(()=>{
      rpElapsed++;if(rpElapsed>=r.ds){clearInterval(rpTimer);rpOn=false;return;}
      el('rp-fill').style.width=(rpElapsed/r.ds*100)+'%';
      el('rp-time').textContent=fmt(rpElapsed)+' / '+r.d;
    },1000);
  } else {
    clearInterval(rpTimer);
    el('rp-play-icon').innerHTML='<polygon points="5 3 19 12 5 21 5 3"/>';
  }
}
el('rp-btn-play').addEventListener('click',togglePlay);
el('rp-play-big').addEventListener('click',togglePlay);
el('rp-track').addEventListener('click',e=>{
  const r=RP_DATA[rpIdx];
  const rect=el('rp-track').getBoundingClientRect();
  const pct=(e.clientX-rect.left)/rect.width;
  rpElapsed=Math.round(pct*r.ds);
  el('rp-fill').style.width=(pct*100)+'%';
  el('rp-time').textContent=fmt(rpElapsed)+' / '+r.d;
});
el('btn-rp-back').addEventListener('click',()=>{clearInterval(rpTimer);rpOn=false;hide('rp-player-view');show('rp-list-view');});
renderReplays();
</script>
