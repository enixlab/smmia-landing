---
import BrandFloatingIcons from './BrandFloatingIcons.astro';
---

<section id="crm" class="crm-section" style="position:relative;overflow:hidden;">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:500px;background:radial-gradient(ellipse,rgba(168,85,247,0.07),transparent 70%);pointer-events:none;"></div>
  <BrandFloatingIcons icons={["TikTok", "Facebook", "YouTube", "Shopify"]} />

  <div style="max-width:1040px;margin:0 auto;padding:0 24px;position:relative;z-index:2;">
    <div style="text-align:center;margin-bottom:64px;" data-animate>
      <div style="display:inline-flex;align-items:center;gap:8px;padding:7px 16px;background:rgba(168,85,247,0.12);border:1px solid rgba(168,85,247,0.35);border-radius:9999px;font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:#C4B5FD;font-weight:700;margin-bottom:24px;">Accès membre exclusif</div>
      <h2 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:900;letter-spacing:-0.03em;margin-bottom:16px;line-height:1.1;">Ton Accès Exclusif <span style="color:#A855F7;">en un clic</span></h2>
      <p style="font-size:1rem;color:rgba(255,255,255,0.5);max-width:520px;margin:0 auto;">Clique sur chaque section pour voir comment ça marche en vrai.</p>
    </div>

    <div id="crm-shell" style="border:1px solid rgba(168,85,247,0.3);border-radius:20px;overflow:hidden;background:linear-gradient(135deg,#140828 0%,#0a0413 100%);box-shadow:0 20px 60px rgba(168,85,247,0.18),0 0 0 1px rgba(168,85,247,0.1),inset 0 1px 0 rgba(255,255,255,0.06);" data-animate data-delay="0.1">
      <div style="padding:11px 20px;border-bottom:1px solid rgba(168,85,247,0.12);display:flex;align-items:center;gap:8px;background:linear-gradient(180deg,rgba(168,85,247,0.08) 0%,rgba(0,0,0,0.3) 100%);">
        <div style="width:10px;height:10px;border-radius:50%;background:#6D28D9;box-shadow:0 0 4px rgba(109,40,217,0.6);"></div>
        <div style="width:10px;height:10px;border-radius:50%;background:#A855F7;box-shadow:0 0 4px rgba(168,85,247,0.6);"></div>
        <div style="width:10px;height:10px;border-radius:50%;background:#C084FC;box-shadow:0 0 4px rgba(192,132,252,0.6);"></div>
        <span style="margin-left:12px;font-size:0.73rem;color:rgba(196,181,253,0.5);font-family:'IBM Plex Mono',monospace;letter-spacing:0.02em;">smmia.app/dashboard</span>
        <div style="margin-left:auto;display:flex;align-items:center;gap:6px;padding:3px 10px;border-radius:999px;background:rgba(168,85,247,0.12);border:1px solid rgba(168,85,247,0.3);"><div style="width:6px;height:6px;border-radius:50%;background:#C084FC;box-shadow:0 0 8px #A855F7;animation:blink 1.8s infinite;"></div><span style="font-size:0.64rem;color:#DDD6FE;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">Connecté</span></div>
      </div>

      <div class="crm-layout" style="display:grid;grid-template-columns:190px 1fr;min-height:480px;">
        <div class="crm-sidebar" style="border-right:1px solid rgba(168,85,247,0.12);background:linear-gradient(180deg,rgba(26,13,51,0.7) 0%,rgba(15,6,33,0.85) 100%);display:flex;flex-direction:column;">
          <div class="crm-sidebar-logo" style="padding:18px 16px 14px;border-bottom:1px solid rgba(255,255,255,0.04);">
            <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" class="crm-logo-dark" style="width:76px;height:auto;" />
            <img src="/images/logos/SMMIA-logo-light.png" alt="SMMIA" class="crm-logo-light" style="width:96px;height:auto;display:none;" />
          </div>
          <div class="crm-menu" style="padding:12px 8px;flex:1;">
            <div class="crm-menu-label" style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.2);padding:0 8px;margin-bottom:6px;">Menu</div>
            <div class="si active" data-p="portfolio">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
              Portfolio
            </div>
            <div class="si" data-p="services">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              Services Prime
            </div>
            <div class="si" data-p="audit">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              Audit IA
            </div>
            <div class="si" data-p="clients">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Portefeuille
            </div>
            <div class="si" data-p="replays">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
              Replays
            </div>
            <div class="crm-menu-sep" style="margin:10px 0;border-top:1px solid rgba(255,255,255,0.04);"></div>
            <div class="si si-lock" data-p="mystery">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              ???
              <span style="margin-left:auto;font-size:0.58rem;padding:1px 6px;background:rgba(168,85,247,0.2);border-radius:9999px;color:#A855F7;">Soon</span>
            </div>
            <div class="si si-lock" data-p="mystery">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              ???
              <span style="margin-left:auto;font-size:0.58rem;padding:1px 6px;background:rgba(168,85,247,0.2);border-radius:9999px;color:#A855F7;">Soon</span>
            </div>
          </div>
          <div class="crm-sidebar-profile" style="padding:12px 16px;border-top:1px solid rgba(168,85,247,0.12);background:rgba(168,85,247,0.04);">
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#C084FC 0%,#A855F7 50%,#7C3AED 100%);border:1.5px solid rgba(255,255,255,0.18);display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:800;color:#fff;box-shadow:0 4px 12px rgba(168,85,247,0.5);">TN</div>
              <div><div style="font-size:0.75rem;color:#fff;font-weight:700;line-height:1.2;">Toi · Niveau 1</div><div style="font-size:0.62rem;color:#C4B5FD;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;">Membre Focus</div></div>
            </div>
          </div>
        </div>

        <div id="crm-main" style="overflow:hidden;position:relative;min-height:600px;">

          <!-- PORTFOLIO -->
          <div id="p-portfolio" class="pg" style="padding:28px;height:100%;overflow:auto;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
              <div><h3 style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:2px;">Nos réalisations</h3><p style="font-size:0.72rem;color:rgba(255,255,255,0.35);">Présente-les comme si c'était les tiennes</p></div>
              <button class="cb" id="btn-share-portfolio">⬆ Partager</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
              <div class="pc" data-id="0"><div class="pt pt-img"><img src="/images/services/bento/12-sites-web-SQUARE.webp" alt="Site Restaurant" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Site Restaurant</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Site web IA</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">1 200€</div></div></div>
              <div class="pc" data-id="1"><div class="pt pt-img"><img src="/images/services/bento/15-campagnes-ads-SQUARE.webp" alt="Meta Ads" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Meta Ads Salon</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Meta Ads</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">2 400€</div></div></div>
              <div class="pc" data-id="2"><div class="pt pt-img"><img src="/images/services/bento/11-visuels-SQUARE.webp" alt="Branding Barbershop" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Branding Barbershop</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Visuels Lovart</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">600€</div></div></div>
              <div class="pc" data-id="3"><div class="pt pt-img"><img src="/images/services/bento/15-campagnes-ads-SQUARE.webp" alt="Google Ads" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Google Ads Plombier</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Google Ads</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">1 800€</div></div></div>
              <div class="pc" data-id="4"><div class="pt pt-img"><img src="/images/services/bento/13-nfc-SQUARE.webp" alt="NFC Avis Google" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">NFC Avis Google</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">NFC justpush.fr</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">400€</div></div></div>
              <div class="pc" data-id="5"><div class="pt pt-img"><img src="/images/services/bento/16-crm-SQUARE.webp" alt="Automation N8N" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Automation N8N</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">N8N</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">3 200€</div></div></div>
              <div class="pc" data-id="6"><div class="pt pt-img"><img src="/images/services/bento/08-landing-pages-SQUARE.webp" alt="Landing Coach" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Landing Coach</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Landing Page IA</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">900€</div></div></div>
              <div class="pc" data-id="7"><div class="pt pt-img"><img src="/images/services/bento/17-whatsapp-SQUARE.webp" alt="WhatsApp Immo" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">WhatsApp Immobilier</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">WhatsApp API</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">700€</div></div></div>
              <div class="pc" data-id="8"><div class="pt pt-img"><img src="/images/services/bento/04-chatbot-sav-SQUARE.webp" alt="Chatbot E-com" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Chatbot E-commerce</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Chatbot IA</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">1 100€</div></div></div>
              <div class="pc" data-id="9"><div class="pt pt-img"><img src="/images/services/bento/05-generation-leads-SQUARE.webp" alt="Leads B2B" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">Leads B2B Saas</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Scrapping + Enrichissement</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">1 500€</div></div></div>
              <div class="pc" data-id="10"><div class="pt pt-img"><img src="/images/services/bento/06-videos-montages-SQUARE.webp" alt="UGC TikTok" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">UGC TikTok E-com</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">Vidéos IA</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">850€</div></div></div>
              <div class="pc" data-id="11"><div class="pt pt-img"><img src="/images/services/bento/19-seo-SQUARE.webp" alt="SEO Local" loading="lazy" /></div><div style="padding:10px;"><div style="font-size:0.78rem;font-weight:600;color:#fff;margin-bottom:2px;">SEO Local Dentiste</div><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:6px;">SEO Complet</div><div style="font-size:0.8rem;font-weight:700;color:#A855F7;">1 400€</div></div></div>
            </div>
          </div>

          <!-- SERVICES PRIME -->
          <div id="p-services" class="pg" style="display:none;padding:28px;height:100%;overflow:auto;">
            <div id="svc-list-view">
              <div style="margin-bottom:20px;"><h3 style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:2px;">Services Prime</h3><p style="font-size:0.72rem;color:rgba(255,255,255,0.35);">Tu vends. Prime livre. Tu gardes la marge.</p></div>
              <div style="display:flex;flex-direction:column;gap:8px;" id="svc-rows"></div>
            </div>
            <div id="svc-form-view" style="display:none;">
              <button class="cb-ghost" id="btn-svc-back" style="margin-bottom:16px;">← Retour</button>
              <div style="border:1px solid rgba(168,85,247,0.2);border-radius:14px;padding:24px;background:rgba(168,85,247,0.03);">
                <div style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:4px;" id="svc-form-title"></div>
                <div style="font-size:0.72rem;color:rgba(255,255,255,0.35);margin-bottom:20px;" id="svc-form-sub"></div>
                <div style="display:flex;flex-direction:column;gap:12px;">
                  <div><label style="font-size:0.72rem;color:rgba(255,255,255,0.5);display:block;margin-bottom:6px;">Nom du client</label><input class="cinput" type="text" placeholder="Ex: Salon Léa Beauty" id="svc-client" /></div>
                  <div><label style="font-size:0.72rem;color:rgba(255,255,255,0.5);display:block;margin-bottom:6px;">Brief (optionnel)</label><textarea class="cinput" rows="3" placeholder="Décris le projet rapidement..." id="svc-brief" style="resize:none;"></textarea></div>
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <div style="border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:14px;text-align:center;"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Coût Prime</div><div style="font-size:1.1rem;font-weight:700;color:#fff;" id="svc-cout"></div></div>
                    <div style="border:1px solid rgba(168,85,247,0.25);border-radius:10px;padding:14px;text-align:center;background:rgba(168,85,247,0.06);"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Ta marge min.</div><div style="font-size:1.1rem;font-weight:700;color:#A855F7;" id="svc-marge"></div></div>
                  </div>
                  <button class="cb" style="width:100%;padding:12px;" id="btn-svc-send">Envoyer la demande à Prime →</button>
                </div>
              </div>
            </div>
            <div id="svc-confirm-view" style="display:none;text-align:center;padding:40px 0;">
              <div style="width:56px;height:56px;border-radius:50%;background:rgba(168,85,247,0.12);border:1px solid rgba(168,85,247,0.35);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <svg width="24" height="24" fill="none" stroke="#A855F7" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:8px;">Demande envoyée à Prime ✓</div>
              <div style="font-size:0.8rem;color:rgba(255,255,255,0.4);max-width:280px;margin:0 auto 24px;">L'équipe Prime te contacte sous 2h. Notif WhatsApp en route.</div>
              <button class="cb-ghost" id="btn-svc-reset">Nouvelle demande</button>
            </div>
          </div>

          <!-- AUDIT IA -->
          <div id="p-audit" class="pg" style="display:none;padding:28px;height:100%;overflow:auto;">
            <div style="margin-bottom:20px;"><h3 style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:2px;">Audit Digital IA</h3><p style="font-size:0.72rem;color:rgba(255,255,255,0.35);">Analyse un prospect. Ferme-le avant le RDV.</p></div>
            <div id="audit-input-wrap">
              <div style="display:flex;gap:8px;margin-bottom:12px;">
                <input id="audit-url" class="cinput" type="text" placeholder="nomdusite.fr ou nom du business..." style="flex:1;" />
                <button class="cb" id="btn-audit-go">Analyser →</button>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center;">
                <span style="font-size:0.65rem;color:rgba(255,255,255,0.2);">Essaie :</span>
                <span class="audit-ex">lebistrot-paris.fr</span>
                <span class="audit-ex">salon-lea.com</span>
                <span class="audit-ex">plombier-marseille.fr</span>
              </div>
            </div>
            <div id="audit-loader-wrap" style="display:none;padding:24px 0;">
              <div style="font-size:0.82rem;font-weight:600;color:#fff;margin-bottom:12px;" id="audit-step-txt">Initialisation...</div>
              <div style="height:4px;background:rgba(255,255,255,0.06);border-radius:4px;overflow:hidden;margin-bottom:16px;"><div id="audit-prog" style="height:100%;width:0%;background:linear-gradient(90deg,#A855F7,#A855F7);border-radius:4px;transition:width 0.4s ease;"></div></div>
              <div id="audit-steps-done" style="display:flex;flex-direction:column;gap:5px;"></div>
            </div>
            <div id="audit-result-wrap" style="display:none;">
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px;">
                <div style="border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:12px;"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Google Business</div><div style="font-size:1.3rem;font-weight:900;color:#A855F7;">3/10</div><div style="height:3px;background:rgba(255,255,255,0.07);border-radius:2px;margin-top:6px;overflow:hidden;"><div style="height:100%;width:30%;background:#A855F7;border-radius:2px;"></div></div></div>
                <div style="border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:12px;"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Site Web</div><div style="font-size:1.3rem;font-weight:900;color:#A855F7;">5/10</div><div style="height:3px;background:rgba(255,255,255,0.07);border-radius:2px;margin-top:6px;overflow:hidden;"><div style="height:100%;width:50%;background:#A855F7;border-radius:2px;"></div></div></div>
                <div style="border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:12px;"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Réseaux Sociaux</div><div style="font-size:1.3rem;font-weight:900;color:#A855F7;">2/10</div><div style="height:3px;background:rgba(255,255,255,0.07);border-radius:2px;margin-top:6px;overflow:hidden;"><div style="height:100%;width:20%;background:#A855F7;border-radius:2px;"></div></div></div>
                <div style="border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:12px;"><div style="font-size:0.65rem;color:rgba(255,255,255,0.35);margin-bottom:4px;">Publicité Active</div><div style="font-size:1.3rem;font-weight:900;color:#A855F7;">0/10</div><div style="height:3px;background:rgba(255,255,255,0.07);border-radius:2px;margin-top:6px;"></div></div>
              </div>
              <div style="border:1px solid rgba(168,85,247,0.2);border-radius:10px;padding:14px;background:rgba(168,85,247,0.04);margin-bottom:12px;">
                <div style="font-size:0.68rem;font-weight:700;color:#A855F7;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:6px;">Recommandation IA</div>
                <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);line-height:1.6;">Ce business perd des dizaines de clients chaque semaine. Zéro pub, réseaux inactifs, site daté. Opportunité claire : site + Google Ads. Potentiel estimé <strong style="color:#fff;">+2 400€/mois</strong>.</div>
              </div>
