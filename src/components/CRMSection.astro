const STEPS=['Recherche du domaine...','Analyse Google Business Profile...','Scan du site web...','Vérification réseaux sociaux...','Détection publicités actives...','Génération recommandations IA...'];
function runAudit(){
  const url=el('audit-url').value.trim();
  if(!url){el('audit-url').focus();return;}
  hide('audit-input-wrap');hide('audit-result-wrap');
  show('audit-loader-wrap');
  const bar=el('audit-prog'),lbl=el('audit-step-txt'),done=el('audit-steps-done');
  done.innerHTML='';bar.style.width='0%';
  let i=0;
  function next(){
    if(i>=STEPS.length){setTimeout(()=>{hide('audit-loader-wrap');show('audit-result-wrap');},400);return;}
    lbl.textContent=STEPS[i];
    const d=document.createElement('div');
    d.style.cssText='font-size:.72rem;color:rgba(255,255,255,.35);display:flex;align-items:center;gap:6px;';
    const ok=document.createElement('span');ok.style.cssText='color:#A855F7;font-size:.8rem;';ok.textContent='✓';
    const tx=document.createElement('span');tx.textContent=STEPS[i].replace(/^[🔍📍🌐📱📢🤖] /,'');
    d.appendChild(ok);d.appendChild(tx);done.appendChild(d);
    bar.style.width=Math.round((i+1)/STEPS.length*100)+'%';
    i++;setTimeout(next,600+Math.random()*400);
  }
  next();
}
function resetAudit(){
  el('audit-url').value='';
  show('audit-input-wrap');hide('audit-result-wrap');hide('audit-loader-wrap');
  hide('pdf-prog-wrap');
}
el('btn-audit-go').addEventListener('click',runAudit);
el('audit-url').addEventListener('keydown',e=>{if(e.key==='Enter')runAudit();});
document.querySelectorAll('.audit-ex').forEach(ex=>{
  ex.addEventListener('click',()=>{el('audit-url').value=ex.textContent;runAudit();});
});
el('btn-audit-new').addEventListener('click',resetAudit);
el('btn-audit-pdf').addEventListener('click',function(){
  this.disabled=true;this.textContent='Génération...';
  const pw=el('pdf-prog-wrap'),pb=el('pdf-bar'),pl=el('pdf-label');
  pw.style.display='block';pb.style.width='0%';
  const steps=['Mise en page...','Insertion scores...','Recommandations IA...','Finalisation PDF...'];
  let i=0;
  const self=this;
  function go(){
    if(i>=steps.length){pl.textContent='✓ Rapport PDF prêt — Téléchargement simulé';self.textContent='✓ PDF généré';self.disabled=false;return;}
    pl.textContent=steps[i];pb.style.width=(i+1)/steps.length*100+'%';i++;setTimeout(go,700);
  }
  go();
});

