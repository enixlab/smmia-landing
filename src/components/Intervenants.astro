---
const intervenants = [
  { nom: "Val", img: "val.png" },
  { nom: "Idriss", img: "idriss.png" },
  { nom: "Moubak", img: "moubak.png" },
  { nom: "Sonny", img: "sonny.png" },
  { nom: "Jamel", img: "jamel.jpg" },
];
---

<section id="intervenants" style="padding:100px 0;background:radial-gradient(ellipse 50% 30% at 50% 50%, rgba(168,85,247,0.04), transparent);">
  <div style="max-width:1100px;margin:0 auto;padding:0 24px;">

    <div style="text-align:center;margin-bottom:64px;">
      <h2 data-animate style="font-size:clamp(1.8rem,4.5vw,3.5rem);font-weight:900;letter-spacing:-0.03em;margin-bottom:16px;">
        5 experts. 1 seul objectif : te rendre rentable.
      </h2>
      <p data-animate data-delay="0.1" style="font-size:1rem;color:rgba(255,255,255,0.55);max-width:560px;margin:0 auto;">
        Fondateurs d'agences, créateurs de contenu, closers — ils vivent de l'IA.
      </p>
    </div>

    <div id="intervenants-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:32px;justify-items:center;">
      {intervenants.map((p, i) => (
        <div
          class="intervenant-card"
          data-animate
          data-delay={String(i * 0.1)}
          data-revealed="false"
          style="display:flex;flex-direction:column;align-items:center;gap:16px;cursor:pointer;"
        >
          <div style="position:relative;">
            <!-- Glow ring -->
            <div class="glow-ring" style="position:absolute;inset:-4px;border-radius:50%;background:linear-gradient(135deg,#A855F7,#E8442A);opacity:0.5;filter:blur(8px);transition:opacity 0.3s;z-index:0;"></div>
            <div style="position:relative;z-index:1;width:160px;height:160px;border-radius:50%;overflow:hidden;border:2px solid #A855F7;box-shadow:0 0 20px rgba(168,85,247,0.5);transition:box-shadow 0.3s,transform 0.3s;">
              <img
                class="card-img"
                src={`/images/intervenants/${p.img}`}
                alt={p.nom}
                style="width:100%;height:100%;object-fit:cover;display:block;"
              />
              <!-- Smoke overlay -->
              <div class="smoke-overlay">
                <div class="overlay-content">
                  <svg class="lock-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                  </svg>
                  <span class="reveal-hint">Cliquer pour révéler</span>
                </div>
              </div>
              <!-- Particules -->
              <div class="particles" aria-hidden="true">
                <span class="particle p1"></span>
                <span class="particle p2"></span>
                <span class="particle p3"></span>
                <span class="particle p4"></span>
              </div>
            </div>
          </div>
          <span class="card-name" style="font-size:1.1rem;font-weight:700;color:#fff;text-align:center;">{p.nom}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* --- État initial flou/fumée --- */
  .intervenant-card .card-img {
    filter: blur(8px);
    transition: filter 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .intervenant-card .smoke-overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(168,85,247,0.6) 0%, rgba(124,58,237,0.3) 50%, transparent 70%);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
  }

  .intervenant-card .overlay-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .intervenant-card .lock-icon {
    opacity: 1;
    transition: opacity 0.3s ease;
    filter: drop-shadow(0 0 6px rgba(168,85,247,0.8));
  }

  .intervenant-card .reveal-hint {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    text-align: center;
    letter-spacing: 0.02em;
    transition: opacity 0.3s ease;
    line-height: 1.3;
    max-width: 80px;
  }

  .intervenant-card .card-name {
    opacity: 0.3;
    filter: blur(3px);
    transition: opacity 0.5s ease 0.2s, filter 0.5s ease 0.2s;
  }

  /* Particules — cachées par défaut */
  .intervenant-card .particles {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }

  .intervenant-card .particle {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #A855F7;
    opacity: 0;
    box-shadow: 0 0 6px #A855F7;
  }

  .p1 { left: 30%; bottom: 20%; }
  .p2 { left: 60%; bottom: 30%; }
  .p3 { left: 45%; bottom: 10%; }
  .p4 { left: 75%; bottom: 25%; }

  /* --- État révélé --- */
  .intervenant-card.revealed .card-img {
    filter: blur(0);
  }

  .intervenant-card.revealed .smoke-overlay {
    opacity: 0;
    transform: scale(1.3) translateY(-10px);
    pointer-events: none;
  }

  .intervenant-card.revealed .lock-icon {
    opacity: 0;
  }

  .intervenant-card.revealed .reveal-hint {
    opacity: 0;
  }

  .intervenant-card.revealed .card-name {
    opacity: 1;
    filter: blur(0);
  }

  /* Animation particules au reveal */
  .intervenant-card.revealed .p1 {
    animation: float-particle 0.8s ease-out 0s forwards;
  }
  .intervenant-card.revealed .p2 {
    animation: float-particle 0.9s ease-out 0.1s forwards;
  }
  .intervenant-card.revealed .p3 {
    animation: float-particle 0.7s ease-out 0.05s forwards;
  }
  .intervenant-card.revealed .p4 {
    animation: float-particle 1s ease-out 0.15s forwards;
  }

  @keyframes float-particle {
    0% {
      opacity: 0.9;
      transform: translateY(0) scale(1);
    }
    60% {
      opacity: 0.6;
    }
    100% {
      opacity: 0;
      transform: translateY(-50px) scale(0.4);
    }
  }

  /* Hover sur carte non-révélée */
  .intervenant-card:not(.revealed):hover > div > div:last-child {
    box-shadow: 0 0 40px rgba(168,85,247,0.8) !important;
    transform: scale(1.05);
  }
  .intervenant-card:not(.revealed):hover > div > .glow-ring {
    opacity: 0.8 !important;
  }

  /* Hover sur carte révélée — effet normal */
  .intervenant-card.revealed:hover > div > div:nth-child(2) {
    box-shadow: 0 0 40px rgba(168,85,247,0.8) !important;
    transform: scale(1.05);
  }
  .intervenant-card.revealed:hover > div > .glow-ring {
    opacity: 0.8 !important;
  }

  @media (max-width: 900px) {
    #intervenants-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
  @media (max-width: 580px) {
    #intervenants-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    #intervenants-grid > div:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intervenant-card .card-img,
    .intervenant-card .smoke-overlay,
    .intervenant-card .card-name,
    .intervenant-card .lock-icon {
      transition: none;
    }
    .intervenant-card.revealed .p1,
    .intervenant-card.revealed .p2,
    .intervenant-card.revealed .p3,
    .intervenant-card.revealed .p4 {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.intervenant-card').forEach(card => {
    card.addEventListener('click', () => {
      const isRevealed = card.dataset.revealed === 'true';
      if (!isRevealed) {
        card.classList.add('revealed');
        card.dataset.revealed = 'true';
      }
    });
  });
</script>
