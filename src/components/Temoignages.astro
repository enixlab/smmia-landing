---

<section id="temoignages-premium" class="tp-section" aria-label="Témoignages">

  <!-- Décors fond -->
  <div class="tp-halo" aria-hidden="true"></div>
  <div class="tp-grid-bg" aria-hidden="true"></div>
  <div class="tp-noise" aria-hidden="true"></div>

  <div class="tp-inner">

    <!-- Header -->
    <header class="tp-header">
      <div class="tp-eyebrow" data-animate>
        <span class="tp-eyebrow-dot"></span>
        <span>Ils l'ont fait avant toi</span>
      </div>

      <h2 class="tp-title" data-animate data-delay="0.08">
        <span class="tp-title-line">Les résultats parlent</span>
        <span class="tp-title-line tp-title-line-2">plus fort que nous.</span>
      </h2>

      <p class="tp-sub" data-animate data-delay="0.18">
        14 membres. 14 métiers. 14 chiffres que tu peux vérifier.
      </p>

      <!-- Mini indicateur interactif -->
      <div class="tp-hint" data-animate data-delay="0.28">
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span>Clique une carte pour voir le détail</span>
      </div>
    </header>

    <!-- Grid asymétrique — 1 featured + 5 standard -->
    <div class="tp-grid">
      {testimonials.map((t, i) => (
        <article
          class={`tp-card ${t.featured ? 'tp-card-featured' : ''}`}
          data-animate
          data-delay={String(0.25 + i * 0.08)}
          data-before={t.rawBefore ?? t.beforeVal}
          data-after={t.afterVal}
          data-unit={t.unit}
          tabindex="0"
          role="button"
          aria-expanded="false"
        >
          <div class="tp-card-inner">

            <!-- Top row : avatar + identité + tag promo -->
            <div class="tp-top">
              <div class="tp-avatar" aria-hidden="true">
                <span class="tp-avatar-initials">{t.initials}</span>
              </div>
              <div class="tp-identity">
                <span class="tp-name">{t.name}</span>
                <span class="tp-role">{t.role}</span>
              </div>
              <span class="tp-since">{t.since}</span>
            </div>

            <!-- Quote -->
            <blockquote class="tp-quote">
              <span class="tp-quote-open" aria-hidden="true">"</span>
              <span class="tp-quote-text">{t.quote}</span>
            </blockquote>

            <!-- Contexte caché révélé à l'expand -->
            <p class="tp-context">
              <span class="tp-context-lbl">Contexte</span>
              {t.context}
            </p>

            <!-- Barre avant→après animée -->
            <div class="tp-bar">
              <div class="tp-bar-head">
                <span class="tp-bar-lbl">{t.beforeLabel}</span>
                <div class="tp-bar-values">
                  <span class="tp-bar-before">
                    {t.rawBefore ?? (t.beforeVal === 0 ? '0' : `${t.beforeVal}${t.unit}`)}
                  </span>
                  <svg class="tp-bar-arrow" viewBox="0 0 20 10" aria-hidden="true">
                    <path d="M1 5h18M19 5l-5-4M19 5l-5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  </svg>
                  <span class="tp-bar-after-val" data-countup data-target={t.afterVal} data-unit={t.unit}>
                    0{t.unit}
                  </span>
                </div>
              </div>
              <div class="tp-bar-track">
                <div class="tp-bar-fill" data-fill-ratio={t.beforeVal && t.beforeVal > 0 ? Math.min(100, (t.beforeVal / t.afterVal) * 100).toFixed(1) : "6"}></div>
                <div class="tp-bar-full"></div>
                <div class="tp-bar-pulse"></div>
              </div>
            </div>

            <!-- Footer : tags + metric -->
            <div class="tp-foot">
              <div class="tp-tags">
                {t.tags.map((tag) => (
                  <span class="tp-tag">{tag}</span>
                ))}
              </div>
              <div class="tp-metric">
                <span class="tp-metric-val">{t.delta}</span>
                <span class="tp-metric-lbl">{t.deltaLabel}</span>
              </div>
            </div>

            <!-- Expand indicator -->
            <button class="tp-expand" aria-label="Voir le détail" type="button">
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </button>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer trust mini -->
    <div class="tp-footer" data-animate data-delay="0.8">
      <span class="tp-footer-dot"></span>
      <span>Témoignages membres Focus — captures d'écran visibles dans la section précédente.</span>
    </div>

  </div>
</section>

<style>
  .tp-section {
    position: relative;
    background: #000;
    padding: 140px 24px 160px;
    overflow: hidden;
    isolation: isolate;
  }

  /* ===== Décors fond ===== */
  .tp-halo {
    position: absolute;
    top: 10%;
    left: 50%;
    width: 90%;
    max-width: 1400px;
    aspect-ratio: 2.5/1;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(168,85,247,0.22) 0%, rgba(139,92,246,0.10) 40%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }
  .tp-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168,85,247,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168,85,247,0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    z-index: 0;
    pointer-events: none;
  }
  .tp-noise {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  .tp-inner {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ===== Header ===== */
  .tp-header {
    text-align: center;
    margin-bottom: 64px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
  }
  .tp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168,85,247,0.08);
    border: 1px solid rgba(168,85,247,0.3);
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(216,180,254,0.9);
    margin-bottom: 26px;
  }
  .tp-eyebrow-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168,85,247,0.6);
    animation: tpPulse 2.2s ease-in-out infinite;
  }
  @keyframes tpPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(168,85,247,0.6); }
    50%     { box-shadow: 0 0 0 8px rgba(168,85,247,0); }
  }

  /* TITRE — aligné sur Hero : Inter 900 */
  .tp-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 6.2vw, 84px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: #fff;
    margin: 0 0 22px;
  }
  .tp-title-line { display: block; }
  .tp-title-line-2 {
    background: linear-gradient(180deg, #ffffff 0%, #d8b4fe 55%, #a855f7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 900;
  }

  .tp-sub {
    font-family: 'Inter', sans-serif;
    font-size: 16.5px;
    font-weight: 400;
    line-height: 1.55;
    color: rgba(255,255,255,0.6);
    margin: 0 auto 18px;
    max-width: 520px;
    letter-spacing: -0.005em;
  }
  .tp-hint {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(216,180,254,0.65);
    padding: 7px 14px;
    border-radius: 9999px;
    background: rgba(168,85,247,0.05);
    border: 1px solid rgba(168,85,247,0.2);
  }
  .tp-hint svg { flex-shrink: 0; }

  /* ===== Grid ===== */
  .tp-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 22px;
    margin-bottom: 72px;
  }

  .tp-card {
    position: relative;
    grid-column: span 2;
    border-radius: 22px;
    background: linear-gradient(160deg, rgba(168,85,247,0.055), rgba(12,6,26,0.88) 55%);
    border: 1px solid rgba(168,85,247,0.2);
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    transition: transform 0.5s cubic-bezier(0.2,0.8,0.2,1),
                border-color 0.4s ease,
                box-shadow 0.5s ease;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.04) inset,
      0 20px 50px -30px rgba(168,85,247,0.15);
  }
  .tp-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(140deg, rgba(216,180,254,0.4), transparent 35%, transparent 70%, rgba(168,85,247,0.25));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.55;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  /* Spotlight qui suit la souris */
  .tp-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 320px at var(--mx, 50%) var(--my, 50%), rgba(168,85,247,0.16), transparent 60%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    border-radius: inherit;
  }
  .tp-card:hover {
    border-color: rgba(168,85,247,0.42);
    transform: translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 28px 70px -30px rgba(168,85,247,0.55),
      0 0 0 1px rgba(216,180,254,0.18) inset;
  }
  .tp-card:hover::before { opacity: 1; }
  .tp-card:hover::after { opacity: 1; }
  .tp-card:focus-visible {
    outline: 2px solid rgba(216,180,254,0.8);
    outline-offset: 3px;
  }

  /* Featured — 4 colonnes */
  .tp-card-featured {
    grid-column: span 4;
    background: linear-gradient(135deg, rgba(168,85,247,0.14), rgba(12,6,26,0.92) 60%);
  }
  .tp-card-featured .tp-quote-text { font-size: clamp(19px, 1.75vw, 26px); }
  .tp-card-featured .tp-metric-val { font-size: clamp(28px, 2.8vw, 40px); }
  .tp-card-featured .tp-bar-after-val { font-size: 22px; }

  .tp-card-inner {
    position: relative;
    z-index: 2;
    padding: 26px 28px 22px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Top row */
  .tp-top {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
  }
  .tp-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a855f7, #7c3aed 80%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow:
      0 0 0 1px rgba(216,180,254,0.3),
      0 6px 16px -4px rgba(168,85,247,0.5);
  }
  .tp-avatar-initials {
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
  }
  .tp-identity {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .tp-name {
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.005em;
  }
  .tp-role {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: rgba(216,180,254,0.62);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tp-since {
    font-family: 'Inter', sans-serif;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(216,180,254,0.55);
    padding: 4px 10px;
    border-radius: 9999px;
    border: 1px solid rgba(168,85,247,0.22);
