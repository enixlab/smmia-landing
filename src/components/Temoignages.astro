    .tp-card { transform: none !important; }
    .tp-card.is-inview .tp-bar-full { width: 100%; }
  }
</style>

<script>
  // Spotlight qui suit la souris
  const cards = document.querySelectorAll<HTMLElement>('#temoignages-premium .tp-card');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        card.style.setProperty('--mx', `${x}%`);
        card.style.setProperty('--my', `${y}%`);
      }, { passive: true });
    });
  }

  // Click / keyboard pour expand
  cards.forEach((card) => {
    const toggle = () => {
      const isOpen = card.classList.toggle('is-open');
      card.setAttribute('aria-expanded', String(isOpen));
    };
    card.addEventListener('click', (e) => {
      // éviter de fermer quand on clique sur un lien interne plus tard
      if ((e.target as HTMLElement).closest('a')) return;
      toggle();
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  });

  // Reveal : barres animées + count-up quand la card entre dans le viewport
  function animateCard(card: HTMLElement) {
    if (card.dataset.animated === '1') return;
    card.dataset.animated = '1';
    card.classList.add('is-inview');

    // Count up du chiffre "après"
    const target = parseFloat(card.getAttribute('data-after') || '0');
    const unit = card.getAttribute('data-unit') || '';
    const el = card.querySelector<HTMLElement>('.tp-bar-after-val');
    if (!el) return;

    const hasDecimal = !Number.isInteger(target);
    const format = (v: number) => {
      if (unit === '€' && target >= 1000) {
        return Math.round(v).toLocaleString('fr-FR') + unit;
      }
      if (hasDecimal) {
        return v.toFixed(1).replace('.', ',') + unit;
      }
      return Math.round(v) + unit;
    };

    if (reduced) {
      el.textContent = format(target);
      return;
    }

    const duration = 1400;
    const start = performance.now();
    const step = (now: number) => {
      const p = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = format(eased * target);
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = format(target);
    };
    requestAnimationFrame(step);
  }

  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        animateCard(e.target as HTMLElement);
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.35 });

  cards.forEach((c) => io.observe(c));
</script>
