---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- ============ SCÈNE FUTURISTE ============ -->
  <div class="hero-galaxy" aria-hidden="true">
    <div class="galaxy-deep"></div>
    <div class="galaxy-stars"></div>
    <div class="galaxy-nebula galaxy-nebula--a"></div>
    <div class="galaxy-nebula galaxy-nebula--b"></div>

    <!-- Grid perspective floor (cyberpunk/futuriste) -->
    <div class="grid-floor" aria-hidden="true"></div>

    <!-- Scan lines subtiles -->
    <div class="scan-lines" aria-hidden="true"></div>

    <!-- GLOBE WIREFRAME 3D + HUD -->
    <div class="orb-scene">

      <!-- Glow externe -->
      <div class="orb-glow"></div>

      <!-- Aura "expose" (anneaux qui partent de l'orb) -->
      <div class="orb-expose orb-expose--1"></div>
      <div class="orb-expose orb-expose--2"></div>

      <!-- Orbital rings 3D inclinés (rotation en boucle) -->
      <div class="orb-ring orb-ring--1"></div>
      <div class="orb-ring orb-ring--2"></div>
      <div class="orb-ring orb-ring--3"></div>

      <!-- GLOBE (méridiens + parallèles CSS 3D) -->
      <div class="globe-3d">
        <div class="globe-spin">
          <!-- 8 méridiens (rotateY espacés de 22.5°) -->
          <div class="meridian" style="--a:0deg"></div>
          <div class="meridian" style="--a:22.5deg"></div>
          <div class="meridian" style="--a:45deg"></div>
          <div class="meridian" style="--a:67.5deg"></div>
          <div class="meridian" style="--a:90deg"></div>
          <div class="meridian" style="--a:112.5deg"></div>
          <div class="meridian" style="--a:135deg"></div>
          <div class="meridian" style="--a:157.5deg"></div>
        </div>
        <!-- 5 parallèles fixes (ellipses horizontales) -->
        <div class="parallel" style="--y:-78px;--rx:38px"></div>
        <div class="parallel" style="--y:-42px;--rx:68px"></div>
        <div class="parallel" style="--y:0;--rx:82px"></div>
        <div class="parallel" style="--y:42px;--rx:68px"></div>
        <div class="parallel" style="--y:78px;--rx:38px"></div>
        <!-- Core glow au centre -->
        <div class="globe-core"></div>
        <!-- 3 markers avec target -->
        <div class="globe-target globe-target--1">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
        <div class="globe-target globe-target--2">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
        <div class="globe-target globe-target--3">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
      </div>

      <!-- HUD overlay -->
      <div class="hud hud--tl">
        <div class="hud-bracket"></div>
        <div class="hud-label">SYS.ORB / 01</div>
        <div class="hud-value">48.8566°N · 2.3522°E</div>
      </div>
      <div class="hud hud--tr">
        <div class="hud-bracket hud-bracket--tr"></div>
        <div class="hud-label">STATUS</div>
        <div class="hud-value hud-value--active"><span class="hud-dot"></span>ONLINE</div>
      </div>
      <div class="hud hud--br">
        <div class="hud-bracket hud-bracket--br"></div>
        <div class="hud-label">BOOST RATE</div>
        <div class="hud-value hud-value--big">+347%</div>
      </div>
    </div>
  </div>

  <!-- Corner brackets de la section (HUD frame) -->
  <div class="hero-corners" aria-hidden="true">
    <span class="corner corner--tl"></span>
    <span class="corner corner--tr"></span>
    <span class="corner corner--bl"></span>
    <span class="corner corner--br"></span>
  </div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet derrière la tagline -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Eyebrow : badge session live -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot"></span>
      <span class="eyebrow-text">Session Mai 2026 · Places limitées</span>
    </div>

    <!-- Logo SMMIA -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia" />
    </div>

    <!-- Tagline -->
    <h1 class="hero-title">
      <span class="tagline-top reveal" style="--d:0.2s">Ton agence rentable</span>
      <span class="tagline-boost reveal" style="--d:0.4s">
        <span class="boost-bracket boost-bracket--l" aria-hidden="true">[</span>
        <span class="boost-holo-border" aria-hidden="true"></span>
        <span class="boost-aura" aria-hidden="true"></span>
        <span class="boost-word">BOOSTER</span>
        <span class="boost-bracket boost-bracket--r" aria-hidden="true">]</span>
      </span>
      <span class="tagline-bottom reveal" style="--d:0.6s">par l'IA.</span>
    </h1>

    <!-- Data readouts sous la tagline (mono futuriste) -->
    <div class="hero-readouts reveal" style="--d:0.65s" aria-hidden="true">
      <span class="readout"><span class="readout-key">v11.0</span><span class="readout-val">// STABLE</span></span>
      <span class="readout-sep"></span>
      <span class="readout"><span class="readout-key">UPTIME</span><span class="readout-val">99.98%</span></span>
      <span class="readout-sep"></span>
      <span class="readout"><span class="readout-key">AGENCES</span><span class="readout-val">847</span></span>
    </div>

    <!-- CTA -->
    <div class="hero-ctas reveal" style="--d:0.8s">
      <a href="#pricing" class="hero-cta-primary">
        <span class="cta-label">Rejoindre la session</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg viewBox="0 0 14 12" fill="none" width="14" height="12">
            <path d="M1 6H13M13 6L8 1M13 6L8 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <a href="#programme" class="hero-cta-secondary">Voir le programme</a>
    </div>

  </div>

  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  /* =============== Scène Hero =============== */
  #hero {
    position: relative;
    width: 100%;
    background:
      radial-gradient(ellipse 120% 80% at 50% 0%, #1a0730 0%, #0d0320 40%, #06010F 75%, #000 100%);
    padding: 110px 24px 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 880px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }

  /* =============== GALAXIE =============== */
  .hero-galaxy {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .galaxy-deep {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(124, 58, 237, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(168, 85, 247, 0.12) 0%, transparent 60%);
  }

  .galaxy-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 25% 40%, rgba(216,180,254,0.85), transparent),
      radial-gradient(1.5px 1.5px at 45% 22%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 62% 8%, rgba(233,213,255,0.85), transparent),
      radial-gradient(1px 1px at 78% 35%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.5px 1.5px at 88% 62%, rgba(216,180,254,0.9), transparent),
      radial-gradient(1px 1px at 15% 70%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1px 1px at 40% 85%, rgba(233,213,255,0.75), transparent),
      radial-gradient(1.5px 1.5px at 70% 78%, rgba(255,255,255,0.85), transparent),
      radial-gradient(1px 1px at 92% 12%, rgba(192,132,252,0.85), transparent),
      radial-gradient(1px 1px at 30% 55%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 55% 68%, rgba(216,180,254,0.7), transparent);
    opacity: 0.9;
    animation: starsTwinkle 6s ease-in-out infinite;
  }
  @keyframes starsTwinkle {
    0%, 100% { opacity: 0.9; }
    50%      { opacity: 0.55; }
  }

  .galaxy-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    mix-blend-mode: screen;
  }
  .galaxy-nebula--a {
    width: 520px; height: 520px;
    top: -10%; right: -6%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.45) 0%, transparent 65%);
    animation: nebulaA 28s ease-in-out infinite;
  }
  .galaxy-nebula--b {
    width: 420px; height: 420px;
    top: 58%; left: -8%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.38) 0%, transparent 65%);
    animation: nebulaB 32s ease-in-out infinite;
  }
  @keyframes nebulaA {
    0%, 100% { transform: translate(0, 0); opacity: 0.55; }
    50%      { transform: translate(-30px, 30px); opacity: 0.8; }
  }
  @keyframes nebulaB {
    0%, 100% { transform: translate(0, 0); opacity: 0.5; }
    50%      { transform: translate(40px, -20px); opacity: 0.75; }
  }

  /* Grid perspective floor (cyberpunk vibe) */
  .grid-floor {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 45%;
    background-image:
      linear-gradient(to right, rgba(168,85,247,0.18) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(168,85,247,0.18) 1px, transparent 1px);
    background-size: 60px 60px;
    transform: perspective(700px) rotateX(66deg);
    transform-origin: bottom center;
    mask-image: linear-gradient(to top, #000 0%, #000 30%, transparent 90%);
    -webkit-mask-image: linear-gradient(to top, #000 0%, #000 30%, transparent 90%);
    opacity: 0.6;
    animation: gridScroll 6s linear infinite;
  }
  @keyframes gridScroll {
    from { background-position: 0 0; }
    to   { background-position: 0 60px; }
  }

  /* Scan lines */
  .scan-lines {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      rgba(216, 180, 254, 0.025) 0,
      rgba(216, 180, 254, 0.025) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0.5;
  }

  /* =============== ORB SCÈNE =============== */
  .orb-scene {
    position: absolute;
    top: 50%;
    right: 6%;
    transform: translateY(-50%);
    width: 420px;
    height: 420px;
    perspective: 1000px;
    transform-style: preserve-3d;
    z-index: 1;
  }

  .orb-glow {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.28) 0%, rgba(168, 85, 247, 0.1) 45%, transparent 72%);
    filter: blur(24px);
    animation: orbGlowPulse 5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes orbGlowPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }

  /* Expose rings */
  .orb-expose {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(216, 180, 254, 0.6);
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 18px rgba(168, 85, 247, 0.5);
  }
  .orb-expose--1 { animation: exposeRing 4.5s ease-out infinite; }
  .orb-expose--2 { animation: exposeRing 4.5s ease-out 2.2s infinite; }
  @keyframes exposeRing {
    0%   { transform: scale(1);   opacity: 0.85; border-width: 2px; }
    70%  { opacity: 0.18; }
    100% { transform: scale(1.8); opacity: 0;   border-width: 0.5px; }
  }

  /* Orbital rings 3D (inclinés, rotation à vitesses différentes) */
  .orb-ring {
    position: absolute;
    inset: -8%;
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 50%;
    pointer-events: none;
  }
  .orb-ring::before {
    content: '';
    position: absolute;
    top: 50%; left: -4px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #E9D5FF;
    box-shadow: 0 0 10px 2px rgba(216, 180, 254, 0.9), 0 0 20px 4px rgba(168, 85, 247, 0.5);
    transform: translateY(-50%);
  }
  .orb-ring--1 { transform: rotateX(70deg) rotateZ(0deg);  animation: ringSpin 22s linear infinite; }
  .orb-ring--2 { transform: rotateX(80deg) rotateZ(45deg); animation: ringSpin 28s linear infinite reverse; inset: -14%; opacity: 0.7; }
  .orb-ring--3 { transform: rotateX(60deg) rotateZ(90deg); animation: ringSpin 34s linear infinite; inset: -20%; opacity: 0.5; border-style: dashed; }
  @keyframes ringSpin {
    from { transform: rotateX(70deg) rotateZ(0deg); }
    to   { transform: rotateX(70deg) rotateZ(360deg); }
  }

  /* =============== GLOBE 3D wireframe =============== */
  .globe-3d {
    position: absolute;
    inset: 15%;
    transform-style: preserve-3d;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 30%,
      rgba(168, 85, 247, 0.25) 0%,
      rgba(124, 58, 237, 0.15) 30%,
      rgba(46, 16, 101, 0.45) 65%,
      rgba(10, 4, 24, 0.85) 95%);
    box-shadow:
      inset -20px -20px 60px rgba(10, 4, 24, 0.85),
      inset 14px 14px 40px rgba(216, 180, 254, 0.2),
      0 0 0 1px rgba(216, 180, 254, 0.15);
  }

  .globe-spin {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    animation: globeSpin 24s linear infinite;
  }
  @keyframes globeSpin {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  /* Méridiens : cercles verticaux avec rotateY */
  .meridian {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(168, 85, 247, 0.45);
    border-radius: 50%;
    transform: rotateY(var(--a));
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.3);
  }

  /* Parallèles : ellipses horizontales fixes (pas affectées par la rotation) */
  .parallel {
    position: absolute;
    left: 50%;
    top: 50%;
    width: calc(var(--rx) * 2);
    height: 4px;
    margin-left: calc(var(--rx) * -1);
    border: 1px solid rgba(216, 180, 254, 0.5);
    border-radius: 50%;
    transform: translateY(var(--y));
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.35);
  }

  /* Core glow (centre de la sphère, effet lumineux) */
  .globe-core {
    position: absolute;
    top: 50%; left: 50%;
    width: 60%; height: 60%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle,
      rgba(233, 213, 255, 0.5) 0%,
      rgba(168, 85, 247, 0.25) 35%,
      transparent 65%);
    filter: blur(12px);
    animation: coreBreath 3.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes coreBreath {
    0%, 100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;   transform: translate(-50%, -50%) scale(1.1); }
  }

  /* Targets (markers futuristes style crosshair) */
  .globe-target {
    position: absolute;
    width: 28px;
    height: 28px;
    color: #F3E8FF;
    pointer-events: none;
    z-index: 5;
    filter: drop-shadow(0 0 6px rgba(216, 180, 254, 0.9)) drop-shadow(0 0 14px rgba(168, 85, 247, 0.6));
  }
  .globe-target svg { width: 100%; height: 100%; stroke: currentColor; fill: currentColor; stroke-width: 0.8; }
  .globe-target--1 { top: 22%; left: 32%; animation: targetPulse 2.4s ease-in-out infinite; }
  .globe-target--2 { top: 45%; left: 70%; animation: targetPulse 2.4s ease-in-out 0.8s infinite; }
  .globe-target--3 { top: 68%; left: 40%; animation: targetPulse 2.4s ease-in-out 1.6s infinite; }
  @keyframes targetPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.1); }
  }

  /* =============== HUD overlay =============== */
  .hud {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    color: rgba(216, 180, 254, 0.85);
    pointer-events: none;
    z-index: 6;
  }
  .hud-bracket {
    position: absolute;
    width: 24px; height: 24px;
    border: 1.5px solid rgba(216, 180, 254, 0.7);
    border-right: none;
    border-bottom: none;
    top: -8px; left: -8px;
  }
  .hud-bracket--tr {
    left: auto; right: -8px;
    border-right: 1.5px solid rgba(216, 180, 254, 0.7);
    border-left: none;
  }
  .hud-bracket--br {
    top: auto; bottom: -8px; left: auto; right: -8px;
    border: 1.5px solid rgba(216, 180, 254, 0.7);
    border-left: none;
    border-top: none;
  }
  .hud-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.55);
    line-height: 1;
  }
  .hud-value {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #F3E8FF;
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hud-value--big {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #F3E8FF 0%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hud-value--active {
    color: #86EFAC;
  }
  .hud-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #86EFAC;
    box-shadow: 0 0 8px rgba(134, 239, 172, 0.9);
    animation: hudDot 1.6s ease-in-out infinite;
  }
  @keyframes hudDot {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.45; }
  }
  .hud--tl { top: -20px; left: -40px; }
  .hud--tr { top: -20px; right: -40px; text-align: right; align-items: flex-end; }
  .hud--br { bottom: -20px; right: -40px; text-align: right; align-items: flex-end; }

  /* Corner brackets de la section entière */
  .hero-corners {
    position: absolute;
    inset: 24px;
    pointer-events: none;
    z-index: 3;
  }
  .corner {
    position: absolute;
    width: 28px;
    height: 28px;
    border: 1.5px solid rgba(168, 85, 247, 0.4);
  }
  .corner--tl { top: 0; left: 0; border-right: none; border-bottom: none; }
  .corner--tr { top: 0; right: 0; border-left: none; border-bottom: none; }
  .corner--bl { bottom: 0; left: 0; border-right: none; border-top: none; }
  .corner--br { bottom: 0; right: 0; border-left: none; border-top: none; }

  /* =============== Halo spotlight =============== */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 40%;
    width: 68%;
    max-width: 900px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.45) 0%, rgba(124, 58, 237, 0.18) 40%, transparent 72%);
    filter: blur(30px);
    z-index: 0;
    pointer-events: none;
    animation: spotlightBreath 6s ease-in-out infinite;
  }
  @keyframes spotlightBreath {
    0%, 100% { opacity: 0.85; }
    50%      { opacity: 1; }
  }

  /* =============== EYEBROW badge =============== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'JetBrains Mono', 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* =============== LOGO =============== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }
  .brand-logo {
    display: block;
    width: auto;
