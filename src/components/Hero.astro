  .b3d-stage:hover .b3d-letter:nth-child(6) { transform: translate3d(70px, 38px, 85px) rotate3d(0.5, 1, 0.4, 24deg); }
  .b3d-stage:hover .b3d-letter:nth-child(7) { transform: translate3d(105px, -50px, 50px) rotate3d(1, 0.7, 0.6, -26deg); }

