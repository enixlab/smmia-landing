---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">Ton agence</span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Flash blanc au moment de la rupture -->
        <span class="booster-flash" aria-hidden="true"></span>

        <!-- Mot splitté par lettre, chaque lettre = trajectoire 3D individuelle -->
        <span class="booster-3d__word">
          <span class="boost-letter" style="--i:0">B</span>
          <span class="boost-letter" style="--i:1">O</span>
          <span class="boost-letter" style="--i:2">O</span>
          <span class="boost-letter" style="--i:3">S</span>
          <span class="boost-letter" style="--i:4">T</span>
          <span class="boost-letter" style="--i:5">E</span>
          <span class="boost-letter" style="--i:6">R</span>
        </span>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        par l'<span class="tl-accent">IA</span>.
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: rgba(255, 255, 255, 0.82);
  }
  .tl-line--top    { margin-bottom: 0.1em; }
  .tl-line--bottom { margin-top: 0.05em; }
  .tl-accent {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    color: rgba(216, 180, 254, 0.95);
  }

  /* ========== BOOSTER 3D — EXPLOSION PREMIUM lettre par lettre ==========
     Cycle 7s:
       0-26%  (0-1.8s)   : stable, respiration subtile
       26-30% (1.8-2.1s) : charge énergie (flash blanc + brightness up)
       30-48% (2.1-3.4s) : EXPLOSION (chaque lettre s'éjecte en 3D avec motion blur)
       48-72% (3.4-5s)   : dérive + fade out
       72-85% (5-6s)     : invisible
       85-100% (6-7s)    : reformation (lettres reviennent fluides)
  */

  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.08em 0 0.04em;
    perspective: 1400px;
    transform-style: preserve-3d;
  }

  /* Flash blanc au moment où le mot explose */
  .booster-flash {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120%;
    height: 220%;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(243, 232, 255, 0.55) 25%,
      rgba(168, 85, 247, 0.25) 50%,
      transparent 72%);
    filter: blur(22px);
    transform: translate(-50%, -50%) scale(0.6);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterFlash 7s ease-out infinite;
  }
  @keyframes boosterFlash {
    0%, 24%  { opacity: 0;    transform: translate(-50%, -50%) scale(0.6); }
    27%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.1); }
    30%      { opacity: 0.85; transform: translate(-50%, -50%) scale(1.4); }
    36%      { opacity: 0;    transform: translate(-50%, -50%) scale(1.8); }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scale(0.6); }
  }

  .booster-3d__word {
    position: relative;
    display: inline-flex;
    z-index: 2;
  }

  /* Chaque lettre = span indépendant avec sa trajectoire 3D */
  .boost-letter {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(80px, 16vw, 232px);
    line-height: 0.92;
    letter-spacing: -0.032em;
    /* Couleur premium monochrome — blanc cassé avec tint lavande subtil */
    color: #FDFBFF;
    /* Extrusion 3D discrète + glow ambient */
    text-shadow:
      0 1px 0 rgba(76, 29, 149, 0.95),
      0 2px 0 rgba(76, 29, 149, 0.75),
      0 3px 0 rgba(76, 29, 149, 0.55),
      0 4px 8px rgba(76, 29, 149, 0.6),
      0 0 36px rgba(168, 85, 247, 0.35);
    transform-origin: center center;
    will-change: transform, opacity, filter;
    animation: letterLife 7s cubic-bezier(0.4, 0, 0.15, 1) infinite;
    animation-delay: calc(var(--i, 0) * -0.012s);
  }

  /* Trajectoires 3D par lettre — directions variées, rotations 3D naturelles */
  .boost-letter:nth-child(1) { --dx: -220px; --dy: -140px; --rx:  22deg; --ry: -40deg; --rz: -32deg; }
  .boost-letter:nth-child(2) { --dx: -100px; --dy: -220px; --rx: -26deg; --ry:  14deg; --rz:  18deg; }
  .boost-letter:nth-child(3) { --dx:   30px; --dy: -185px; --rx:  16deg; --ry: -22deg; --rz: -10deg; }
  .boost-letter:nth-child(4) { --dx:  -45px; --dy:  200px; --rx: -20deg; --ry:  30deg; --rz: -26deg; }
  .boost-letter:nth-child(5) { --dx:   95px; --dy: -120px; --rx:  32deg; --ry: -16deg; --rz:  24deg; }
  .boost-letter:nth-child(6) { --dx:  170px; --dy:  180px; --rx: -28deg; --ry:  34deg; --rz: -36deg; }
  .boost-letter:nth-child(7) { --dx:  240px; --dy:  -80px; --rx:  18deg; --ry: -26deg; --rz:  42deg; }

  @keyframes letterLife {
    /* Phase 1 : stable + respiration très subtile */
    0%, 22%  {
      transform: translate3d(0, 0, 0) rotateX(0) rotateY(0) rotateZ(0);
      opacity: 1;
      filter: blur(0) brightness(1);
    }
    /* Phase 2 : charge — lumière monte, tout reste en place */
    27%      {
      transform: translate3d(0, 0, 0) rotateX(0) rotateY(0) rotateZ(0) scale(1.03);
      opacity: 1;
      filter: blur(0) brightness(1.4);
    }
    /* Phase 3 : EXPLOSION — éjection violente avec motion blur */
    32%      {
      transform: translate3d(calc(var(--dx) * 0.25), calc(var(--dy) * 0.25), 60px)
                 rotateX(calc(var(--rx) * 0.4))
                 rotateY(calc(var(--ry) * 0.4))
                 rotateZ(calc(var(--rz) * 0.3));
      opacity: 1;
      filter: blur(10px) brightness(1.2);
    }
    42%      {
      transform: translate3d(var(--dx), var(--dy), 40px)
                 rotateX(var(--rx))
                 rotateY(var(--ry))
                 rotateZ(var(--rz));
      opacity: 1;
      filter: blur(6px) brightness(1);
    }
    /* Phase 4 : dérive — motion blur s'atténue */
    55%      {
      transform: translate3d(calc(var(--dx) * 1.2), calc(var(--dy) * 1.2), 20px)
                 rotateX(calc(var(--rx) * 1.25))
                 rotateY(calc(var(--ry) * 1.25))
                 rotateZ(calc(var(--rz) * 1.3));
      opacity: 0.6;
      filter: blur(2px) brightness(0.85);
    }
    /* Phase 5 : fade out au loin */
    70%      {
      transform: translate3d(calc(var(--dx) * 1.5), calc(var(--dy) * 1.5), 0)
                 rotateX(calc(var(--rx) * 1.5))
                 rotateY(calc(var(--ry) * 1.5))
                 rotateZ(calc(var(--rz) * 1.6));
      opacity: 0;
      filter: blur(0) brightness(0.6);
    }
    /* Phase 6 : invisible */
    74%, 84% {
      opacity: 0;
      transform: translate3d(0, 0, -60px) rotateX(0) rotateY(0) rotateZ(0);
      filter: blur(0);
    }
    /* Phase 7 : reformation — chaque lettre revient de l'avant avec ease */
    92%      {
      opacity: 1;
      transform: translate3d(0, 0, 20px) rotateX(0) rotateY(0) rotateZ(0);
      filter: blur(0) brightness(1.1);
    }
    100%     {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotateX(0) rotateY(0) rotateZ(0);
      filter: blur(0) brightness(1);
    }
  }

  /* Pause cycle au hover (voir l'état explosé figé) */
  .booster-3d:hover .boost-letter,
  .booster-3d:hover .booster-flash {
    animation-play-state: paused;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .boost-letter { font-size: clamp(64px, 18vw, 128px); }
    .boost-letter:nth-child(1) { --dx: -120px; --dy:  -80px; }
    .boost-letter:nth-child(2) { --dx:  -55px; --dy: -125px; }
    .boost-letter:nth-child(3) { --dx:   18px; --dy: -105px; }
    .boost-letter:nth-child(4) { --dx:  -25px; --dy:  115px; }
    .boost-letter:nth-child(5) { --dx:   50px; --dy:  -70px; }
    .boost-letter:nth-child(6) { --dx:   95px; --dy:  100px; }
    .boost-letter:nth-child(7) { --dx:  135px; --dy:  -45px; }
  }
  @media (max-width: 480px) {
    .boost-letter {
      text-shadow:
        0 1px 0 rgba(76, 29, 149, 0.95),
        0 2px 0 rgba(76, 29, 149, 0.7),
        0 3px 6px rgba(76, 29, 149, 0.55),
        0 0 24px rgba(168, 85, 247, 0.3);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .boost-letter,
    .booster-flash {
      animation: none;
    }
    .boost-letter {
      transform: none;
      opacity: 1;
      filter: none;
    }
    .booster-flash { opacity: 0; }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 700px; }
    .hero-inner { gap: 28px; }
    .brand-smmia { height: 95px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 560px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 72px; }
    .line-outline { -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.85); }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }
</script>
