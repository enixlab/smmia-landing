<script>
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ============ SPLIT TEXT : wrap chaque caractère en <span.letter> ============
  if (hero) {
    const splits = hero.querySelectorAll<HTMLElement>('.split-reveal .line-inner');
    splits.forEach((line) => {
      // Récupère tous les nodes texte et les wrap en letters, en préservant les éléments enfants (serif-italic, etc.)
      const walk = (node: Node) => {
        const children = Array.from(node.childNodes);
        children.forEach((child) => {
          if (child.nodeType === Node.TEXT_NODE && child.textContent) {
            const text = child.textContent;
            const frag = document.createDocumentFragment();
            for (const ch of text) {
              if (ch === ' ' || ch === ' ') {
                const space = document.createElement('span');
                space.className = 'letter letter--space';
                space.setAttribute('aria-hidden', 'true');
                space.innerHTML = '&nbsp;';
                frag.appendChild(space);
              } else {
                const letter = document.createElement('span');
                letter.className = 'letter';
                letter.textContent = ch;
                frag.appendChild(letter);
              }
            }
            child.parentNode?.replaceChild(frag, child);
          } else if (child.nodeType === Node.ELEMENT_NODE) {
            const el = child as HTMLElement;
            // Ne pas descendre dans les éléments de décoration (aura, boost-word complet)
            if (el.classList.contains('boost-aura') || el.classList.contains('boost-word')) return;
            walk(el);
          }
        });
      };
      walk(line);
      // Assigner --i sur chaque letter pour le stagger
      const letters = line.querySelectorAll<HTMLElement>('.letter');
      letters.forEach((l, i) => l.style.setProperty('--i', String(i)));
    });
  }

  // ============ BOOSTER 3D interactif : rotation mousemove sur le rotator ============
  const b3dStage = document.getElementById('boosterStage');
  const b3dRotator = document.getElementById('boosterRotator');
  if (b3dStage && b3dRotator && !reduced) {
    let rafB3d = 0;
    let tbx = 0, tby = 0, cbx = 0, cby = 0;

    b3dStage.addEventListener('mousemove', (e) => {
      const r = b3dStage.getBoundingClientRect();
      tbx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      tby = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafB3d) rafB3d = requestAnimationFrame(b3dLoop);
    });

    b3dStage.addEventListener('mouseleave', () => {
      tbx = 0; tby = 0;
      if (!rafB3d) rafB3d = requestAnimationFrame(b3dLoop);
    });

    function b3dLoop() {
      cbx += (tbx - cbx) * 0.08;
      cby += (tby - cby) * 0.08;
      b3dRotator!.style.transform = `rotateY(${cbx * 22}deg) rotateX(${cby * -16}deg)`;
      if (Math.abs(tbx - cbx) > 0.001 || Math.abs(tby - cby) > 0.001) {
        rafB3d = requestAnimationFrame(b3dLoop);
      } else { rafB3d = 0; }
    }
  }

  // ============ CUSTOM CURSOR (dot + ring, lerp follow) ============
  const cursor = document.getElementById('cursor');
  const cursorDot = cursor?.querySelector<HTMLElement>('.cursor-dot');
  const cursorRing = cursor?.querySelector<HTMLElement>('.cursor-ring');

  if (cursor && cursorDot && cursorRing && !reduced && window.matchMedia('(hover: hover)').matches) {
    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let dx = mx, dy = my;  // dot (instant)
    let rx = mx, ry = my;  // ring (lerp)

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX; my = e.clientY;
      dx = mx; dy = my;
      cursor.classList.add('is-visible');
    });

    document.addEventListener('mouseleave', () => { cursor.classList.remove('is-visible'); });

    const hoverables = hero?.querySelectorAll<HTMLElement>('a, .scroll-indicator, .globe-target, [data-magnetic]');
    hoverables?.forEach((el) => {
      el.addEventListener('mouseenter', () => cursor.classList.add('is-hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('is-hover'));
    });

    function loop() {
      // dot = instant (suit la souris direct)
      cursorDot!.style.transform = `translate3d(${dx}px, ${dy}px, 0) translate(-50%, -50%)`;
      // ring = lerp 0.15
      rx += (mx - rx) * 0.15;
      ry += (my - ry) * 0.15;
      cursorRing!.style.transform = `translate3d(${rx}px, ${ry}px, 0) translate(-50%, -50%)` +
        (cursor.classList.contains('is-hover') ? ' scale(2.2)' : ' scale(1)');
      requestAnimationFrame(loop);
    }
    loop();
  }

  // ============ MAGNETIC hover sur markers/scroll-indicator ============
  if (!reduced && window.matchMedia('(hover: hover)').matches) {
    const magnets = hero?.querySelectorAll<HTMLElement>('.globe-target, .scroll-indicator');
    magnets?.forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dxm = ((e as MouseEvent).clientX - cx) * 0.35;
        const dym = ((e as MouseEvent).clientY - cy) * 0.35;
        el.style.transform = `translate(${dxm}px, ${dym}px)`;
        // Preserve scroll-indicator's translateX(-50%)
        if (el.classList.contains('scroll-indicator')) {
          el.style.transform = `translateX(calc(-50% + ${dxm}px)) translateY(${dym}px)`;
        }
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = el.classList.contains('scroll-indicator') ? 'translateX(-50%)' : '';
        el.style.transition = 'transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1)';
        setTimeout(() => { el.style.transition = ''; }, 500);
      });
    });
  }

  // ============ 3D TILT sur le globe (mousemove proportional) ============
  if (hero && !reduced) {
    const orbScene = hero.querySelector<HTMLElement>('.orb-scene');
    if (orbScene) {
      let rafOrb = 0;
      let tOrbX = 0, tOrbY = 0, cOrbX = 0, cOrbY = 0;

      hero.addEventListener('mousemove', (e) => {
        const r = hero.getBoundingClientRect();
        tOrbX = ((e.clientX - r.left) / r.width - 0.5) * 2;  // -1..1
        tOrbY = ((e.clientY - r.top) / r.height - 0.5) * 2;
        if (!rafOrb) rafOrb = requestAnimationFrame(orbLoop);
      });

      hero.addEventListener('mouseleave', () => { tOrbX = 0; tOrbY = 0; if (!rafOrb) rafOrb = requestAnimationFrame(orbLoop); });

      function orbLoop() {
        cOrbX += (tOrbX - cOrbX) * 0.05;
        cOrbY += (tOrbY - cOrbY) * 0.05;
        orbScene!.style.transform = `translateY(-50%) rotateY(${cOrbX * 12}deg) rotateX(${cOrbY * -8}deg)`;
        if (Math.abs(tOrbX - cOrbX) > 0.001 || Math.abs(tOrbY - cOrbY) > 0.001) {
          rafOrb = requestAnimationFrame(orbLoop);
        } else { rafOrb = 0; }
      }
    }
  }

  // ============ Parallaxe subtile sur le logo ============
  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }

  // Number counters animés (signature Awwwards)
  const counters = document.querySelectorAll<HTMLElement>('[data-count]');
  counters.forEach((el) => {
    const target = parseFloat(el.dataset.count || '0');
    const suffix = el.dataset.suffix || '';
    const isFloat = target % 1 !== 0;
    const duration = 1800;
    const start = performance.now();
    const prefix = el.textContent?.match(/^\+/) ? '+' : '';

    function step(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);
      const value = target * eased;
      el.textContent = prefix + (isFloat ? value.toFixed(2) : Math.floor(value).toString()) + suffix;
      if (t < 1) requestAnimationFrame(step);
      else el.textContent = prefix + (isFloat ? target.toFixed(2) : target.toString()) + suffix;
    }
    // Démarrer après un léger délai (après reveal)
    setTimeout(() => requestAnimationFrame(step), 900);
  });
</script>
