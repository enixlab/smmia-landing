    50%      { transform: translateZ(20px) translateY(-6px) rotateY(0deg) rotateX(-3deg); }
    75%      { transform: translateZ(14px) translateY(-3px) rotateY(-5deg) rotateX(-2deg); }
  }

  /* Chaque couche = copie de la lettre translatée en Z — 28 couches, -2.4px step = profondeur 67px */
  .b3d-layer {
    display: inline-block;
    transform: translateZ(calc(var(--d) * -2.4px));
    /* Dégradé progressif vers le fond : chrome lavande → violet profond */
    background: linear-gradient(160deg,
      hsla(285, calc(20% + var(--d, 0) * 2.8%), calc(96% - var(--d, 0) * 2.6%), 1) 0%,
