---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Galaxie minimale (léger) -->
  <div class="hero-galaxy" aria-hidden="true">
    <div class="galaxy-deep"></div>
    <div class="galaxy-stars"></div>
    <div class="galaxy-nebula galaxy-nebula--a"></div>
    <div class="galaxy-nebula galaxy-nebula--b"></div>

    <!-- Planète 3D style Dribbble (clean premium) -->
    <div class="galaxy-planet">
      <div class="planet-glow"></div>
      <div class="planet-expose planet-expose--1"></div>
      <div class="planet-expose planet-expose--2"></div>
      <div class="planet-sphere">
        <div class="planet-atmosphere"></div>
        <div class="planet-dots"></div>
        <div class="planet-terminator"></div>
        <div class="planet-shine"></div>
        <span class="planet-marker planet-marker--1"></span>
        <span class="planet-marker planet-marker--2"></span>
        <span class="planet-marker planet-marker--3"></span>
      </div>
      <svg class="planet-arc" viewBox="-60 -60 120 120" aria-hidden="true">
        <defs>
          <linearGradient id="arcG" x1="0" x2="1">
            <stop offset="0%"   stop-color="#F3E8FF" stop-opacity="0"/>
            <stop offset="50%"  stop-color="#D8B4FE" stop-opacity="1"/>
            <stop offset="100%" stop-color="#A855F7" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <path d="M -38 -10 Q 0 -58 38 -6" fill="none" stroke="url(#arcG)" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Logos brand flottants (déjà performant) -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet derrière la tagline -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Eyebrow : badge session live -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot"></span>
      <span class="eyebrow-text">Session Mai 2026 · Places limitées</span>
    </div>

    <!-- Logo SMMIA -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia" />
    </div>

    <!-- Tagline : Ton agence rentable BOOSTER par l'IA -->
    <h1 class="hero-title">
      <span class="tagline-top reveal" style="--d:0.2s">Ton agence rentable</span>
      <span class="tagline-boost reveal" style="--d:0.4s">
        <span class="boost-aura" aria-hidden="true"></span>
        <span class="boost-word">BOOSTER</span>
      </span>
      <span class="tagline-bottom reveal" style="--d:0.6s">par l'IA.</span>
    </h1>

    <!-- CTA -->
    <div class="hero-ctas reveal" style="--d:0.75s">
      <a href="#pricing" class="hero-cta-primary">
        <span class="cta-label">Rejoindre la session</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg viewBox="0 0 14 12" fill="none" width="14" height="12">
            <path d="M1 6H13M13 6L8 1M13 6L8 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <a href="#programme" class="hero-cta-secondary">Voir le programme</a>
    </div>

  </div>

  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  /* =============== Scène Hero =============== */
  #hero {
    position: relative;
    width: 100%;
    background:
      radial-gradient(ellipse 120% 80% at 50% 0%, #1a0730 0%, #0d0320 40%, #06010F 75%, #000 100%);
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 820px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  /* =============== GALAXIE (minimaliste) =============== */
  .hero-galaxy {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .galaxy-deep {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(124, 58, 237, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(168, 85, 247, 0.12) 0%, transparent 60%);
  }

  /* Starfield : une seule couche statique box-shadow (zéro animation par frame) */
  .galaxy-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 25% 40%, rgba(216,180,254,0.85), transparent),
      radial-gradient(1.5px 1.5px at 45% 22%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 62% 8%, rgba(233,213,255,0.85), transparent),
      radial-gradient(1px 1px at 78% 35%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.5px 1.5px at 88% 62%, rgba(216,180,254,0.9), transparent),
      radial-gradient(1px 1px at 15% 70%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1px 1px at 40% 85%, rgba(233,213,255,0.75), transparent),
      radial-gradient(1.5px 1.5px at 70% 78%, rgba(255,255,255,0.85), transparent),
      radial-gradient(1px 1px at 92% 12%, rgba(192,132,252,0.85), transparent),
      radial-gradient(1px 1px at 30% 55%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 55% 68%, rgba(216,180,254,0.7), transparent);
    opacity: 0.9;
    animation: starsTwinkle 6s ease-in-out infinite;
  }
  @keyframes starsTwinkle {
    0%, 100% { opacity: 0.9; }
    50%      { opacity: 0.55; }
  }

  /* 2 nébuleuses violettes — blurs modérés (50px max) */
  .galaxy-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  .galaxy-nebula--a {
    width: 520px; height: 520px;
    top: -8%; right: -6%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.5) 0%, transparent 65%);
    animation: nebulaA 28s ease-in-out infinite;
  }
  .galaxy-nebula--b {
    width: 420px; height: 420px;
    top: 58%; left: -8%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.42) 0%, transparent 65%);
    animation: nebulaB 32s ease-in-out infinite;
  }
  @keyframes nebulaA {
    0%, 100% { transform: translate(0, 0); opacity: 0.6; }
    50%      { transform: translate(-30px, 30px); opacity: 0.85; }
  }
  @keyframes nebulaB {
    0%, 100% { transform: translate(0, 0); opacity: 0.55; }
    50%      { transform: translate(40px, -20px); opacity: 0.8; }
  }

  /* =============== PLANÈTE style Dribbble =============== */
  .galaxy-planet {
    position: absolute;
    bottom: -14%;
    left: 4%;
    width: 460px;
    height: 460px;
    z-index: 1;
    pointer-events: none;
    animation: planetFloat 14s ease-in-out infinite;
    filter: drop-shadow(0 18px 50px rgba(124, 58, 237, 0.55));
  }
  @keyframes planetFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }

  .planet-glow {
    position: absolute;
    inset: -14%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.3) 0%, rgba(168, 85, 247, 0.12) 42%, transparent 70%);
    filter: blur(20px);
    animation: planetGlowPulse 5s ease-in-out infinite;
  }
  @keyframes planetGlowPulse {
    0%, 100% { opacity: 0.75; }
    50%      { opacity: 1; }
  }

  /* Aura "qui expose" — 2 anneaux qui partent de la sphère */
  .planet-expose {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(216, 180, 254, 0.6);
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.45);
  }
  .planet-expose--1 { animation: exposeRing 4.5s ease-out infinite; }
  .planet-expose--2 { animation: exposeRing 4.5s ease-out 2.2s infinite; }
  @keyframes exposeRing {
    0%   { transform: scale(1);   opacity: 0.85; border-width: 2px; }
    70%  { opacity: 0.2; }
    100% { transform: scale(1.9); opacity: 0;   border-width: 0.5px; }
  }

  .planet-sphere {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(circle at 32% 30%,
        #E9D5FF 0%,
        #C084FC 10%,
        #A855F7 25%,
        #7C3AED 48%,
        #5B21B6 72%,
        #2E1065 92%);
    box-shadow:
      inset -18px -18px 60px rgba(10, 4, 24, 0.85),
      inset 14px 14px 36px rgba(216, 180, 254, 0.28);
  }

  .planet-atmosphere {
    position: absolute;
    inset: -1%;
    border-radius: 50%;
    box-shadow:
      inset 0 0 20px rgba(216, 180, 254, 0.55),
      0 0 30px rgba(168, 85, 247, 0.3);
    pointer-events: none;
  }

  /* Dots continents : léger, GPU friendly (pas de repeating-linear-gradient) */
  .planet-dots {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background-image:
      radial-gradient(circle at 22% 32%, rgba(216, 180, 254, 0.7) 0%, transparent 9%),
      radial-gradient(circle at 68% 30%, rgba(233, 213, 255, 0.6) 0%, transparent 7%),
      radial-gradient(circle at 78% 58%, rgba(192, 132, 252, 0.5) 0%, transparent 8%),
      radial-gradient(circle at 32% 70%, rgba(216, 180, 254, 0.5) 0%, transparent 10%),
      radial-gradient(circle, rgba(233, 213, 255, 0.28) 1px, transparent 1.4px);
    background-size: 100% 100%, 100% 100%, 100% 100%, 100% 100%, 14px 14px;
    mix-blend-mode: overlay;
    opacity: 0.8;
  }

  .planet-terminator {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 72% 62%, transparent 0%, transparent 32%, rgba(0, 0, 0, 0.5) 82%);
    pointer-events: none;
  }

  .planet-shine {
    position: absolute;
    top: 14%; left: 20%;
    width: 38%; height: 30%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.4) 0%, transparent 70%);
    filter: blur(8px);
    pointer-events: none;
  }

  /* 3 markers de location pulsants */
  .planet-marker {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #F3E8FF;
    box-shadow: 0 0 10px 2px rgba(216, 180, 254, 0.8), 0 0 20px 4px rgba(168, 85, 247, 0.4);
    z-index: 4;
  }
  .planet-marker::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid rgba(216, 180, 254, 0.7);
    animation: markerPulse 2.2s ease-out infinite;
  }
  .planet-marker--1 { top: 28%; left: 32%; }
  .planet-marker--2 { top: 40%; left: 66%; }
  .planet-marker--3 { top: 62%; left: 42%; }
  .planet-marker--2::after { animation-delay: 0.7s; }
  .planet-marker--3::after { animation-delay: 1.4s; }
  @keyframes markerPulse {
    0%   { transform: scale(1);   opacity: 1; }
    100% { transform: scale(3.8); opacity: 0; }
  }

  /* Arc lumineux qui relie 2 markers */
  .planet-arc {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    z-index: 5;
    pointer-events: none;
    filter: drop-shadow(0 0 3px rgba(216, 180, 254, 0.9));
  }
  .planet-arc path {
    stroke-dasharray: 160;
    stroke-dashoffset: 160;
    animation: arcDraw 5s ease-in-out infinite;
  }
  @keyframes arcDraw {
    0%   { stroke-dashoffset: 160; opacity: 0; }
    15%  { opacity: 1; }
    60%  { stroke-dashoffset: 0;   opacity: 1; }
    85%  { stroke-dashoffset: -160; opacity: 0; }
    100% { stroke-dashoffset: -160; opacity: 0; }
  }

  /* =============== Halo spotlight derrière tagline =============== */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 78%;
    max-width: 1100px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.45) 0%, rgba(124, 58, 237, 0.2) 40%, transparent 72%);
    filter: blur(30px);
    z-index: 0;
    pointer-events: none;
    animation: spotlightBreath 6s ease-in-out infinite;
  }
  @keyframes spotlightBreath {
    0%, 100% { opacity: 0.85; }
    50%      { opacity: 1; }
  }

  /* =============== EYEBROW badge =============== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* =============== LOGO =============== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }
  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
  }
  .brand-smmia { height: 110px; }
  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* =============== TAGLINE =============== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(34px, 5.5vw, 76px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: -40px;
  }
  .tagline-top {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.82);
    letter-spacing: -0.01em;
  }
  .tagline-bottom {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.015em;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }
  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* =============== BOOSTER — mot héros =============== */
  .tagline-boost {
    position: relative;
    display: inline-block;
    padding: 8px 0;
    line-height: 1;
  }

  /* Aura violet derrière le mot (CSS pur, léger) */
  .boost-aura {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 160%;
    height: 250%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse 55% 45% at 50% 50%, rgba(233, 213, 255, 0.5) 0%, rgba(168, 85, 247, 0.3) 35%, rgba(124, 58, 237, 0.15) 60%, transparent 80%);
    filter: blur(20px);
    opacity: 0.9;
    mix-blend-mode: screen;
    animation: auraBreath 4s ease-in-out infinite;
  }
  @keyframes auraBreath {
    0%, 100% { opacity: 0.75; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.08); }
  }

  /* Le mot BOOSTER — gradient chrome violet + animation de pulse simple */
  .boost-word {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(68px, 12vw, 180px);
    line-height: 1;
    letter-spacing: -0.045em;
    background: linear-gradient(135deg,
      #FFFFFF 0%,
      #F3E8FF 15%,
      #D8B4FE 32%,
      #A855F7 55%,
      #7C3AED 78%,
      #4C1D95 100%);
    background-size: 220% 220%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 18px rgba(216, 180, 254, 0.55))
      drop-shadow(0 0 38px rgba(168, 85, 247, 0.4));
    animation: boostGradientShift 6s ease-in-out infinite, boostPulse 3.4s ease-in-out infinite;
    z-index: 2;
    transform-origin: center;
    will-change: transform, background-position;
  }
  @keyframes boostGradientShift {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }
  @keyframes boostPulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.04); }
  }

  /* =============== CTAs =============== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6);
  }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }
  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }

  /* =============== DÉCORATIONS =============== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }
  .hero-fade {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* =============== RESPONSIVE =============== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 740px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 95px; }
    .galaxy-planet { width: 340px; height: 340px; bottom: -10%; left: 2%; }
  }

  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 640px; }
    .hero-inner { gap: 20px; }
    .brand-smmia { height: 72px; }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
    .tagline-top, .tagline-bottom { font-size: clamp(18px, 5vw, 22px); }
    .boost-word { font-size: clamp(52px, 15vw, 78px); }
    .galaxy-planet { width: 220px; height: 220px; bottom: -4%; left: -8%; opacity: 0.85; }
    .galaxy-nebula { filter: blur(35px); }
  }

  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
    .boost-word { font-size: clamp(44px, 14vw, 60px); }
    .galaxy-planet { width: 180px; height: 180px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal,
    .galaxy-stars, .galaxy-nebula,
    .boost-word, .boost-aura,
    .galaxy-planet, .planet-glow, .planet-expose,
    .planet-marker::after, .planet-arc path,
    .hero-spotlight, .pulse-dot {
      animation: none;
      opacity: 1;
    }
    .planet-expose { display: none; }
  }
</style>

<script>
  // Parallaxe subtile sur les logos (léger)
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }
</script>
