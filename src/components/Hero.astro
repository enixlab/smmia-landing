---
// Hero SMMIA — Prism Coin Spline en BANNIÈRE plein écran (2026-04-23)
// Le Spline prend 100vw × 100vh. Overlay SMMIA minimal, zéro ombre.
---

<section id="hero" class="hero-spline">

  <!-- Scène Spline PLEIN ÉCRAN — c'est la bannière -->
  <div class="hero-spline__stage">
    <spline-viewer
      url="https://prod.spline.design/c1hpRlTUtuLLXEFU/scene.splinecode"
      loading-anim-type="none"
      events-target="global"
    ></spline-viewer>
  </div>

  <!-- Overlay SMMIA — logo + CTA en bas, ultra léger -->
  <div class="hero-spline__overlay">

    <div class="hero-spline__top">
      <div class="hero-spline__eyebrow reveal" style="--d:0s">
        <span class="pulse-dot" aria-hidden="true"></span>
        <span>Agence IA · E-commerce · 2026</span>
      </div>

      <div class="hero-spline__brand reveal" style="--d:0.15s">
        <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" class="hero-brand-img hero-brand-img--dark" />
        <img src="/images/logos/SMMIA-logo-transparent-light.png" alt="SMMIA" class="hero-brand-img hero-brand-img--light" />
      </div>
    </div>

    <div class="hero-spline__bottom">
      <div class="hero-spline__ctas reveal" style="--d:0.4s">
        <a href="#pricing" class="cta-primary">
          Rejoindre SMMIA
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#programme" class="cta-ghost">Voir le programme</a>
      </div>
    </div>

  </div>

</section>

<style>
  /* === HERO — Bannière Spline plein écran, zéro ombre === */
  .hero-spline {
    position: relative;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    margin: 0;
    padding: 0;
    overflow: hidden;
    font-family: 'Inter', system-ui, sans-serif;
    isolation: isolate;
    background: transparent;
  }

  /* Décalage pour compenser la Navbar si elle est fixed */
  :global([data-theme="dark"]) .hero-spline { --hero-fg: #FFFFFF; --hero-muted: rgba(255,255,255,0.72); --hero-border: rgba(255,255,255,0.18); --hero-card: rgba(0,0,0,0.35); }
  :global([data-theme="light"]) .hero-spline { --hero-fg: #0A0514; --hero-muted: rgba(10,5,20,0.68); --hero-border: rgba(10,5,20,0.18); --hero-card: rgba(255,255,255,0.72); }

  /* Stage Spline = tout l'écran */
  .hero-spline__stage {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-spline__stage spline-viewer {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent !important;
    --spline-logo: none;
  }
  .hero-spline__stage spline-viewer::part(logo) { display: none !important; }

  /* Overlay SMMIA — ultra minimal, PAS DE SHADOW */
  .hero-spline__overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(5rem, 10vh, 7rem) clamp(1.5rem, 4vw, 3rem) clamp(2rem, 5vh, 3.5rem);
    pointer-events: none;
  }
  .hero-spline__overlay > * { pointer-events: auto; }

  /* Top overlay : eyebrow + logo */
  .hero-spline__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }

  .hero-spline__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.95rem;
    border: 1px solid var(--hero-border);
    border-radius: 999px;
    background: var(--hero-card);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--hero-fg);
  }
  .hero-spline__eyebrow .pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22D3EE;
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.85); }
  }

  .hero-spline__brand { display: flex; justify-content: center; }
  .hero-brand-img {
    height: clamp(34px, 4.5vw, 48px);
    width: auto;
    display: none;
  }
  :global([data-theme="dark"]) .hero-brand-img--dark { display: block; }
  :global([data-theme="light"]) .hero-brand-img--light { display: block; }

  /* Bottom overlay : CTAs */
  .hero-spline__bottom {
    display: flex;
    justify-content: center;
  }
  .hero-spline__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 45%, #FB923C 100%);
    color: #FFFFFF;
    font-weight: 600;
    font-size: 0.98rem;
    text-decoration: none;
    border: none;
    transition: transform 0.25s ease;
  }
  .cta-primary:hover { transform: translateY(-2px); }
  .cta-primary svg { transition: transform 0.25s ease; }
  .cta-primary:hover svg { transform: translateX(3px); }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    border: 1px solid var(--hero-border);
    background: var(--hero-card);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--hero-fg);
    font-weight: 500;
    font-size: 0.98rem;
    text-decoration: none;
    transition: border-color 0.25s ease;
  }
  .cta-ghost:hover { border-color: var(--hero-fg); }

  .reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: reveal 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes reveal { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 768px) {
    .hero-spline__ctas {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }
    .cta-primary, .cta-ghost {
      justify-content: center;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal { animation: none; opacity: 1; transform: none; }
    .pulse-dot { animation: none; }
  }
</style>
