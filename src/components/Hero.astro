---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Star field (nébuleuse cosmos) -->
  <svg class="hero-stars" aria-hidden="true" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="starGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1"/>
        <stop offset="50%" stop-color="#E9D5FF" stop-opacity="0.5"/>
        <stop offset="100%" stop-color="#E9D5FF" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <!-- 80 étoiles de taille/position pseudo-aléatoire -->
    <g class="stars-small">
      <circle cx="120" cy="80" r="0.8" fill="#fff"/><circle cx="320" cy="150" r="1" fill="#fff"/><circle cx="580" cy="60" r="0.6" fill="#fff"/><circle cx="820" cy="120" r="1.2" fill="#fff"/><circle cx="1100" cy="90" r="0.8" fill="#fff"/><circle cx="1320" cy="170" r="1" fill="#fff"/>
      <circle cx="60" cy="280" r="0.7" fill="#fff"/><circle cx="250" cy="340" r="1" fill="#fff"/><circle cx="440" cy="260" r="0.8" fill="#fff"/><circle cx="920" cy="290" r="1.2" fill="#fff"/><circle cx="1180" cy="310" r="0.6" fill="#fff"/><circle cx="1380" cy="350" r="1" fill="#fff"/>
      <circle cx="180" cy="480" r="0.9" fill="#fff"/><circle cx="380" cy="520" r="0.7" fill="#fff"/><circle cx="1060" cy="470" r="1.1" fill="#fff"/><circle cx="1260" cy="540" r="0.8" fill="#fff"/>
      <circle cx="80" cy="660" r="1" fill="#fff"/><circle cx="280" cy="720" r="0.8" fill="#fff"/><circle cx="480" cy="680" r="0.6" fill="#fff"/><circle cx="720" cy="780" r="1" fill="#fff"/><circle cx="980" cy="720" r="0.9" fill="#fff"/><circle cx="1220" cy="760" r="1.2" fill="#fff"/><circle cx="1400" cy="700" r="0.7" fill="#fff"/>
      <circle cx="160" cy="40" r="0.5" fill="#E9D5FF"/><circle cx="420" cy="210" r="0.5" fill="#E9D5FF"/><circle cx="680" cy="180" r="0.5" fill="#E9D5FF"/><circle cx="880" cy="420" r="0.5" fill="#E9D5FF"/><circle cx="1140" cy="220" r="0.5" fill="#E9D5FF"/>
      <circle cx="340" cy="420" r="0.6" fill="#C084FC"/><circle cx="560" cy="390" r="0.5" fill="#C084FC"/><circle cx="760" cy="350" r="0.5" fill="#C084FC"/><circle cx="1020" cy="360" r="0.6" fill="#C084FC"/>
      <circle cx="100" cy="580" r="0.4" fill="#fff"/><circle cx="600" cy="640" r="0.5" fill="#fff"/><circle cx="860" cy="620" r="0.4" fill="#fff"/><circle cx="1160" cy="640" r="0.5" fill="#fff"/>
      <circle cx="240" cy="100" r="0.4" fill="#fff"/><circle cx="520" cy="280" r="0.4" fill="#fff"/><circle cx="780" cy="240" r="0.4" fill="#fff"/><circle cx="1000" cy="180" r="0.4" fill="#fff"/>
    </g>
    <!-- 8 étoiles brillantes avec twinkle -->
    <g class="stars-bright">
      <circle cx="220" cy="200" r="2.5" fill="url(#starGlow)" class="star-twinkle" style="--td:0s"/>
      <circle cx="640" cy="120" r="3" fill="url(#starGlow)" class="star-twinkle" style="--td:0.8s"/>
      <circle cx="1080" cy="250" r="2" fill="url(#starGlow)" class="star-twinkle" style="--td:1.5s"/>
      <circle cx="140" cy="420" r="2.8" fill="url(#starGlow)" class="star-twinkle" style="--td:2.2s"/>
      <circle cx="1280" cy="480" r="2.2" fill="url(#starGlow)" class="star-twinkle" style="--td:0.3s"/>
      <circle cx="840" cy="560" r="2.5" fill="url(#starGlow)" class="star-twinkle" style="--td:1.1s"/>
      <circle cx="420" cy="660" r="2" fill="url(#starGlow)" class="star-twinkle" style="--td:1.8s"/>
      <circle cx="1160" cy="800" r="2.8" fill="url(#starGlow)" class="star-twinkle" style="--td:2.5s"/>
    </g>
  </svg>

  <!-- Hyperspace streaks (lignes radiales qui jaillissent du centre — image 2) -->
  <div class="hero-streaks" aria-hidden="true"></div>

  <!-- Éclairs violets convergents (image 1 — purple lightning) -->
  <svg class="hero-lightning" aria-hidden="true" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id="lightningGlow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <linearGradient id="boltGrad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#4C1D95" stop-opacity="0"/>
        <stop offset="20%" stop-color="#6D28D9" stop-opacity="0.85"/>
        <stop offset="50%" stop-color="#7C3AED" stop-opacity="1"/>
        <stop offset="80%" stop-color="#6D28D9" stop-opacity="0.85"/>
        <stop offset="100%" stop-color="#4C1D95" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <!-- 8 éclairs qui convergent vers le centre (720, 450) -->
    <g filter="url(#lightningGlow)" stroke="url(#boltGrad)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <polyline class="bolt" style="--bd:0s"    points="80,120 180,220 240,200 340,290 420,310 520,380 640,420 720,450"/>
      <polyline class="bolt" style="--bd:0.3s"  points="1360,100 1240,180 1180,260 1040,310 940,350 820,410 720,450"/>
      <polyline class="bolt" style="--bd:0.7s"  points="60,780 160,690 280,650 400,580 520,540 620,490 720,450"/>
      <polyline class="bolt" style="--bd:1.1s"  points="1380,820 1260,720 1140,680 1020,600 900,560 810,490 720,450"/>
      <polyline class="bolt" style="--bd:1.5s"  points="720,60 700,160 740,240 700,330 730,400 720,450"/>
      <polyline class="bolt" style="--bd:1.9s"  points="720,840 740,750 700,660 740,560 710,500 720,450"/>
      <polyline class="bolt" style="--bd:2.3s"  points="40,450 180,430 320,470 460,440 580,460 700,450 720,450"/>
      <polyline class="bolt" style="--bd:2.7s"  points="1400,450 1260,430 1120,470 980,440 860,460 740,450 720,450"/>
    </g>
  </svg>

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <!-- Orbes violettes flottantes (fond de scène) -->
  <div class="hero-orbs" aria-hidden="true">
    <span class="orb orb-1"></span>
    <span class="orb orb-2"></span>
    <span class="orb orb-3"></span>
    <span class="orb orb-4"></span>
  </div>

  <div class="hero-inner">

    <!-- Eyebrow : badge agence IA -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot" aria-hidden="true"></span>
      <span class="eyebrow-text">Agence IA · E-commerce · 2026</span>
    </div>

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">
        <span class="tl-kicker-bar" aria-hidden="true"></span>
        <span class="tl-kicker-text">Ton agence</span>
      </span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Halo néon violet enveloppant -->
        <span class="booster-halo" aria-hidden="true"></span>

        <!-- Reflet de sol (le mot se reflète comme posé sur un miroir avant de tomber) -->
        <span class="booster-reflection" aria-hidden="true">BOOSTER</span>

        <!-- SPIDER-WEB CRACKS — apparaissent AVANT le shatter (ref Envato) -->
        <svg class="booster-cracks" aria-hidden="true" viewBox="0 0 800 200" preserveAspectRatio="none">
          <defs>
            <filter id="crackGlow" x="-10%" y="-10%" width="120%" height="120%">
              <feGaussianBlur stdDeviation="0.4" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <g filter="url(#crackGlow)" stroke="#4C1D95" stroke-width="1" fill="none" stroke-linecap="round">
            <!-- Fissures principales radiantes depuis 3 points d'impact (barycentres des lettres) -->
            <path class="crack c1" style="--cd:0s"    d="M200,100 L150,40 M200,100 L260,30 M200,100 L310,95 M200,100 L270,170 M200,100 L130,165 M200,100 L80,110 M200,100 L95,45"/>
            <path class="crack c2" style="--cd:0.08s" d="M400,100 L380,30 M400,100 L470,50 M400,100 L510,110 M400,100 L450,175 M400,100 L340,170 M400,100 L290,115 M400,100 L320,40"/>
            <path class="crack c3" style="--cd:0.16s" d="M600,100 L610,25 M600,100 L690,60 M600,100 L720,130 M600,100 L640,180 M600,100 L555,175 M600,100 L490,130 M600,100 L530,40"/>
            <!-- Fissures secondaires (ramifications) -->
            <path class="crack c4" style="--cd:0.24s" d="M150,40 L110,15 M260,30 L300,10 M310,95 L370,100 M130,165 L100,190 M470,50 L510,20 M450,175 L480,195 M690,60 L730,35 M720,130 L760,165"/>
            <path class="crack c5" style="--cd:0.32s" d="M95,45 L50,30 M270,170 L260,195 M380,30 L360,5 M340,170 L320,190 M610,25 L600,5 M555,175 L560,195 M290,115 L240,140 M530,40 L490,15"/>
            <!-- Petites fissures fines (détails) -->
            <path class="crack c6" style="--cd:0.4s"  d="M175,85 L155,75 M215,85 L235,70 M375,90 L355,80 M425,85 L440,70 M580,85 L560,75 M625,85 L640,68 M180,120 L160,135 M230,120 L250,135 M380,125 L365,140 M425,120 L445,135 M575,125 L555,140 M625,125 L650,140"/>
          </g>
        </svg>

        <!-- Flash d'impact (positionné en BAS — comme un verre qui touche le sol) -->
        <span class="booster-impact" aria-hidden="true"></span>

        <!-- Shockwave ring (onde de choc au sol) -->
        <span class="booster-shockwave" aria-hidden="true"></span>

        <!-- Nuage de poussière violette post-explosion -->
        <span class="booster-dust" aria-hidden="true"></span>

        <!-- Mot : 7 lettres × 8 shards polygonaux avec gravité -->
        <span class="booster-3d__word">
          <span class="glass-letter" style="--i:0">
            <span class="glyph">B</span>
            <span class="shard s1" aria-hidden="true">B</span>
            <span class="shard s2" aria-hidden="true">B</span>
            <span class="shard s3" aria-hidden="true">B</span>
            <span class="shard s4" aria-hidden="true">B</span>
            <span class="shard s5" aria-hidden="true">B</span>
            <span class="shard s6" aria-hidden="true">B</span>
            <span class="shard s7" aria-hidden="true">B</span>
            <span class="shard s8" aria-hidden="true">B</span>
          </span>
          <span class="glass-letter" style="--i:1">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
            <span class="shard s7" aria-hidden="true">O</span>
            <span class="shard s8" aria-hidden="true">O</span>
          </span>
          <span class="glass-letter" style="--i:2">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
            <span class="shard s7" aria-hidden="true">O</span>
            <span class="shard s8" aria-hidden="true">O</span>
          </span>
          <span class="glass-letter" style="--i:3">
            <span class="glyph">S</span>
            <span class="shard s1" aria-hidden="true">S</span>
            <span class="shard s2" aria-hidden="true">S</span>
            <span class="shard s3" aria-hidden="true">S</span>
            <span class="shard s4" aria-hidden="true">S</span>
            <span class="shard s5" aria-hidden="true">S</span>
            <span class="shard s6" aria-hidden="true">S</span>
            <span class="shard s7" aria-hidden="true">S</span>
            <span class="shard s8" aria-hidden="true">S</span>
          </span>
          <span class="glass-letter" style="--i:4">
            <span class="glyph">T</span>
            <span class="shard s1" aria-hidden="true">T</span>
            <span class="shard s2" aria-hidden="true">T</span>
            <span class="shard s3" aria-hidden="true">T</span>
            <span class="shard s4" aria-hidden="true">T</span>
            <span class="shard s5" aria-hidden="true">T</span>
            <span class="shard s6" aria-hidden="true">T</span>
            <span class="shard s7" aria-hidden="true">T</span>
            <span class="shard s8" aria-hidden="true">T</span>
          </span>
          <span class="glass-letter" style="--i:5">
            <span class="glyph">E</span>
            <span class="shard s1" aria-hidden="true">E</span>
            <span class="shard s2" aria-hidden="true">E</span>
            <span class="shard s3" aria-hidden="true">E</span>
            <span class="shard s4" aria-hidden="true">E</span>
            <span class="shard s5" aria-hidden="true">E</span>
            <span class="shard s6" aria-hidden="true">E</span>
            <span class="shard s7" aria-hidden="true">E</span>
            <span class="shard s8" aria-hidden="true">E</span>
          </span>
          <span class="glass-letter" style="--i:6">
            <span class="glyph">R</span>
            <span class="shard s1" aria-hidden="true">R</span>
            <span class="shard s2" aria-hidden="true">R</span>
            <span class="shard s3" aria-hidden="true">R</span>
            <span class="shard s4" aria-hidden="true">R</span>
            <span class="shard s5" aria-hidden="true">R</span>
            <span class="shard s6" aria-hidden="true">R</span>
            <span class="shard s7" aria-hidden="true">R</span>
            <span class="shard s8" aria-hidden="true">R</span>
          </span>
        </span>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        <span class="tl-prefix">par l'</span><span class="tl-accent">IA</span><span class="tl-dot">.</span>
      </span>
    </h1>

    <!-- CTAs primary + ghost -->
    <div class="hero-ctas reveal" style="--d:0.7s">
      <a href="#pricing" class="hero-cta-primary">
        <span>Booster mon agence</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      <a href="#services" class="hero-cta-secondary">Voir les offres</a>
    </div>

    <!-- Trust strip : note + agences boostées -->
    <div class="hero-trust reveal" style="--d:0.85s">
      <span class="trust-stars" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
      </span>
      <span class="trust-text"><strong>4.9/5</strong> · clients accompagnés</span>
