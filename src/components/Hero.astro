---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">Ton agence</span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Mot principal (visible 0-32% du cycle, fade out avant explosion) -->
        <span class="booster-3d__word" data-text="BOOSTER">BOOSTER</span>

        <!-- 6 fragments du mot en clip-path qui s'éjectent -->
        <span class="booster-frags" aria-hidden="true">
          <span class="frag frag--1" data-text="BOOSTER">BOOSTER</span>
          <span class="frag frag--2" data-text="BOOSTER">BOOSTER</span>
          <span class="frag frag--3" data-text="BOOSTER">BOOSTER</span>
          <span class="frag frag--4" data-text="BOOSTER">BOOSTER</span>
          <span class="frag frag--5" data-text="BOOSTER">BOOSTER</span>
          <span class="frag frag--6" data-text="BOOSTER">BOOSTER</span>
        </span>

        <!-- Fissures SVG qui précèdent l'explosion -->
        <svg class="booster-3d__cracks" viewBox="0 0 400 120" preserveAspectRatio="none" aria-hidden="true">
          <g class="cracks-glow">
            <path class="crack crack--1" d="M 20 38 L 62 30 L 96 46 L 142 28 L 188 44 L 232 26 L 276 48 L 320 32 L 378 50"/>
            <path class="crack crack--2" d="M 28 84 L 72 94 L 118 78 L 166 92 L 218 80 L 268 96 L 318 82 L 372 94"/>
            <path class="crack crack--3" d="M 72 18 L 68 38 L 82 52 L 76 72"/>
            <path class="crack crack--4" d="M 186 62 L 192 78 L 180 92 L 196 108"/>
            <path class="crack crack--5" d="M 262 20 L 272 44 L 264 60 L 278 78"/>
            <path class="crack crack--6" d="M 340 24 L 334 48 L 346 64 L 338 84"/>
          </g>
          <g class="cracks-main">
            <path class="crack crack--1" d="M 20 38 L 62 30 L 96 46 L 142 28 L 188 44 L 232 26 L 276 48 L 320 32 L 378 50"/>
            <path class="crack crack--2" d="M 28 84 L 72 94 L 118 78 L 166 92 L 218 80 L 268 96 L 318 82 L 372 94"/>
            <path class="crack crack--3" d="M 72 18 L 68 38 L 82 52 L 76 72"/>
            <path class="crack crack--4" d="M 186 62 L 192 78 L 180 92 L 196 108"/>
            <path class="crack crack--5" d="M 262 20 L 272 44 L 264 60 L 278 78"/>
            <path class="crack crack--6" d="M 340 24 L 334 48 L 346 64 L 338 84"/>
          </g>
        </svg>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        par l'<span class="tl-accent">IA</span>.
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: rgba(255, 255, 255, 0.82);
  }
  .tl-line--top    { margin-bottom: 0.1em; }
  .tl-line--bottom { margin-top: 0.05em; }
  .tl-accent {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    color: rgba(216, 180, 254, 0.95);
  }

  /* ========== BOOSTER 3D — cycle fissures → EXPLOSION ========== */
  /* Cycle global = 8s
     0-12.5% (0-1s)    : mot intact
     12.5-27.5% (1-2.2s): fissures se dessinent
     27.5-32.5% (2.2-2.6s): fissuré stable + micro-shake
     32.5-47.5% (2.6-3.8s): EXPLOSION (fragments s'éjectent)
     47.5-75% (3.8-6s)  : éclaté au loin, fade out
     75-87.5% (6-7s)    : invisible
     87.5-100% (7-8s)   : reformation
  */

  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.08em 0 0.04em;
    perspective: 900px;
  }

  /* Variables de style communes à .booster-3d__word + .frag */
  .booster-3d__word,
  .frag {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(80px, 16vw, 224px);
    line-height: 0.9;
    letter-spacing: -0.025em;
    background: linear-gradient(180deg,
      #FFFFFF 0%,
      #F3E8FF 28%,
      #D8B4FE 55%,
      #A855F7 85%,
      #7C3AED 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 2px 0 #7C3AED)
      drop-shadow(0 6px 0 #4C1D95)
      drop-shadow(0 14px 22px rgba(124, 58, 237, 0.45));
    transform-origin: 50% 80%;
  }

  .booster-3d__word {
    position: relative;
    display: inline-block;
    will-change: transform, opacity;
    animation: wordLife 8s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }
  /* Bevel highlight */
  .booster-3d__word::before {
    content: attr(data-text);
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    font: inherit;
    letter-spacing: inherit;
    background: none;
    -webkit-background-clip: initial;
    background-clip: initial;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.3);
    pointer-events: none;
    z-index: 1;
  }
  @keyframes wordLife {
    /* Intact */
    0%, 12%  { opacity: 1; transform: rotateX(4deg) translate(0, 0); }
    /* Fissures arrivent */
    27%      { opacity: 1; transform: rotateX(4deg) translate(0, 0); }
    /* Micro-shake */
    29%      { opacity: 1; transform: rotateX(4deg) translate(2.5px, 0); }
    31%      { opacity: 1; transform: rotateX(4deg) translate(-2.5px, 0); }
    /* Disparition avant explosion */
    32%      { opacity: 1; transform: rotateX(4deg) translate(0, 0) scale(1.02); }
    35%      { opacity: 0; transform: rotateX(4deg) translate(0, 0) scale(1.05); }
    /* Invisible pendant toute la phase explosion */
    87%      { opacity: 0; transform: rotateX(4deg) translate(0, 0) scale(0.95); }
    /* Reformation */
    95%, 100%{ opacity: 1; transform: rotateX(4deg) translate(0, 0) scale(1); }
  }

  /* ============ FRAGMENTS EN CLIP-PATH ============ */
  .booster-frags {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 4;
  }
  .frag {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-block;
    opacity: 0;
    will-change: transform, opacity;
    animation: fragExplode 8s cubic-bezier(0.2, 0.8, 0.2, 1) infinite;
  }

  /* Clip-paths : 6 zones qui pavent le mot (2 rangées x 3 colonnes) avec lignes brisées */
  .frag--1 { clip-path: polygon(0 0,    35% 0,    33% 50%,  0 50%); }
  .frag--2 { clip-path: polygon(35% 0,  65% 0,    66% 50%, 33% 50%); }
  .frag--3 { clip-path: polygon(65% 0, 100% 0,  100% 50%, 66% 50%); }
  .frag--4 { clip-path: polygon(0 50%, 33% 50%,  35% 100%, 0 100%); }
  .frag--5 { clip-path: polygon(33% 50%, 66% 50%, 65% 100%, 35% 100%); }
  .frag--6 { clip-path: polygon(66% 50%, 100% 50%, 100% 100%, 65% 100%); }

  /* Directions d'éjection par fragment */
  .frag--1 { --dx: -120px; --dy:  -75px; --dr: -22deg; }
  .frag--2 { --dx:   -10px; --dy: -110px; --dr:   8deg; }
  .frag--3 { --dx:  130px; --dy:  -65px; --dr:  26deg; }
  .frag--4 { --dx: -100px; --dy:   75px; --dr: -28deg; }
  .frag--5 { --dx:   12px; --dy:  115px; --dr:  -5deg; }
  .frag--6 { --dx:  140px; --dy:   85px; --dr:  30deg; }

  @keyframes fragExplode {
    /* Invisible avant l'explosion */
    0%, 32%  {
      opacity: 0;
      transform: rotateX(4deg) translate(0, 0) rotate(0deg);
    }
    /* Apparaissent pile quand le mot principal disparaît */
    35%      {
      opacity: 1;
      transform: rotateX(4deg) translate(0, 0) rotate(0deg);
    }
    /* Explosion : s'éjectent rapidement */
    47%      {
      opacity: 1;
      transform: rotateX(4deg) translate(var(--dx), var(--dy)) rotate(var(--dr));
    }
    /* Continuent à dériver */
    62%      {
      opacity: 0.7;
      transform: rotateX(4deg)
        translate(calc(var(--dx) * 1.3), calc(var(--dy) * 1.3))
        rotate(calc(var(--dr) * 1.4));
    }
    /* Fade out progressif */
    75%      {
      opacity: 0;
      transform: rotateX(4deg)
        translate(calc(var(--dx) * 1.6), calc(var(--dy) * 1.6))
        rotate(calc(var(--dr) * 1.8));
    }
    /* Invisible + reset discret */
    88%, 100%{
      opacity: 0;
      transform: rotateX(4deg) translate(0, 0) rotate(0deg);
    }
  }

  /* ============ FISSURES (cycle synchronisé sur 8s) ============ */
  .booster-3d__cracks {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 3;
    transform: rotateX(4deg);
    transform-origin: 50% 80%;
  }
  .cracks-glow .crack {
    stroke: rgba(168, 85, 247, 0.75);
    stroke-width: 1px;
    fill: none;
    transform: translate(1px, 1.5px);
    filter: blur(0.5px);
  }
  .cracks-main .crack {
    stroke: #000;
    stroke-width: 2.4px;
    stroke-linecap: butt;
    stroke-linejoin: miter;
    fill: none;
  }
  .crack {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: crackCycle 8s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }
  /* Cascade via delay négatifs très courts (garde le cycle 8s global) */
  .cracks-main .crack--2, .cracks-glow .crack--2 { animation-delay: -0.04s; }
  .cracks-main .crack--3, .cracks-glow .crack--3 { animation-delay: -0.08s; }
  .cracks-main .crack--4, .cracks-glow .crack--4 { animation-delay: -0.12s; }
  .cracks-main .crack--5, .cracks-glow .crack--5 { animation-delay: -0.16s; }
  .cracks-main .crack--6, .cracks-glow .crack--6 { animation-delay: -0.2s; }

  @keyframes crackCycle {
    0%, 13%  { stroke-dashoffset: 400; opacity: 1; }
    27%      { stroke-dashoffset: 0;   opacity: 1; }
    32%      { stroke-dashoffset: 0;   opacity: 1; }
    35%      { stroke-dashoffset: 0;   opacity: 0; }  /* disparaissent avec le mot */
    99%      { stroke-dashoffset: 0;   opacity: 0; }
    100%     { stroke-dashoffset: 400; opacity: 0; }
  }

  /* Pause cycle au hover = le mot reste éclaté plus longtemps */
  .booster-3d:hover .booster-3d__word,
  .booster-3d:hover .frag,
  .booster-3d:hover .crack {
    animation-play-state: paused;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .booster-3d__word,
    .frag { font-size: clamp(64px, 18vw, 120px); }
  }
  @media (max-width: 480px) {
    .booster-3d__word,
    .frag {
      filter:
        drop-shadow(0 2px 0 #7C3AED)
        drop-shadow(0 4px 0 #4C1D95)
        drop-shadow(0 10px 16px rgba(124, 58, 237, 0.45));
    }
    /* Amplitude d'explosion réduite mobile */
    .frag--1 { --dx: -60px;  --dy: -40px; }
    .frag--2 { --dx:  -5px;  --dy: -60px; }
    .frag--3 { --dx:  70px;  --dy: -35px; }
    .frag--4 { --dx: -55px;  --dy:  40px; }
    .frag--5 { --dx:   8px;  --dy:  65px; }
    .frag--6 { --dx:  75px;  --dy:  45px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .booster-3d__word,
    .frag,
    .crack {
      animation: none;
    }
    .booster-3d__word { opacity: 1; transform: rotateX(4deg); }
    .frag { opacity: 0; }
    .crack { stroke-dashoffset: 0; opacity: 1; }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
