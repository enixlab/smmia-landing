---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Galaxy starfield (layers) -->
  <div class="hero-galaxy" aria-hidden="true">
    <div class="galaxy-stars galaxy-stars--far"></div>
    <div class="galaxy-stars galaxy-stars--mid"></div>
    <div class="galaxy-stars galaxy-stars--near"></div>
    <div class="galaxy-nebula galaxy-nebula--a"></div>
    <div class="galaxy-nebula galaxy-nebula--b"></div>
    <div class="galaxy-nebula galaxy-nebula--c"></div>
    <span class="galaxy-shooting galaxy-shooting--1"></span>
    <span class="galaxy-shooting galaxy-shooting--2"></span>
    <span class="galaxy-shooting galaxy-shooting--3"></span>
  </div>

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet pulsant derrière la tagline -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Eyebrow : badge session live -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot"></span>
      <span class="eyebrow-text">Session Mai 2026 · Places limitées</span>
    </div>

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence rentable BOOSTÉE par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tagline-line tagline-top reveal" style="--d:0.2s">
        Ton agence rentable
      </span>
      <span class="tagline-line tagline-boost-line reveal" style="--d:0.4s">
        <span class="boost-word" aria-label="Boostée">
          <!-- Rayons d'explosion SVG -->
          <svg class="boost-rays" viewBox="-100 -100 200 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
            <defs>
              <linearGradient id="rayG" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#FCD34D"/>
                <stop offset="35%" stop-color="#FB923C"/>
                <stop offset="70%" stop-color="#A855F7"/>
                <stop offset="100%" stop-color="#22D3EE"/>
              </linearGradient>
            </defs>
            <g class="boost-rays-group" stroke="url(#rayG)" stroke-width="2.2" stroke-linecap="round" opacity="0.85">
              <line x1="-92" y1="0"   x2="-44" y2="0"   />
              <line x1="92"  y1="0"   x2="44"  y2="0"   />
              <line x1="0"   y1="-92" x2="0"   y2="-44" />
              <line x1="0"   y1="92"  x2="0"   y2="44"  />
              <line x1="-66" y1="-66" x2="-32" y2="-32" />
              <line x1="66"  y1="66"  x2="32"  y2="32"  />
              <line x1="-66" y1="66"  x2="-32" y2="32"  />
              <line x1="66"  y1="-66" x2="32"  y2="-32" />
              <line x1="-82" y1="-34" x2="-42" y2="-18" stroke-width="1.4"/>
              <line x1="82"  y1="34"  x2="42"  y2="18"  stroke-width="1.4"/>
              <line x1="-34" y1="-82" x2="-18" y2="-42" stroke-width="1.4"/>
              <line x1="34"  y1="82"  x2="18"  y2="42"  stroke-width="1.4"/>
              <line x1="-82" y1="34"  x2="-42" y2="18"  stroke-width="1.4"/>
              <line x1="82"  y1="-34" x2="42"  y2="-18" stroke-width="1.4"/>
              <line x1="-34" y1="82"  x2="-18" y2="42"  stroke-width="1.4"/>
              <line x1="34"  y1="-82" x2="18"  y2="-42" stroke-width="1.4"/>
            </g>
          </svg>
          <!-- Particules d'explosion -->
          <span class="boost-particle boost-particle--1"></span>
          <span class="boost-particle boost-particle--2"></span>
          <span class="boost-particle boost-particle--3"></span>
          <span class="boost-particle boost-particle--4"></span>
          <span class="boost-particle boost-particle--5"></span>
          <span class="boost-particle boost-particle--6"></span>
          <!-- Le mot BOOSTÉE -->
          <span class="boost-word-text" data-text="BOOSTÉE">BOOSTÉE</span>
        </span>
      </span>
      <span class="tagline-line tagline-bottom reveal" style="--d:0.6s">
        par l'IA.
      </span>
    </h1>

    <!-- CTA premium + secondaire -->
    <div class="hero-ctas reveal" style="--d:0.75s">
      <a href="#pricing" class="hero-cta-primary">
        <span class="cta-label">Rejoindre la session</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg viewBox="0 0 14 12" fill="none" width="14" height="12">
            <path d="M1 6H13M13 6L8 1M13 6L8 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <a href="#programme" class="hero-cta-secondary">
        Voir le programme
      </a>
    </div>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight pulsant multi-couleur derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 78%;
    max-width: 1100px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(251, 146, 60, 0.22) 0%, transparent 55%),
      radial-gradient(ellipse at center, rgba(168, 85, 247, 0.35) 0%, rgba(124, 58, 237, 0.18) 40%, transparent 72%),
      radial-gradient(ellipse at 72% 50%, rgba(34, 211, 238, 0.22) 0%, transparent 55%);
    filter: blur(32px);
    z-index: 0;
    pointer-events: none;
    animation: spotlightBreath 7s ease-in-out infinite;
  }
  @keyframes spotlightBreath {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.06); }
  }

  /* ===================== GALAXIE ACTIVE ===================== */
  .hero-galaxy {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Starfield — 3 profondeurs, box-shadow multi-étoiles */
  .galaxy-stars {
    position: absolute;
    inset: -20% -10%;
    background: transparent;
    will-change: transform;
  }
  .galaxy-stars::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }
  .galaxy-stars--far::before {
    width: 2px; height: 2px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      120px 80px rgba(255,255,255,0.85),
      260px 180px rgba(216,180,254,0.9),
      440px 40px rgba(255,255,255,0.7),
      580px 220px rgba(192,132,252,0.85),
      720px 130px rgba(255,255,255,0.6),
      860px 60px rgba(255,255,255,0.8),
      980px 280px rgba(216,180,254,0.7),
      1140px 180px rgba(255,255,255,0.9),
      1280px 90px rgba(192,132,252,0.8),
      1420px 230px rgba(255,255,255,0.7),
      1580px 60px rgba(255,255,255,0.65),
      1720px 150px rgba(216,180,254,0.8),
      80px 320px rgba(255,255,255,0.7),
      220px 420px rgba(192,132,252,0.85),
      380px 500px rgba(255,255,255,0.7),
      540px 380px rgba(255,255,255,0.8),
      680px 560px rgba(216,180,254,0.75),
      820px 460px rgba(255,255,255,0.65),
      960px 620px rgba(192,132,252,0.9),
      1120px 400px rgba(255,255,255,0.8),
      1280px 540px rgba(255,255,255,0.7),
      1440px 460px rgba(216,180,254,0.85),
      1600px 580px rgba(255,255,255,0.7),
      1760px 380px rgba(192,132,252,0.8);
    animation: starsTwinkle 4s ease-in-out infinite, starsDriftFar 120s linear infinite;
  }
  .galaxy-stars--mid::before {
    width: 2.5px; height: 2.5px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      180px 120px rgba(255,255,255,1),
      340px 260px rgba(34,211,238,0.9),
      520px 80px rgba(255,255,255,0.85),
      680px 360px rgba(251,146,60,0.8),
      840px 190px rgba(255,255,255,0.9),
      1020px 80px rgba(252,211,77,0.85),
      1200px 320px rgba(255,255,255,0.8),
      1380px 220px rgba(34,211,238,0.85),
      1560px 140px rgba(255,255,255,0.9),
      1720px 300px rgba(251,146,60,0.8),
      140px 480px rgba(255,255,255,0.85),
      320px 560px rgba(34,211,238,0.9),
      500px 620px rgba(255,255,255,0.8),
      680px 480px rgba(252,211,77,0.9),
      860px 600px rgba(255,255,255,0.85),
      1040px 520px rgba(251,146,60,0.8),
      1220px 640px rgba(255,255,255,0.9),
      1400px 560px rgba(34,211,238,0.85),
      1580px 620px rgba(255,255,255,0.8),
      1760px 500px rgba(252,211,77,0.9);
    animation: starsTwinkle 3s ease-in-out infinite 0.5s, starsDriftMid 80s linear infinite;
  }
  .galaxy-stars--near::before {
    width: 3.5px; height: 3.5px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      240px 100px rgba(255,255,255,1),
      480px 240px rgba(216,180,254,1),
      760px 160px rgba(34,211,238,0.95),
      1040px 300px rgba(255,255,255,1),
      1320px 180px rgba(251,146,60,0.95),
      1620px 240px rgba(255,255,255,1),
      200px 440px rgba(252,211,77,1),
      460px 560px rgba(255,255,255,1),
      760px 620px rgba(216,180,254,0.95),
      1060px 480px rgba(34,211,238,1),
      1360px 580px rgba(255,255,255,1),
      1660px 420px rgba(251,146,60,0.9);
    filter: drop-shadow(0 0 6px rgba(255,255,255,0.6));
    animation: starsTwinkle 2.2s ease-in-out infinite 1s, starsDriftNear 60s linear infinite;
  }

  @keyframes starsTwinkle {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.35; }
  }
  @keyframes starsDriftFar {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-40px, 18px, 0); }
  }
  @keyframes starsDriftMid {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-80px, 30px, 0); }
  }
  @keyframes starsDriftNear {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-140px, 50px, 0); }
  }

  /* Nébuleuses colorées qui bougent lentement */
  .galaxy-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    opacity: 0.55;
    will-change: transform, opacity;
  }
  .galaxy-nebula--a {
    width: 520px; height: 520px;
    top: -8%; left: -6%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.7) 0%, rgba(124, 58, 237, 0.3) 45%, transparent 70%);
    animation: nebulaFloatA 22s ease-in-out infinite;
  }
  .galaxy-nebula--b {
    width: 460px; height: 460px;
    top: 55%; right: -8%;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.6) 0%, rgba(14, 165, 233, 0.25) 45%, transparent 70%);
    animation: nebulaFloatB 28s ease-in-out infinite;
  }
  .galaxy-nebula--c {
    width: 380px; height: 380px;
    bottom: -6%; left: 30%;
    background: radial-gradient(circle, rgba(251, 146, 60, 0.5) 0%, rgba(252, 211, 77, 0.2) 45%, transparent 70%);
    animation: nebulaFloatC 26s ease-in-out infinite;
  }
  @keyframes nebulaFloatA {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.55; }
    50%      { transform: translate(40px, 60px) scale(1.08); opacity: 0.7; }
  }
  @keyframes nebulaFloatB {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50%      { transform: translate(-50px, -40px) scale(1.1); opacity: 0.65; }
  }
  @keyframes nebulaFloatC {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.45; }
    50%      { transform: translate(30px, -50px) scale(1.12); opacity: 0.6; }
  }

  /* Étoiles filantes */
  .galaxy-shooting {
    position: absolute;
    width: 2px;
    height: 2px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.8);
    opacity: 0;
  }
  .galaxy-shooting::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 2px;
    width: 140px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.95), rgba(216, 180, 254, 0.6));
    transform: translateY(-50%);
  }
  .galaxy-shooting--1 {
    top: 18%; left: -10%;
    animation: shootingStar 8s ease-in 2s infinite;
  }
  .galaxy-shooting--2 {
    top: 42%; left: -10%;
    animation: shootingStar 11s ease-in 5s infinite;
  }
  .galaxy-shooting--3 {
    top: 68%; left: -10%;
    animation: shootingStar 14s ease-in 8s infinite;
  }
  @keyframes shootingStar {
    0%   { transform: translate3d(0, 0, 0); opacity: 0; }
    5%   { opacity: 1; }
    40%  { opacity: 1; }
    60%  { opacity: 0; }
    100% { transform: translate3d(130vw, 24vh, 0); opacity: 0; }
  }

  /* =============== TAGLINE — multilignes =============== */
  .tagline-line {
    display: block;
    line-height: 1;
  }
  .tagline-top {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.82);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  :global([data-theme="light"]) .tagline-top {
    color: rgba(10, 4, 24, 0.78);
  }
  .tagline-bottom {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.015em;
    margin-top: 4px;
  }
  :global([data-theme="light"]) .tagline-bottom {
    color: rgba(10, 4, 24, 0.92);
  }

  /* =============== BOOSTÉE — explosion =============== */
  .tagline-boost-line {
    position: relative;
    display: block;
    padding: 8px 0;
    line-height: 1;
  }

  .boost-word {
    position: relative;
    display: inline-block;
    line-height: 1;
    z-index: 1;
  }

  /* Rayons d'explosion */
  .boost-rays {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 160%;
    height: 320%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    overflow: visible;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.65))
            drop-shadow(0 0 28px rgba(251, 146, 60, 0.35));
  }
  .boost-rays-group {
    transform-origin: center;
    animation: raysPulse 3.4s ease-in-out infinite, raysSpin 38s linear infinite;
  }
  @keyframes raysPulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.08); }
  }
  @keyframes raysSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Particules d'explosion */
  .boost-particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  .boost-particle--1 { background: #FCD34D; box-shadow: 0 0 12px 2px rgba(252, 211, 77, 0.85); animation: particleBurst 3s ease-out 0.4s infinite;  --px: -240px; --py: -110px; }
  .boost-particle--2 { background: #FB923C; box-shadow: 0 0 12px 2px rgba(251, 146, 60, 0.85); animation: particleBurst 3.2s ease-out 0.9s infinite; --px:  240px; --py: -130px; }
  .boost-particle--3 { background: #A855F7; box-shadow: 0 0 12px 2px rgba(168, 85, 247, 0.85); animation: particleBurst 3.6s ease-out 0.2s infinite; --px: -280px; --py:  120px; }
  .boost-particle--4 { background: #22D3EE; box-shadow: 0 0 12px 2px rgba(34, 211, 238, 0.85); animation: particleBurst 3.4s ease-out 1.3s infinite; --px:  280px; --py:  110px; }
  .boost-particle--5 { background: #FFFFFF; box-shadow: 0 0 14px 2px rgba(255, 255, 255, 0.9);  animation: particleBurst 3.8s ease-out 0.7s infinite; --px:  -60px; --py: -160px; }
  .boost-particle--6 { background: #FFFFFF; box-shadow: 0 0 14px 2px rgba(255, 255, 255, 0.9);  animation: particleBurst 3s ease-out 1.7s infinite;   --px:   60px; --py:  160px; }
  @keyframes particleBurst {
    0%   { transform: translate(-50%, -50%) scale(0.4); opacity: 0; }
    15%  { opacity: 1; }
    100% { transform: translate(calc(-50% + var(--px)), calc(-50% + var(--py))) scale(0.2); opacity: 0; }
  }

  /* Le mot BOOSTÉE */
  .boost-word-text {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(68px, 12vw, 180px);
    line-height: 1;
    letter-spacing: -0.045em;
    background: linear-gradient(135deg,
      #FCD34D 0%,
      #FB923C 25%,
      #A855F7 55%,
      #7C3AED 78%,
      #22D3EE 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 18px rgba(251, 146, 60, 0.55))
      drop-shadow(0 0 36px rgba(168, 85, 247, 0.5))
      drop-shadow(0 0 56px rgba(34, 211, 238, 0.35));
    animation: boostGradientShift 6s ease-in-out infinite, boostPulseScale 3.2s ease-in-out infinite;
    z-index: 2;
    transform-origin: center;
  }
  .boost-word-text::before {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    -webkit-text-fill-color: transparent;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.28);
    z-index: -1;
    pointer-events: none;
  }
  @keyframes boostGradientShift {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }
  @keyframes boostPulseScale {
    0%, 100% { transform: scale(1); filter:
                drop-shadow(0 0 18px rgba(251, 146, 60, 0.55))
                drop-shadow(0 0 36px rgba(168, 85, 247, 0.5))
                drop-shadow(0 0 56px rgba(34, 211, 238, 0.35)); }
    50%      { transform: scale(1.035); filter:
                drop-shadow(0 0 26px rgba(251, 146, 60, 0.8))
                drop-shadow(0 0 52px rgba(168, 85, 247, 0.75))
                drop-shadow(0 0 80px rgba(34, 211, 238, 0.55)); }
  }

  :global([data-theme="light"]) .boost-word-text::before {
    -webkit-text-stroke: 1.5px rgba(10, 4, 24, 0.18);
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
