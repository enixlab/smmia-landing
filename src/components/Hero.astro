    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
