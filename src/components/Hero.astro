---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Custom cursor (dot + ring blend-mode difference) -->
  <div class="cursor" id="cursor" aria-hidden="true">
    <span class="cursor-dot"></span>
    <span class="cursor-ring"></span>
  </div>

  <!-- Gradient mesh blobs morphing (remplace une partie des nébuleuses) -->
  <div class="gradient-mesh" aria-hidden="true">
    <span class="mesh-blob mesh-blob--1"></span>
    <span class="mesh-blob mesh-blob--2"></span>
    <span class="mesh-blob mesh-blob--3"></span>
  </div>

  <!-- ============ SCÈNE FUTURISTE ============ -->
  <div class="hero-galaxy" aria-hidden="true">
    <div class="galaxy-deep"></div>
    <div class="galaxy-stars"></div>
    <div class="galaxy-nebula galaxy-nebula--a"></div>
    <div class="galaxy-nebula galaxy-nebula--b"></div>

    <!-- Noise texture grain analogique (signature Awwwards) -->
    <div class="hero-noise" aria-hidden="true"></div>

    <!-- GLOBE WIREFRAME 3D + HUD -->
    <div class="orb-scene">

      <!-- Glow externe -->
      <div class="orb-glow"></div>

      <!-- Aura "expose" (anneaux qui partent de l'orb) -->
      <div class="orb-expose orb-expose--1"></div>
      <div class="orb-expose orb-expose--2"></div>

      <!-- Orbital rings 3D inclinés (rotation en boucle) -->
      <div class="orb-ring orb-ring--1"></div>
      <div class="orb-ring orb-ring--2"></div>
      <div class="orb-ring orb-ring--3"></div>

      <!-- GLOBE (méridiens + parallèles CSS 3D) -->
      <div class="globe-3d">
        <div class="globe-spin">
          <!-- 8 méridiens (rotateY espacés de 22.5°) -->
          <div class="meridian" style="--a:0deg"></div>
          <div class="meridian" style="--a:22.5deg"></div>
          <div class="meridian" style="--a:45deg"></div>
          <div class="meridian" style="--a:67.5deg"></div>
          <div class="meridian" style="--a:90deg"></div>
          <div class="meridian" style="--a:112.5deg"></div>
          <div class="meridian" style="--a:135deg"></div>
          <div class="meridian" style="--a:157.5deg"></div>
        </div>
        <!-- 5 parallèles fixes (ellipses horizontales) -->
        <div class="parallel" style="--y:-78px;--rx:38px"></div>
        <div class="parallel" style="--y:-42px;--rx:68px"></div>
        <div class="parallel" style="--y:0;--rx:82px"></div>
        <div class="parallel" style="--y:42px;--rx:68px"></div>
        <div class="parallel" style="--y:78px;--rx:38px"></div>
        <!-- Core glow au centre -->
        <div class="globe-core"></div>
        <!-- 3 markers avec target -->
        <div class="globe-target globe-target--1">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
        <div class="globe-target globe-target--2">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
        <div class="globe-target globe-target--3">
          <svg viewBox="-12 -12 24 24"><circle cx="0" cy="0" r="2.5"/><circle cx="0" cy="0" r="6" fill="none" stroke-width="0.6"/><line x1="-10" y1="0" x2="-7" y2="0"/><line x1="10" y1="0" x2="7" y2="0"/><line x1="0" y1="-10" x2="0" y2="-7"/><line x1="0" y1="10" x2="0" y2="7"/></svg>
        </div>
      </div>

      <!-- HUD minimaliste : un seul label élégant -->
      <div class="hud hud--br">
        <div class="hud-label">BOOST RATE</div>
        <div class="hud-value hud-value--big" data-count="347">+0%</div>
      </div>
    </div>
  </div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet derrière la tagline -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia" />
    </div>

    <!-- Tagline éditoriale : split-text letter stagger reveal (signature Awwwards) -->
    <h1 class="hero-title">
      <span class="tagline-top split-reveal" style="--start:0.15s">
        <span class="line-inner">
          <span class="serif-italic">Ton</span>&nbsp;agence&nbsp;rentable
        </span>
      </span>
      <span class="tagline-boost">
        <span class="boost-aura" aria-hidden="true"></span>

        <!-- Burst radial style manga (lignes qui partent du centre) -->
        <span class="boost-burst" aria-hidden="true">
          <svg viewBox="-100 -100 200 200" preserveAspectRatio="xMidYMid meet">
            {Array.from({length: 36}, (_, i) => {
              const a = (i / 36) * 360;
              const long = i % 2 === 0;
              return (
                <line
                  x1="0" y1="0"
                  x2={long ? 90 : 70} y2="0"
                  stroke-width={long ? 3.2 : 1.6}
                  transform={`rotate(${a})`}
                />
              );
            })}
          </svg>
        </span>

        <!-- Éclats 3D qui flottent en permanence autour du mot -->
        <span class="boost-shards" aria-hidden="true">
          {Array.from({length: 14}, (_, i) => (
            <span class={`shard shard--${i + 1}`}>
              <svg viewBox="0 0 20 20">
                <polygon points="10,0 20,10 10,20 0,10" />
              </svg>
            </span>
          ))}
        </span>

        <!-- VRAI rendu 3D Z-stacked : chaque lettre = 28 couches translatées en Z -->
        <span class="b3d-stage" id="boosterStage">
          <span class="b3d-rotator" id="boosterRotator">
            {['B','O','O','S','T','E','R'].map((l, i) => (
              <span class="b3d-letter" style={`--li:${i}`}>
                {Array.from({length: 28}, (_, d) => (
                  <span class="b3d-layer" style={`--d:${d}`}>{l}</span>
                ))}
              </span>
            ))}
          </span>
        </span>
      </span>
      <span class="tagline-bottom split-reveal" style="--start:0.6s">
        <span class="line-inner">
          par&nbsp;l'<span class="serif-italic">intelligence</span>.
        </span>
      </span>
    </h1>

    <!-- Data readouts sous la tagline (mono futuriste, compteurs animés) -->
    <div class="hero-readouts reveal" style="--d:0.65s" aria-hidden="true">
      <span class="readout"><span class="readout-key">UPTIME</span><span class="readout-val"><span data-count="99.98" data-suffix="%">0</span></span></span>
      <span class="readout-sep"></span>
      <span class="readout"><span class="readout-key">AGENCES</span><span class="readout-val" data-count="847">0</span></span>
      <span class="readout-sep"></span>
      <span class="readout"><span class="readout-key">v11.0</span><span class="readout-val">// STABLE</span></span>
    </div>

  </div>

  <!-- Scroll indicator minimaliste -->
  <a href="#programme" class="scroll-indicator" aria-label="Faire défiler">
    <span class="scroll-line"></span>
    <span class="scroll-text">SCROLL</span>
  </a>

  <!-- Marquee ticker en bas (scroll infini, signature Awwwards) -->
  <div class="hero-marquee" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item">BOOSTER ·</span>
      <span class="marquee-item marquee-item--dim">AI AUTOMATION</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">HIGH TICKET</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">MRR RECURRING</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">SCALE x10</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">PROSPECTION 24/7</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">SESSION 2026</span>
      <span class="marquee-item">·</span>
      <!-- duplicate for seamless loop -->
      <span class="marquee-item">BOOSTER ·</span>
      <span class="marquee-item marquee-item--dim">AI AUTOMATION</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">HIGH TICKET</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">MRR RECURRING</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">SCALE x10</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">PROSPECTION 24/7</span>
      <span class="marquee-item">·</span>
      <span class="marquee-item marquee-item--dim">SESSION 2026</span>
      <span class="marquee-item">·</span>
    </div>
  </div>

  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  /* =============== Custom cursor (Awwwards signature) =============== */
  .cursor {
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99999;
    mix-blend-mode: difference;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .cursor.is-visible { opacity: 1; }
  .cursor-dot {
    position: fixed;
    top: 0; left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ffffff;
    transform: translate3d(-50%, -50%, 0);
    will-change: transform;
  }
  .cursor-ring {
    position: fixed;
    top: 0; left: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #ffffff;
    transform: translate3d(-50%, -50%, 0) scale(1);
    will-change: transform;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), width 0.3s ease, height 0.3s ease;
  }
  .cursor.is-hover .cursor-ring {
    transform: translate3d(-50%, -50%, 0) scale(2.2);
    border-width: 1px;
  }
  .cursor.is-hover .cursor-dot {
    opacity: 0.3;
  }
  /* Hide custom cursor on touch/mobile */
  @media (hover: none), (max-width: 768px) {
    .cursor { display: none !important; }
  }

  /* =============== Gradient mesh blobs morphing =============== */
  .gradient-mesh {
    position: absolute;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    filter: blur(60px);
    mix-blend-mode: screen;
  }
  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform, border-radius;
  }
  .mesh-blob--1 {
    top: 10%; left: 20%;
    width: 480px; height: 480px;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.55) 0%, transparent 70%);
    animation: meshMorph1 18s ease-in-out infinite;
  }
  .mesh-blob--2 {
    top: 50%; left: 70%;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.5) 0%, transparent 70%);
    animation: meshMorph2 22s ease-in-out infinite;
  }
  .mesh-blob--3 {
    top: 65%; left: 10%;
    width: 380px; height: 380px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.45) 0%, transparent 70%);
    animation: meshMorph3 20s ease-in-out infinite;
  }
  @keyframes meshMorph1 {
    0%, 100% { transform: translate(0, 0) scale(1); border-radius: 50% 40% 50% 40%; }
    50%      { transform: translate(40px, 30px) scale(1.15); border-radius: 40% 60% 40% 50%; }
  }
  @keyframes meshMorph2 {
    0%, 100% { transform: translate(0, 0) scale(1); border-radius: 45% 55% 50% 50%; }
    50%      { transform: translate(-50px, 40px) scale(1.2); border-radius: 55% 45% 60% 40%; }
  }
  @keyframes meshMorph3 {
    0%, 100% { transform: translate(0, 0) scale(1); border-radius: 50%; }
    50%      { transform: translate(30px, -40px) scale(1.1); border-radius: 40% 60% 55% 45%; }
  }

  /* =============== Scène Hero =============== */
  #hero {
    position: relative;
    width: 100%;
    background:
      radial-gradient(ellipse 120% 80% at 50% 0%, #1a0730 0%, #0d0320 40%, #06010F 75%, #000 100%);
    padding: 110px 24px 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 880px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }

  /* =============== GALAXIE =============== */
  .hero-galaxy {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .galaxy-deep {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(124, 58, 237, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(168, 85, 247, 0.12) 0%, transparent 60%);
  }

  .galaxy-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 25% 40%, rgba(216,180,254,0.85), transparent),
      radial-gradient(1.5px 1.5px at 45% 22%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 62% 8%, rgba(233,213,255,0.85), transparent),
      radial-gradient(1px 1px at 78% 35%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.5px 1.5px at 88% 62%, rgba(216,180,254,0.9), transparent),
      radial-gradient(1px 1px at 15% 70%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1px 1px at 40% 85%, rgba(233,213,255,0.75), transparent),
      radial-gradient(1.5px 1.5px at 70% 78%, rgba(255,255,255,0.85), transparent),
      radial-gradient(1px 1px at 92% 12%, rgba(192,132,252,0.85), transparent),
      radial-gradient(1px 1px at 30% 55%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 55% 68%, rgba(216,180,254,0.7), transparent);
    opacity: 0.9;
    animation: starsTwinkle 6s ease-in-out infinite;
  }
  @keyframes starsTwinkle {
    0%, 100% { opacity: 0.9; }
    50%      { opacity: 0.55; }
  }

  .galaxy-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    mix-blend-mode: screen;
  }
  .galaxy-nebula--a {
    width: 520px; height: 520px;
    top: -10%; right: -6%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.45) 0%, transparent 65%);
    animation: nebulaA 28s ease-in-out infinite;
  }
  .galaxy-nebula--b {
    width: 420px; height: 420px;
    top: 58%; left: -8%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.38) 0%, transparent 65%);
    animation: nebulaB 32s ease-in-out infinite;
  }
  @keyframes nebulaA {
    0%, 100% { transform: translate(0, 0); opacity: 0.55; }
    50%      { transform: translate(-30px, 30px); opacity: 0.8; }
  }
  @keyframes nebulaB {
    0%, 100% { transform: translate(0, 0); opacity: 0.5; }
    50%      { transform: translate(40px, -20px); opacity: 0.75; }
  }

  /* Noise texture grain analogique (signature Awwwards premium) */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    opacity: 0.08;
    background-image: url("data:image/svg+xml;utf8,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }

  /* =============== ORB SCÈNE =============== */
  .orb-scene {
    position: absolute;
    top: 50%;
    right: 6%;
    transform: translateY(-50%);
    width: 420px;
    height: 420px;
    perspective: 1000px;
    transform-style: preserve-3d;
    z-index: 1;
  }

  .orb-glow {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.28) 0%, rgba(168, 85, 247, 0.1) 45%, transparent 72%);
    filter: blur(24px);
    animation: orbGlowPulse 5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes orbGlowPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }

  /* Expose rings */
  .orb-expose {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(216, 180, 254, 0.6);
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 18px rgba(168, 85, 247, 0.5);
  }
  .orb-expose--1 { animation: exposeRing 4.5s ease-out infinite; }
  .orb-expose--2 { animation: exposeRing 4.5s ease-out 2.2s infinite; }
  @keyframes exposeRing {
    0%   { transform: scale(1);   opacity: 0.85; border-width: 2px; }
    70%  { opacity: 0.18; }
    100% { transform: scale(1.8); opacity: 0;   border-width: 0.5px; }
  }

  /* Orbital rings 3D (inclinés, rotation à vitesses différentes) */
  .orb-ring {
    position: absolute;
    inset: -8%;
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 50%;
    pointer-events: none;
  }
  .orb-ring::before {
    content: '';
    position: absolute;
    top: 50%; left: -4px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #E9D5FF;
    box-shadow: 0 0 10px 2px rgba(216, 180, 254, 0.9), 0 0 20px 4px rgba(168, 85, 247, 0.5);
    transform: translateY(-50%);
  }
  .orb-ring--1 { transform: rotateX(70deg) rotateZ(0deg);  animation: ringSpin 22s linear infinite; }
  .orb-ring--2 { transform: rotateX(80deg) rotateZ(45deg); animation: ringSpin 28s linear infinite reverse; inset: -14%; opacity: 0.7; }
  .orb-ring--3 { transform: rotateX(60deg) rotateZ(90deg); animation: ringSpin 34s linear infinite; inset: -20%; opacity: 0.5; border-style: dashed; }
  @keyframes ringSpin {
    from { transform: rotateX(70deg) rotateZ(0deg); }
    to   { transform: rotateX(70deg) rotateZ(360deg); }
  }

  /* =============== GLOBE 3D wireframe =============== */
  .globe-3d {
    position: absolute;
    inset: 15%;
    transform-style: preserve-3d;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 30%,
      rgba(168, 85, 247, 0.25) 0%,
      rgba(124, 58, 237, 0.15) 30%,
      rgba(46, 16, 101, 0.45) 65%,
      rgba(10, 4, 24, 0.85) 95%);
    box-shadow:
      inset -20px -20px 60px rgba(10, 4, 24, 0.85),
      inset 14px 14px 40px rgba(216, 180, 254, 0.2),
      0 0 0 1px rgba(216, 180, 254, 0.15);
  }

  .globe-spin {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    animation: globeSpin 24s linear infinite;
  }
  @keyframes globeSpin {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  /* Méridiens : cercles verticaux avec rotateY */
  .meridian {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(168, 85, 247, 0.45);
    border-radius: 50%;
    transform: rotateY(var(--a));
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.3);
  }

  /* Parallèles : ellipses horizontales fixes (pas affectées par la rotation) */
  .parallel {
    position: absolute;
    left: 50%;
    top: 50%;
    width: calc(var(--rx) * 2);
    height: 4px;
    margin-left: calc(var(--rx) * -1);
    border: 1px solid rgba(216, 180, 254, 0.5);
    border-radius: 50%;
    transform: translateY(var(--y));
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.35);
  }

  /* Core glow (centre de la sphère, effet lumineux) */
  .globe-core {
    position: absolute;
    top: 50%; left: 50%;
    width: 60%; height: 60%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle,
      rgba(233, 213, 255, 0.5) 0%,
      rgba(168, 85, 247, 0.25) 35%,
      transparent 65%);
    filter: blur(12px);
    animation: coreBreath 3.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes coreBreath {
    0%, 100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;   transform: translate(-50%, -50%) scale(1.1); }
  }

  /* Targets (markers futuristes style crosshair) */
  .globe-target {
    position: absolute;
    width: 28px;
    height: 28px;
    color: #F3E8FF;
    pointer-events: none;
    z-index: 5;
    filter: drop-shadow(0 0 6px rgba(216, 180, 254, 0.9)) drop-shadow(0 0 14px rgba(168, 85, 247, 0.6));
  }
  .globe-target svg { width: 100%; height: 100%; stroke: currentColor; fill: currentColor; stroke-width: 0.8; }
  .globe-target--1 { top: 22%; left: 32%; animation: targetPulse 2.4s ease-in-out infinite; }
  .globe-target--2 { top: 45%; left: 70%; animation: targetPulse 2.4s ease-in-out 0.8s infinite; }
  .globe-target--3 { top: 68%; left: 40%; animation: targetPulse 2.4s ease-in-out 1.6s infinite; }
  @keyframes targetPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.1); }
  }

  /* =============== HUD minimaliste (seulement BOOST RATE) =============== */
  .hud {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    color: rgba(216, 180, 254, 0.85);
    pointer-events: none;
    z-index: 6;
  }
  .hud-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
