---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <!-- Orbes violettes flottantes (fond de scène) -->
  <div class="hero-orbs" aria-hidden="true">
    <span class="orb orb-1"></span>
    <span class="orb orb-2"></span>
    <span class="orb orb-3"></span>
    <span class="orb orb-4"></span>
  </div>

  <div class="hero-inner">

    <!-- Eyebrow : badge agence IA -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot" aria-hidden="true"></span>
      <span class="eyebrow-text">Agence IA · E-commerce · 2026</span>
    </div>

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">
        <span class="tl-kicker-bar" aria-hidden="true"></span>
        <span class="tl-kicker-text">Ton agence</span>
      </span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Halo néon violet enveloppant -->
        <span class="booster-halo" aria-hidden="true"></span>

        <!-- Reflet de sol (le mot se reflète comme posé sur un miroir avant de tomber) -->
        <span class="booster-reflection" aria-hidden="true">BOOSTER</span>

        <!-- Flash d'impact (positionné en BAS — comme un verre qui touche le sol) -->
        <span class="booster-impact" aria-hidden="true"></span>

        <!-- Shockwave ring (onde de choc au sol) -->
        <span class="booster-shockwave" aria-hidden="true"></span>

        <!-- Nuage de poussière violette post-explosion -->
        <span class="booster-dust" aria-hidden="true"></span>

        <!-- Mot : 7 lettres × 8 shards polygonaux avec gravité -->
        <span class="booster-3d__word">
          <span class="glass-letter" style="--i:0">
            <span class="glyph">B</span>
            <span class="shard s1" aria-hidden="true">B</span>
            <span class="shard s2" aria-hidden="true">B</span>
            <span class="shard s3" aria-hidden="true">B</span>
            <span class="shard s4" aria-hidden="true">B</span>
            <span class="shard s5" aria-hidden="true">B</span>
            <span class="shard s6" aria-hidden="true">B</span>
            <span class="shard s7" aria-hidden="true">B</span>
            <span class="shard s8" aria-hidden="true">B</span>
          </span>
          <span class="glass-letter" style="--i:1">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
            <span class="shard s7" aria-hidden="true">O</span>
            <span class="shard s8" aria-hidden="true">O</span>
          </span>
          <span class="glass-letter" style="--i:2">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
            <span class="shard s7" aria-hidden="true">O</span>
            <span class="shard s8" aria-hidden="true">O</span>
          </span>
          <span class="glass-letter" style="--i:3">
            <span class="glyph">S</span>
            <span class="shard s1" aria-hidden="true">S</span>
            <span class="shard s2" aria-hidden="true">S</span>
            <span class="shard s3" aria-hidden="true">S</span>
            <span class="shard s4" aria-hidden="true">S</span>
            <span class="shard s5" aria-hidden="true">S</span>
            <span class="shard s6" aria-hidden="true">S</span>
            <span class="shard s7" aria-hidden="true">S</span>
            <span class="shard s8" aria-hidden="true">S</span>
          </span>
          <span class="glass-letter" style="--i:4">
            <span class="glyph">T</span>
            <span class="shard s1" aria-hidden="true">T</span>
            <span class="shard s2" aria-hidden="true">T</span>
            <span class="shard s3" aria-hidden="true">T</span>
            <span class="shard s4" aria-hidden="true">T</span>
            <span class="shard s5" aria-hidden="true">T</span>
            <span class="shard s6" aria-hidden="true">T</span>
            <span class="shard s7" aria-hidden="true">T</span>
            <span class="shard s8" aria-hidden="true">T</span>
          </span>
          <span class="glass-letter" style="--i:5">
            <span class="glyph">E</span>
            <span class="shard s1" aria-hidden="true">E</span>
            <span class="shard s2" aria-hidden="true">E</span>
            <span class="shard s3" aria-hidden="true">E</span>
            <span class="shard s4" aria-hidden="true">E</span>
            <span class="shard s5" aria-hidden="true">E</span>
            <span class="shard s6" aria-hidden="true">E</span>
            <span class="shard s7" aria-hidden="true">E</span>
            <span class="shard s8" aria-hidden="true">E</span>
          </span>
          <span class="glass-letter" style="--i:6">
            <span class="glyph">R</span>
            <span class="shard s1" aria-hidden="true">R</span>
            <span class="shard s2" aria-hidden="true">R</span>
            <span class="shard s3" aria-hidden="true">R</span>
            <span class="shard s4" aria-hidden="true">R</span>
            <span class="shard s5" aria-hidden="true">R</span>
            <span class="shard s6" aria-hidden="true">R</span>
            <span class="shard s7" aria-hidden="true">R</span>
            <span class="shard s8" aria-hidden="true">R</span>
          </span>
        </span>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        <span class="tl-prefix">par l'</span><span class="tl-accent">IA</span><span class="tl-dot">.</span>
      </span>
    </h1>

    <!-- CTAs primary + ghost -->
    <div class="hero-ctas reveal" style="--d:0.7s">
      <a href="#pricing" class="hero-cta-primary">
        <span>Booster mon agence</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      <a href="#services" class="hero-cta-secondary">Voir les offres</a>
    </div>

    <!-- Trust strip : note + agences boostées -->
    <div class="hero-trust reveal" style="--d:0.85s">
      <span class="trust-stars" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"/></svg>
      </span>
      <span class="trust-text"><strong>4.9/5</strong> · clients accompagnés</span>
      <span class="trust-sep" aria-hidden="true"></span>
      <span class="trust-text"><strong>+50</strong> agences boostées</span>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll reveal" style="--d:1s" aria-hidden="true">
    <span class="scroll-line"></span>
    <span class="scroll-text">Scroll</span>
  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== ORBES VIOLETTES FLOTTANTES (background scenery) ===== */
  .hero-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  .orb-1 {
    top: 12%;
    left: 14%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.45) 0%, rgba(168, 85, 247, 0) 70%);
    animation: orbFloat 18s ease-in-out infinite;
  }
  .orb-2 {
    top: 60%;
    right: 10%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.38) 0%, rgba(124, 58, 237, 0) 70%);
    animation: orbFloat 22s ease-in-out infinite reverse;
    animation-delay: -4s;
  }
  .orb-3 {
    top: 72%;
    left: 18%;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.32) 0%, rgba(192, 132, 252, 0) 70%);
    animation: orbFloat 25s ease-in-out infinite;
    animation-delay: -8s;
  }
  .orb-4 {
    top: 20%;
    right: 18%;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.4) 0%, rgba(139, 92, 246, 0) 70%);
    animation: orbFloat 20s ease-in-out infinite;
    animation-delay: -12s;
  }
  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0)       scale(1);   opacity: 0.9; }
    25%      { transform: translate(40px, -30px) scale(1.1); opacity: 1;   }
    50%      { transform: translate(-20px, 40px) scale(0.95);opacity: 0.75;}
    75%      { transform: translate(-50px, -20px) scale(1.05);opacity: 0.85;}
  }

  /* ===== TRUST STRIP : note + agences ===== */
  .hero-trust {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 10px 22px;
    margin-top: 8px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(168, 85, 247, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    flex-wrap: wrap;
    justify-content: center;
  }
  .trust-stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: #C084FC;
    filter: drop-shadow(0 0 6px rgba(192, 132, 252, 0.6));
  }
  .trust-stars svg {
    width: 14px;
    height: 14px;
  }
  .trust-text {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.005em;
    white-space: nowrap;
  }
  .trust-text strong {
    color: #FFFFFF;
    font-weight: 700;
  }
  .trust-sep {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(192, 132, 252, 0.6);
    box-shadow: 0 0 6px rgba(192, 132, 252, 0.8);
  }

  /* ===== SCROLL INDICATOR ===== */
  .hero-scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 5;
    pointer-events: none;
  }
  .scroll-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, rgba(192, 132, 252, 0), rgba(192, 132, 252, 0.9));
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    left: 0;
    top: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), #FFFFFF, rgba(255, 255, 255, 0));
    animation: scrollLineMove 2.2s ease-in-out infinite;
  }
  @keyframes scrollLineMove {
    0%   { top: -100%; }
    100% { top: 100%;  }
  }
  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.6);
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: clamp(28px, 3.6vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: #FFFFFF;
  }

  /* "Ton agence" — kicker éditorial avec barre néon gauche */
  .tl-line--top {
    margin-bottom: 0.18em;
    font-weight: 600;
    letter-spacing: 0.002em;
  }
  .tl-kicker-bar {
    display: inline-block;
    width: 44px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(192, 132, 252, 0) 0%,
      #C084FC 35%,
      #E9D5FF 100%);
    box-shadow:
      0 0 12px rgba(192, 132, 252, 1),
      0 0 28px rgba(168, 85, 247, 0.7),
      0 0 52px rgba(139, 92, 246, 0.4);
    transform: translateY(2px);
  }
  .tl-kicker-text {
    color: #FFFFFF;
    font-weight: 600;
    text-shadow:
      0 0 4px rgba(255, 255, 255, 0.5),
      0 0 18px rgba(216, 180, 254, 0.45);
  }

  /* "par l'IA." — prefix sobre + IA en gradient néon + glow violet/cyan */
  .tl-line--bottom {
    margin-top: 0.35em;
    gap: 12px;
    font-weight: 500;
  }
  .tl-prefix {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
    letter-spacing: 0;
    font-style: normal;
  }
  .tl-accent {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg,
      #22D3EE 0%,
      #A855F7 42%,
      #C084FC 72%,
      #FFFFFF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter:
      drop-shadow(0 0 10px rgba(192, 132, 252, 0.75))
      drop-shadow(0 0 24px rgba(168, 85, 247, 0.55))
      drop-shadow(0 0 48px rgba(34, 211, 238, 0.25));
    padding: 0 0.04em;
  }
  .tl-accent::after {
    content: '';
    position: absolute;
    left: -4%;
    right: -4%;
    bottom: -5px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(34, 211, 238, 0) 0%,
      #22D3EE 18%,
      #A855F7 52%,
      #E9D5FF 100%);
    box-shadow:
      0 0 12px rgba(168, 85, 247, 1),
      0 0 26px rgba(192, 132, 252, 0.65);
  }
  .tl-dot {
    color: #FFFFFF;
    font-weight: 900;
    text-shadow:
      0 0 6px rgba(255, 255, 255, 1),
      0 0 14px rgba(192, 132, 252, 0.95),
      0 0 28px rgba(168, 85, 247, 0.6);
    margin-left: -2px;
  }

  /* ========== BOOSTER — VERRE QUI TOMBE ET ÉCLATE AU SOL ==========
     Cycle 10s. Le mot BOOSTER est en cristal blanc pur avec néon violet intense.
     Physique simulée : lettre stable → fissure → impact en bas → shards explosent PUIS
     tombent avec gravité → reformation depuis le haut.

     Timeline (10s) :
       0-60%   STABLE  — mot cristal lumineux, flotte + shimmer subtil (6s de lecture)
       60-62%  CHARGE  — brightness monte, léger tremor, fissure visible
       62%     BANG    — glyph disparaît, 56 shards (7×8) apparaissent assemblés
       62-68%  BURST   — shards projetés radialement depuis leur position d'origine
       68-82%  GRAVITY — shards TOMBENT (translateY augmente parabolique), rotation accélère
       82-88%  VOID    — tout est parti au sol + fade dust cloud
       88-100% REFORM  — lettres retombent depuis le haut (impact inversé, gravité positive)
  */

  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.1em 0 0.16em;
    perspective: 1800px;
    transform-style: preserve-3d;
    --bg-floor: rgba(168, 85, 247, 0.85);
  }

  /* ===== HALO VIOLET PERMANENT (énergie contenue dans le verre) ===== */
  .booster-halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 150%;
    height: 240%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(216, 180, 254, 0.32) 15%,
      rgba(168, 85, 247, 0.22) 38%,
      rgba(124, 58, 237, 0.12) 58%,
      transparent 76%);
    filter: blur(38px);
    transform: translate(-50%, -50%) scale(1);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: boosterHaloPulse 10s ease-in-out infinite;
  }
  @keyframes boosterHaloPulse {
    0%, 55%, 100% { opacity: 0.9; transform: translate(-50%, -50%) scale(1);    }
    58%           { opacity: 1;   transform: translate(-50%, -50%) scale(1.15); }
    62%           { opacity: 1.2; transform: translate(-50%, -50%) scale(1.35); }
    72%           { opacity: 0.6; transform: translate(-50%, -50%) scale(1.5);  }
    85%           { opacity: 0.2; transform: translate(-50%, -50%) scale(0.95); }
    92%           { opacity: 1;   transform: translate(-50%, -50%) scale(1.1);  }
  }

  /* ===== REFLET DE SOL — le mot se reflète en dessous (miroir cristal) ===== */
  .booster-reflection {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translate(-50%, 0) scaleY(-1);
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(62px, 10.5vw, 152px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    color: transparent;
    -webkit-text-stroke: 0;
    background: linear-gradient(to top,
      rgba(192, 132, 252, 0) 0%,
      rgba(192, 132, 252, 0.15) 40%,
      rgba(233, 213, 255, 0.4) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    filter: blur(4px) saturate(1.2);
    opacity: 0.55;
    mask-image: linear-gradient(to top, transparent 0%, black 50%, black 100%);
    -webkit-mask-image: linear-gradient(to top, transparent 0%, black 50%, black 100%);
    pointer-events: none;
    z-index: 0;
    user-select: none;
    animation: boosterReflectionLife 10s linear infinite;
  }
  @keyframes boosterReflectionLife {
    0%, 60%   { opacity: 0.55; }
    62%, 87%  { opacity: 0;    }
    90%, 100% { opacity: 0.55; }
  }

  /* ===== IMPACT FLASH — au BAS du mot (point de contact avec le "sol") ===== */
  .booster-impact {
    position: absolute;
    top: 95%;
    left: 50%;
    width: 220%;
    height: 140%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(255, 255, 255, 1) 0%,
      rgba(243, 232, 255, 0.9) 10%,
      rgba(216, 180, 254, 0.7) 22%,
      rgba(192, 132, 252, 0.45) 40%,
      rgba(168, 85, 247, 0.22) 58%,
      transparent 78%);
    filter: blur(18px);
    transform: translate(-50%, -50%) scaleX(0.2) scaleY(0.1);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterImpact 10s cubic-bezier(0.15, 0.85, 0.2, 1) infinite;
  }
  @keyframes boosterImpact {
    0%, 59%  { opacity: 0;    transform: translate(-50%, -50%) scaleX(0.2) scaleY(0.1); }
    61%      { opacity: 1;    transform: translate(-50%, -50%) scaleX(0.6) scaleY(0.4); }
    62%      { opacity: 1;    transform: translate(-50%, -50%) scaleX(1.1) scaleY(0.7); }
    66%      { opacity: 0.85; transform: translate(-50%, -50%) scaleX(1.5) scaleY(0.9); }
    74%      { opacity: 0.4;  transform: translate(-50%, -50%) scaleX(2.0) scaleY(1.1); }
    82%      { opacity: 0;    transform: translate(-50%, -50%) scaleX(2.4) scaleY(1.3); }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scaleX(0.2) scaleY(0.1); }
  }

  /* ===== SHOCKWAVE — onde de choc circulaire au point d'impact (bas) ===== */
  .booster-shockwave {
    position: absolute;
    top: 95%;
    left: 50%;
    width: 40%;
    height: 80%;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.95);
    box-shadow:
      0 0 24px rgba(243, 232, 255, 0.9),
      0 0 48px rgba(192, 132, 252, 0.7),
      0 0 96px rgba(168, 85, 247, 0.4),
      inset 0 0 16px rgba(233, 213, 255, 0.6);
    transform: translate(-50%, -50%) scaleX(0.3) scaleY(0.15);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterShockwave 10s cubic-bezier(0.18, 0.8, 0.25, 1) infinite;
  }
  @keyframes boosterShockwave {
    0%, 60%  { opacity: 0;    transform: translate(-50%, -50%) scaleX(0.3) scaleY(0.15); border-width: 4px; }
    62%      { opacity: 1;    transform: translate(-50%, -50%) scaleX(0.6) scaleY(0.3);  border-width: 3px; }
    68%      { opacity: 0.75; transform: translate(-50%, -50%) scaleX(2.2) scaleY(1.1);  border-width: 1.5px; }
    76%      { opacity: 0.3;  transform: translate(-50%, -50%) scaleX(3.4) scaleY(1.7);  border-width: 0.8px; }
    82%      { opacity: 0;    transform: translate(-50%, -50%) scaleX(4.2) scaleY(2.1);  border-width: 0.3px; }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scaleX(0.3) scaleY(0.15); border-width: 4px; }
  }

  /* ===== DUST CLOUD — au bas du mot après impact ===== */
  .booster-dust {
    position: absolute;
    top: 98%;
    left: 50%;
    width: 240%;
    height: 180%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(233, 213, 255, 0.55) 0%,
      rgba(192, 132, 252, 0.42) 22%,
      rgba(168, 85, 247, 0.28) 45%,
      rgba(124, 58, 237, 0.12) 65%,
      transparent 80%);
    filter: blur(42px);
    transform: translate(-50%, -50%) scale(0.3);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: boosterDust 10s ease-out infinite;
  }
  @keyframes boosterDust {
    0%, 62%  { opacity: 0;   transform: translate(-50%, -50%) scale(0.3); }
    68%      { opacity: 0.9; transform: translate(-50%, -50%) scale(1.2); }
    78%      { opacity: 0.5; transform: translate(-50%, -50%) scale(1.8) translateY(10px); }
    88%      { opacity: 0;   transform: translate(-50%, -50%) scale(2.4) translateY(20px); }
    100%     { opacity: 0;   transform: translate(-50%, -50%) scale(0.3); }
  }

  /* ===== WORD CONTAINER — tilt 3D interactif souris ===== */
  .booster-3d__word {
    position: relative;
    display: inline-flex;
    z-index: 2;
    transform: rotateX(var(--br-rx, 0deg)) rotateY(var(--br-ry, 0deg));
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* ===== GLASS-LETTER : CORE BLANC PUR + halo violet EN EXTÉRIEUR uniquement =====
     Stratégie : le remplissage des lettres reste BLANC solide (color + fill + stroke blanc),
     et le violet n'intervient QU'EN HALO EXTÉRIEUR (grandes distances, opacité faible)
     pour ne pas "manger" le cœur blanc. */
  .glass-letter {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(68px, 11.5vw, 168px);
    line-height: 0.92;
    letter-spacing: -0.032em;
    color: #FFFFFF !important;
    -webkit-text-fill-color: #FFFFFF !important;
    -webkit-text-stroke: 1.5px #FFFFFF;
    text-shadow:
      /* COEUR BLANC SOLIDE — plusieurs couches blanches très proches */
      0 0 1px  #FFFFFF,
      0 0 2px  #FFFFFF,
      0 0 4px  #FFFFFF,
      0 0 8px  rgba(255, 255, 255, 0.85),
      /* Transition blanc → lavender (encore très clair, opacité moyenne) */
      0 0 16px rgba(245, 240, 255, 0.55),
      0 0 28px rgba(221, 214, 254, 0.45),
      /* Halo violet EN DEHORS des lettres (faible opacité, grands rayons) */
      0 0 52px rgba(192, 132, 252, 0.55),
      0 0 92px rgba(168, 85, 247, 0.45),
      0 0 160px rgba(139, 92, 246, 0.32),
      0 0 240px rgba(124, 58, 237, 0.2);
    transform-style: preserve-3d;
    padding: 0 0.03em;
  }

  /* ===== GLYPH : la lettre visible — charge, casse, reform ===== */
  .glass-letter .glyph {
    display: inline-block;
    position: relative;
    z-index: 2;
    will-change: opacity, filter, transform;
    animation: glyphGlassLife 10s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: calc(var(--i, 0) * -0.015s);
  }
  @keyframes glyphGlassLife {
    /* STABLE 0-55% : subtile respiration crystal */
    0%,   55% { opacity: 1; filter: blur(0) brightness(1);                   transform: translateY(0)     scale(1);    }
    /* TENSION 57% : la lumière monte (verre sous pression) */
    57%       { opacity: 1; filter: blur(0) brightness(1.35) contrast(1.1);  transform: translateY(-1px)  scale(1.02); }
    /* CHARGE 60% : flicker violent juste avant le break */
    60%       { opacity: 1; filter: blur(0) brightness(2.2)  contrast(1.3);  transform: translateY(-2px)  scale(1.05); }
    /* BANG 62% : la lettre DISPARAÎT instantanément (opacity 0) — les shards prennent le relais */
    62%       { opacity: 0; filter: blur(8px) brightness(3);                 transform: translateY(0)     scale(1.12); }
    /* VOID 62-88% : rien */
    87%       { opacity: 0; filter: blur(0) brightness(1);                   transform: translateY(-40px) scale(0.9);  }
    /* REFORM 88-96% : la lettre RETOMBE depuis au-dessus (inverse de la chute des shards) */
    92%       { opacity: 1; filter: blur(0) brightness(1.6);                 transform: translateY(-8px)  scale(1.04); }
    96%       { opacity: 1; filter: blur(0) brightness(1.2);                 transform: translateY(2px)   scale(0.99); }
    100%      { opacity: 1; filter: blur(0) brightness(1);                   transform: translateY(0)     scale(1);    }
  }

  /* ===== SHARDS : 8 fragments polygonaux par lettre, clones du glyph avec clip-path =====
     Chaque shard part de la position 0 (assemblé = reconstitue la lettre) puis
     est PROJETÉ radialement, puis TOMBE avec gravité en accélérant. */
  .shard {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-block;
    font: inherit;
    color: inherit;
    -webkit-text-stroke: inherit;
    text-shadow: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    padding: inherit;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    will-change: transform, opacity, filter;
    transform-origin: 50% 50%;
    animation: shardGlassShatter 10s cubic-bezier(0.22, 0.55, 0.3, 1) infinite;
    animation-delay: calc(var(--i, 0) * -0.015s);
  }

  /* ============================================
     8 SHARDS par lettre — polygons qui s'imbriquent PARFAITEMENT pour reconstituer la lettre
     + trajectoires :
       --bx / --by  = burst (projection initiale radiale, 0-0.5s après bang)
       --fx / --fy  = fall (position finale après gravité — tous avec --fy positif)
       --rz         = rotation finale (deg)
     ============================================ */
  .shard.s1 { /* top-left triangle */
    clip-path: polygon(0% 0%, 54% 0%, 32% 44%, 0% 54%);
    --bx:  -58px; --by: -42px;
    --fx:  -88px; --fy: 180px; --rz: -340deg;
  }
  .shard.s2 { /* top-right triangle */
    clip-path: polygon(54% 0%, 100% 0%, 100% 40%, 70% 36%, 32% 44%);
    --bx:   62px; --by: -48px;
    --fx:   98px; --fy: 210px; --rz:  380deg;
  }
  .shard.s3 { /* middle-right polygon */
    clip-path: polygon(100% 40%, 100% 76%, 64% 70%, 70% 36%);
    --bx:   82px; --by:  -8px;
    --fx:  124px; --fy: 240px; --rz:  290deg;
  }
  .shard.s4 { /* middle-left polygon */
    clip-path: polygon(0% 54%, 32% 44%, 46% 70%, 28% 82%, 0% 78%);
    --bx:  -86px; --by:  10px;
    --fx: -132px; --fy: 220px; --rz: -280deg;
  }
  .shard.s5 { /* center small fragment */
    clip-path: polygon(32% 44%, 70% 36%, 64% 70%, 46% 70%);
    --bx:   -4px; --by: -24px;
    --fx:   16px; --fy: 260px; --rz:  420deg;
  }
  .shard.s6 { /* bottom-right triangle */
    clip-path: polygon(100% 76%, 100% 100%, 58% 100%, 64% 70%);
    --bx:   68px; --by:  38px;
    --fx:   92px; --fy: 200px; --rz:  240deg;
  }
  .shard.s7 { /* bottom-left triangle */
    clip-path: polygon(0% 78%, 28% 82%, 30% 100%, 0% 100%);
    --bx:  -64px; --by:  44px;
    --fx:  -76px; --fy: 170px; --rz: -220deg;
  }
  .shard.s8 { /* bottom-center polygon */
    clip-path: polygon(28% 82%, 46% 70%, 64% 70%, 58% 100%, 30% 100%);
    --bx:    6px; --by:  52px;
    --fx:   24px; --fy: 160px; --rz:  180deg;
  }

  /* ========================================================================
     SHARD ANIMATION — le vrai glass shatter avec gravité :
       0-60%    : invisible (la lettre entière est visible via glyph)
       62%      : BANG — tous les shards apparaissent à leur position native
                  (ensemble, ils reconstituent visuellement la lettre)
       64%      : burst initial (--bx/--by) + début rotation + flash blanc
       70%      : mi-chute, rotation s'emballe, position entre burst et chute
       78%      : chute avancée — gravité forte, rotation finale presque atteinte
       84%      : au sol, opacity fade out, blur fort
       85-100%  : invisible (glyph reform prend le relais)
     ======================================================================== */
  @keyframes shardGlassShatter {
    0%, 60%   {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate3d(1, 0.3, 0.2, 0deg);
      filter: blur(0) brightness(1);
    }
    /* BANG 61% : flash blanc, tous shards visibles assemblés */
    61%       {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate3d(1, 0.3, 0.2, 0deg);
      filter: blur(0) brightness(2.5);
    }
    /* 63% : BURST initial violent (projection forte) */
    63%       {
      opacity: 1;
      transform:
        translate3d(var(--bx), var(--by), 40px)
        rotate3d(1, 0.3, 0.2, calc(var(--rz) * 0.12));
      filter: blur(0) brightness(2);
    }
    /* 66% : fragments encore très visibles (pleine opacité) */
    66%       {
      opacity: 1;
      transform:
        translate3d(
          calc(var(--bx) * 1.2 + var(--fx) * 0.1),
          calc(var(--by) * 0.6 + var(--fy) * 0.15),
          30px)
        rotate3d(1, 0.3, 0.3, calc(var(--rz) * 0.32));
      filter: blur(0.4px) brightness(1.7);
    }
    /* 72% : mi-chute, encore bien lisibles */
    72%       {
      opacity: 0.95;
      transform:
        translate3d(
          calc(var(--bx) * 0.5 + var(--fx) * 0.45),
          calc(var(--fy) * 0.4),
          20px)
        rotate3d(1, 0.4, 0.3, calc(var(--rz) * 0.6));
      filter: blur(0.8px) brightness(1.4);
    }
    /* 78% : chute avancée */
    78%       {
      opacity: 0.85;
      transform:
        translate3d(
          calc(var(--fx) * 0.85),
          calc(var(--fy) * 0.75),
          12px)
        rotate3d(1, 0.4, 0.3, calc(var(--rz) * 0.88));
      filter: blur(1.5px) brightness(1.15);
    }
    /* 83% : presque au sol, fade commence */
    83%       {
      opacity: 0.5;
      transform:
        translate3d(calc(var(--fx) * 0.98), calc(var(--fy) * 0.95), 4px)
        rotate3d(1, 0.4, 0.3, calc(var(--rz) * 1.05));
      filter: blur(2.5px) brightness(1);
    }
    /* 86% : au sol, fade out final */
    86%       {
      opacity: 0;
      transform:
        translate3d(var(--fx), var(--fy), 0)
        rotate3d(1, 0.4, 0.3, var(--rz));
      filter: blur(4px) brightness(0.85);
    }
    /* VOID 86-100% : shards invisibles, le glyph reform prend le relais */
    88%, 100% {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate3d(1, 0.3, 0.2, 0deg);
      filter: blur(0) brightness(1);
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .glass-letter { font-size: clamp(56px, 14vw, 118px); }
    .booster-reflection { font-size: clamp(56px, 14vw, 118px); }
    .shard.s1 { --bx: -40px; --by: -30px; --fx:  -60px; --fy: 130px; }
    .shard.s2 { --bx:  42px; --by: -34px; --fx:   66px; --fy: 150px; }
    .shard.s3 { --bx:  54px; --by:  -6px; --fx:   82px; --fy: 170px; }
    .shard.s4 { --bx: -58px; --by:   8px; --fx:  -88px; --fy: 155px; }
    .shard.s5 { --bx:  -2px; --by: -18px; --fx:   12px; --fy: 180px; }
    .shard.s6 { --bx:  48px; --by:  28px; --fx:   62px; --fy: 140px; }
    .shard.s7 { --bx: -44px; --by:  32px; --fx:  -52px; --fy: 118px; }
    .shard.s8 { --bx:   4px; --by:  36px; --fx:   18px; --fy: 110px; }
  }
  @media (max-width: 480px) {
    .glass-letter {
      -webkit-text-stroke: 1px #FFFFFF;
      text-shadow:
        0 0 1px  #FFFFFF,
        0 0 2px  #FFFFFF,
        0 0 4px  #FFFFFF,
        0 0 8px  rgba(255, 255, 255, 0.8),
        0 0 16px rgba(221, 214, 254, 0.4),
        0 0 36px rgba(192, 132, 252, 0.5),
        0 0 70px rgba(168, 85, 247, 0.38),
        0 0 120px rgba(139, 92, 246, 0.25);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .glyph, .shard,
    .booster-impact, .booster-shockwave, .booster-dust,
    .booster-halo, .booster-reflection {
      animation: none;
    }
    .glyph { opacity: 1; transform: none; filter: none; }
    .shard, .booster-impact, .booster-shockwave, .booster-dust { opacity: 0; }
    .booster-halo { opacity: 0.8; }
    .booster-reflection { opacity: 0.45; }
    .booster-3d__word { transform: none; }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 700px; }
    .hero-inner { gap: 28px; }
    .brand-smmia { height: 95px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 560px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 72px; }
    .line-outline { -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.85); }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }

  /* ========== TILT 3D INTERACTIF sur BOOSTER ==========
     Le mot suit la souris : rotateX suivant Y curseur, rotateY suivant X curseur.
     Lerp doux + reset au mouseleave. */
  const boosterBox = document.querySelector<HTMLElement>('.booster-3d');
  const boosterWord = boosterBox?.querySelector<HTMLElement>('.booster-3d__word');

  if (boosterBox && boosterWord && !reduced) {
    let targetRx = 0, targetRy = 0;
    let currRx = 0, currRy = 0;
    let tiltRaf = 0;

    boosterBox.addEventListener('mousemove', (e: MouseEvent) => {
      const r = boosterBox.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width  - 0.5;
      const py = (e.clientY - r.top)  / r.height - 0.5;
      targetRy = px * 22;
      targetRx = -py * 14;
      if (!tiltRaf) tiltRaf = requestAnimationFrame(tiltLoop);
    });

    boosterBox.addEventListener('mouseleave', () => {
      targetRx = 0; targetRy = 0;
      if (!tiltRaf) tiltRaf = requestAnimationFrame(tiltLoop);
    });

    function tiltLoop() {
      currRx += (targetRx - currRx) * 0.12;
      currRy += (targetRy - currRy) * 0.12;
      boosterWord!.style.setProperty('--br-rx', `${currRx.toFixed(2)}deg`);
      boosterWord!.style.setProperty('--br-ry', `${currRy.toFixed(2)}deg`);
      if (Math.abs(targetRx - currRx) > 0.05 || Math.abs(targetRy - currRy) > 0.05) {
        tiltRaf = requestAnimationFrame(tiltLoop);
      } else { tiltRaf = 0; }
    }
  }
</script>
