---
// Hero SMMIA — port EXACT du rendu Claude Design "SMMIA Hero v4 Light" (LATEST)
// Source : claude.ai/design/p/6cb92b07-fe86-4062-8949-d8f47fb566dd?file=SMMIA+Hero+v4+Light.html
// Light mode : fond blanc + halo violet soft + planète Spline Full DAY + logo SMM/IA + 4 icônes PNG
---

<section id="hero" class="hero-root">
  <div class="stage"></div>
  <div class="grid-bg"></div>
  <div class="halo-soft"></div>

  <div class="orbit-anchor orbit-tl bloom d3">
    <div class="float-a"><div class="spin-a"><div class="orbit-icon"><img src="/hero-icons/claude.png" alt="Claude" /></div></div></div>
    <div class="orbit-label">CLAUDE</div>
  </div>
  <div class="orbit-anchor orbit-tr bloom d3">
    <div class="float-b"><div class="spin-b"><div class="orbit-icon"><img src="/hero-icons/gemini.png" alt="Gemini" /></div></div></div>
    <div class="orbit-label">GEMINI</div>
  </div>
  <div class="orbit-anchor orbit-bl bloom d4">
    <div class="float-c"><div class="spin-c"><div class="orbit-icon"><img src="/hero-icons/n8n.png" alt="N8N" /></div></div></div>
    <div class="orbit-label">N8N</div>
  </div>
  <div class="orbit-anchor orbit-br bloom d4">
    <div class="float-d"><div class="spin-d"><div class="orbit-icon"><img src="/hero-icons/shopify.png" alt="Shopify" /></div></div></div>
    <div class="orbit-label">SHOPIFY</div>
  </div>

  <div class="planet-stage bloom d2">
    <div class="spline-crop">
      <div class="planet-skeleton"></div>
      <spline-viewer
        id="smmia-spline"
        url="https://prod.spline.design/RhEy0ALrUQlCxkVR/scene.splinecode"
        loading-anim-type="none"
        events-target="global"
      ></spline-viewer>
      <div class="daylight-wash"></div>
    </div>
    <div class="planet-atmo"></div>
    <div class="logo-text">
      <span class="logo-smm">SMM</span><span class="logo-ia">IA</span>
    </div>
  </div>

  <div class="tagline-block rise d5">
    <div class="tag-line tag-size-base">TON AGENCE RENTABLE</div>
    <div class="tag-boosted tag-size-boost my-1">BOOSTÉE</div>
    <div class="tag-line tag-size-base">PAR L'IA</div>
  </div>
</section>

<script is:inline>
  (function () {
    var nav = document.getElementById('navbar');
    var hero = document.getElementById('hero');
    if (nav && hero) {
      nav.style.transition = 'transform 0.35s ease, opacity 0.35s ease';
      function updateNav() {
        var bottom = hero.getBoundingClientRect().bottom;
        if (bottom > window.innerHeight * 0.25) {
          nav.style.transform = 'translateY(-100%)';
          nav.style.opacity = '0';
        } else {
          nav.style.transform = 'translateY(0)';
          nav.style.opacity = '1';
        }
      }
      updateNav();
      window.addEventListener('scroll', updateNav, { passive: true });
      window.addEventListener('resize', updateNav);
    }

    // Force canvas Spline carré + nuke watermark shadow DOM
    function fixSpline() {
      document.querySelectorAll('spline-viewer').forEach(function (v) {
        var sr = v.shadowRoot;
        if (!sr) return;
        var c = sr.querySelector('canvas');
        if (!c) return;
        var r = v.getBoundingClientRect();
        var side = Math.min(r.width, r.height);
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        c.style.width = side + 'px';
        c.style.height = side + 'px';
        c.style.position = 'absolute';
        c.style.left = '50%';
        c.style.top = '50%';
        c.style.transform = 'translate(-50%, -50%)';
        c.width = Math.round(side * dpr);
        c.height = Math.round(side * dpr);

        if (!sr.querySelector('style[data-nuke]')) {
          var st = document.createElement('style');
          st.setAttribute('data-nuke', '1');
          st.textContent =
            '#logo, .logo, a[href*="spline"], button[aria-label*="Spline" i],' +
            '#spline-logo, .spline-logo, [class*="watermark" i], [class*="branding" i] {' +
            'display: none !important; opacity: 0 !important; visibility: hidden !important;' +
            'pointer-events: none !important; }';
          sr.appendChild(st);
        }
        sr.querySelectorAll('a[href*="spline"], #logo, .logo').forEach(function (el) { el.remove(); });
      });
      window.dispatchEvent(new Event('resize'));
    }
    [300, 700, 1400, 2500, 4000, 6000, 9000].forEach(function (t) { setTimeout(fixSpline, t); });
    setInterval(fixSpline, 2000);
    window.addEventListener('resize', fixSpline);
  })();
</script>

<script is:inline>
  if (!document.querySelector('script[data-spline-viewer]')) {
    var s = document.createElement('script');
    s.type = 'module';
    s.src = 'https://unpkg.com/@splinetool/viewer@1.9.28/build/spline-viewer.js';
    s.setAttribute('data-spline-viewer', '1');
    document.head.appendChild(s);
  }
</script>

<style>
  :root {
    --violet-100: #F3E8FF;
    --violet-300: #D8B4FE;
    --violet-500: #A855F7;
    --violet-700: #7C3AED;
    --violet-900: #4C1D95;
    --ink: #1A0933;
  }

  .hero-root {
    position: relative;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    isolation: isolate;
    font-family: 'Oswald', sans-serif;
    background: #FFFFFF;
    color: var(--ink);
  }

  .stage {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 45% at 50% 50%,
        rgba(168, 85, 247, 0.18) 0%,
        rgba(192, 132, 252, 0.10) 30%,
        rgba(233, 213, 255, 0.05) 55%,
        #FFFFFF 80%);
    z-index: 0;
  }

  .halo-soft {
    position: absolute;
    left: 50%;
    top: 44%;
    transform: translate(-50%, -50%);
    width: min(1600px, 110vmin);
    aspect-ratio: 1 / 1;
    background: radial-gradient(circle at center,
      rgba(168, 85, 247, 0.28) 0%,
      rgba(124, 58, 237, 0.16) 25%,
      transparent 60%);
    filter: blur(70px);
    pointer-events: none;
    z-index: 1;
    opacity: 0.25;
    animation: softBreath 10s ease-in-out infinite;
  }
  @keyframes softBreath {
    0%, 100% { opacity: .25; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: .30; transform: translate(-50%, -50%) scale(1.04); }
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(124, 58, 237, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124, 58, 237, 0.07) 1px, transparent 1px);
    background-size: 60px 60px;
    -webkit-mask-image: radial-gradient(ellipse at center, black 25%, transparent 82%);
    mask-image: radial-gradient(ellipse at center, black 25%, transparent 82%);
    pointer-events: none;
    z-index: 1;
  }

  /* ===== PLANET STAGE ===== */
  .planet-stage {
    position: absolute;
    left: 50%;
    top: 44%;
    transform: translate(-50%, -50%);
    width: min(2800px, 170vmin);
    height: min(2800px, 170vmin);
    aspect-ratio: 1 / 1;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    filter:
      drop-shadow(0 60px 120px rgba(76, 29, 149, 0.38))
      drop-shadow(0 25px 60px rgba(124, 58, 237, 0.32))
      drop-shadow(0 0 80px rgba(168, 85, 247, 0.45));
  }
  @media (max-width: 1280px) { .planet-stage { width: min(2300px, 165vmin); height: min(2300px, 165vmin); } }
  @media (max-width: 1024px) { .planet-stage { width: min(1750px, 160vmin); height: min(1750px, 160vmin); } }
  @media (max-width: 640px)  { .planet-stage { width: min(1100px, 155vmin); height: min(1100px, 155vmin); } }

  .planet-stage canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    background: transparent;
  }

  .spline-crop {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 9999px;
  }
  .spline-crop spline-viewer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    /* Full DAY mode — kill the night side */
    filter:
      brightness(2.15)
      contrast(0.72)
      saturate(1.55)
      hue-rotate(-6deg);
    mix-blend-mode: normal;
    --spline-logo: none;
  }
  .spline-crop spline-viewer::part(logo) { display: none !important; }

  /* Daylight wash */
  .spline-crop .daylight-wash {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background:
      radial-gradient(circle at 30% 30%,
        rgba(255, 250, 235, 0.45) 0%,
        rgba(255, 240, 215, 0.25) 25%,
        rgba(224, 231, 255, 0.18) 50%,
        rgba(196, 181, 253, 0.12) 70%,
        transparent 90%);
    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 3;
  }

  /* Belt-and-suspenders: white patch over Spline watermark */
  .spline-crop::after {
    content: '';
    position: absolute;
    right: -8px;
    bottom: -8px;
    width: 180px;
    height: 70px;
    background: linear-gradient(135deg, transparent 0%, rgba(255, 255, 255, 0.92) 35%, #FFFFFF 100%);
    z-index: 50;
    pointer-events: none;
    border-radius: 8px;
  }
  /* Specular highlight top-left */
  .spline-crop::before {
    content: '';
    position: absolute;
    left: 18%;
    top: 14%;
    width: 28%;
    height: 28%;
    border-radius: 9999px;
    background: radial-gradient(circle at 35% 35%,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0.18) 35%,
      transparent 65%);
    filter: blur(14px);
    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 3;
  }
  spline-viewer::part(canvas) {
    width: 100% !important;
    height: 100% !important;
  }

  .planet-atmo {
    position: absolute;
    inset: -8%;
    border-radius: 9999px;
    pointer-events: none;
    background: radial-gradient(circle at center,
      transparent 46%,
      rgba(192, 132, 252, 0.35) 50%,
      rgba(168, 85, 247, 0.22) 55%,
      rgba(168, 85, 247, 0.08) 62%,
      transparent 72%);
    filter: blur(6px);
    mix-blend-mode: screen;
    z-index: 0;
  }

  .planet-skeleton {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: transparent;
    pointer-events: none;
    opacity: 0;
  }

  /* ===== LOGO TEXT ===== */
  .logo-text {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    font-family: 'Barlow Condensed', 'Saira Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    letter-spacing: 0.005em;
    line-height: 1;
    white-space: nowrap;
    font-size: clamp(120px, 18vw, 340px);
    animation: logoFloat 7s ease-in-out infinite;
    pointer-events: none;
    user-select: none;
  }
  .logo-smm {
    color: transparent;
    -webkit-text-stroke: 3px #FFFFFF;
    text-stroke: 3px #FFFFFF;
    filter: drop-shadow(0 0 16px rgba(255, 255, 255, 0.4));
  }
  .logo-ia {
    color: #A855F7;
    -webkit-text-stroke: 3px #C084FC;
    text-stroke: 3px #C084FC;
    text-shadow:
      0 0 6px #FFFFFF,
      0 0 16px #E9D5FF,
      0 0 32px #C084FC,
      0 0 60px #A855F7,
      0 0 100px #7C3AED,
      0 4px 0 #6D28D9,
      0 7px 0 #5B21B6,
      0 10px 0 #4C1D95;
  }
  @keyframes logoFloat {
    0%, 100% { transform: translate(-50%, -50%); }
    50%      { transform: translate(-50%, calc(-50% - 6px)); }
  }

  /* ===== TAGLINE ===== */
  .tagline-block {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 6%;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 30;
    pointer-events: none;
    padding: 0 1.5rem;
  }
  .tag-line {
    font-family: 'Barlow Condensed', 'Saira Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    color: transparent;
    letter-spacing: 0.005em;
    line-height: 0.95;
    white-space: nowrap;
    -webkit-text-stroke: 2px #FFFFFF;
    text-stroke: 2px #FFFFFF;
    filter: drop-shadow(0 2px 10px rgba(255, 255, 255, 0.35));
  }
  .tag-boosted {
    font-family: 'Barlow Condensed', 'Saira Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    color: #A855F7;
    letter-spacing: 0.005em;
    line-height: 0.95;
    display: inline-block;
    white-space: nowrap;
    -webkit-text-stroke: 2px #C084FC;
    text-stroke: 2px #C084FC;
    text-shadow:
      0 0 4px #FFFFFF,
      0 0 10px #E9D5FF,
      0 0 22px #C084FC,
      0 0 40px #A855F7,
      0 0 65px #7C3AED,
      0 2px 0 #6D28D9,
      0 4px 0 #5B21B6,
      0 6px 0 #4C1D95;
  }
  .tag-size-base  { font-size: clamp(28px, 4.4vw, 82px); }
  .tag-size-boost { font-size: clamp(40px, 6.2vw, 118px); }
  .my-1 { margin-top: 0.25rem; margin-bottom: 0.25rem; }
  @media (max-width: 640px) {
    .tag-size-boost { font-size: clamp(3.2rem, 15vw, 5rem); }
    .tag-size-base  { font-size: clamp(1.8rem, 8vw, 2.6rem); }
  }

  /* ===== ORBIT ICONS (PNG images) ===== */
  .orbit-anchor {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 20;
  }
  .orbit-tl { top: 14%; left: 5%; }
  .orbit-tr { top: 14%; right: 5%; }
  .orbit-bl { bottom: 26%; left: 5%; }
  .orbit-br { bottom: 26%; right: 5%; }

  .orbit-icon {
    position: relative;
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
  }
  .orbit-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter:
      drop-shadow(0 12px 24px rgba(124, 58, 237, 0.35))
      drop-shadow(0 4px 8px rgba(76, 29, 149, 0.25));
  }
  .orbit-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(76, 29, 149, 0.7);
    margin-top: 10px;
    white-space: nowrap;
  }

  @keyframes floatA { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(6px, -14px); } }
  @keyframes floatB { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-10px, -10px); } }
  @keyframes floatC { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-6px, 14px); } }
  @keyframes floatD { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(12px, 8px); } }
  @keyframes spinSlow  { to { transform: rotate(360deg); } }
  @keyframes spinSlowR { to { transform: rotate(-360deg); } }
  .float-a { animation: floatA 14s ease-in-out infinite; }
  .float-b { animation: floatB 14s ease-in-out infinite; }
  .float-c { animation: floatC 14s ease-in-out infinite; }
  .float-d { animation: floatD 14s ease-in-out infinite; }
  .spin-a  { animation: spinSlow  28s linear infinite; }
  .spin-b  { animation: spinSlowR 32s linear infinite; }
  .spin-c  { animation: spinSlow  34s linear infinite; }
  .spin-d  { animation: spinSlowR 30s linear infinite; }

  @media (max-width: 640px) {
    .orbit-icon { width: 64px; height: 64px; }
    .orbit-label { font-size: 9px; }
    .orbit-tl { top: 8%; left: 3%; }
    .orbit-tr { top: 8%; right: 3%; }
    .orbit-bl { bottom: 36%; left: 3%; }
    .orbit-br { bottom: 36%; right: 3%; }
  }

  /* ===== ENTRY ANIMATIONS ===== */
  @keyframes rise  { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes bloom { from { opacity: 0; } to { opacity: 1; } }
  .rise  { animation: rise 1s cubic-bezier(.22, .61, .36, 1) both; }
  .bloom { animation: bloom 1.4s cubic-bezier(.22, .61, .36, 1) both; }
  .d1 { animation-delay: .1s; }
  .d2 { animation-delay: .25s; }
  .d3 { animation-delay: .4s; }
  .d4 { animation-delay: .55s; }
  .d5 { animation-delay: .7s; }
</style>
