---
---

<section id="hero" class="violet-grid" style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:68px;">

  <!-- Background image -->
  <div style="position:absolute;inset:0;z-index:0;">
    <img
      src="/images/hero/hero-arcane-v1.png"
      alt=""
      style="width:100%;height:100%;object-fit:cover;object-position:center top;"
      onerror="this.src='/images/hero/hero-openspace-v1.png';this.onerror=null;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.8) 60%, #000 100%);"></div>
    <!-- Radial violet glow -->
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%, rgba(168,85,247,0.12), transparent 70%);"></div>
  </div>

  <!-- Content -->
  <div style="position:relative;z-index:1;text-align:center;padding:0 24px;max-width:900px;margin:0 auto;">

    <!-- Logo SMMIA × FOCUS -->
    <div data-animate data-delay="0" style="margin-bottom:40px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;">
      <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" style="height:60px;width:auto;filter:drop-shadow(0 0 30px rgba(168,85,247,0.5));" />
      <span style="font-size:1.8rem;color:rgba(255,255,255,0.3);font-weight:300;">×</span>
      <img src="/images/logos/focus-logo-3d.png" alt="Focus" style="height:80px;width:auto;filter:drop-shadow(0 0 24px rgba(168,85,247,0.5)) brightness(1.1);" />
    </div>

    <!-- Headline -->
    <h1 data-animate data-delay="0.1" style="font-size:clamp(2rem,5vw,4rem);font-weight:900;line-height:1.1;letter-spacing:-0.03em;margin-bottom:24px;color:#A855F7;">
      L'IA travaille.<br>Toi t'encaisse.
    </h1>

    <!-- Ligne décorative -->
    <div data-animate data-delay="0.35" style="width:80px;height:2px;background:linear-gradient(90deg,#A855F7,#E8442A);margin:0 auto 32px;border-radius:2px;"></div>

    <!-- Tagline -->
    <p data-animate data-delay="0.45" style="font-size:clamp(0.95rem,2vw,1.2rem);color:rgba(255,255,255,0.6);max-width:560px;margin:0 auto 16px;line-height:1.6;font-weight:400;font-style:italic;">
      On te lâche pas tant que t'as pas rentabilisé le Module.
    </p>

    <!-- FOMO -->
    <div data-animate data-delay="0.5" style="display:inline-flex;align-items:center;gap:8px;background:rgba(232,68,42,0.12);border:1px solid rgba(232,68,42,0.35);border-radius:9999px;padding:8px 20px;margin-bottom:32px;">
      <span style="width:8px;height:8px;border-radius:50%;background:#E8442A;display:inline-block;animation:pulse-red 1.5s ease-in-out infinite;flex-shrink:0;"></span>
      <span style="font-size:0.85rem;font-weight:700;color:#E8442A;letter-spacing:0.03em;">Places Limitées — Session Mai 2026</span>
    </div>

    <!-- CTA -->
    <div data-animate data-delay="0.55">
      <a href="#prix" class="btn-pill" style="font-size:1.1rem;padding:16px 40px;">
        Je veux ma place dans Focus &rarr;
      </a>
    </div>

    <!-- Social proof Trustpilot -->
    <div data-animate data-delay="0.65" style="margin-top:32px;display:flex;align-items:center;justify-content:center;gap:12px;">
      <div style="display:flex;gap:3px;">
        {"★★★★★".split("").map(() => (
          <span style="color:#00B67A;font-size:1.1rem;">★</span>
        ))}
      </div>
      <span style="color:rgba(255,255,255,0.7);font-size:0.85rem;font-weight:600;">93 avis vérifiés</span>
      <span style="color:rgba(255,255,255,0.25);font-size:0.8rem;">sur Trustpilot</span>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:1;opacity:0.5;">
    <div style="width:1px;height:50px;background:linear-gradient(to bottom,rgba(168,85,247,0.8),transparent);margin:0 auto;"></div>
  </div>
</section>
