---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Galaxy : atmosphère violet deep + planète + starfield + nébuleuses -->
  <div class="hero-galaxy" aria-hidden="true">
    <div class="galaxy-deep"></div>
    <div class="galaxy-stars galaxy-stars--far"></div>
    <div class="galaxy-stars galaxy-stars--mid"></div>
    <div class="galaxy-stars galaxy-stars--near"></div>
    <div class="galaxy-nebula galaxy-nebula--a"></div>
    <div class="galaxy-nebula galaxy-nebula--b"></div>
    <div class="galaxy-nebula galaxy-nebula--c"></div>

    <!-- Planète violette avec anneaux, atmosphère et terminator -->
    <div class="galaxy-planet">
      <div class="planet-glow-outer"></div>
      <div class="planet-ring planet-ring--back"></div>
      <div class="planet-sphere">
        <div class="planet-atmosphere"></div>
        <div class="planet-terminator"></div>
        <div class="planet-surface"></div>
        <div class="planet-shine"></div>
      </div>
      <div class="planet-ring planet-ring--front"></div>
      <div class="planet-moon"></div>
    </div>

    <!-- Mini planète 2 (lointaine, droite haute) -->
    <div class="galaxy-planet-mini">
      <div class="planet-mini-glow"></div>
      <div class="planet-mini-body"></div>
    </div>

    <span class="galaxy-shooting galaxy-shooting--1"></span>
    <span class="galaxy-shooting galaxy-shooting--2"></span>
    <span class="galaxy-shooting galaxy-shooting--3"></span>
  </div>

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet pulsant derrière la tagline -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Eyebrow : badge session live -->
    <div class="hero-eyebrow reveal" style="--d:0s">
      <span class="pulse-dot"></span>
      <span class="eyebrow-text">Session Mai 2026 · Places limitées</span>
    </div>

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence rentable BOOSTÉE par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tagline-line tagline-top reveal" style="--d:0.2s">
        Ton agence rentable
      </span>
      <span class="tagline-line tagline-boost-line reveal" style="--d:0.4s">
        <span class="boost-word" aria-label="Boostée">

          <!-- Flame aura violette derrière (SVG turbulence) -->
          <svg class="boost-flame" viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <filter id="flameTurb" x="-20%" y="-20%" width="140%" height="140%">
                <feTurbulence type="fractalNoise" baseFrequency="0.012 0.018" numOctaves="2" seed="7" result="noise">
                  <animate attributeName="baseFrequency" dur="14s" values="0.012 0.018;0.018 0.012;0.012 0.018" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="40" xChannelSelector="R" yChannelSelector="G"/>
                <feGaussianBlur stdDeviation="8"/>
              </filter>
              <radialGradient id="flameGrad" cx="0.5" cy="0.55" r="0.5">
                <stop offset="0%"   stop-color="#F3E8FF" stop-opacity="0.9"/>
                <stop offset="25%"  stop-color="#D8B4FE" stop-opacity="0.85"/>
                <stop offset="55%"  stop-color="#A855F7" stop-opacity="0.7"/>
                <stop offset="80%"  stop-color="#6D28D9" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="#2E1065" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <ellipse cx="200" cy="200" rx="180" ry="100" fill="url(#flameGrad)" filter="url(#flameTurb)"/>
          </svg>

          <!-- Canvas particules physiques (fond) -->
          <canvas class="boost-canvas" id="boost-canvas" aria-hidden="true"></canvas>

          <!-- Fissures énergétiques (cracks qui déchirent l'espace) -->
          <svg class="boost-cracks" viewBox="-100 -100 200 200" aria-hidden="true">
            <defs>
              <filter id="crackGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="2.2" result="b"/>
                <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <linearGradient id="crackG" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%"  stop-color="#FFFFFF"/>
                <stop offset="35%" stop-color="#F3E8FF"/>
                <stop offset="70%" stop-color="#C084FC"/>
                <stop offset="100%" stop-color="#7C3AED" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <g filter="url(#crackGlow)" stroke="url(#crackG)" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path class="crack crack--1" d="M 0,0 L -14,-22 L -22,-40 L -36,-56 L -30,-78 L -48,-94 L -42,-118"/>
              <path class="crack crack--2" d="M 0,0 L 16,-18 L 30,-32 L 26,-54 L 42,-70 L 38,-92 L 56,-108"/>
              <path class="crack crack--3" d="M 0,0 L -24,-10 L -44,-14 L -62,-6 L -82,-16 L -102,-8"/>
              <path class="crack crack--4" d="M 0,0 L 22,-6 L 44,-12 L 66,-2 L 88,-10 L 108,0"/>
              <path class="crack crack--5" d="M 0,0 L -18,12 L -32,28 L -26,46 L -44,60 L -36,82 L -52,98"/>
              <path class="crack crack--6" d="M 0,0 L 20,14 L 36,30 L 28,50 L 48,64 L 42,86 L 60,102"/>
              <path class="crack crack--7" d="M 0,0 L -26,8 L -50,18 L -72,12 L -94,22"/>
              <path class="crack crack--8" d="M 0,0 L 28,12 L 52,22 L 76,16 L 100,26"/>
              <path class="crack crack--9"  d="M -18,-22 L -28,-28 L -22,-40" stroke-width="1"/>
              <path class="crack crack--10" d="M 20,-16 L 34,-22 L 28,-36"   stroke-width="1"/>
              <path class="crack crack--11" d="M -14,18 L -30,22 L -24,36"   stroke-width="1"/>
              <path class="crack crack--12" d="M 16,18 L 28,28 L 22,42"      stroke-width="1"/>
            </g>
          </svg>

          <!-- Fragments / débris (shards) qui volent -->
          <svg class="boost-shards" viewBox="-100 -100 200 200" aria-hidden="true">
            <g fill="url(#crackG)" opacity="0.9">
              <polygon class="shard shard--1" points="-4,-2 4,-3 3,4 -3,3"/>
              <polygon class="shard shard--2" points="-5,0 3,-4 5,2 -2,5"/>
              <polygon class="shard shard--3" points="0,-5 5,0 2,4 -4,2"/>
              <polygon class="shard shard--4" points="-3,-3 4,-2 3,3 -4,2"/>
              <polygon class="shard shard--5" points="-4,0 2,-4 5,1 0,5"/>
              <polygon class="shard shard--6" points="-2,-4 4,-1 3,4 -3,3"/>
              <polygon class="shard shard--7" points="-5,-1 3,-3 4,3 -3,4"/>
              <polygon class="shard shard--8" points="-3,-4 5,-1 2,5 -4,2"/>
              <polygon class="shard shard--9" points="0,-4 4,0 1,4 -4,1"/>
              <polygon class="shard shard--10" points="-3,-2 4,-3 3,4 -3,3"/>
              <polygon class="shard shard--11" points="-4,1 1,-4 5,2 0,5"/>
              <polygon class="shard shard--12" points="-2,-5 5,0 1,4 -4,2"/>
            </g>
          </svg>

          <!-- Étincelles individuelles (sparks) -->
          <span class="spark spark--1" aria-hidden="true"></span>
          <span class="spark spark--2" aria-hidden="true"></span>
          <span class="spark spark--3" aria-hidden="true"></span>
          <span class="spark spark--4" aria-hidden="true"></span>
          <span class="spark spark--5" aria-hidden="true"></span>
          <span class="spark spark--6" aria-hidden="true"></span>
          <span class="spark spark--7" aria-hidden="true"></span>
          <span class="spark spark--8" aria-hidden="true"></span>

          <!-- Speed lines anime (zoom radial) -->
          <div class="boost-speedlines" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span>
          </div>

          <!-- Lens flare horizontal qui balaie -->
          <span class="boost-lensflare" aria-hidden="true"></span>

          <!-- Éclairs violets (lightning bolts) -->
          <svg class="boost-lightning" viewBox="-100 -100 200 200" aria-hidden="true">
            <defs>
              <filter id="lightGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="1.8" result="coloredBlur"/>
                <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <g filter="url(#lightGlow)" stroke="#F3E8FF" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <polyline class="bolt bolt--1" points="0,0 -20,-18 -14,-36 -30,-54 -22,-72 -38,-92"/>
              <polyline class="bolt bolt--2" points="0,0 22,-14 18,-34 36,-50 28,-70 44,-88"/>
              <polyline class="bolt bolt--3" points="0,0 -26,14 -14,34 -36,48 -28,68 -46,84"/>
              <polyline class="bolt bolt--4" points="0,0 24,18 14,38 34,50 22,72 42,88"/>
              <polyline class="bolt bolt--5" points="0,0 -42,-6 -64,-18 -80,-8"/>
              <polyline class="bolt bolt--6" points="0,0 42,8 66,-4 82,10"/>
            </g>
          </svg>

          <!-- Mega flash initial (big bang au load) -->
          <span class="boost-bigbang" aria-hidden="true"></span>

          <!-- Onde de choc (shockwave violette) -->
          <span class="boost-shockwave boost-shockwave--1" aria-hidden="true"></span>
          <span class="boost-shockwave boost-shockwave--2" aria-hidden="true"></span>
          <span class="boost-shockwave boost-shockwave--3" aria-hidden="true"></span>

          <!-- Rayons d'explosion SVG — full violet -->
          <svg class="boost-rays" viewBox="-100 -100 200 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
            <defs>
              <linearGradient id="rayG" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%"  stop-color="#F3E8FF"/>
                <stop offset="25%" stop-color="#D8B4FE"/>
                <stop offset="55%" stop-color="#A855F7"/>
                <stop offset="100%" stop-color="#6D28D9"/>
              </linearGradient>
              <radialGradient id="rayCore" cx="0.5" cy="0.5" r="0.5">
                <stop offset="0%"  stop-color="#FFFFFF" stop-opacity="0.95"/>
                <stop offset="40%" stop-color="#E9D5FF" stop-opacity="0.8"/>
                <stop offset="100%" stop-color="#A855F7" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <!-- Core glow -->
            <circle cx="0" cy="0" r="34" fill="url(#rayCore)" class="boost-core-glow"/>
            <g class="boost-rays-group" stroke="url(#rayG)" stroke-width="2.4" stroke-linecap="round" opacity="0.9">
              <line x1="-96" y1="0"   x2="-40" y2="0"   />
              <line x1="96"  y1="0"   x2="40"  y2="0"   />
              <line x1="0"   y1="-96" x2="0"   y2="-40" />
              <line x1="0"   y1="96"  x2="0"   y2="40"  />
              <line x1="-68" y1="-68" x2="-30" y2="-30" />
              <line x1="68"  y1="68"  x2="30"  y2="30"  />
              <line x1="-68" y1="68"  x2="-30" y2="30"  />
              <line x1="68"  y1="-68" x2="30"  y2="-30" />
              <line x1="-86" y1="-36" x2="-40" y2="-16" stroke-width="1.4"/>
              <line x1="86"  y1="36"  x2="40"  y2="16"  stroke-width="1.4"/>
              <line x1="-36" y1="-86" x2="-16" y2="-40" stroke-width="1.4"/>
              <line x1="36"  y1="86"  x2="16"  y2="40"  stroke-width="1.4"/>
              <line x1="-86" y1="36"  x2="-40" y2="16"  stroke-width="1.4"/>
              <line x1="86"  y1="-36" x2="40"  y2="-16" stroke-width="1.4"/>
              <line x1="-36" y1="86"  x2="-16" y2="40"  stroke-width="1.4"/>
              <line x1="36"  y1="-86" x2="16"  y2="-40" stroke-width="1.4"/>
            </g>
            <g class="boost-rays-group boost-rays-group--counter" stroke="#D8B4FE" stroke-width="1" stroke-linecap="round" opacity="0.55">
              <line x1="-76" y1="-20" x2="-38" y2="-10" />
              <line x1="76"  y1="20"  x2="38"  y2="10"  />
              <line x1="-20" y1="-76" x2="-10" y2="-38" />
              <line x1="20"  y1="76"  x2="10"  y2="38"  />
              <line x1="-76" y1="20"  x2="-38" y2="10"  />
              <line x1="76"  y1="-20" x2="38"  y2="-10" />
              <line x1="-20" y1="76"  x2="-10" y2="38"  />
              <line x1="20"  y1="-76" x2="10"  y2="-38" />
            </g>
          </svg>
          <!-- Particules d'explosion -->
          <span class="boost-particle boost-particle--1"></span>
          <span class="boost-particle boost-particle--2"></span>
          <span class="boost-particle boost-particle--3"></span>
          <span class="boost-particle boost-particle--4"></span>
          <span class="boost-particle boost-particle--5"></span>
          <span class="boost-particle boost-particle--6"></span>
          <!-- Chromatic aberration : copies décalées pour glitch violet -->
          <span class="boost-rgb boost-rgb--back" aria-hidden="true">BOOSTÉE</span>
          <span class="boost-rgb boost-rgb--front" aria-hidden="true">BOOSTÉE</span>

          <!-- Le mot BOOSTÉE — chaque lettre animée séparément -->
          <span class="boost-word-text" data-text="BOOSTÉE">
            <span class="boost-letter" style="--i:0">B</span>
            <span class="boost-letter" style="--i:1">O</span>
            <span class="boost-letter" style="--i:2">O</span>
            <span class="boost-letter" style="--i:3">S</span>
            <span class="boost-letter" style="--i:4">T</span>
            <span class="boost-letter" style="--i:5">É</span>
            <span class="boost-letter" style="--i:6">E</span>
          </span>
        </span>
      </span>
      <span class="tagline-line tagline-bottom reveal" style="--d:0.6s">
        par l'IA.
      </span>
    </h1>

    <!-- CTA premium + secondaire -->
    <div class="hero-ctas reveal" style="--d:0.75s">
      <a href="#pricing" class="hero-cta-primary">
        <span class="cta-label">Rejoindre la session</span>
        <span class="cta-arrow" aria-hidden="true">
          <svg viewBox="0 0 14 12" fill="none" width="14" height="12">
            <path d="M1 6H13M13 6L8 1M13 6L8 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <a href="#programme" class="hero-cta-secondary">
        Voir le programme
      </a>
    </div>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background:
      radial-gradient(ellipse 120% 80% at 50% 0%, #1a0730 0%, #0d0320 40%, #06010F 75%, #000 100%);
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 860px;
    perspective: 1200px;
  }

  /* Atmosphère deep space — voile radial qui crée la profondeur */
  .galaxy-deep {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(124, 58, 237, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 80% 70% at 20% 80%, rgba(88, 28, 135, 0.22) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(168, 85, 247, 0.15) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
    animation: deepShift 18s ease-in-out infinite alternate;
  }
  @keyframes deepShift {
    from { transform: scale(1) translate(0, 0); }
    to   { transform: scale(1.08) translate(-2%, 1%); }
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet pulsant derrière la tagline — full violet aurora */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 82%;
    max-width: 1200px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(192, 132, 252, 0.32) 0%, transparent 55%),
      radial-gradient(ellipse at center, rgba(168, 85, 247, 0.55) 0%, rgba(124, 58, 237, 0.28) 38%, transparent 72%),
      radial-gradient(ellipse at 72% 50%, rgba(139, 92, 246, 0.3) 0%, transparent 55%);
    filter: blur(36px);
    z-index: 0;
    pointer-events: none;
    animation: spotlightBreath 6s ease-in-out infinite;
  }
  @keyframes spotlightBreath {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.08); }
  }

  /* ===================== GALAXIE ACTIVE ===================== */
  .hero-galaxy {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Starfield — 3 profondeurs, box-shadow multi-étoiles */
  .galaxy-stars {
    position: absolute;
    inset: -20% -10%;
    background: transparent;
    will-change: transform;
  }
  .galaxy-stars::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }
  .galaxy-stars--far::before {
    width: 2px; height: 2px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      120px 80px rgba(255,255,255,0.85),
      260px 180px rgba(216,180,254,0.9),
      440px 40px rgba(255,255,255,0.7),
      580px 220px rgba(192,132,252,0.85),
      720px 130px rgba(255,255,255,0.6),
      860px 60px rgba(255,255,255,0.8),
      980px 280px rgba(216,180,254,0.7),
      1140px 180px rgba(255,255,255,0.9),
      1280px 90px rgba(192,132,252,0.8),
      1420px 230px rgba(255,255,255,0.7),
      1580px 60px rgba(255,255,255,0.65),
      1720px 150px rgba(216,180,254,0.8),
      80px 320px rgba(255,255,255,0.7),
      220px 420px rgba(192,132,252,0.85),
      380px 500px rgba(255,255,255,0.7),
      540px 380px rgba(255,255,255,0.8),
      680px 560px rgba(216,180,254,0.75),
      820px 460px rgba(255,255,255,0.65),
      960px 620px rgba(192,132,252,0.9),
      1120px 400px rgba(255,255,255,0.8),
      1280px 540px rgba(255,255,255,0.7),
      1440px 460px rgba(216,180,254,0.85),
      1600px 580px rgba(255,255,255,0.7),
      1760px 380px rgba(192,132,252,0.8);
    animation: starsTwinkle 4s ease-in-out infinite, starsDriftFar 120s linear infinite;
  }
  .galaxy-stars--mid::before {
    width: 2.5px; height: 2.5px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      180px 120px rgba(255,255,255,1),
      340px 260px rgba(216,180,254,0.95),
      520px 80px rgba(255,255,255,0.85),
      680px 360px rgba(192,132,252,0.9),
      840px 190px rgba(255,255,255,0.9),
      1020px 80px rgba(233,213,255,0.95),
      1200px 320px rgba(255,255,255,0.8),
      1380px 220px rgba(216,180,254,0.9),
      1560px 140px rgba(255,255,255,0.9),
      1720px 300px rgba(192,132,252,0.85),
      140px 480px rgba(255,255,255,0.85),
      320px 560px rgba(216,180,254,0.95),
      500px 620px rgba(255,255,255,0.8),
      680px 480px rgba(233,213,255,0.95),
      860px 600px rgba(255,255,255,0.85),
      1040px 520px rgba(192,132,252,0.85),
      1220px 640px rgba(255,255,255,0.9),
      1400px 560px rgba(216,180,254,0.9),
      1580px 620px rgba(255,255,255,0.8),
      1760px 500px rgba(233,213,255,0.95);
    animation: starsTwinkle 3s ease-in-out infinite 0.5s, starsDriftMid 80s linear infinite;
  }
  .galaxy-stars--near::before {
    width: 3.5px; height: 3.5px; left: 0; top: 0;
    background: #fff;
    box-shadow:
      240px 100px rgba(255,255,255,1),
      480px 240px rgba(216,180,254,1),
      760px 160px rgba(192,132,252,0.95),
      1040px 300px rgba(255,255,255,1),
      1320px 180px rgba(233,213,255,0.95),
      1620px 240px rgba(255,255,255,1),
      200px 440px rgba(192,132,252,1),
      460px 560px rgba(255,255,255,1),
      760px 620px rgba(216,180,254,0.95),
      1060px 480px rgba(233,213,255,1),
      1360px 580px rgba(255,255,255,1),
      1660px 420px rgba(192,132,252,0.9);
    filter: drop-shadow(0 0 6px rgba(216,180,254,0.7));
    animation: starsTwinkle 2.2s ease-in-out infinite 1s, starsDriftNear 60s linear infinite;
  }

  @keyframes starsTwinkle {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.35; }
  }
  @keyframes starsDriftFar {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-40px, 18px, 0); }
  }
  @keyframes starsDriftMid {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-80px, 30px, 0); }
  }
  @keyframes starsDriftNear {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-140px, 50px, 0); }
  }

  /* Nébuleuses violettes qui bougent lentement — full violet atmosphere */
  .galaxy-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    mix-blend-mode: screen;
    opacity: 0.7;
    will-change: transform, opacity;
  }
  .galaxy-nebula--a {
    width: 580px; height: 580px;
    top: -10%; left: -8%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.75) 0%, rgba(124, 58, 237, 0.35) 45%, transparent 70%);
    animation: nebulaFloatA 22s ease-in-out infinite;
  }
  .galaxy-nebula--b {
    width: 520px; height: 520px;
    top: 50%; right: -10%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.7) 0%, rgba(88, 28, 135, 0.3) 45%, transparent 70%);
    animation: nebulaFloatB 28s ease-in-out infinite;
  }
  .galaxy-nebula--c {
    width: 440px; height: 440px;
    bottom: -8%; left: 28%;
    background: radial-gradient(circle, rgba(147, 51, 234, 0.6) 0%, rgba(109, 40, 217, 0.25) 45%, transparent 70%);
    animation: nebulaFloatC 26s ease-in-out infinite;
  }
  @keyframes nebulaFloatA {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.55; }
    50%      { transform: translate(40px, 60px) scale(1.08); opacity: 0.7; }
  }
  @keyframes nebulaFloatB {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50%      { transform: translate(-50px, -40px) scale(1.1); opacity: 0.65; }
  }
  @keyframes nebulaFloatC {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.45; }
    50%      { transform: translate(30px, -50px) scale(1.12); opacity: 0.6; }
  }

  /* Étoiles filantes */
  .galaxy-shooting {
    position: absolute;
    width: 2px;
    height: 2px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.8);
    opacity: 0;
  }
  .galaxy-shooting::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 2px;
    width: 140px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.95), rgba(216, 180, 254, 0.6));
    transform: translateY(-50%);
  }
  .galaxy-shooting--1 {
    top: 18%; left: -10%;
    animation: shootingStar 8s ease-in 2s infinite;
  }
  .galaxy-shooting--2 {
    top: 42%; left: -10%;
    animation: shootingStar 11s ease-in 5s infinite;
  }
  .galaxy-shooting--3 {
    top: 68%; left: -10%;
    animation: shootingStar 14s ease-in 8s infinite;
  }
  @keyframes shootingStar {
    0%   { transform: translate3d(0, 0, 0); opacity: 0; }
    5%   { opacity: 1; }
    40%  { opacity: 1; }
    60%  { opacity: 0; }
    100% { transform: translate3d(130vw, 24vh, 0); opacity: 0; }
  }

  /* ============ PLANÈTE VIOLETTE PREMIUM ============ */
  .galaxy-planet {
    position: absolute;
    bottom: -14%;
    left: 8%;
    width: 380px;
    height: 380px;
    z-index: 1;
    pointer-events: none;
    animation: planetFloat 14s ease-in-out infinite;
    filter: drop-shadow(0 30px 80px rgba(124, 58, 237, 0.45));
  }
  @keyframes planetFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-18px) rotate(0.6deg); }
  }

  /* Halo atmosphérique externe */
  .planet-glow-outer {
    position: absolute;
    inset: -22%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.3) 0%, rgba(168, 85, 247, 0.15) 40%, transparent 70%);
    filter: blur(28px);
    animation: planetGlowPulse 5s ease-in-out infinite;
  }
  @keyframes planetGlowPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }

  /* Sphère violette avec lighting réaliste */
  .planet-sphere {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(circle at 32% 30%,
        #E9D5FF 0%,
        #C084FC 8%,
        #A855F7 22%,
        #7C3AED 45%,
        #5B21B6 68%,
        #2E1065 88%,
        #0a0418 100%);
    box-shadow:
      inset -24px -24px 80px rgba(10, 4, 24, 0.85),
      inset 18px 18px 50px rgba(216, 180, 254, 0.3),
      inset 0 0 0 1px rgba(216, 180, 254, 0.2);
  }

  /* Surface : bandes de "gaz" (style Jupiter violet) */
  .planet-surface {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
      repeating-linear-gradient(
        8deg,
        transparent 0px,
        transparent 16px,
        rgba(76, 29, 149, 0.22) 16px,
        rgba(76, 29, 149, 0.22) 22px,
        transparent 22px,
        transparent 38px,
        rgba(216, 180, 254, 0.12) 38px,
        rgba(216, 180, 254, 0.12) 43px
      );
    mix-blend-mode: overlay;
    opacity: 0.85;
    animation: surfaceDrift 22s linear infinite;
  }
  @keyframes surfaceDrift {
    from { background-position: 0 0; }
    to   { background-position: 0 200px; }
  }

  /* Atmosphère violet lumineuse au limbe */
  .planet-atmosphere {
    position: absolute;
    inset: -2%;
    border-radius: 50%;
    box-shadow:
      inset 0 0 24px rgba(216, 180, 254, 0.55),
      0 0 40px rgba(168, 85, 247, 0.35);
    pointer-events: none;
  }

  /* Terminator (ligne jour/nuit) */
  .planet-terminator {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 72% 62%, transparent 0%, transparent 30%, rgba(0, 0, 0, 0.55) 80%);
    pointer-events: none;
  }

  /* Specular highlight */
  .planet-shine {
    position: absolute;
    top: 14%;
    left: 20%;
    width: 40%;
    height: 32%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.45) 0%, rgba(233, 213, 255, 0.15) 40%, transparent 70%);
    filter: blur(12px);
    pointer-events: none;
    animation: shineBreath 6s ease-in-out infinite;
  }
  @keyframes shineBreath {
    0%, 100% { opacity: 0.8; }
    50%      { opacity: 1; }
  }

  /* Anneaux en perspective */
  .planet-ring {
    position: absolute;
    left: -32%;
    right: -32%;
    top: 44%;
    height: 46px;
    border-radius: 50%;
    transform: rotateX(76deg) rotateZ(-14deg);
    pointer-events: none;
    background:
      radial-gradient(ellipse at center,
        transparent 0%,
        transparent 38%,
        rgba(216, 180, 254, 0.7) 44%,
        rgba(168, 85, 247, 0.6) 52%,
        rgba(124, 58, 237, 0.5) 62%,
        rgba(88, 28, 135, 0.35) 72%,
        transparent 82%);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.45));
  }
  .planet-ring--back {
    clip-path: inset(0 0 50% 0);
    z-index: 0;
  }
  .planet-ring--front {
    clip-path: inset(50% 0 0 0);
    z-index: 3;
  }

  /* Lune en orbite */
  .planet-moon {
    position: absolute;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    background: radial-gradient(circle at 30% 30%, #F3E8FF 0%, #C084FC 40%, #6D28D9 100%);
    box-shadow: 0 0 18px rgba(192, 132, 252, 0.7), inset -4px -4px 8px rgba(0, 0, 0, 0.5);
    transform-origin: -160px -20px;
    animation: moonOrbit 16s linear infinite;
  }
  @keyframes moonOrbit {
    from { transform: translate(-50%, -50%) rotate(0deg) translate(220px) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg) translate(220px) rotate(-360deg); }
  }

  /* Mini planète 2 (coin haut droit) */
  .galaxy-planet-mini {
    position: absolute;
    top: 12%;
    right: 6%;
    width: 90px;
    height: 90px;
    z-index: 1;
    pointer-events: none;
    opacity: 0.85;
    animation: planetFloat 18s ease-in-out infinite 3s;
  }
  .planet-mini-glow {
    position: absolute;
    inset: -40%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.35) 0%, transparent 70%);
    filter: blur(18px);
  }
  .planet-mini-body {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 30%, #D8B4FE 0%, #A855F7 30%, #6D28D9 65%, #2E1065 100%);
    box-shadow:
      inset -8px -8px 20px rgba(0, 0, 0, 0.7),
      inset 4px 4px 10px rgba(216, 180, 254, 0.3),
      0 0 20px rgba(168, 85, 247, 0.4);
  }

  /* =============== TAGLINE — multilignes =============== */
  .tagline-line {
    display: block;
    line-height: 1;
  }
  .tagline-top {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.82);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  :global([data-theme="light"]) .tagline-top {
    color: rgba(10, 4, 24, 0.78);
  }
  .tagline-bottom {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 3.2vw, 42px);
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.015em;
    margin-top: 4px;
  }
  :global([data-theme="light"]) .tagline-bottom {
    color: rgba(10, 4, 24, 0.92);
  }

  /* =============== BOOSTÉE — explosion =============== */
  .tagline-boost-line {
    position: relative;
    display: block;
    padding: 8px 0;
    line-height: 1;
  }

  .boost-word {
    position: relative;
    display: inline-block;
    line-height: 1;
    z-index: 1;
  }

  /* ============ FLAME AURA (turbulence SVG ondulante) ============ */
  .boost-flame {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 280%;
    height: 320%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    opacity: 0.85;
    animation: flameBreath 4s ease-in-out infinite;
    overflow: visible;
  }
  @keyframes flameBreath {
    0%, 100% { opacity: 0.75; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.08); }
  }

  /* ============ FISSURES (cracks) ============ */
  .boost-cracks {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 260%;
    height: 500%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 2;
    overflow: visible;
    filter:
      drop-shadow(0 0 8px rgba(233, 213, 255, 0.95))
      drop-shadow(0 0 20px rgba(168, 85, 247, 0.75))
      drop-shadow(0 0 40px rgba(124, 58, 237, 0.5));
  }
  .crack {
    stroke-width: 1.8;
    stroke-dasharray: 260;
    stroke-dashoffset: 260;
    opacity: 0;
    animation: crackStrike 3.6s ease-out infinite;
  }
  .crack--1  { animation-delay: 0.1s;  }
  .crack--2  { animation-delay: 0.25s; animation-duration: 3.2s; }
  .crack--3  { animation-delay: 0.45s; animation-duration: 3.8s; }
  .crack--4  { animation-delay: 0.15s; animation-duration: 3.4s; }
  .crack--5  { animation-delay: 0.6s;  animation-duration: 3.6s; }
  .crack--6  { animation-delay: 0.35s; animation-duration: 3.5s; }
  .crack--7  { animation-delay: 0.8s;  animation-duration: 3.9s; }
  .crack--8  { animation-delay: 0.9s;  animation-duration: 3.3s; }
  .crack--9  { animation-delay: 1.1s;  animation-duration: 3.1s; stroke-width: 1; }
  .crack--10 { animation-delay: 1.2s;  animation-duration: 3.0s; stroke-width: 1; }
  .crack--11 { animation-delay: 1.3s;  animation-duration: 3.2s; stroke-width: 1; }
  .crack--12 { animation-delay: 1.4s;  animation-duration: 3.0s; stroke-width: 1; }
  @keyframes crackStrike {
    0%   { stroke-dashoffset: 260; opacity: 0; }
    6%   { opacity: 1; stroke-dashoffset: 260; }
    20%  { opacity: 1; stroke-dashoffset: 0; }
    26%  { opacity: 0.2; }
    30%  { opacity: 1; }
    60%  { opacity: 0.6; }
    100% { opacity: 0; stroke-dashoffset: 0; }
  }

  /* ============ FRAGMENTS / DÉBRIS (shards) ============ */
  .boost-shards {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 220%;
    height: 420%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 3;
    overflow: visible;
    filter: drop-shadow(0 0 4px rgba(233, 213, 255, 0.9));
  }
  .shard {
    transform-origin: center;
    animation-iteration-count: infinite;
    animation-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
    opacity: 0;
  }
  .shard--1  { animation: shardFly1  3.2s 0.6s infinite; }
  .shard--2  { animation: shardFly2  3.4s 0.9s infinite; }
  .shard--3  { animation: shardFly3  3.0s 0.3s infinite; }
  .shard--4  { animation: shardFly4  3.6s 1.2s infinite; }
  .shard--5  { animation: shardFly5  3.3s 0.5s infinite; }
  .shard--6  { animation: shardFly6  3.5s 1.5s infinite; }
  .shard--7  { animation: shardFly7  3.1s 0.8s infinite; }
  .shard--8  { animation: shardFly8  3.4s 1.1s infinite; }
  .shard--9  { animation: shardFly1  2.8s 1.8s infinite reverse; }
  .shard--10 { animation: shardFly3  3.2s 2.0s infinite reverse; }
  .shard--11 { animation: shardFly5  3.0s 1.3s infinite reverse; }
  .shard--12 { animation: shardFly7  3.4s 1.7s infinite reverse; }
  @keyframes shardFly1 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate(-90px, -120px) rotate(720deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly2 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate( 110px, -100px) rotate(-640deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly3 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate(-130px,  80px) rotate(580deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly4 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate( 140px,  90px) rotate(-720deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly5 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate( -50px, -140px) rotate(540deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly6 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate(  60px, 130px) rotate(-600deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly7 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate(-160px, -40px) rotate(680deg) scale(0.2); opacity: 0; } }
  @keyframes shardFly8 { 0% { transform: translate(0,0) rotate(0deg) scale(1); opacity: 1; } 100% { transform: translate( 170px, -30px) rotate(-580deg) scale(0.2); opacity: 0; } }

  /* ============ ÉTINCELLES (sparks) ============ */
  .spark {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #FFFFFF;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    box-shadow:
      0 0 6px 2px rgba(255, 255, 255, 0.95),
      0 0 14px 4px rgba(216, 180, 254, 0.7),
      0 0 24px 6px rgba(168, 85, 247, 0.4);
  }
  .spark::after {
    content: '';
    position: absolute;
    right: 3px;
    top: 50%;
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(233, 213, 255, 0.9));
    transform: translateY(-50%);
  }
  .spark--1 { animation: sparkFly 2s ease-out 0.2s infinite;  --sx: -180px; --sy: -60px; --sr: 180deg; }
  .spark--2 { animation: sparkFly 2.2s ease-out 0.6s infinite; --sx:  200px; --sy: -80px; --sr:  0deg;  }
  .spark--3 { animation: sparkFly 1.9s ease-out 1.0s infinite; --sx: -160px; --sy:  90px; --sr: 210deg; }
  .spark--4 { animation: sparkFly 2.3s ease-out 1.4s infinite; --sx:  210px; --sy:  70px; --sr: -30deg; }
  .spark--5 { animation: sparkFly 2.1s ease-out 0.4s infinite; --sx:  -40px; --sy:-140px; --sr: 110deg; }
  .spark--6 { animation: sparkFly 2.4s ease-out 1.6s infinite; --sx:   50px; --sy: 130px; --sr: -70deg; }
  .spark--7 { animation: sparkFly 2s   ease-out 0.9s infinite; --sx: -220px; --sy:  20px; --sr: 190deg; }
  .spark--8 { animation: sparkFly 2.2s ease-out 1.2s infinite; --sx:  230px; --sy: -10px; --sr:  -10deg; }
  @keyframes sparkFly {
    0%   { transform: translate(-50%, -50%) rotate(var(--sr)); opacity: 0; }
    10%  { opacity: 1; }
    100% { transform: translate(calc(-50% + var(--sx)), calc(-50% + var(--sy))) rotate(var(--sr)); opacity: 0; }
  }

  /* ============ CHROMATIC RGB SPLIT (glitch violet) ============ */
  .boost-rgb {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(68px, 12vw, 180px);
    line-height: 1;
    letter-spacing: -0.045em;
    pointer-events: none;
    z-index: 1;
    white-space: nowrap;
    mix-blend-mode: screen;
  }
  .boost-rgb--back {
    color: rgba(216, 180, 254, 0.7);
    animation: rgbShiftBack 3s ease-in-out infinite;
    filter: blur(0.5px);
  }
  .boost-rgb--front {
    color: rgba(124, 58, 237, 0.65);
    animation: rgbShiftFront 3s ease-in-out infinite;
    filter: blur(0.5px);
  }
  @keyframes rgbShiftBack {
    0%, 100% { transform: translateX(calc(-50% - 2px)) translateY(0);   opacity: 0.7; }
    40%      { transform: translateX(calc(-50% - 5px)) translateY(-1px); opacity: 0.9; }
    42%      { transform: translateX(calc(-50% - 1px)) translateY(1px);  opacity: 0.4; }
    60%      { transform: translateX(calc(-50% - 6px)) translateY(-2px); opacity: 1; }
    62%      { transform: translateX(calc(-50% - 2px)) translateY(0);    opacity: 0.5; }
  }
  @keyframes rgbShiftFront {
    0%, 100% { transform: translateX(calc(-50% + 2px)) translateY(0);   opacity: 0.65; }
    40%      { transform: translateX(calc(-50% + 5px)) translateY(1px);  opacity: 0.85; }
    42%      { transform: translateX(calc(-50% + 1px)) translateY(-1px); opacity: 0.35; }
    60%      { transform: translateX(calc(-50% + 6px)) translateY(2px);  opacity: 1; }
    62%      { transform: translateX(calc(-50% + 2px)) translateY(0);    opacity: 0.5; }
  }

  /* ============ CANVAS PARTICULES PHYSIQUES ============ */
  .boost-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2000px;
    height: 1000px;
    max-width: none;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
  }

  /* ============ SPEED LINES (anime zoom radial) ============ */
  .boost-speedlines {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 160vw;
    height: 160vw;
    max-width: 1600px;
    max-height: 1600px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    mask-image: radial-gradient(circle, transparent 8%, #000 22%, #000 52%, transparent 72%);
    -webkit-mask-image: radial-gradient(circle, transparent 8%, #000 22%, #000 52%, transparent 72%);
  }
  .boost-speedlines span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 2px;
    height: 50%;
    background: linear-gradient(to bottom, transparent 0%, rgba(216, 180, 254, 0.9) 30%, rgba(168, 85, 247, 0.4) 80%, transparent 100%);
    transform-origin: top center;
    animation: speedZoom 2.2s linear infinite;
    opacity: 0;
  }
  .boost-speedlines span:nth-child(1)  { transform: rotate(0deg);   animation-delay: 0s;     }
  .boost-speedlines span:nth-child(2)  { transform: rotate(12deg);  animation-delay: 0.07s;  }
  .boost-speedlines span:nth-child(3)  { transform: rotate(24deg);  animation-delay: 0.14s;  }
  .boost-speedlines span:nth-child(4)  { transform: rotate(36deg);  animation-delay: 0.21s;  }
  .boost-speedlines span:nth-child(5)  { transform: rotate(48deg);  animation-delay: 0.28s;  }
  .boost-speedlines span:nth-child(6)  { transform: rotate(60deg);  animation-delay: 0.35s;  }
  .boost-speedlines span:nth-child(7)  { transform: rotate(72deg);  animation-delay: 0.42s;  }
  .boost-speedlines span:nth-child(8)  { transform: rotate(84deg);  animation-delay: 0.49s;  }
  .boost-speedlines span:nth-child(9)  { transform: rotate(96deg);  animation-delay: 0.56s;  }
  .boost-speedlines span:nth-child(10) { transform: rotate(108deg); animation-delay: 0.63s;  }
  .boost-speedlines span:nth-child(11) { transform: rotate(120deg); animation-delay: 0.7s;   }
  .boost-speedlines span:nth-child(12) { transform: rotate(132deg); animation-delay: 0.77s;  }
  .boost-speedlines span:nth-child(13) { transform: rotate(144deg); animation-delay: 0.84s;  }
  .boost-speedlines span:nth-child(14) { transform: rotate(156deg); animation-delay: 0.91s;  }
  .boost-speedlines span:nth-child(15) { transform: rotate(168deg); animation-delay: 0.98s;  }
  .boost-speedlines span:nth-child(16) { transform: rotate(180deg); animation-delay: 1.05s;  }
  .boost-speedlines span:nth-child(17) { transform: rotate(192deg); animation-delay: 1.12s;  }
  .boost-speedlines span:nth-child(18) { transform: rotate(204deg); animation-delay: 1.19s;  }
  .boost-speedlines span:nth-child(19) { transform: rotate(216deg); animation-delay: 1.26s;  }
  .boost-speedlines span:nth-child(20) { transform: rotate(228deg); animation-delay: 1.33s;  }
  .boost-speedlines span:nth-child(21) { transform: rotate(240deg); animation-delay: 1.4s;   }
  .boost-speedlines span:nth-child(22) { transform: rotate(252deg); animation-delay: 1.47s;  }
  .boost-speedlines span:nth-child(23) { transform: rotate(264deg); animation-delay: 1.54s;  }
  .boost-speedlines span:nth-child(24) { transform: rotate(276deg); animation-delay: 1.61s;  }
  .boost-speedlines span:nth-child(25) { transform: rotate(288deg); animation-delay: 1.68s;  }
  .boost-speedlines span:nth-child(26) { transform: rotate(300deg); animation-delay: 1.75s;  }
  .boost-speedlines span:nth-child(27) { transform: rotate(312deg); animation-delay: 1.82s;  }
  .boost-speedlines span:nth-child(28) { transform: rotate(324deg); animation-delay: 1.89s;  }
  .boost-speedlines span:nth-child(29) { transform: rotate(336deg); animation-delay: 1.96s;  }
  .boost-speedlines span:nth-child(30) { transform: rotate(348deg); animation-delay: 2.03s;  }
  @keyframes speedZoom {
    0%   { transform-origin: top center; transform: rotate(var(--r, 0deg)) scaleY(0); opacity: 0; }
    20%  { opacity: 1; }
    100% { transform: rotate(var(--r, 0deg)) scaleY(1); opacity: 0; }
  }

  /* ============ LENS FLARE horizontal qui balaie ============ */
  .boost-lensflare {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 180%;
    height: 30%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 3;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(216, 180, 254, 0) 35%,
      rgba(233, 213, 255, 0.85) 48%,
      rgba(255, 255, 255, 1) 50%,
      rgba(233, 213, 255, 0.85) 52%,
      rgba(216, 180, 254, 0) 65%,
      transparent 100%);
    filter: blur(6px);
    mix-blend-mode: screen;
    opacity: 0;
    animation: flareSweep 5.5s ease-in-out infinite;
  }
  @keyframes flareSweep {
    0%   { transform: translate(-130%, -50%) skewX(-14deg); opacity: 0; }
    40%  { opacity: 0; }
    50%  { transform: translate(-50%, -50%) skewX(-14deg);  opacity: 1; }
    60%  { opacity: 0; }
    100% { transform: translate(30%, -50%) skewX(-14deg);   opacity: 0; }
  }

  /* ============ ÉCLAIRS (lightning bolts) ============ */
  .boost-lightning {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 240%;
    height: 480%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 2;
    overflow: visible;
    filter:
      drop-shadow(0 0 10px rgba(233, 213, 255, 0.95))
      drop-shadow(0 0 22px rgba(168, 85, 247, 0.8));
  }
  .bolt {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    opacity: 0;
    animation: boltStrike 4s ease-out infinite;
  }
  .bolt--1 { animation-delay: 0.2s; }
  .bolt--2 { animation-delay: 0.8s; animation-duration: 3.4s; }
  .bolt--3 { animation-delay: 1.6s; animation-duration: 4.6s; }
  .bolt--4 { animation-delay: 2.4s; animation-duration: 3.2s; }
  .bolt--5 { animation-delay: 0.4s; animation-duration: 3.8s; }
  .bolt--6 { animation-delay: 2.0s; animation-duration: 4.2s; }
  @keyframes boltStrike {
    0%   { stroke-dashoffset: 220; opacity: 0; }
    8%   { stroke-dashoffset: 0;   opacity: 1; }
    14%  { opacity: 0.2; }
    18%  { opacity: 1; }
    24%  { opacity: 0; stroke-dashoffset: 0; }
    100% { opacity: 0; stroke-dashoffset: 0; }
  }

  /* ============ BIG BANG initial (flash au load) ============ */
  .boost-bigbang {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: radial-gradient(circle, #FFFFFF 0%, #F3E8FF 25%, #D8B4FE 55%, rgba(168, 85, 247, 0) 80%);
    transform: translate(-50%, -50%) scale(0);
    pointer-events: none;
    z-index: 4;
    animation: bigbang 1.8s cubic-bezier(0.19, 1, 0.22, 1) 0.35s forwards;
  }
  @keyframes bigbang {
    0%   { transform: translate(-50%, -50%) scale(0);   opacity: 0; }
    8%   { transform: translate(-50%, -50%) scale(0.2); opacity: 1; filter: blur(0); }
    35%  { transform: translate(-50%, -50%) scale(22);  opacity: 0.9; filter: blur(6px); }
    100% { transform: translate(-50%, -50%) scale(60);  opacity: 0; filter: blur(40px); }
  }

  /* Shockwaves violettes concentriques */
  .boost-shockwave {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid rgba(216, 180, 254, 0.85);
    transform: translate(-50%, -50%) scale(0);
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    box-shadow:
      0 0 28px rgba(168, 85, 247, 0.75),
      inset 0 0 18px rgba(216, 180, 254, 0.5);
  }
  .boost-shockwave--1 { animation: shockwave 2.4s ease-out infinite; }
  .boost-shockwave--2 { animation: shockwave 2.4s ease-out 0.8s infinite; }
  .boost-shockwave--3 { animation: shockwave 2.4s ease-out 1.6s infinite; }
  @keyframes shockwave {
    0%   { transform: translate(-50%, -50%) scale(0);   opacity: 1;    border-width: 3.5px; }
    70%  { opacity: 0.3; border-width: 1.5px; }
    100% { transform: translate(-50%, -50%) scale(18);  opacity: 0;    border-width: 1px; }
  }

  /* Rayons d'explosion — full violet */
  .boost-rays {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 380%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    overflow: visible;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.8))
            drop-shadow(0 0 32px rgba(124, 58, 237, 0.55))
            drop-shadow(0 0 56px rgba(88, 28, 135, 0.35));
  }
  .boost-core-glow {
    animation: corePulse 2.4s ease-in-out infinite;
    transform-origin: center;
  }
  @keyframes corePulse {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.18); }
  }
  .boost-rays-group {
    transform-origin: center;
    animation: raysPulse 3.4s ease-in-out infinite, raysSpin 38s linear infinite;
  }
  .boost-rays-group--counter {
    animation: raysPulse 2.8s ease-in-out infinite 0.6s, raysSpin 52s linear infinite reverse;
  }
  @keyframes raysPulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.08); }
  }
  @keyframes raysSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Particules d'explosion — full violet + blanc */
  .boost-particle {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  .boost-particle--1 { background: #D8B4FE; box-shadow: 0 0 14px 3px rgba(216, 180, 254, 0.9); animation: particleBurst 3s ease-out 0.4s infinite;  --px: -240px; --py: -110px; }
  .boost-particle--2 { background: #C084FC; box-shadow: 0 0 14px 3px rgba(192, 132, 252, 0.9); animation: particleBurst 3.2s ease-out 0.9s infinite; --px:  240px; --py: -130px; }
  .boost-particle--3 { background: #A855F7; box-shadow: 0 0 14px 3px rgba(168, 85, 247, 0.9); animation: particleBurst 3.6s ease-out 0.2s infinite; --px: -280px; --py:  120px; }
  .boost-particle--4 { background: #E9D5FF; box-shadow: 0 0 14px 3px rgba(233, 213, 255, 0.9); animation: particleBurst 3.4s ease-out 1.3s infinite; --px:  280px; --py:  110px; }
  .boost-particle--5 { background: #FFFFFF; box-shadow: 0 0 16px 3px rgba(255, 255, 255, 0.95), 0 0 32px 6px rgba(216, 180, 254, 0.6); animation: particleBurst 3.8s ease-out 0.7s infinite; --px:  -60px; --py: -180px; }
  .boost-particle--6 { background: #FFFFFF; box-shadow: 0 0 16px 3px rgba(255, 255, 255, 0.95), 0 0 32px 6px rgba(192, 132, 252, 0.6); animation: particleBurst 3s ease-out 1.7s infinite;   --px:   60px; --py:  180px; }
  @keyframes particleBurst {
    0%   { transform: translate(-50%, -50%) scale(0.4); opacity: 0; }
    15%  { opacity: 1; }
    100% { transform: translate(calc(-50% + var(--px)), calc(-50% + var(--py))) scale(0.2); opacity: 0; }
  }

  /* Le mot BOOSTÉE — gradient full violet + chrome */
  .boost-word-text {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: clamp(68px, 12vw, 180px);
    line-height: 1;
    letter-spacing: -0.045em;
    background: linear-gradient(135deg,
      #FFFFFF 0%,
      #F3E8FF 15%,
      #D8B4FE 32%,
      #A855F7 55%,
      #7C3AED 78%,
      #4C1D95 100%);
    background-size: 220% 220%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 22px rgba(216, 180, 254, 0.7))
      drop-shadow(0 0 42px rgba(168, 85, 247, 0.65))
      drop-shadow(0 0 72px rgba(124, 58, 237, 0.45));
    animation: boostGradientShift 6s ease-in-out infinite, boostPulseScale 3.2s ease-in-out infinite;
    z-index: 2;
    transform-origin: center;
  }
  .boost-word-text::before {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    -webkit-text-fill-color: transparent;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(216, 180, 254, 0.35);
    z-index: -1;
    pointer-events: none;
  }

  /* Lettres : assemblage initial (chaque lettre jaillit du centre) */
  .boost-letter {
    display: inline-block;
    opacity: 0;
    transform: translate3d(0, 0, 0) scale(0.1) rotate(0deg);
    animation:
      letterAssemble 1s cubic-bezier(0.19, 1, 0.22, 1) calc(0.7s + var(--i) * 0.05s) forwards,
      letterFlicker 6s ease-in-out calc(2.5s + var(--i) * 0.15s) infinite;
    transform-origin: center;
    will-change: transform, opacity;
  }
  @keyframes letterAssemble {
    0%   {
      opacity: 0;
      transform: translate3d(
        calc((var(--i) - 3) * 80px),
        calc(-20px + (var(--i) - 3) * -10px),
        0) scale(0.2) rotate(calc((var(--i) - 3) * 45deg));
      filter: blur(10px);
    }
    60%  {
      opacity: 1;
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
      filter: blur(0);
    }
  }
  @keyframes letterFlicker {
    0%, 100%   { opacity: 1; text-shadow: none; }
    48%        { opacity: 1; }
    50%        { opacity: 0.6; text-shadow: 0 0 20px rgba(233, 213, 255, 0.95); }
    52%        { opacity: 1; }
  }
  @keyframes boostGradientShift {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }
  @keyframes boostPulseScale {
    0%, 100% { transform: scale(1); filter:
                drop-shadow(0 0 22px rgba(216, 180, 254, 0.7))
                drop-shadow(0 0 42px rgba(168, 85, 247, 0.65))
                drop-shadow(0 0 72px rgba(124, 58, 237, 0.45)); }
    50%      { transform: scale(1.04); filter:
                drop-shadow(0 0 32px rgba(233, 213, 255, 0.9))
                drop-shadow(0 0 60px rgba(168, 85, 247, 0.9))
                drop-shadow(0 0 100px rgba(124, 58, 237, 0.65)); }
  }

  :global([data-theme="light"]) .boost-word-text::before {
    -webkit-text-stroke: 1.5px rgba(10, 4, 24, 0.18);
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -40px;
    gap: 0;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 780px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 95px; }
    .boost-word-text { font-size: clamp(56px, 11vw, 110px); }
    .boost-rays { width: 220%; height: 380%; }
    .galaxy-planet { width: 280px; height: 280px; bottom: -10%; left: 2%; }
    .galaxy-planet-mini { width: 70px; height: 70px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 680px; }
    .hero-inner { gap: 20px; }
    .brand-smmia { height: 72px; }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
    .tagline-top, .tagline-bottom { font-size: clamp(18px, 5vw, 22px); }
    .boost-word-text { font-size: clamp(52px, 15vw, 78px); }
    .boost-rays { width: 240%; height: 420%; }
    .boost-particle { width: 5px; height: 5px; }
    .galaxy-nebula { filter: blur(60px); }
    .galaxy-planet { width: 200px; height: 200px; bottom: -6%; left: -6%; opacity: 0.85; }
    .galaxy-planet-mini { width: 56px; height: 56px; top: 9%; right: 4%; }
    .planet-moon { display: none; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
    .boost-word-text { font-size: clamp(44px, 14vw, 60px); }
    .galaxy-planet { width: 170px; height: 170px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal,
    .galaxy-stars::before, .galaxy-nebula, .galaxy-shooting,
    .boost-rays-group, .boost-particle, .boost-word-text,
    .boost-shockwave, .boost-core-glow, .galaxy-deep,
    .galaxy-planet, .planet-moon, .planet-shine,
    .galaxy-planet-mini, .planet-surface,
    .crack, .shard, .spark, .boost-rgb, .boost-flame, .boost-letter,
    .boost-lensflare, .bolt, .boost-speedlines span,
    .hero-spotlight {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .boost-particle, .boost-shockwave, .spark, .shard, .boost-rgb,
    .boost-speedlines, .boost-lensflare, .boost-canvas, .boost-bigbang {
      display: none;
    }
    .planet-moon { display: none; }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }

  // ============ CANVAS : explosion de particules physiques ============
  const canvas = document.getElementById('boost-canvas') as HTMLCanvasElement | null;
  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    function resize() {
      if (!canvas) return;
      const w = canvas.offsetWidth, h = canvas.offsetHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx?.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', () => { resize(); });

    type P = { x:number; y:number; vx:number; vy:number; life:number; max:number; r:number; hue:number; light:number; trail:{x:number;y:number}[]; kind:'dust'|'streak'|'ember' };
    const particles: P[] = [];
    const W = () => canvas.offsetWidth;
    const H = () => canvas.offsetHeight;

    const violetHues = [265, 272, 278, 285, 292, 298];

    function spawnBurst(count: number, intensity = 1, big = false) {
      const cx = W() / 2, cy = H() / 2;
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = (1.5 + Math.random() * (big ? 9 : 5.5)) * intensity;
        const hue = violetHues[Math.floor(Math.random() * violetHues.length)];
        const roll = Math.random();
        const isWhite = roll < 0.22;
        const kind: P['kind'] = roll < 0.12 ? 'streak' : (roll < 0.32 ? 'ember' : 'dust');
        particles.push({
          x: cx, y: cy,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 0,
          max: (kind === 'streak' ? 50 : 70) + Math.random() * 80,
          r: (kind === 'streak' ? 1 : 1.4) + Math.random() * 2.8,
          hue: isWhite ? 0 : hue,
          light: isWhite ? 100 : 60 + Math.random() * 30,
          trail: [],
          kind,
        });
      }
    }

    // Big bang initial + burst secondaire (déchirure)
    setTimeout(() => spawnBurst(280, 1.8, true), 450);
    setTimeout(() => spawnBurst(120, 1.2, true), 900);
    // Bursts cycliques (déchirure qui se re-déclenche)
    setInterval(() => spawnBurst(90, 1.1, false), 1200);
    setInterval(() => spawnBurst(30, 1.6, true), 3600);

    function tick() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Emission continue pour que l'espace reste vivant
      if (Math.random() < 0.8) spawnBurst(4, 0.6);

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.life++;

        // Turbulence (jitter non-linéaire sur les embers)
        if (p.kind === 'ember') {
          p.vx += (Math.random() - 0.5) * 0.12;
          p.vy += (Math.random() - 0.5) * 0.12;
        }
        // Gravité négative légère
        p.vy -= 0.018;
        // Friction
        const fr = p.kind === 'streak' ? 0.995 : 0.982;
        p.vx *= fr; p.vy *= fr;
        p.x += p.vx; p.y += p.vy;

        // Trail pour streaks
        if (p.kind === 'streak') {
          p.trail.push({ x: p.x, y: p.y });
          if (p.trail.length > 8) p.trail.shift();
        }

        const t = p.life / p.max;
        if (t >= 1) { particles.splice(i, 1); continue; }
        const alpha = (1 - t) * 0.95;

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';

        // Trail line pour les streaks (déchirure lumineuse)
        if (p.kind === 'streak' && p.trail.length > 2) {
          ctx.beginPath();
          ctx.moveTo(p.trail[0].x, p.trail[0].y);
          for (let j = 1; j < p.trail.length; j++) ctx.lineTo(p.trail[j].x, p.trail[j].y);
          ctx.strokeStyle = p.hue === 0
            ? `rgba(255,255,255,${alpha * 0.9})`
            : `hsla(${p.hue}, 95%, ${p.light}%, ${alpha * 0.9})`;
          ctx.lineWidth = p.r * 1.2;
          ctx.lineCap = 'round';
          ctx.shadowColor = p.hue === 0 ? 'rgba(233,213,255,1)' : `hsla(${p.hue},95%,80%,1)`;
          ctx.shadowBlur = 14;
          ctx.stroke();
          ctx.shadowBlur = 0;
        }

        // Halo radial
        const haloR = p.r * (p.kind === 'ember' ? 8 : 5);
        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, haloR);
        if (p.hue === 0) {
          grad.addColorStop(0,   `rgba(255, 255, 255, ${alpha})`);
          grad.addColorStop(0.3, `rgba(233, 213, 255, ${alpha * 0.6})`);
          grad.addColorStop(1,   `rgba(168, 85, 247, 0)`);
        } else {
          grad.addColorStop(0,   `hsla(${p.hue}, 95%, ${p.light}%, ${alpha})`);
          grad.addColorStop(0.4, `hsla(${p.hue}, 85%, ${p.light - 20}%, ${alpha * 0.55})`);
          grad.addColorStop(1,   `hsla(${p.hue}, 75%, 45%, 0)`);
        }
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(p.x, p.y, haloR, 0, Math.PI * 2);
        ctx.fill();

        // Core
        ctx.fillStyle = p.hue === 0
          ? `rgba(255,255,255,${alpha})`
          : `hsla(${p.hue}, 98%, ${Math.min(p.light + 20, 98)}%, ${alpha})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      requestAnimationFrame(tick);
    }
    tick();
  }
</script>
