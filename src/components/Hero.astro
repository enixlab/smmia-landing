---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">
        <span class="tl-kicker-bar" aria-hidden="true"></span>
        <span class="tl-kicker-text">Ton agence</span>
      </span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Halo néon violet enveloppant (énergie contenue) -->
        <span class="booster-neon-halo" aria-hidden="true"></span>

        <!-- SVG filter — fissures/displacement pour pré-explosion -->
        <svg class="booster-svg-defs" width="0" height="0" aria-hidden="true">
          <defs>
            <filter id="crackDisplace" x="-20%" y="-20%" width="140%" height="140%">
              <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="2" seed="4" result="noise">
                <animate attributeName="baseFrequency" values="0.015;0.08;0.015" dur="8s" repeatCount="indefinite"/>
              </feTurbulence>
              <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G">
                <animate attributeName="scale" values="0;0;0;22;0;0;0" keyTimes="0;0.32;0.37;0.42;0.5;0.9;1" dur="8s" repeatCount="indefinite"/>
              </feDisplacementMap>
            </filter>
          </defs>
        </svg>

        <!-- Flash blanc au moment de la rupture -->
        <span class="booster-flash" aria-hidden="true"></span>

        <!-- Shockwave ring (une seule onde, expanse radiale) -->
        <span class="booster-shockwave" aria-hidden="true"></span>

        <!-- Dust cloud post-explosion -->
        <span class="booster-dust" aria-hidden="true"></span>

        <!-- Mot splitté par lettre — chaque lettre éclate en 6 shards polygonaux (glass shatter) -->
        <span class="booster-3d__word">
          <span class="boost-letter" style="--i:0">
            <span class="glyph">B</span>
            <span class="shard s1" aria-hidden="true">B</span>
            <span class="shard s2" aria-hidden="true">B</span>
            <span class="shard s3" aria-hidden="true">B</span>
            <span class="shard s4" aria-hidden="true">B</span>
            <span class="shard s5" aria-hidden="true">B</span>
            <span class="shard s6" aria-hidden="true">B</span>
          </span>
          <span class="boost-letter" style="--i:1">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
          </span>
          <span class="boost-letter" style="--i:2">
            <span class="glyph">O</span>
            <span class="shard s1" aria-hidden="true">O</span>
            <span class="shard s2" aria-hidden="true">O</span>
            <span class="shard s3" aria-hidden="true">O</span>
            <span class="shard s4" aria-hidden="true">O</span>
            <span class="shard s5" aria-hidden="true">O</span>
            <span class="shard s6" aria-hidden="true">O</span>
          </span>
          <span class="boost-letter" style="--i:3">
            <span class="glyph">S</span>
            <span class="shard s1" aria-hidden="true">S</span>
            <span class="shard s2" aria-hidden="true">S</span>
            <span class="shard s3" aria-hidden="true">S</span>
            <span class="shard s4" aria-hidden="true">S</span>
            <span class="shard s5" aria-hidden="true">S</span>
            <span class="shard s6" aria-hidden="true">S</span>
          </span>
          <span class="boost-letter" style="--i:4">
            <span class="glyph">T</span>
            <span class="shard s1" aria-hidden="true">T</span>
            <span class="shard s2" aria-hidden="true">T</span>
            <span class="shard s3" aria-hidden="true">T</span>
            <span class="shard s4" aria-hidden="true">T</span>
            <span class="shard s5" aria-hidden="true">T</span>
            <span class="shard s6" aria-hidden="true">T</span>
          </span>
          <span class="boost-letter" style="--i:5">
            <span class="glyph">E</span>
            <span class="shard s1" aria-hidden="true">E</span>
            <span class="shard s2" aria-hidden="true">E</span>
            <span class="shard s3" aria-hidden="true">E</span>
            <span class="shard s4" aria-hidden="true">E</span>
            <span class="shard s5" aria-hidden="true">E</span>
            <span class="shard s6" aria-hidden="true">E</span>
          </span>
          <span class="boost-letter" style="--i:6">
            <span class="glyph">R</span>
            <span class="shard s1" aria-hidden="true">R</span>
            <span class="shard s2" aria-hidden="true">R</span>
            <span class="shard s3" aria-hidden="true">R</span>
            <span class="shard s4" aria-hidden="true">R</span>
            <span class="shard s5" aria-hidden="true">R</span>
            <span class="shard s6" aria-hidden="true">R</span>
          </span>
        </span>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        <span class="tl-prefix">par l'</span><span class="tl-accent">IA</span><span class="tl-dot">.</span>
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: clamp(28px, 3.6vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: #FFFFFF;
  }

  /* "Ton agence" — kicker éditorial avec barre néon gauche */
  .tl-line--top {
    margin-bottom: 0.18em;
    font-weight: 600;
    letter-spacing: 0.002em;
  }
  .tl-kicker-bar {
    display: inline-block;
    width: 44px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(192, 132, 252, 0) 0%,
      #C084FC 35%,
      #E9D5FF 100%);
    box-shadow:
      0 0 12px rgba(192, 132, 252, 1),
      0 0 28px rgba(168, 85, 247, 0.7),
      0 0 52px rgba(139, 92, 246, 0.4);
    transform: translateY(2px);
  }
  .tl-kicker-text {
    color: #FFFFFF;
    font-weight: 600;
    text-shadow:
      0 0 4px rgba(255, 255, 255, 0.5),
      0 0 18px rgba(216, 180, 254, 0.45);
  }

  /* "par l'IA." — prefix sobre + IA en gradient néon + glow violet/cyan */
  .tl-line--bottom {
    margin-top: 0.35em;
    gap: 12px;
    font-weight: 500;
  }
  .tl-prefix {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
    letter-spacing: 0;
    font-style: normal;
  }
  .tl-accent {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg,
      #22D3EE 0%,
      #A855F7 42%,
      #C084FC 72%,
      #FFFFFF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter:
      drop-shadow(0 0 10px rgba(192, 132, 252, 0.75))
      drop-shadow(0 0 24px rgba(168, 85, 247, 0.55))
      drop-shadow(0 0 48px rgba(34, 211, 238, 0.25));
    padding: 0 0.04em;
  }
  .tl-accent::after {
    content: '';
    position: absolute;
    left: -4%;
    right: -4%;
    bottom: -5px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(34, 211, 238, 0) 0%,
      #22D3EE 18%,
      #A855F7 52%,
      #E9D5FF 100%);
    box-shadow:
      0 0 12px rgba(168, 85, 247, 1),
      0 0 26px rgba(192, 132, 252, 0.65);
  }
  .tl-dot {
    color: #FFFFFF;
    font-weight: 900;
    text-shadow:
      0 0 6px rgba(255, 255, 255, 1),
      0 0 14px rgba(192, 132, 252, 0.95),
      0 0 28px rgba(168, 85, 247, 0.6);
    margin-left: -2px;
  }

  /* ========== BOOSTER — BOMBE PREMIUM qui se désintègre ==========
     Cycle 8s, calé à la taille du logo SMMIA (110px) — BOOSTER ~140-150px desktop.

     Phases :
       0-35%   stable + micro-fissures qui respirent (SVG turbulence)
       35-40%  charge (brightness up, scale 1.04)
       40-42%  FLASH BLANC + SHOCKWAVE RING expansion
       42-55%  DISINTEGRATION : lettres éjectées 3D + burst de particules (box-shadow) + motion blur
       55-72%  DRIFT + gravité : particules continuent, dust cloud se dilate et fade
       72-82%  void (invisible)
       82-100% reformation fluide, lettres reviennent en Z
  */

  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.06em 0 0.04em;
    perspective: 1600px;
    transform-style: preserve-3d;
  }

  .booster-svg-defs {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* Halo néon violet permanent — enveloppe le mot, respire doucement */
  .booster-neon-halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 130%;
    height: 220%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(216, 180, 254, 0.35) 0%,
      rgba(168, 85, 247, 0.22) 30%,
      rgba(124, 58, 237, 0.12) 55%,
      transparent 75%);
    filter: blur(34px);
    transform: translate(-50%, -50%) scale(1);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: haloPulse 6s ease-in-out infinite;
  }
  @keyframes haloPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.85; }
    50%      { transform: translate(-50%, -50%) scale(1.08); opacity: 1;    }
  }

  /* Flash violet-blanc (pointe d'énergie à l'instant de la rupture) */
  .booster-flash {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140%;
    height: 260%;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      rgba(255, 255, 255, 1) 0%,
      rgba(243, 232, 255, 0.85) 14%,
      rgba(216, 180, 254, 0.65) 28%,
      rgba(168, 85, 247, 0.4) 48%,
      rgba(124, 58, 237, 0.18) 62%,
      transparent 75%);
    filter: blur(24px);
    transform: translate(-50%, -50%) scale(0.55);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterFlash 8s ease-out infinite;
  }
  @keyframes boosterFlash {
    0%, 38%  { opacity: 0;    transform: translate(-50%, -50%) scale(0.55); }
    41%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.15); }
    44%      { opacity: 0.7;  transform: translate(-50%, -50%) scale(1.6); }
    50%      { opacity: 0;    transform: translate(-50%, -50%) scale(2.0); }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scale(0.55); }
  }

  /* Shockwave ring — une seule onde violet néon qui s'expanse */
  .booster-shockwave {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30%;
    height: 160%;
    border-radius: 50%;
    border: 2px solid rgba(216, 180, 254, 0.95);
    box-shadow:
      0 0 32px rgba(192, 132, 252, 0.75),
      0 0 64px rgba(168, 85, 247, 0.45),
      inset 0 0 18px rgba(233, 213, 255, 0.5);
    transform: translate(-50%, -50%) scale(0.3);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterShock 8s cubic-bezier(0.2, 0.6, 0.3, 1) infinite;
  }
  @keyframes boosterShock {
    0%, 40%  { opacity: 0;    transform: translate(-50%, -50%) scale(0.3); border-width: 4px; }
    42%      { opacity: 1;    transform: translate(-50%, -50%) scale(0.5); border-width: 3px; }
    52%      { opacity: 0.4;  transform: translate(-50%, -50%) scale(2.8); border-width: 1px; }
    58%      { opacity: 0;    transform: translate(-50%, -50%) scale(3.8); border-width: 0.5px; }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scale(0.3); border-width: 4px; }
  }

  /* Dust cloud — nuage de poussière violet néon après l'explosion */
  .booster-dust {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 320%;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      rgba(233, 213, 255, 0.45) 0%,
      rgba(192, 132, 252, 0.32) 28%,
      rgba(168, 85, 247, 0.22) 50%,
      rgba(124, 58, 237, 0.1) 65%,
      transparent 78%);
    filter: blur(44px);
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: boosterDust 8s ease-out infinite;
  }
  @keyframes boosterDust {
    0%, 42%  { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
    50%      { opacity: 0.9; transform: translate(-50%, -50%) scale(1.1); }
    65%      { opacity: 0.5; transform: translate(-50%, -50%) scale(1.6); }
    78%      { opacity: 0; transform: translate(-50%, -50%) scale(2.0); }
    100%     { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
  }

  .booster-3d__word {
    position: relative;
    display: inline-flex;
    z-index: 2;
    filter: url(#crackDisplace);
  }

  /* Chaque lettre = tube néon BLANC bordé de violet néon (Inter 900)
     Pas de shadow sombre — glow violet néon uniquement pour un vrai effet verre lumineux */
  .boost-letter {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(62px, 10.5vw, 152px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    color: #FFFFFF;
    -webkit-text-stroke: 1px rgba(216, 180, 254, 0.7);
    text-shadow:
      /* core blanc intense (verre brillant) */
      0 0 4px rgba(255, 255, 255, 1),
      0 0 10px rgba(243, 232, 255, 0.95),
      /* halo néon violet en cascade (tube lumineux) */
      0 0 18px rgba(221, 214, 254, 0.95),
      0 0 32px rgba(192, 132, 252, 0.9),
      0 0 58px rgba(168, 85, 247, 0.8),
      0 0 96px rgba(139, 92, 246, 0.65),
      0 0 150px rgba(124, 58, 237, 0.45);
    transform-style: preserve-3d;
    padding: 0 0.02em;
  }

  /* GLYPH — visible 0-60%, disparaît instantanément au BANG (remplacé par les shards),
     void 60-90%, reforme fluide 90-100% */
  .boost-letter .glyph {
    display: inline-block;
    position: relative;
    z-index: 2;
    will-change: opacity, filter, transform;
    animation: glyphLife 7s cubic-bezier(0.3, 0.05, 0.2, 1) infinite;
    animation-delay: calc(var(--i, 0) * -0.02s);
  }
  @keyframes glyphLife {
    /* Phase stable 0-55% (lettre visible) */
    0%, 55%   { opacity: 1; filter: blur(0) brightness(1);   transform: scale(1); }
    /* Charge 55-60% (brightness up, léger scale) */
    58%       { opacity: 1; filter: blur(0) brightness(1.6); transform: scale(1.04); }
    60%       { opacity: 0; filter: blur(6px) brightness(2.4); transform: scale(1.12); }
    /* Void 60-90% — les shards prennent le relais */
    89%       { opacity: 0; filter: blur(0) brightness(1);   transform: scale(0.85); }
    /* Reform 90-100% — lettre revient */
    94%       { opacity: 1; filter: blur(0) brightness(1.2); transform: scale(1.03); }
    100%      { opacity: 1; filter: blur(0) brightness(1);   transform: scale(1); }
  }

  /* SHARD — chaque lettre a 6 fragments polygonaux (clip-path) qui sont
     des CLONES complets du glyph. Au BANG ils apparaissent assemblés (reconstituant
     visuellement la lettre), puis s'éjectent en 3D avec rotation + blur + fade.
     C'est le vrai effet "verre qui éclate". */
  .shard {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-block;
    font: inherit;
    color: inherit;
    -webkit-text-stroke: inherit;
    text-shadow: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    will-change: transform, opacity, filter;
    transform-origin: 50% 50%;
    animation: shardEject 7s cubic-bezier(0.22, 0.6, 0.3, 1) infinite;
    animation-delay: calc(var(--i, 0) * -0.02s);
  }

  /* 6 shards par lettre, chacun avec son clip-path polygon + trajectoire 3D unique.
     Les clip-paths découpent la lettre en fragments triangulaires / polygonaux
     qui s'imbriquent (comme un verre fracturé). */
  .shard.s1 {
    clip-path: polygon(0% 0%, 52% 0%, 34% 46%, 0% 58%);
    --dx: -138px; --dy:  -78px; --dz: 90px; --rz: -42deg;
  }
  .shard.s2 {
    clip-path: polygon(52% 0%, 100% 0%, 100% 42%, 66% 38%, 34% 46%);
    --dx:  112px; --dy:  -96px; --dz: 75px; --rz:  36deg;
  }
  .shard.s3 {
    clip-path: polygon(100% 42%, 100% 100%, 56% 100%, 60% 64%, 66% 38%);
    --dx:  138px; --dy:   32px; --dz: 100px; --rz:  48deg;
  }
  .shard.s4 {
    clip-path: polygon(0% 58%, 34% 46%, 46% 72%, 26% 100%, 0% 100%);
    --dx: -146px; --dy:   48px; --dz: 72px; --rz: -48deg;
  }
  .shard.s5 {
    clip-path: polygon(34% 46%, 66% 38%, 60% 64%, 46% 72%);
    --dx:  -28px; --dy:  118px; --dz: 55px; --rz:  18deg;
  }
  .shard.s6 {
    clip-path: polygon(46% 72%, 60% 64%, 56% 100%, 26% 100%);
    --dx:   62px; --dy:  132px; --dz: 82px; --rz: -32deg;
  }

  /* Éjection 3D des shards — 60% BANG, 60-84% projection, 84-90% void, 90-100% reform */
  @keyframes shardEject {
    0%, 58%  {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg);
      filter: blur(0);
    }
    /* 60% BANG — shards apparaissent TOUS assemblés (position 0) = lettre reconstituée */
    60%      {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg);
      filter: blur(0) brightness(1.6);
    }
    /* 66% — début projection (accélération) */
    66%      {
      opacity: 1;
      transform: translate3d(
          calc(var(--dx) * 0.28),
          calc(var(--dy) * 0.28),
          calc(var(--dz) * 0.5)
        )
        rotate3d(1, 0.4, 0.3, calc(var(--rz) * 0.3));
      filter: blur(0.5px);
    }
    /* 76% — projection max + rotation + blur (motion) */
    76%      {
      opacity: 0.88;
      transform: translate3d(
          calc(var(--dx) * 0.85),
          calc(var(--dy) * 0.85),
          var(--dz)
        )
        rotate3d(1, 0.4, 0.3, var(--rz));
      filter: blur(1.8px);
    }
    /* 84% — shards au loin, fade */
    84%      {
      opacity: 0;
      transform: translate3d(
          var(--dx),
          var(--dy),
          var(--dz)
        )
        rotate3d(1, 0.4, 0.3, calc(var(--rz) * 1.35));
      filter: blur(3.5px);
    }
    /* Void 84-93% — rien visible, shards déjà retournés à position 0 mais opacity 0 */
    88%, 93% {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg);
      filter: blur(0);
    }
    /* Reform éphémère 93-100% : les shards réapparaissent brièvement assemblés
       puis s'éteignent pendant que le glyph reprend le lead */
    94%      {
      opacity: 0.85;
      transform: translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg);
      filter: blur(0);
    }
    100%     {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg);
      filter: blur(0);
    }
  }

  /* Word container — permet tilt 3D interactif via CSS vars (--br-rx, --br-ry) */
  .booster-3d__word {
    transform: rotateX(var(--br-rx, 0deg)) rotateY(var(--br-ry, 0deg));
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Responsive — trajectoires shards réduites sur mobile */
  @media (max-width: 768px) {
    .boost-letter { font-size: clamp(54px, 13vw, 110px); }
    .shard.s1 { --dx:  -92px; --dy: -54px; --dz: 60px; }
    .shard.s2 { --dx:   76px; --dy: -66px; --dz: 52px; }
    .shard.s3 { --dx:   94px; --dy:  22px; --dz: 68px; }
    .shard.s4 { --dx: -100px; --dy:  32px; --dz: 50px; }
    .shard.s5 { --dx:  -18px; --dy:  80px; --dz: 38px; }
    .shard.s6 { --dx:   42px; --dy:  88px; --dz: 55px; }
  }
  @media (max-width: 480px) {
    .boost-letter {
      -webkit-text-stroke: 0.7px rgba(216, 180, 254, 0.6);
      text-shadow:
        0 0 3px rgba(255, 255, 255, 1),
        0 0 8px rgba(243, 232, 255, 0.9),
        0 0 14px rgba(192, 132, 252, 0.85),
        0 0 26px rgba(168, 85, 247, 0.7),
        0 0 52px rgba(139, 92, 246, 0.45);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .glyph, .shard,
    .booster-flash, .booster-shockwave, .booster-dust,
    .booster-neon-halo {
      animation: none;
    }
    .glyph { opacity: 1; transform: none; filter: none; }
    .shard { opacity: 0; }
    .booster-flash, .booster-shockwave, .booster-dust { opacity: 0; }
    .booster-neon-halo { opacity: 0.7; }
    .booster-3d__word { filter: none; transform: none; }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 700px; }
    .hero-inner { gap: 28px; }
    .brand-smmia { height: 95px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 560px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 72px; }
    .line-outline { -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.85); }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }

  /* ========== TILT 3D INTERACTIF sur BOOSTER ==========
     Le mot suit la souris : rotateX suivant Y curseur, rotateY suivant X curseur.
     Lerp doux + reset au mouseleave. */
  const boosterBox = document.querySelector<HTMLElement>('.booster-3d');
  const boosterWord = boosterBox?.querySelector<HTMLElement>('.booster-3d__word');

  if (boosterBox && boosterWord && !reduced) {
    let targetRx = 0, targetRy = 0;
    let currRx = 0, currRy = 0;
    let tiltRaf = 0;

    boosterBox.addEventListener('mousemove', (e: MouseEvent) => {
      const r = boosterBox.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width  - 0.5;
      const py = (e.clientY - r.top)  / r.height - 0.5;
      targetRy = px * 22;
      targetRx = -py * 14;
      if (!tiltRaf) tiltRaf = requestAnimationFrame(tiltLoop);
    });

    boosterBox.addEventListener('mouseleave', () => {
      targetRx = 0; targetRy = 0;
      if (!tiltRaf) tiltRaf = requestAnimationFrame(tiltLoop);
    });

    function tiltLoop() {
      currRx += (targetRx - currRx) * 0.12;
      currRy += (targetRy - currRy) * 0.12;
      boosterWord!.style.setProperty('--br-rx', `${currRx.toFixed(2)}deg`);
      boosterWord!.style.setProperty('--br-ry', `${currRy.toFixed(2)}deg`);
      if (Math.abs(targetRx - currRx) > 0.05 || Math.abs(targetRy - currRy) > 0.05) {
        tiltRaf = requestAnimationFrame(tiltLoop);
      } else { tiltRaf = 0; }
    }
  }
</script>
