---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Aurora multi-couches premium -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-blob a1"></div>
    <div class="aurora-blob a2"></div>
    <div class="aurora-blob a3"></div>
  </div>

  <!-- Halo violet diffus qui pulse -->
  <div class="hero-glow" aria-hidden="true"></div>

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain premium) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <div class="hero-inner">

    <!-- Logos SMMIA x PRIME avec parallaxe subtile -->
    <div class="hero-brands" id="heroBrands">

      <div class="brand-wrap brand-wrap-smmia" data-depth="0.5">
        <img src="/images/logos/SMMIA-logo-cropped.png" alt="SMMIA" class="brand-logo brand-smmia" />
      </div>

      <span class="brand-cross" aria-hidden="true" data-depth="1.0">
        <span class="cross-ring cross-ring-1"></span>
        <span class="cross-x">×</span>
      </span>

      <div class="brand-wrap brand-wrap-prime" data-depth="0.7">
        <img src="/images/logos/prime-logo-blanc.png" alt="Prime" class="brand-logo brand-prime" />
      </div>
    </div>

    <!-- Tagline principale -->
    <h1 class="hero-title">
      <span class="line-outline reveal" style="--d:0.15s">Tu vends.</span>
      <span class="line-fill reveal" style="--d:0.35s">
        Prime livre.
        <svg class="underline-svg" viewBox="0 0 400 22" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="ug" x1="0" x2="1">
              <stop offset="0%"   stop-color="#c4b5fd"/>
              <stop offset="50%"  stop-color="#a855f7"/>
              <stop offset="100%" stop-color="#7c3aed"/>
            </linearGradient>
          </defs>
          <path d="M 6 14 C 100 6, 200 18, 296 10 S 380 6, 394 14"
                fill="none"
                stroke="url(#ug)"
                stroke-width="6"
                stroke-linecap="round"/>
        </svg>
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>

  <!-- Scroll CTA premium -->
  <a href="#programme" class="hero-scroll-cta" aria-label="Découvrir le programme">
    <span class="scroll-text">Découvrir</span>
    <span class="scroll-mouse">
      <span class="scroll-wheel"></span>
    </span>
  </a>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 70px 24px 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 600px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
    transform-style: preserve-3d;
  }

  /* ===== ZONE LOGOS =====
     × DEAD-CENTER via absolute positioning.
     SMMIA & PRIME ancres a 50% avec margin symetrique → equidistants du ×.
  */
  .hero-brands {
    position: relative;
    display: block;
    height: 100px;
    width: 100%;
    margin: 0 auto;
  }

  /* × au centre géométrique exact (50%) */
  .brand-wrap-smmia {
    position: absolute;
    top: 50%;
    right: 50%;
    margin-right: 80px;
    transform: translateY(-50%) translate3d(var(--tx), var(--ty), 0);
  }

  .brand-wrap-prime {
    position: absolute;
    top: 50%;
    left: 50%;
    margin-left: 80px;
    transform: translateY(-50%) translate3d(var(--tx), var(--ty), 0);
  }


  .brand-wrap {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
  }

  .brand-wrap-prime {
    animation-delay: 0.3s;
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .brand-wrap:hover .brand-logo {
    transform: scale(1.06);
  }

  /* SMMIA = marque principale (recadree sans padding) */
  .brand-smmia {
    height: 100px;
    filter: drop-shadow(0 10px 35px rgba(168, 85, 247, 0.45));
  }

  /* PRIME = sous-marque, plus petit */
  .brand-prime {
    height: 65px;
    filter: drop-shadow(0 6px 20px rgba(168, 85, 247, 0.3));
  }

  .brand-wrap:hover .brand-smmia {
    filter: drop-shadow(0 20px 55px rgba(168, 85, 247, 0.85));
  }

  .brand-wrap:hover .brand-prime {
    filter: drop-shadow(0 14px 40px rgba(168, 85, 247, 0.7));
  }

  @keyframes brandEnter {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  /* ===== CROSS × au centre exact (50%) ===== */
  .brand-cross {
    --tx: 0px;
    --ty: 0px;
    position: absolute;
    top: 50%;
    left: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    transform: translate(-50%, -50%) translate3d(var(--tx), var(--ty), 0);
    opacity: 0;
    animation: crossEnter 0.9s cubic-bezier(0.2, 0.8, 0.2, 1) 0.55s forwards;
  }

  @keyframes crossEnter {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  .cross-ring {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .cross-ring-1 {
    inset: 0;
    border: 1px dashed rgba(168, 85, 247, 0.55);
    animation: ringSpin 16s linear infinite;
  }

  .cross-x {
    animation: xPulse 4s ease-in-out infinite;
  }

  @keyframes xPulse {
    0%, 100% { opacity: 0.9; text-shadow: 0 0 12px rgba(168, 85, 247, 0.5); }
    50%      { opacity: 1;   text-shadow: 0 0 22px rgba(168, 85, 247, 0.9); }
  }

  .cross-x {
    font-family: 'Inter', sans-serif;
    font-size: 26px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1;
    position: relative;
    z-index: 1;
    text-shadow: 0 0 16px rgba(168, 85, 247, 0.6);
  }

  @keyframes ringSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(180deg, #ffffff 0%, #e9d5ff 45%, #a855f7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ===== AURORA BLOBS (premium depth) ===== */
  .hero-aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.6;
    mix-blend-mode: screen;
    will-change: transform;
  }

  .aurora-blob.a1 {
    top: -15%;
    left: 10%;
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.7) 0%, transparent 65%);
    animation: auroraDrift1 18s ease-in-out infinite;
  }

  .aurora-blob.a2 {
    top: 20%;
    right: 5%;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(216, 180, 254, 0.5) 0%, transparent 65%);
    animation: auroraDrift2 22s ease-in-out infinite;
  }

  .aurora-blob.a3 {
    bottom: -20%;
    left: 40%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.55) 0%, transparent 70%);
    animation: auroraDrift3 26s ease-in-out infinite;
  }

  @keyframes auroraDrift1 {
    0%, 100% { transform: translate(0, 0)     scale(1);   }
    50%      { transform: translate(60px, 40px) scale(1.15); }
  }
  @keyframes auroraDrift2 {
    0%, 100% { transform: translate(0, 0)       scale(1);   }
    50%      { transform: translate(-80px, 30px) scale(1.1); }
  }
  @keyframes auroraDrift3 {
    0%, 100% { transform: translate(0, 0)       scale(1);   }
    50%      { transform: translate(40px, -50px) scale(1.2); }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 80%;
    max-width: 1200px;
    aspect-ratio: 2.5 / 1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.35), transparent 65%);
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
    will-change: opacity;
    animation: glowBreathe 10s ease-in-out infinite;
  }

  @keyframes glowBreathe {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1);   }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.08); }
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 60px 20px 90px; min-height: 500px; }
    .hero-brands { height: 140px; max-width: 720px; }
    .brand-wrap-smmia { margin-right: 56px; }
    .brand-wrap-prime { margin-left: 56px; }
    .brand-smmia { height: 140px; }
    .brand-prime { height: 48px; }
    .brand-cross { width: 50px; height: 50px; }
    .cross-x { font-size: 22px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 50px 16px 80px; min-height: 400px; }
    .hero-brands { height: 90px; max-width: 100%; }
    .brand-wrap-smmia { margin-right: 28px; }
    .brand-wrap-prime { margin-left: 28px; }
    .brand-smmia { height: 90px; }
    .brand-prime { height: 30px; }
    .brand-cross { width: 34px; height: 34px; }
    .cross-x { font-size: 15px; }
    .line-outline { -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.85); }
    .hero-scroll { bottom: 14px; }
    .hero-scroll-line { height: 30px; }
    .energy-line { height: 140px; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 40px 14px 70px; }
    .hero-brands { height: 72px; }
    .brand-wrap-smmia { margin-right: 20px; }
    .brand-wrap-prime { margin-left: 20px; }
    .brand-smmia { height: 72px; }
    .brand-prime { height: 24px; }
    .brand-cross { width: 28px; height: 28px; }
    .cross-x { font-size: 13px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .brand-wrap, .brand-cross, .reveal,
    .cross-ring-1, .hero-glow, .hero-scroll-line {
      animation: none;
    }
    .brand-wrap, .reveal { opacity: 1; transform: none; }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }
</script>
