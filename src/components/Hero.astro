---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">
        <span class="tl-kicker-bar" aria-hidden="true"></span>
        <span class="tl-kicker-text">Ton agence</span>
      </span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <!-- Halo néon violet enveloppant (énergie contenue) -->
        <span class="booster-neon-halo" aria-hidden="true"></span>

        <!-- SVG filter — fissures/displacement pour pré-explosion -->
        <svg class="booster-svg-defs" width="0" height="0" aria-hidden="true">
          <defs>
            <filter id="crackDisplace" x="-20%" y="-20%" width="140%" height="140%">
              <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="2" seed="4" result="noise">
                <animate attributeName="baseFrequency" values="0.015;0.08;0.015" dur="8s" repeatCount="indefinite"/>
              </feTurbulence>
              <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G">
                <animate attributeName="scale" values="0;0;0;22;0;0;0" keyTimes="0;0.32;0.37;0.42;0.5;0.9;1" dur="8s" repeatCount="indefinite"/>
              </feDisplacementMap>
            </filter>
          </defs>
        </svg>

        <!-- Flash blanc au moment de la rupture -->
        <span class="booster-flash" aria-hidden="true"></span>

        <!-- Shockwave ring (une seule onde, expanse radiale) -->
        <span class="booster-shockwave" aria-hidden="true"></span>

        <!-- Dust cloud post-explosion -->
        <span class="booster-dust" aria-hidden="true"></span>

        <!-- Mot splitté par lettre — chaque lettre explose en particules (box-shadow burst) -->
        <span class="booster-3d__word">
          <span class="boost-letter" style="--i:0">
            <span class="glyph">B</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:1">
            <span class="glyph">O</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:2">
            <span class="glyph">O</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:3">
            <span class="glyph">S</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:4">
            <span class="glyph">T</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:5">
            <span class="glyph">E</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
          <span class="boost-letter" style="--i:6">
            <span class="glyph">R</span>
            <span class="burst" aria-hidden="true"></span>
          </span>
        </span>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        <span class="tl-prefix">par l'</span><span class="tl-accent">IA</span><span class="tl-dot">.</span>
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: rgba(255, 255, 255, 0.88);
  }

  /* "Ton agence" — kicker éditorial avec barre néon gauche */
  .tl-line--top {
    margin-bottom: 0.15em;
    font-weight: 500;
    letter-spacing: 0.005em;
  }
  .tl-kicker-bar {
    display: inline-block;
    width: 34px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(192, 132, 252, 0) 0%,
      #C084FC 40%,
      #E9D5FF 100%);
    box-shadow:
      0 0 10px rgba(192, 132, 252, 0.85),
      0 0 22px rgba(168, 85, 247, 0.55);
    transform: translateY(1px);
    opacity: 0.9;
  }
  .tl-kicker-text {
    background: linear-gradient(90deg, #FFFFFF 0%, #F3E8FF 50%, #E9D5FF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 500;
  }

  /* "par l'IA." — IA en gradient néon + glow violet */
  .tl-line--bottom {
    margin-top: 0.25em;
    gap: 10px;
  }
  .tl-prefix {
    color: rgba(233, 213, 255, 0.72);
    font-weight: 400;
    letter-spacing: 0.005em;
    font-style: italic;
  }
  .tl-accent {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-style: normal;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg,
      #22D3EE 0%,
      #A855F7 45%,
      #C084FC 75%,
      #E9D5FF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 0 12px rgba(168, 85, 247, 0.55))
            drop-shadow(0 0 28px rgba(192, 132, 252, 0.35));
  }
  .tl-accent::after {
    content: '';
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: -4px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg,
      rgba(34, 211, 238, 0) 0%,
      #22D3EE 20%,
      #A855F7 55%,
      #E9D5FF 100%);
    box-shadow:
      0 0 10px rgba(168, 85, 247, 0.8),
      0 0 22px rgba(192, 132, 252, 0.5);
    opacity: 0.9;
  }
  .tl-dot {
    color: #C084FC;
    font-weight: 800;
    text-shadow:
      0 0 8px rgba(192, 132, 252, 0.9),
      0 0 18px rgba(168, 85, 247, 0.6);
    margin-left: -4px;
  }

  /* ========== BOOSTER — BOMBE PREMIUM qui se désintègre ==========
     Cycle 8s, calé à la taille du logo SMMIA (110px) — BOOSTER ~140-150px desktop.

     Phases :
       0-35%   stable + micro-fissures qui respirent (SVG turbulence)
       35-40%  charge (brightness up, scale 1.04)
       40-42%  FLASH BLANC + SHOCKWAVE RING expansion
       42-55%  DISINTEGRATION : lettres éjectées 3D + burst de particules (box-shadow) + motion blur
       55-72%  DRIFT + gravité : particules continuent, dust cloud se dilate et fade
       72-82%  void (invisible)
       82-100% reformation fluide, lettres reviennent en Z
  */

  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.06em 0 0.04em;
    perspective: 1600px;
    transform-style: preserve-3d;
  }

  .booster-svg-defs {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* Halo néon violet permanent — enveloppe le mot, respire doucement */
  .booster-neon-halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 130%;
    height: 220%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(216, 180, 254, 0.35) 0%,
      rgba(168, 85, 247, 0.22) 30%,
      rgba(124, 58, 237, 0.12) 55%,
      transparent 75%);
    filter: blur(34px);
    transform: translate(-50%, -50%) scale(1);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: haloPulse 6s ease-in-out infinite;
  }
  @keyframes haloPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.85; }
    50%      { transform: translate(-50%, -50%) scale(1.08); opacity: 1;    }
  }

  /* Flash violet-blanc (pointe d'énergie à l'instant de la rupture) */
  .booster-flash {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140%;
    height: 260%;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      rgba(255, 255, 255, 1) 0%,
      rgba(243, 232, 255, 0.85) 14%,
      rgba(216, 180, 254, 0.65) 28%,
      rgba(168, 85, 247, 0.4) 48%,
      rgba(124, 58, 237, 0.18) 62%,
      transparent 75%);
    filter: blur(24px);
    transform: translate(-50%, -50%) scale(0.55);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterFlash 8s ease-out infinite;
  }
  @keyframes boosterFlash {
    0%, 38%  { opacity: 0;    transform: translate(-50%, -50%) scale(0.55); }
    41%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.15); }
    44%      { opacity: 0.7;  transform: translate(-50%, -50%) scale(1.6); }
    50%      { opacity: 0;    transform: translate(-50%, -50%) scale(2.0); }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scale(0.55); }
  }

  /* Shockwave ring — une seule onde violet néon qui s'expanse */
  .booster-shockwave {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30%;
    height: 160%;
    border-radius: 50%;
    border: 2px solid rgba(216, 180, 254, 0.95);
    box-shadow:
      0 0 32px rgba(192, 132, 252, 0.75),
      0 0 64px rgba(168, 85, 247, 0.45),
      inset 0 0 18px rgba(233, 213, 255, 0.5);
    transform: translate(-50%, -50%) scale(0.3);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
    animation: boosterShock 8s cubic-bezier(0.2, 0.6, 0.3, 1) infinite;
  }
  @keyframes boosterShock {
    0%, 40%  { opacity: 0;    transform: translate(-50%, -50%) scale(0.3); border-width: 4px; }
    42%      { opacity: 1;    transform: translate(-50%, -50%) scale(0.5); border-width: 3px; }
    52%      { opacity: 0.4;  transform: translate(-50%, -50%) scale(2.8); border-width: 1px; }
    58%      { opacity: 0;    transform: translate(-50%, -50%) scale(3.8); border-width: 0.5px; }
    100%     { opacity: 0;    transform: translate(-50%, -50%) scale(0.3); border-width: 4px; }
  }

  /* Dust cloud — nuage de poussière violet néon après l'explosion */
  .booster-dust {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 320%;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      rgba(233, 213, 255, 0.45) 0%,
      rgba(192, 132, 252, 0.32) 28%,
      rgba(168, 85, 247, 0.22) 50%,
      rgba(124, 58, 237, 0.1) 65%,
      transparent 78%);
    filter: blur(44px);
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    animation: boosterDust 8s ease-out infinite;
  }
  @keyframes boosterDust {
    0%, 42%  { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
    50%      { opacity: 0.9; transform: translate(-50%, -50%) scale(1.1); }
    65%      { opacity: 0.5; transform: translate(-50%, -50%) scale(1.6); }
    78%      { opacity: 0; transform: translate(-50%, -50%) scale(2.0); }
    100%     { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
  }

  .booster-3d__word {
    position: relative;
    display: inline-flex;
    z-index: 2;
    filter: url(#crackDisplace);
  }

  /* Chaque lettre = tube néon violet (Inter 900) avec profondeur 3D douce */
  .boost-letter {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(62px, 10.5vw, 152px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    color: #FBF7FF;
    -webkit-text-stroke: 0.5px rgba(233, 213, 255, 0.55);
    text-shadow:
      /* relief 3D subtil (2 couches, pas 28) */
      0 1px 0 rgba(91, 33, 182, 0.95),
      0 2px 0 rgba(76, 29, 149, 0.75),
      0 3px 8px rgba(55, 18, 112, 0.55),
      /* halo néon tube (cascade de glow violet) */
      0 0 6px rgba(243, 232, 255, 0.9),
      0 0 14px rgba(216, 180, 254, 0.85),
