---
import FloatingBrandIcons from './FloatingBrandIcons.astro';
---

<section id="hero">

  <!-- Grille subtile -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Noise texture (grain) -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="subtle" seed={12} />

  <!-- Halo violet fixe derrière la tagline (pas pulsant) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Logo SMMIA seul (switch dark/light) -->
    <div class="hero-brand" data-depth="0.5">
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--dark" />
      <img src="/images/logos/nj.png" alt="SMMIA" class="brand-logo brand-smmia brand-smmia--light" />
    </div>

    <!-- Tagline principale : Ton agence BOOSTER par l'IA -->
    <h1 class="hero-title hero-title--solo">
      <span class="tl-line tl-line--top reveal" style="--d:0.15s">Ton agence</span>

      <span class="booster-3d reveal" style="--d:0.3s">
        <span class="booster-3d__word" data-text="BOOSTER">BOOSTER</span>
        <svg class="booster-3d__cracks" viewBox="0 0 400 120" preserveAspectRatio="none" aria-hidden="true">
          <!-- doublon glow violet décalé 1px = profondeur dans la fissure -->
          <g class="cracks-glow">
            <path class="crack crack--1" d="M 20 38 L 62 30 L 96 46 L 142 28 L 188 44 L 232 26 L 276 48 L 320 32 L 378 50"/>
            <path class="crack crack--2" d="M 28 84 L 72 94 L 118 78 L 166 92 L 218 80 L 268 96 L 318 82 L 372 94"/>
            <path class="crack crack--3" d="M 72 18 L 68 38 L 82 52 L 76 72"/>
            <path class="crack crack--4" d="M 186 62 L 192 78 L 180 92 L 196 108"/>
            <path class="crack crack--5" d="M 262 20 L 272 44 L 264 60 L 278 78"/>
            <path class="crack crack--6" d="M 340 24 L 334 48 L 346 64 L 338 84"/>
          </g>
          <!-- fissures principales noires -->
          <g class="cracks-main">
            <path class="crack crack--1" d="M 20 38 L 62 30 L 96 46 L 142 28 L 188 44 L 232 26 L 276 48 L 320 32 L 378 50"/>
            <path class="crack crack--2" d="M 28 84 L 72 94 L 118 78 L 166 92 L 218 80 L 268 96 L 318 82 L 372 94"/>
            <path class="crack crack--3" d="M 72 18 L 68 38 L 82 52 L 76 72"/>
            <path class="crack crack--4" d="M 186 62 L 192 78 L 180 92 L 196 108"/>
            <path class="crack crack--5" d="M 262 20 L 272 44 L 264 60 L 278 78"/>
            <path class="crack crack--6" d="M 340 24 L 334 48 L 346 64 L 338 84"/>
          </g>
        </svg>
      </span>

      <span class="tl-line tl-line--bottom reveal" style="--d:0.45s">
        par l'<span class="tl-accent">IA</span>.
      </span>
    </h1>

  </div>

  <!-- Fade vers le noir en bas -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  #hero {
    position: relative;
    width: 100%;
    background: #000;
    padding: 90px 24px 130px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    min-height: 800px;
    perspective: 1200px;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    transform-style: preserve-3d;
  }

  /* Spotlight violet fixe derrière la tagline */
  .hero-spotlight {
    position: absolute;
    top: 48%;
    left: 50%;
    width: 72%;
    max-width: 1000px;
    aspect-ratio: 3/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.28) 0%, rgba(139, 92, 246, 0.15) 35%, transparent 70%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  /* ===== EYEBROW badge session ===== */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 14px;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a855f7;
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
    animation: pulseDot 2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7); }
    50%      { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
  }
  .eyebrow-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== SOUS-PHRASE ===== */
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    /* taille adaptative : suffisamment petite en mobile pour que la phrase tienne sur une ligne */
    font-size: clamp(11px, 2.15vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
    max-width: none;
    margin: 0;
    letter-spacing: -0.005em;
    padding: 0 10px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  .sub-main {
    display: inline-block;
    white-space: nowrap;
  }
  /* "tourne seul." toujours ensemble */
  .nobr {
    white-space: nowrap;
  }
  .sub-accent {
    font-weight: 500;
    color: rgba(216, 180, 254, 0.85);
    font-size: 0.9em;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* ===== CTAs ===== */
  .hero-ctas {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 34px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.25) inset,
      0 8px 30px rgba(168, 85, 247, 0.38),
      0 2px 0 rgba(255, 255, 255, 0.08) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.35s ease;
    overflow: hidden;
  }
  .hero-cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .hero-cta-primary > * { position: relative; z-index: 1; }
  .hero-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.4) inset,
      0 14px 42px rgba(168, 85, 247, 0.6),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }
  .hero-cta-primary:hover::before { opacity: 1; }
  .cta-arrow {
    display: inline-flex;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-cta-primary:hover .cta-arrow { transform: translateX(4px); }

  .hero-cta-secondary {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(216, 180, 254, 0.85);
    text-decoration: none;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.4);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .hero-cta-secondary:hover {
    color: #fff;
    border-bottom-color: #a855f7;
  }


  /* ===== LOGO SMMIA seul ===== */
  .hero-brand {
    --tx: 0px;
    --ty: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    opacity: 0;
    animation: brandEnter 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
    transform: translate3d(var(--tx), var(--ty), 0);
  }

  .brand-logo {
    display: block;
    width: auto;
    object-fit: contain;
    transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  .hero-brand:hover .brand-logo {
    transform: scale(1.04);
  }

  .brand-smmia {
    height: 110px;
    filter: none;
  }

  .hero-brand:hover .brand-smmia {
    filter: none;
  }

  /* Switch logo dark / light — Astro style scoping forces global via :global() */
  .brand-smmia--light { display: none; }

  @keyframes brandEnter {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ===== TITRE PRINCIPAL ===== */
  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 112px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero-title--solo {
    font-size: clamp(34px, 5.5vw, 76px);
    letter-spacing: -0.03em;
    margin-top: -70px;
  }
  .hero-title--solo .line-fill { padding-bottom: 14px; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) var(--d, 0s) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .line-outline {
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: default;
    transition: -webkit-text-stroke 0.4s ease,
                transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    display: inline-block;
  }

  .line-outline:hover {
    -webkit-text-stroke: 2px rgba(216, 180, 254, 1);
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.55));
    transform: translateY(-2px);
  }

  .line-fill {
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 30%, #c4b5fd 60%, #a855f7 85%, #7c3aed 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 14px;
    cursor: default;
    filter: drop-shadow(0 4px 20px rgba(168, 85, 247, 0.25));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
  }

  .line-fill:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.55));
  }

  .underline-svg {
    position: absolute;
    left: 2%;
    right: 2%;
    bottom: -4px;
    width: 96%;
    height: 22px;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.6))
            drop-shadow(0 2px 12px rgba(168, 85, 247, 0.4));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease;
    transform-origin: center;
    transform: scaleX(1);
  }

  .underline-svg path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: drawLine 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .line-fill:hover .underline-svg {
    transform: scaleX(1.08);
    filter: drop-shadow(0 0 16px rgba(216, 180, 254, 0.9));
  }

  /* ========== TAGLINE : Ton agence BOOSTER par l'IA ========== */
  .tl-line {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: rgba(255, 255, 255, 0.82);
  }
  .tl-line--top    { margin-bottom: 0.1em; }
  .tl-line--bottom { margin-top: 0.05em; }
  .tl-accent {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    color: rgba(216, 180, 254, 0.95);
  }

  /* ========== BOOSTER 3D fissuré ========== */
  .booster-3d {
    position: relative;
    display: inline-block;
    line-height: 0.9;
    margin: 0.08em 0 0.04em;
    perspective: 800px;
  }

  .booster-3d__word {
    position: relative;
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-style: normal;
    font-size: clamp(80px, 16vw, 224px);
    line-height: 0.9;
    letter-spacing: -0.025em;
    /* Fill blanc → lavande → violet deep */
    background: linear-gradient(180deg,
      #FFFFFF 0%,
      #F3E8FF 28%,
      #D8B4FE 55%,
      #A855F7 85%,
      #7C3AED 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    /* Extrusion 3D : 2 ombres dures courtes + 1 ambient molle */
    filter:
      drop-shadow(0 2px 0 #7C3AED)
      drop-shadow(0 6px 0 #4C1D95)
      drop-shadow(0 14px 22px rgba(124, 58, 237, 0.45));
    transform: rotateX(4deg);
    transform-origin: 50% 80%;
    will-change: transform;
  }

  /* Bevel highlight : copie du texte légèrement translatée vers le haut avec fill blanc translucide */
  .booster-3d__word::before {
    content: attr(data-text);
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    font: inherit;
    letter-spacing: inherit;
    background: none;
    -webkit-background-clip: initial;
    background-clip: initial;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.3);
    pointer-events: none;
    z-index: 1;
  }

  /* Fissures SVG overlay */
  .booster-3d__cracks {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 3;
    transform: rotateX(4deg);
    transform-origin: 50% 80%;
  }

  /* Doublon glow violet : profondeur dans la fissure (simule lumière sortant) */
  .cracks-glow .crack {
    stroke: rgba(168, 85, 247, 0.7);
    stroke-width: 1px;
    fill: none;
    transform: translate(1px, 1.5px);
    filter: blur(0.5px);
  }
  /* Fissures principales noires */
  .cracks-main .crack {
    stroke: #000;
    stroke-width: 2.4px;
    stroke-linecap: butt;
    stroke-linejoin: miter;
    fill: none;
  }

  /* Animation : chaque crack se dessine en cascade */
  .crack {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: crackDraw 1s cubic-bezier(0.7, 0, 0.3, 1) forwards;
  }
  .cracks-main .crack--1, .cracks-glow .crack--1 { animation-delay: 1.4s; }
  .cracks-main .crack--2, .cracks-glow .crack--2 { animation-delay: 1.5s; }
  .cracks-main .crack--3, .cracks-glow .crack--3 { animation-delay: 1.58s; }
  .cracks-main .crack--4, .cracks-glow .crack--4 { animation-delay: 1.66s; }
  .cracks-main .crack--5, .cracks-glow .crack--5 { animation-delay: 1.74s; }
  .cracks-main .crack--6, .cracks-glow .crack--6 { animation-delay: 1.82s; }
  @keyframes crackDraw {
    to { stroke-dashoffset: 0; }
  }

  /* Micro-secousse quand la dernière fissure arrive (2.4s-2.52s) */
  .booster-3d__word {
    animation: microShake 0.16s ease-out 2.4s 1;
  }
  @keyframes microShake {
    0%   { transform: rotateX(4deg) translateX(0);    }
    25%  { transform: rotateX(4deg) translateX(2px);  }
    55%  { transform: rotateX(4deg) translateX(-2px); }
    80%  { transform: rotateX(4deg) translateX(1px);  }
    100% { transform: rotateX(4deg) translateX(0);    }
  }

  /* Responsive : fissures adaptent */
  @media (max-width: 768px) {
    .booster-3d__word { font-size: clamp(64px, 18vw, 120px); }
  }
  @media (max-width: 480px) {
    .booster-3d__word {
      filter:
        drop-shadow(0 2px 0 #7C3AED)
        drop-shadow(0 4px 0 #4C1D95)
        drop-shadow(0 10px 16px rgba(124, 58, 237, 0.45));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .booster-3d__word { animation: none; transform: rotateX(4deg); }
    .crack {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }
  }

  /* ===== NOISE TEXTURE ===== */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  /* ===== DECORATIONS BG ===== */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #000);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== SCROLL CTA PREMIUM ===== */
  .hero-scroll-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    opacity: 0;
    animation: ctaFadeIn 0.8s ease 1.2s forwards;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .hero-scroll-cta:hover { transform: translateX(-50%) translateY(-4px); }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.8);
    transition: color 0.3s ease;
  }
  .hero-scroll-cta:hover .scroll-text { color: #fff; }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid rgba(168, 85, 247, 0.7);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 7px;
    background: #a855f7;
    border-radius: 2px;
    animation: wheelScroll 1.8s ease-in-out infinite;
  }

  @keyframes wheelScroll {
    0%   { transform: translateY(0);  opacity: 1; }
    80%  { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0);  opacity: 0; }
  }

  @keyframes ctaFadeIn {
    to { opacity: 1; }
  }

  /* ===== TABLETTE ===== */
  @media (max-width: 1024px) {
    #hero { padding: 70px 20px 110px; min-height: 700px; }
    .hero-inner { gap: 28px; }
    .brand-smmia { height: 95px; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 640px) {
    #hero { padding: 60px 16px 100px; min-height: 560px; }
    .hero-inner { gap: 24px; }
    .brand-smmia { height: 72px; }
    .line-outline { -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.85); }
    .hero-cta-primary { padding: 15px 26px; font-size: 14px; }
    .eyebrow-text { font-size: 11px; letter-spacing: 0.14em; }
  }

  /* ===== PETIT MOBILE ===== */
  @media (max-width: 380px) {
    #hero { padding: 50px 14px 90px; }
    .brand-smmia { height: 58px; }
  }

  /* reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-brand, .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Parallaxe subtile sur les logos au deplacement du curseur
  const hero = document.querySelector<HTMLElement>('#hero');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !reduced) {
    const items = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId = 0;
    let tx = 0, ty = 0, cx = 0, cy = 0;

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
      ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    hero.addEventListener('mouseleave', () => {
      tx = 0; ty = 0;
      if (!rafId) rafId = requestAnimationFrame(loop);
    });

    function loop() {
      cx += (tx - cx) * 0.06;
      cy += (ty - cy) * 0.06;
      items.forEach((el) => {
        const d = parseFloat(el.dataset.depth || '1');
        el.style.setProperty('--tx', `${cx * 8 * d}px`);
        el.style.setProperty('--ty', `${cy * 5 * d}px`);
      });
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        rafId = requestAnimationFrame(loop);
      } else { rafId = 0; }
    }
  }
</script>
