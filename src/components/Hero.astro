---
---

<section id="hero">

  <!-- Banniere SMMIA x Focus -->
  <div class="hero-banner-wrap">
    <img
      src="/images/hero/banniere.png"
      alt="SMMIA × Focus"
      class="hero-banner"
    />
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse 100% 80% at 50% 40%, #1a0626 0%, #0a0012 60%, #000 100%);
    padding: 88px 16px 48px;
    overflow: hidden;
  }

  .hero-banner-wrap {
    width: 100%;
    max-width: 1400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-banner {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 80px rgba(168, 85, 247, 0.35));
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0.5;
  }

  .hero-scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(168, 85, 247, 0.8), transparent);
    margin: 0 auto;
  }

  /* Tablette */
  @media (max-width: 1024px) {
    #hero {
      min-height: 90vh;
      padding: 84px 16px 40px;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    #hero {
      min-height: 70vh;
      padding: 80px 12px 32px;
    }
    .hero-banner {
      filter: drop-shadow(0 10px 40px rgba(168, 85, 247, 0.35));
    }
    .hero-scroll {
      bottom: 20px;
    }
    .hero-scroll-line {
      height: 36px;
    }
  }

  /* Petit mobile */
  @media (max-width: 380px) {
    #hero {
      min-height: 60vh;
      padding: 76px 8px 24px;
    }
  }
</style>
