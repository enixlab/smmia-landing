---
---

<section id="hero" style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:68px;">

  <!-- Background image -->
  <div style="position:absolute;inset:0;z-index:0;">
    <img
      src="/images/hero/hero-arcane-v1.png"
      alt=""
      style="width:100%;height:100%;object-fit:cover;object-position:center top;"
      onerror="this.src='/images/hero/hero-openspace-v1.png';this.onerror=null;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.8) 60%, #000 100%);"></div>
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%, rgba(168,85,247,0.12), transparent 70%);"></div>
  </div>

  <!-- Content -->
  <div style="position:relative;z-index:1;text-align:center;padding:0 24px;">

    <!-- Logos SMMIA × Focus -->
    <div style="display:flex;align-items:center;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:56px;">
      <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" style="height:140px;width:auto;filter:drop-shadow(0 0 50px rgba(168,85,247,0.7));" />
      <span style="font-size:4rem;color:rgba(255,255,255,0.25);font-weight:300;">×</span>
      <img src="/images/logos/focus-logo-3d.png" alt="Focus" style="height:160px;width:auto;filter:drop-shadow(0 0 40px rgba(168,85,247,0.6)) brightness(1.1);" />
    </div>

  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:1;opacity:0.5;">
    <div style="width:1px;height:50px;background:linear-gradient(to bottom,rgba(168,85,247,0.8),transparent);margin:0 auto;"></div>
  </div>
</section>
