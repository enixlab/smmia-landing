---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

const pillars = [
  { id: "01", slug: "ia-quotidien",         title: "IA au quotidien",          sub: "Outils, robot, facturation — l'IA intégrée dans ton SMMA." },
  { id: "02", slug: "prospection-24-7",     title: "Prospection auto 24/7",    sub: "Emails, cold DM, scraping : les leads arrivent seuls." },
  { id: "04", slug: "high-ticket",          title: "High Ticket + Recurring",  sub: "Tickets premium 5K–20K + revenus mensuels récurrents." },
  { id: "03", slug: "automations-delivery", title: "Automations + Delivery IA",sub: "Closing, signature, livraison — le système tourne sans toi." },
  { id: "05", slug: "branding-flyers",      title: "Branding Design + Flyers IA", sub: "Visuels, identité, flyers — l'image qui vend." },
];
---

<section id="programme" class="prog-section">
  <BrandFloatingIcons icons={["Gemini", "Claude", "n8n", "TikTok"]} />
  <div class="prog-inner">

    <!-- Header -->
    <div class="prog-header">
      <h2 data-animate data-delay="0.05" class="prog-title">
        Ce que tu maîtrises en 2 mois
      </h2>
      <p data-animate data-delay="0.1" class="prog-sub">
        2 lives par semaine &middot; Replays inclus
      </p>
    </div>

  </div>

  <!-- Marquee piliers défilant -->
  <div class="pillars-marquee-wrap" data-animate data-delay="0.15">
    <div class="pillars-marquee-track">
      {[...pillars, ...pillars].map((p) => (
        <div class="pillar-card">
          <div class="pillar-media">
            <img
              src={`/images/programme/PILIER-${p.id}-${p.slug}.png?v=notext`}
              alt={p.title}
              loading="lazy"
            />
          </div>
          <div class="pillar-body">
            <h3 class="pillar-title">{p.title}</h3>
            <p class="pillar-sub">{p.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .prog-section {
    position: relative;
    overflow: hidden;
    padding: 120px 0 140px;
    background:
      radial-gradient(ellipse 70% 60% at 15% 50%, rgba(168,85,247,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 85% 50%, rgba(168,85,247,0.03) 0%, transparent 60%);
  }
  .prog-inner { position: relative; z-index: 2; }

  .prog-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Header ── */
  .prog-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .prog-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 100px;
    padding: 6px 16px;
    margin-bottom: 22px;
    font-size: 0.72rem;
    font-weight: 800;
    color: #C4B5FD;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.8);
    animation: blink 1.4s ease-in-out infinite;
  }

  .prog-title {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 14px;
    line-height: 1.08;
  }

  .prog-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.38);
    max-width: 420px;
    margin: 0 auto;
  }

  /* ── Marquee piliers défilant ── */
  .pillars-marquee-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    padding: 20px 0;
    z-index: 3; /* au-dessus des floating brand icons (.fbi-item z:1) */
  }
  .pillars-marquee-track {
    display: flex;
    gap: 28px;
    width: max-content;
    animation: pillars-marquee 28s linear infinite;
    will-change: transform;
  }
  .pillars-marquee-wrap:hover .pillars-marquee-track {
    animation-play-state: paused;
  }
  @keyframes pillars-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pillars-marquee-track { animation: none; }
  }

  .pillar-card {
    position: relative;
    flex: 0 0 auto;
    width: 680px;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(23, 10, 42, 0.55), rgba(10, 5, 16, 0.85));
    border: 1px solid rgba(168, 85, 247, 0.25);
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.3s ease,
                box-shadow 0.5s ease;
    box-shadow: 0 14px 48px rgba(0,0,0,0.4), 0 0 0 1px rgba(168,85,247,0.08) inset;
  }
  .pillar-card:hover {
    transform: translateY(-10px);
    border-color: rgba(168, 85, 247, 0.6);
    box-shadow: 0 26px 64px rgba(0,0,0,0.55), 0 16px 40px rgba(168, 85, 247, 0.4);
  }

  .pillar-media {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #06020F;
  }
  .pillar-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .pillar-card:hover .pillar-media img {
    transform: scale(1.04);
  }

  .pillar-body {
    padding: 26px 28px 28px;
  }
  .pillar-title {
    font-size: 1.38rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 10px;
  }
  .pillar-sub {
    font-size: 0.98rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .pillar-card { width: 560px; }
    .pillars-marquee-track { gap: 22px; animation-duration: 24s; }
    .pillar-title { font-size: 1.24rem; }
  }
  @media (max-width: 768px) {
    .prog-inner { padding: 0 16px; }
    .prog-section { padding: 80px 0 100px; }
    .pillar-card { width: 440px; }
    .pillars-marquee-track { gap: 18px; animation-duration: 22s; }
    .pillar-body { padding: 20px 22px 22px; }
    .pillar-title { font-size: 1.1rem; }
    .pillar-sub { font-size: 0.88rem; }
  }
  @media (max-width: 520px) {
    .pillar-card { width: 330px; }
    .pillars-marquee-track { gap: 14px; animation-duration: 18s; }
  }
</style>
