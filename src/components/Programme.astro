---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

const pillars = [
  { id: "01", slug: "technique-ia",   title: "Technique IA",            sub: "Outils, agents, workflows maîtrisés." },
  { id: "02", slug: "agence-saas",    title: "Agence / SaaS Prime",     sub: "Ton agence IA opérationnelle." },
  { id: "03", slug: "closing-vente",  title: "Closing / Vente",         sub: "Des prospects qui signent." },
  { id: "04", slug: "high-ticket",    title: "High Ticket / Recurring", sub: "Tarifs premium. Revenus récurrents." },
];
---

<section id="programme" class="prog-section">
  <BrandFloatingIcons icons={["Gemini", "Claude", "n8n", "TikTok"]} />
  <div class="prog-inner">

    <!-- Header -->
    <div class="prog-header">
      <div data-animate class="prog-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>Programme — 2 mois</span>
      </div>
      <h2 data-animate data-delay="0.05" class="prog-title">
        Ce que tu maîtrises en 2 mois
      </h2>
      <p data-animate data-delay="0.1" class="prog-sub">
        2 lives par semaine &middot; Replays inclus
      </p>
    </div>

    <!-- 4 Piliers -->
    <div class="pillars-grid" data-animate data-delay="0.15">
      {pillars.map((p, i) => (
        <div class="pillar-card" data-animate data-delay={0.2 + i * 0.08}>
          <div class="pillar-media">
            <img
              src={`/images/programme/PILIER-${p.id}-${p.slug}.png?v=2`}
              alt={p.title}
              loading="lazy"
            />
          </div>
          <div class="pillar-body">
            <h3 class="pillar-title">{p.title}</h3>
            <p class="pillar-sub">{p.sub}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .prog-section {
    position: relative;
    overflow: hidden;
    padding: 120px 0 140px;
    background:
      radial-gradient(ellipse 70% 60% at 15% 50%, rgba(168,85,247,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 85% 50%, rgba(168,85,247,0.03) 0%, transparent 60%);
  }
  .prog-inner { position: relative; z-index: 2; }

  .prog-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Header ── */
  .prog-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .prog-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 100px;
    padding: 6px 16px;
    margin-bottom: 22px;
    font-size: 0.72rem;
    font-weight: 800;
    color: #C4B5FD;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.8);
    animation: blink 1.4s ease-in-out infinite;
  }

  .prog-title {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 14px;
    line-height: 1.08;
  }

  .prog-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.38);
    max-width: 420px;
    margin: 0 auto;
  }

  /* ── 4 Piliers Grid ── */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .pillar-card {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(23, 10, 42, 0.5), rgba(10, 5, 16, 0.8));
    border: 1px solid rgba(168, 85, 247, 0.22);
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.3s ease,
                box-shadow 0.5s ease;
    box-shadow: 0 10px 40px rgba(0,0,0,0.35);
  }
  .pillar-card:hover {
    transform: translateY(-8px);
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 20px 54px rgba(0,0,0,0.5), 0 10px 32px rgba(168, 85, 247, 0.3);
  }

  .pillar-media {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #06020F;
  }
  .pillar-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .pillar-card:hover .pillar-media img {
    transform: scale(1.05);
  }

  .pillar-body {
    padding: 20px 20px 22px;
  }
  .pillar-title {
    font-size: 1.12rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  .pillar-sub {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.58);
    line-height: 1.45;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .pillars-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
  }
  @media (max-width: 768px) {
    .prog-inner { padding: 0 16px; }
    .prog-section { padding: 80px 0 100px; }
    .pillar-body { padding: 16px 18px 18px; }
    .pillar-title { font-size: 1.02rem; }
    .pillar-sub { font-size: 0.82rem; }
  }
  @media (max-width: 520px) {
    .pillars-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
