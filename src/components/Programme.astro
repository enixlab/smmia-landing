---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

const lives = Array.from({ length: 25 }, (_, i) =>
  `LIVE-${String(i + 1).padStart(2, '0')}.png`
);
---

<section id="programme" class="prog-section">
  <BrandFloatingIcons icons={["Gemini", "Claude", "n8n", "TikTok"]} />
  <div class="prog-inner">

    <!-- Header -->
    <div class="prog-header">
      <div data-animate class="prog-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>Programme — 2 mois</span>
      </div>
      <h2 data-animate data-delay="0.05" class="prog-title">
        Ce que tu maîtrises en 2 mois
      </h2>
      <p data-animate data-delay="0.1" class="prog-sub">
        2 lives par semaine &middot; Replays inclus &middot; 100% actionnable
      </p>
    </div>

    <!-- Main Preview -->
    <div class="main-preview" data-animate data-delay="0.15">
      <img
        id="preview-img"
        src={`/images/lives/${lives[0]}`}
        alt="Live aperçu"
      />
      <button class="arrow arrow--prev" id="arrow-prev" aria-label="Précédent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="arrow arrow--next" id="arrow-next" aria-label="Suivant">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Thumbnail Strip -->
    <div class="strip-wrap" data-animate data-delay="0.2">
      <div class="thumb-strip" id="thumb-strip">
        {lives.map((file, i) => (
          <button
            class={`thumb${i === 0 ? ' thumb--active' : ''}`}
            data-src={`/images/lives/${file}`}
            data-index={i}
            aria-label={`Live ${i + 1}`}
          >
            <img src={`/images/lives/${file}`} alt="" loading="lazy" />
            <span class="thumb-num">{String(i + 1).padStart(2, '0')}</span>
          </button>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .prog-section {
    position: relative;
    overflow: hidden;
    padding: 120px 0 140px;
    background:
      radial-gradient(ellipse 70% 60% at 15% 50%, rgba(168,85,247,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 85% 50%, rgba(168,85,247,0.03) 0%, transparent 60%);
    content-visibility: auto;
    contain-intrinsic-size: 1400px;
  }
  .prog-inner { position: relative; z-index: 2; }

  .prog-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Header ── */
  .prog-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .prog-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 100px;
    padding: 6px 16px;
    margin-bottom: 22px;
    font-size: 0.72rem;
    font-weight: 800;
    color: #C4B5FD;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.8);
    animation: blink 1.4s ease-in-out infinite;
  }

  .prog-title {
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 14px;
    line-height: 1.08;
  }

  .prog-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.38);
    max-width: 420px;
    margin: 0 auto;
  }

  /* ── Main Preview ── */
  .main-preview {
    border-radius: 20px;
    overflow: hidden;
    border: 1.5px solid rgba(168,85,247,0.35);
    box-shadow: 0 0 60px rgba(168,85,247,0.15), 0 0 120px rgba(168,85,247,0.06);
    margin-bottom: 16px;
    aspect-ratio: 16/9;
    background: #0a0510;
    position: relative;
  }

  .main-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }

  .main-preview img.fade {
    opacity: 0;
  }

  /* ── Arrows on preview ── */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    border: 1.5px solid rgba(168,85,247,0.4);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    backdrop-filter: blur(6px);
  }
  .arrow:hover {
    background: rgba(168,85,247,0.3);
    border-color: #A855F7;
    transform: translateY(-50%) scale(1.08);
  }
  .arrow--prev { left: 16px; }
  .arrow--next { right: 16px; }
  .arrow:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
  }

  /* ── Thumbnail Strip ── */
  .strip-wrap {
    position: relative;
  }

  .thumb-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 4px 2px;
  }
  .thumb-strip::-webkit-scrollbar { display: none; }

  .thumb {
    flex: 0 0 auto;
    width: calc((100% - 240px) / 25);
    min-width: 70px;
    max-width: 100px;
    aspect-ratio: 16/9;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.07);
    background: #0a0510;
    cursor: pointer;
    padding: 0;
    position: relative;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .thumb:hover {
    border-color: rgba(168,85,247,0.45);
    transform: translateY(-2px);
  }
  .thumb--active {
    border-color: #A855F7 !important;
    box-shadow: 0 0 16px rgba(168,85,247,0.5);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-num {
    position: absolute;
    bottom: 4px;
    right: 6px;
    font-size: 0.6rem;
    font-weight: 800;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.05em;
    line-height: 1;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }
  .thumb--active .thumb-num {
    color: rgba(168,85,247,0.9);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .prog-inner { padding: 0 16px; }
    .prog-section { padding: 80px 0 100px; }
    .thumb {
      min-width: 70px;
    }
  }
</style>

<script>
  const preview = document.getElementById('preview-img') as HTMLImageElement;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.thumb');
  const btnPrev = document.getElementById('arrow-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('arrow-next') as HTMLButtonElement;
  let current = 0;
  const total = thumbs.length;

  function goTo(index: number) {
    if (index < 0 || index >= total) return;
    current = index;
    const thumb = thumbs[current];
    const src = thumb.dataset.src!;
    preview.classList.add('fade');
    setTimeout(() => {
      preview.src = src;
      preview.onload = () => preview.classList.remove('fade');
    }, 150);
    thumbs.forEach(t => t.classList.remove('thumb--active'));
    thumb.classList.add('thumb--active');
    thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    btnPrev.disabled = current === 0;
    btnNext.disabled = current === total - 1;
  }

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener('click', () => goTo(i));
  });

  btnPrev.addEventListener('click', () => goTo(current - 1));
  btnNext.addEventListener('click', () => goTo(current + 1));

  // init state
  btnPrev.disabled = true;
</script>
