---
// FloatingBrandIcons — éléments flottants premium avec logos marketing/IA/SMMA
// Variants: 'dense' (8 icônes), 'medium' (6 icônes), 'subtle' (4 icônes)
// Toutes les icônes sont en gradient violet, blur glow, animations float + rotate

interface Props {
  variant?: 'dense' | 'medium' | 'subtle';
  seed?: number; // Pour varier les positions selon la section
}

const { variant = 'medium', seed = 0 } = Astro.props;

const allIcons = [
  { src: '/images/brand-icons/claude.png',  alt: 'Claude' },
  { src: '/images/brand-icons/gemini.png',  alt: 'Gemini' },
  { src: '/images/brand-icons/stripe.png',  alt: 'Stripe' },
  { src: '/images/brand-icons/shopify.png', alt: 'Shopify' },
];

// 4 positions stratégiques — bien espacées autour du contenu central
// Haut-gauche / Haut-droite / Bas-gauche / Bas-droite, plus loin des bords
const positions = [
  { top: '18%', left: '12%', size: 68, delay: 0,   duration: 14, rot: -8 },
  { top: '22%', left: '88%', size: 62, delay: 1.4, duration: 16, rot: 12 },
  { top: '72%', left: '10%', size: 64, delay: 2.2, duration: 15, rot: -10 },
  { top: '68%', left: '90%', size: 66, delay: 0.7, duration: 17, rot: 9  },
];

// Toujours 4 icones (Claude, Gemini, Stripe, Shopify)
const count = 4;

const selected = positions.slice(0, count).map((pos, i) => {
  const iconIndex = (i + seed) % allIcons.length;
  return { ...pos, ...allIcons[iconIndex] };
});
---

<div class="fbi-layer" aria-hidden="true">
  {selected.map((item) => (
    <div
      class="fbi-item"
      style={`top:${item.top}; left:${item.left}; --size:${item.size}px; --delay:${item.delay}s; --duration:${item.duration}s; --rot:${item.rot}deg;`}
    >
      <div class="fbi-ring"></div>
      <div class="fbi-glow"></div>
      <img src={item.src} alt={item.alt} class="fbi-img" loading="lazy" />
      <span class="fbi-label">{item.alt}</span>
    </div>
  ))}
</div>

<style>
  .fbi-layer {
    position: absolute;
    inset: 0;
    pointer-events: none; /* le layer laisse passer, mais les items sont interactifs */
    overflow: hidden;
    z-index: 0;
  }

  .fbi-item {
    position: absolute;
    width: var(--size);
    height: var(--size);
    transform: translate(-50%, -50%);
    animation: fbi-float var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
    will-change: transform;
    pointer-events: auto;
    cursor: pointer;
    transition: filter 0.4s ease;
  }

  .fbi-item:hover .fbi-img {
    transform: scale(1.25) rotate(0deg);
    opacity: 1;
    filter: drop-shadow(0 12px 32px rgba(168, 85, 247, 0.85));
  }

  .fbi-item:hover .fbi-glow {
    opacity: 1;
    transform: scale(1.6);
  }

  .fbi-glow {
    position: absolute;
    inset: -30%;
    background: radial-gradient(
      circle at center,
      rgba(168, 85, 247, 0.4) 0%,
      rgba(192, 132, 252, 0.2) 40%,
      transparent 70%
    );
    filter: blur(10px);
    z-index: 0;
    animation: fbi-pulse 4s ease-in-out infinite;
    animation-delay: var(--delay);
    will-change: auto;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .fbi-img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 2;
    opacity: 0.85;
    filter: drop-shadow(0 6px 18px rgba(168, 85, 247, 0.45));
    animation: fbi-rotate var(--duration) linear infinite;
    animation-delay: var(--delay);
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease,
                opacity 0.3s ease;
  }

  /* Ring UI/UX : anneau qui apparait au hover */
  .fbi-ring {
    position: absolute;
    inset: -18%;
    border-radius: 50%;
    border: 1.5px solid rgba(168, 85, 247, 0.5);
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 1;
    pointer-events: none;
  }

  .fbi-item:hover .fbi-ring {
    opacity: 1;
    transform: scale(1);
  }

  /* Tooltip label UI/UX */
  .fbi-label {
    position: absolute;
    left: 50%;
    top: calc(100% + 10px);
    transform: translateX(-50%) translateY(6px);
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.95);
    background: rgba(20, 10, 30, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(168, 85, 247, 0.35);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 3;
  }

  .fbi-item:hover .fbi-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes fbi-float {
    0%, 100% {
      transform: translate(-50%, -50%) translateY(0);
    }
    50% {
      transform: translate(-50%, -50%) translateY(-22px);
    }
  }

  @keyframes fbi-rotate {
    0% { transform: rotate(0deg); }
    50% { transform: rotate(var(--rot)); }
    100% { transform: rotate(0deg); }
  }

  @keyframes fbi-pulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.15); }
  }

  /* Tablette : icônes plus petites */
  @media (max-width: 1024px) {
    .fbi-item {
      width: calc(var(--size) * 0.78);
      height: calc(var(--size) * 0.78);
    }
  }

  /* Mobile : très réduites, opacité moindre, pas trop chargé */
  @media (max-width: 640px) {
    .fbi-item {
      width: calc(var(--size) * 0.55);
      height: calc(var(--size) * 0.55);
    }
    .fbi-img {
      opacity: 0.7;
    }
    .fbi-glow {
      filter: blur(14px);
    }
    /* On masque les icônes du milieu sur mobile pour ne pas gêner le contenu */
    .fbi-item:nth-child(n+5) {
      display: none;
    }
  }

  /* Reduced motion : on coupe tout */
  @media (prefers-reduced-motion: reduce) {
    .fbi-item,
    .fbi-img,
    .fbi-glow {
      animation: none !important;
    }
  }
</style>
