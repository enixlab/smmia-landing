---
// BrandFloatingIcons — icônes brand 3D interactives
// Positionnées en absolute dans la section parente (doit être position:relative + overflow:hidden)
// Hover = zoom + glow + label ; Click = label épinglé

interface Props {
  icons: string[]; // alt names à afficher, dans l'ordre des positions (top-left, top-right, middle-left, middle-right, [bottom-left, bottom-right])
}

const { icons } = Astro.props;

const pool: Record<string, { src: string; alt: string }> = {
  Claude:   { src: '/images/brand-icons/claude.png',   alt: 'Claude'   },
  Gemini:   { src: '/images/brand-icons/gemini.png',   alt: 'Gemini'   },
  Shopify:  { src: '/images/brand-icons/shopify.png',  alt: 'Shopify'  },
  Stripe:   { src: '/images/brand-icons/stripe.png',   alt: 'Stripe'   },
  n8n:      { src: '/images/brand-icons/n8n.png',      alt: 'n8n'      },
  TikTok:   { src: '/images/brand-icons/tiktok.png',   alt: 'TikTok'   },
  YouTube:  { src: '/images/brand-icons/youtube.png',  alt: 'YouTube'  },
  Facebook: { src: '/images/brand-icons/facebook.png', alt: 'Facebook' },
  Sparkle:  { src: '/images/brand-icons/sparkle.png',  alt: 'Sparkle'  },
};

// 6 positions sur les bords — contenu central libre
const positions = [
  { top: '12%', left: '4%',  size: 56, delay: 0,   duration: 14, rot: -8 },
  { top: '18%', left: '95%', size: 52, delay: 1.4, duration: 16, rot: 10 },
  { top: '48%', left: '3%',  size: 58, delay: 2.2, duration: 15, rot: -9 },
  { top: '52%', left: '96%', size: 54, delay: 0.7, duration: 17, rot: 9  },
  { top: '84%', left: '5%',  size: 50, delay: 3.0, duration: 13, rot: 7  },
  { top: '82%', left: '94%', size: 52, delay: 1.9, duration: 18, rot: -11 },
];

const items = icons
  .map((name, i) => {
    const icon = pool[name];
    const pos = positions[i];
    return icon && pos ? { ...pos, ...icon } : null;
  })
  .filter(Boolean) as Array<typeof positions[0] & { src: string; alt: string }>;
---

<div class="bfi-layer" aria-hidden="true">
  {items.map((item) => (
    <button
      type="button"
      class="bfi-item"
      style={`top:${item.top}; left:${item.left}; --size:${item.size}px; --delay:${item.delay}s; --duration:${item.duration}s; --rot:${item.rot}deg;`}
      aria-label={item.alt}
    >
      <span class="bfi-ring"></span>
      <span class="bfi-glow"></span>
      <img src={item.src} alt={item.alt} class="bfi-img" loading="lazy" />
      <span class="bfi-label">{item.alt}</span>
    </button>
  ))}
</div>

<style>
  .bfi-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1; /* au-dessus des backgrounds décoratifs (z<=1), sous le contenu (z=2+) */
  }

  .bfi-item {
    position: absolute;
    width: var(--size);
    height: var(--size);
    transform: translate(-50%, -50%);
    animation: bfi-float var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
    will-change: transform;
    pointer-events: auto;
    cursor: pointer;
    background: transparent;
    border: 0;
    padding: 0;
    transition: filter 0.4s ease;
  }

  .bfi-item:hover .bfi-img,
  .bfi-item.active .bfi-img {
    transform: scale(1.28) rotate(0deg);
    opacity: 1;
    filter: drop-shadow(0 12px 32px rgba(168, 85, 247, 0.85));
  }

  .bfi-item:hover .bfi-glow,
  .bfi-item.active .bfi-glow {
    opacity: 1;
    transform: scale(1.6);
  }

  .bfi-glow {
    position: absolute;
    inset: -30%;
    background: radial-gradient(
      circle at center,
      rgba(168, 85, 247, 0.45) 0%,
      rgba(192, 132, 252, 0.22) 40%,
      transparent 70%
    );
    filter: blur(12px);
    z-index: 0;
    opacity: 0.55;
    animation: bfi-pulse 4s ease-in-out infinite;
    animation-delay: var(--delay);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .bfi-img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 2;
    opacity: 0.85;
    filter: drop-shadow(0 6px 18px rgba(168, 85, 247, 0.45));
    animation: bfi-rotate var(--duration) linear infinite;
    animation-delay: var(--delay);
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.4s ease,
                opacity 0.3s ease;
    pointer-events: none;
  }

  .bfi-ring {
    position: absolute;
    inset: -18%;
    border-radius: 50%;
    border: 1.5px solid rgba(168, 85, 247, 0.5);
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 1;
    pointer-events: none;
  }

  .bfi-item:hover .bfi-ring,
  .bfi-item.active .bfi-ring {
    opacity: 1;
    transform: scale(1);
  }

  .bfi-label {
    position: absolute;
    left: 50%;
    top: calc(100% + 10px);
    transform: translateX(-50%) translateY(6px);
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(216, 180, 254, 0.95);
    background: rgba(20, 10, 30, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(168, 85, 247, 0.35);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 3;
  }

  .bfi-item:hover .bfi-label,
  .bfi-item.active .bfi-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes bfi-float {
    0%, 100% { transform: translate(-50%, -50%) translateY(0); }
    50%      { transform: translate(-50%, -50%) translateY(-20px); }
  }

  @keyframes bfi-rotate {
    0%   { transform: rotate(0deg); }
    50%  { transform: rotate(var(--rot)); }
    100% { transform: rotate(0deg); }
  }

  @keyframes bfi-pulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%      { opacity: 0.85; transform: scale(1.15); }
  }

  /* Tablette : icônes plus petites + opacité réduite (restent derrière le contenu grâce à z-index 1) */
  @media (max-width: 1024px) {
    .bfi-item { width: calc(var(--size) * 0.6); height: calc(var(--size) * 0.6); }
    .bfi-img  { opacity: 0.35; }
  }

  /* Mobile : encore plus petites et plus transparentes, uniquement sur les bords */
  @media (max-width: 640px) {
    .bfi-item { width: calc(var(--size) * 0.45); height: calc(var(--size) * 0.45); }
    .bfi-img  { opacity: 0.22; }
    /* On garde seulement les 2 icônes du haut (top-left + top-right) pour aérer */
    .bfi-item:nth-child(n+3) { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bfi-item, .bfi-img, .bfi-glow { animation: none !important; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.bfi-item').forEach((item) => {
    item.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasActive = item.classList.contains('active');
      document.querySelectorAll('.bfi-item.active').forEach((el) => el.classList.remove('active'));
      if (!wasActive) item.classList.add('active');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.bfi-item.active').forEach((el) => el.classList.remove('active'));
  });
</script>
