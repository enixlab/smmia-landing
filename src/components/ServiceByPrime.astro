---
import FloatingBrandIcons from './FloatingBrandIcons.astro';

const services = [
  "09-avis-google-PORTRAIT.png",
  "24-gmb-SQUARE.png",
  "01-tiktok-certif-SQUARE.png",
  "21-e-reputation-SQUARE.png",
  "02-snapchat-certif-SQUARE.png",
  "11-visuels-WIDE.jpeg",
  "14-ugc-ia-PORTRAIT.jpeg",
  "10-flyers-SQUARE.png",
  "06-videos-montages-WIDE.png",
  "12-sites-web-WIDE.png",
  "08-landing-pages-SQUARE.png",
  "19-seo-SQUARE.png",
  "15-campagnes-ads-WIDE.png",
  "20-audit-SQUARE.png",
  "05-generation-leads-WIDE.png",
  "07-apple-wallet-PORTRAIT.png",
  "04-chatbot-sav-SQUARE.png",
  "13-nfc-PORTRAIT.png",
  "03-sms-mail-SQUARE.png",
  "16-crm-PORTRAIT.png",
  "17-whatsapp-SQUARE.png",
  "18-scrapping-SQUARE.png",
  "25-underground-WIDE.png",
  "22-osint-PORTRAIT.png",
  "23-creation-societe-PORTRAIT.png",
];

const row1 = services.filter((_, i) => i % 2 === 0);
const row2 = services.filter((_, i) => i % 2 === 1);
---

<section id="prime" class="prime-section">

  <!-- Pattern de fond subtil -->
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-vignette" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <FloatingBrandIcons variant="medium" seed={4} />

  <div class="prime-inner">
    <!-- Header premium -->
    <div class="prime-header">

      <!-- Badge animé -->
      <div class="badge" data-animate>
        <span class="badge-dot"></span>
        Exclusif membres SMMIA
      </div>

      <!-- Co-branding : wrappers meme hauteur = meme ligne + lettres meme taille -->
      <div class="cobrand" data-animate data-delay="0.08">
        <div class="logo-box logo-box-smmia">
          <img
            src="/images/logos/SMMIA-logo-transparent-v2.png"
            alt="SMMIA"
          />
        </div>
        <div class="cobrand-x" aria-hidden="true">
          <span class="x-mark">×</span>
          <svg class="x-orbit" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="44" />
          </svg>
        </div>
        <div class="logo-box logo-box-prime">
          <img
            src="/images/logos/prime-logo-blanc.png"
            alt="Prime"
          />
        </div>
      </div>

      <!-- Headline dramatique -->
      <h2 class="headline" data-animate data-delay="0.16">
        <span class="line line-1"><span class="outline">Tu vends.</span></span>
        <span class="line line-2">
          <span class="line-2-text">Prime livre.</span>
          <svg class="underline" viewBox="0 0 400 16" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 11 Q 100 2, 200 8 T 398 6" fill="none" stroke="url(#ug)" stroke-width="4" stroke-linecap="round"/>
            <defs>
              <linearGradient id="ug" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#C084FC"/>
                <stop offset="50%" stop-color="#A855F7"/>
                <stop offset="100%" stop-color="#6D28D9"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h2>

      <!-- Subheader punchy -->
      <p class="sub" data-animate data-delay="0.22">
        Accède à l'agence Prime à des tarifs imbattables. <strong>Tu closes, on livre.</strong>
      </p>

      <!-- Stats strip -->
      <div class="stats" data-animate data-delay="0.3">
        <div class="stat">
          <div class="stat-value" data-count="25">25</div>
          <div class="stat-label">services</div>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat">
          <div class="stat-value">72h</div>
          <div class="stat-label">livraison</div>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat">
          <div class="stat-value">-70%</div>
          <div class="stat-label">vs agence</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Croix diagonale (X) premium -->
  <div class="cross-stage">

    <!-- Spotlight multi-couches au centre -->
    <div class="spot spot-core" aria-hidden="true"></div>
    <div class="spot spot-halo" aria-hidden="true"></div>

    <!-- Bande 1 : diagonale /  -->
    <div class="band band-1">
      <div class="track track-1">
        {[...row1, ...row1, ...row1].map((file) => (
          <div class="tile" data-tilt>
            <img src={`/images/services-cards/${file}`} alt="" loading="lazy" />
            <div class="tile-sheen" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bande 2 : diagonale \ -->
    <div class="band band-2">
      <div class="track track-2">
        {[...row2, ...row2, ...row2].map((file) => (
          <div class="tile" data-tilt>
            <img src={`/images/services-cards/${file}`} alt="" loading="lazy" />
            <div class="tile-sheen" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ──────────── Section ──────────── */
  .prime-section {
    position: relative;
    padding: 120px 0 140px;
    background: radial-gradient(ellipse at 50% 0%, #120820 0%, #050309 60%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .prime-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  /* Pattern grille subtil */
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 55%, rgba(168, 85, 247, 0.12), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ──────────── Header premium ──────────── */
  .prime-header {
    text-align: center;
    margin-bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  /* Co-branding : hauteurs calibrees + spacing asymetrique pour centrer visuellement ×
     translateX negatif pour compenser le glow neon "IA" de SMMIA qui tire
     le centre de masse visuel vers la droite */
  .cobrand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;                         /* gap gere par les marges du × pour equilibrage optique */
    margin-bottom: 36px;
    flex-wrap: nowrap;
    transform: translateX(clamp(-42px, -3vw, -18px));
  }

  .logo-box {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    cursor: pointer;
    animation: float-y 6s ease-in-out infinite,
               glow-pulse 4s ease-in-out infinite;
  }

  .logo-box:hover {
    transform: scale(1.06);
    animation-play-state: paused;
    filter: drop-shadow(0 0 42px rgba(192, 132, 252, 0.9));
  }

  .logo-box img {
    height: 100%;
    width: auto;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* Petit decalage pour aligner le centre optique du logo SMMIA (son "IA" neon
     tire le centre visuel vers le bas) avec celui de PRIME et du × */
  .logo-box-smmia img {
    transform: translateY(-4%);
  }

  /* SMMIA : PNG avec glow integre (lettres ~45% de l'image)
     → wrapper large pour inclure lettres + glow neon */
  .logo-box-smmia {
    height: clamp(72px, 12.5vw, 144px);
    animation-delay: 0s, 0s;
  }

  /* PRIME : texte pur (lettres ~87% de l'image)
     → wrapper calibre pour cap-height identique a SMMIA */
  .logo-box-prime {
    height: clamp(34px, 5.6vw, 66px);
    animation-delay: -3s, -2s;
  }

  /* Glow pulse partage entre les deux logos */
  @keyframes glow-pulse {
    0%, 100% { filter: drop-shadow(0 0 22px rgba(168, 85, 247, 0.45)); }
    50%      { filter: drop-shadow(0 0 34px rgba(192, 132, 252, 0.8)); }
  }

  @keyframes float-y {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-4px); }
  }

  /* Divider × anime
     Marges asymetriques : SMMIA a un glow qui s'etend a droite de ses lettres,
     donc on reduit l'espace SMMIA↔× pour que × apparaisse a l'equidistance
     optique entre les DERNIÈRES lettres de SMMIA et la 1re lettre de PRIME */
  .cobrand-x {
    position: relative;
    width: clamp(36px, 5.5vw, 60px);
    height: clamp(36px, 5.5vw, 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 2;
    margin-left: clamp(-18px, -1.6vw, -8px);   /* colle au glow trailing de SMMIA */
    margin-right: clamp(18px, 2.6vw, 32px);    /* gap normal jusqu'a PRIME */
  }

  .x-mark {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 200;
    color: #fff;
    line-height: 1;
    text-shadow: 0 0 18px rgba(168, 85, 247, 0.5);
  }

  .x-orbit {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    animation: spin 14s linear infinite;
  }

  .x-orbit circle {
    fill: none;
    stroke: rgba(168, 85, 247, 0.5);
    stroke-width: 1.5;
    stroke-dasharray: 4 6;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Headline dramatique */
  .headline {
    font-size: clamp(3rem, 10vw, 6.5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 26px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .line { display: inline-block; }

  /* Ligne 1 : outline uniquement (transparent + stroke) */
  .line-1 .outline {
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
    color: transparent;
    font-style: italic;
    padding-right: 0.05em;
  }

  /* Ligne 2 : gradient solide + underline anime */
  .line-2 {
    position: relative;
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 6px 30px rgba(168, 85, 247, 0.45));
  }

  .line-2-text { display: inline-block; }

  .underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18em;
    width: 100%;
    height: 0.22em;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.6));
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw-line 2.4s cubic-bezier(0.65, 0, 0.35, 1) 0.6s forwards;
  }

  .underline path {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw-line 2.4s cubic-bezier(0.65, 0, 0.35, 1) 0.6s forwards;
  }

  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }

  /* Sous-titre */
  .sub {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: rgba(255, 255, 255, 0.65);
    max-width: 720px;
    margin: 0 auto 36px;
    line-height: 1.55;
    font-weight: 400;
  }

  .sub strong {
    color: #fff;
    font-weight: 700;
    white-space: nowrap;     /* empeche que "Tu closes, on livre" soit coupe */
    display: inline-block;
  }

  /* Stats strip */
  .stats {
    display: inline-flex;
    align-items: center;
    gap: clamp(20px, 4vw, 44px);
    padding: 18px 28px;
    border-radius: 20px;
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.18);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .stat {
    text-align: center;
    min-width: 64px;
  }

  .stat-value {
    font-size: clamp(1.75rem, 3.2vw, 2.35rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, #C084FC);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .stat-sep {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, rgba(168, 85, 247, 0.5), transparent);
  }

  /* ──────────── Scene croix X ──────────── */
  .cross-stage {
    position: relative;
    width: 100%;
    height: 620px;
    perspective: 1600px;
    /* Vignette elegante : un seul masque radial au lieu de 4 fades */
    mask-image: radial-gradient(ellipse 80% 80% at center, #000 45%, rgba(0,0,0,0.55) 75%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at center, #000 45%, rgba(0,0,0,0.55) 75%, transparent 100%);
  }

  /* Spotlight multi-couches au croisement */
  .spot {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1;
  }

  .spot-core {
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.55) 0%, rgba(168, 85, 247, 0.25) 35%, transparent 70%);
    filter: blur(30px);
    animation: pulse-core 4.5s ease-in-out infinite;
  }

  .spot-halo {
    width: 720px;
    height: 720px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.18) 0%, rgba(88, 28, 135, 0.1) 40%, transparent 75%);
    filter: blur(60px);
  }

  @keyframes pulse-core {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.15); }
  }

  /* Bande diagonale */
  .band {
    position: absolute;
    top: 50%;
    left: -20%;
    right: -20%;
    height: 220px;
    transform-origin: center center;
    overflow: visible;
    transform-style: preserve-3d;
  }

  .band-1 {
    transform: translateY(-50%) rotate(-10deg);
    z-index: 2;
  }

  .band-2 {
    transform: translateY(-50%) rotate(10deg);
    z-index: 3;
  }

  /* Track */
  .track {
    display: flex;
    flex-direction: row;
    gap: 20px;
    width: max-content;
    height: 100%;
    align-items: center;
    will-change: transform;
  }

  .track-1 {
    animation: slide-left 62s linear infinite;
  }

  .track-2 {
    animation: slide-left 70s linear infinite reverse;
  }

  @keyframes slide-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.3333%); }
  }

  .cross-stage:hover .track {
    animation-play-state: paused;
  }

  /* ──────────── Tuile premium ──────────── */
  .tile {
    position: relative;
    flex: 0 0 auto;
    width: 220px;
    height: 220px;
    border-radius: 22px;
    overflow: hidden;
    background: #0a0615;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
                box-shadow 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.9),
      0 8px 20px -8px rgba(88, 28, 135, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    isolation: isolate;
  }

  /* Bordure en gradient (technique mask-composite) */
  .tile::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg,
      rgba(192, 132, 252, 0.55) 0%,
      rgba(168, 85, 247, 0.15) 40%,
      rgba(168, 85, 247, 0) 60%,
      rgba(192, 132, 252, 0.35) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.4s;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 1;
    position: relative;
  }

  /* Reflet "sheen" diagonal qui balaie au hover */
  .tile-sheen {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.12) 50%,
      transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
    z-index: 2;
  }

  .tile:hover {
    transform: translateY(-6px) scale(1.05);
    box-shadow:
      0 30px 70px -20px rgba(0, 0, 0, 0.95),
      0 20px 40px -10px rgba(168, 85, 247, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    z-index: 50;
  }

  .tile:hover img {
    transform: scale(1.08);
  }

  .tile:hover .tile-sheen {
    transform: translateX(120%);
  }

  /* ──────────── Tablette ──────────── */
  @media (max-width: 1024px) {
    .prime-section { padding: 96px 0 112px; }
    .prime-header { margin-bottom: 64px; }
    .cobrand { gap: 28px; margin-bottom: 32px; }
    .stats { padding: 16px 24px; gap: 28px; }
    .cross-stage { height: 520px; }
    .band { height: 190px; }
    .band-1 { transform: translateY(-50%) rotate(-9deg); }
    .band-2 { transform: translateY(-50%) rotate(9deg); }
    .tile { width: 180px; height: 180px; border-radius: 20px; }
    .track { gap: 16px; animation-duration: 54s; }
    .track-2 { animation-duration: 60s; }
    .spot-core { width: 200px; height: 200px; }
    .spot-halo { width: 560px; height: 560px; }
  }

  /* ──────────── Mobile ──────────── */
  @media (max-width: 640px) {
    .prime-section { padding: 72px 0 88px; }
    .prime-header { margin-bottom: 52px; }
    .badge { font-size: 0.72rem; padding: 6px 14px; margin-bottom: 22px; }
    .cobrand { margin-bottom: 26px; }
    .logo-box-smmia { height: 86px; }
    .logo-box-prime { height: 38px; }
    .headline { gap: 2px; margin-bottom: 20px; }
    .line-1 .outline { -webkit-text-stroke-width: 1.5px; }
    .sub { margin-bottom: 26px; }
    .stats { padding: 14px 18px; gap: 18px; border-radius: 16px; }
    .stat-sep { height: 24px; }
    .cross-stage { height: 420px; }
    .band { height: 150px; }
    .band-1 { transform: translateY(-50%) rotate(-7deg); }
    .band-2 { transform: translateY(-50%) rotate(7deg); }
    .tile { width: 140px; height: 140px; border-radius: 16px; }
    .track { gap: 12px; animation-duration: 42s; }
    .track-2 { animation-duration: 48s; }
    .spot-core { width: 160px; height: 160px; }
    .spot-halo { width: 380px; height: 380px; }
    .bg-grid { background-size: 44px 44px; }
  }

  /* ──────────── Petit mobile ──────────── */
  @media (max-width: 380px) {
    .logo-box-smmia { height: 62px; }
    .logo-box-prime { height: 28px; }
    .stats { gap: 12px; padding: 12px 14px; }
    .stat { min-width: 50px; }
    .cross-stage { height: 360px; }
    .band { height: 130px; }
    .band-1 { transform: translateY(-50%) rotate(-6deg); }
    .band-2 { transform: translateY(-50%) rotate(6deg); }
    .tile { width: 120px; height: 120px; border-radius: 14px; }
    .track { gap: 10px; }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .track, .spot-core { animation: none; }
  }
</style>

<script>
  // Tilt 3D magnetique au hover sur chaque tuile (effet premium)
  const tiles = document.querySelectorAll<HTMLElement>('.tile[data-tilt]');

  tiles.forEach((tile) => {
    tile.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = tile.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const cx = rect.width / 2;
      const cy = rect.height / 2;
      const rx = ((y - cy) / cy) * -8;
      const ry = ((x - cx) / cx) * 8;
      tile.style.transform =
        `translateY(-6px) scale(1.05) perspective(600px) rotateX(${rx}deg) rotateY(${ry}deg)`;
    });

    tile.addEventListener('mouseleave', () => {
      tile.style.transform = '';
    });
  });
</script>
