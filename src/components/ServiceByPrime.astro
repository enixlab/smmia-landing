  }

  /* Filtered-out state : la tuile disparait completement */
  .tile.dimmed {
    opacity: 0;
    transform: scale(0) !important;
    width: 0 !important;
    max-width: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
