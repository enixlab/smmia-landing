---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

const services = [
  "09-avis-google-SQUARE.png",
  "24-gmb-SQUARE.png",
  "01-tiktok-certif-SQUARE.png",
  "21-e-reputation-SQUARE.png",
  "02-snapchat-certif-SQUARE.png",
  "11-visuels-SQUARE.png",
  "14-ugc-ia-SQUARE.png",
  "10-flyers-SQUARE.png",
  "06-videos-montages-SQUARE.png",
  "12-sites-web-SQUARE.png",
  "08-landing-pages-SQUARE.png",
  "19-seo-SQUARE.png",
  "15-campagnes-ads-SQUARE.png",
  "20-audit-SQUARE.png",
  "05-generation-leads-SQUARE.png",
  "07-apple-wallet-SQUARE.png",
  "04-chatbot-sav-SQUARE.png",
  "13-nfc-SQUARE.png",
  "03-sms-mail-SQUARE.png",
  "16-crm-SQUARE.png",
  "17-whatsapp-SQUARE.png",
  "18-scrapping-SQUARE.png",
  "25-underground-SQUARE.png",
  "22-osint-SQUARE.png",
  "23-creation-societe-SQUARE.png",
];

const categories: Record<string, string> = {
  "09-avis-google-SQUARE.png": "reputation",
  "24-gmb-SQUARE.png": "reputation",
  "01-tiktok-certif-SQUARE.png": "reputation",
  "21-e-reputation-SQUARE.png": "reputation",
  "02-snapchat-certif-SQUARE.png": "reputation",
  "11-visuels-SQUARE.png": "creatif",
  "14-ugc-ia-SQUARE.png": "creatif",
  "10-flyers-SQUARE.png": "creatif",
  "06-videos-montages-SQUARE.png": "creatif",
  "12-sites-web-SQUARE.png": "web",
  "08-landing-pages-SQUARE.png": "web",
  "19-seo-SQUARE.png": "web",
  "20-audit-SQUARE.png": "web",
  "15-campagnes-ads-SQUARE.png": "publicite",
  "05-generation-leads-SQUARE.png": "publicite",
  "04-chatbot-sav-SQUARE.png": "automatisation",
  "03-sms-mail-SQUARE.png": "automatisation",
  "16-crm-SQUARE.png": "automatisation",
  "17-whatsapp-SQUARE.png": "automatisation",
  "07-apple-wallet-SQUARE.png": "avance",
  "13-nfc-SQUARE.png": "avance",
  "18-scrapping-SQUARE.png": "avance",
  "25-underground-SQUARE.png": "avance",
  "22-osint-SQUARE.png": "avance",
  "23-creation-societe-SQUARE.png": "avance",
};

const row1 = services.filter((_, i) => i % 2 === 0);
const row2 = services.filter((_, i) => i % 2 === 1);
---

<section id="prime" class="prime-section">

  <!-- Pattern de fond subtil -->
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-vignette" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["Stripe", "Gemini", "Claude", "n8n"]} />

  <div class="prime-inner">
    <!-- Header premium innove -->
    <div class="prime-header">

      <!-- Live status -->
      <div class="live-status" data-animate>
        <span class="live-dot"></span>
        <span class="live-label">PRIME EN OPS</span>
        <span class="live-sep" aria-hidden="true"></span>
        <span class="live-detail">
          <span class="live-count" data-count="47">0</span> deals en cours de livraison
        </span>
      </div>

      <!-- Headline : "Dis oui aux deals" + highlight violet sur "t'osais pas prendre" -->
      <h2 class="headline" data-animate data-delay="0.1">
        <span class="headline-line-1">Dis oui aux deals</span>
        <span class="headline-line-2">
          <span class="headline-soft">que </span><span class="headline-mark"><span class="headline-mark-text">t'osais pas prendre</span></span><span class="headline-soft">.</span>
        </span>
      </h2>

      <!-- Subheader re-ecrit -->
      <p class="sub" data-animate data-delay="0.22">
        Prime livre sous ton nom en <strong>72h</strong>. Fini les <em>"je sais pas faire"</em>.
      </p>

      <!-- Stats KPI cards -->
      <div class="stats" data-animate data-delay="0.36">
        <div class="stat-card">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8v6a3 3 0 0 1-6 0V5a2 2 0 0 1 4 0v9a1 1 0 0 1-2 0V7"/></svg>
          </div>
          <div class="stat-body">
            <div class="stat-value"><span class="stat-counter" data-to="25">0</span></div>
            <div class="stat-label">Services dans ton catalogue</div>
            <div class="stat-sub">tout ce qu'un client demande</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon stat-icon-orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="stat-body">
            <div class="stat-value"><span class="stat-counter" data-to="72">0</span>h</div>
            <div class="stat-label">Livré sous ton nom</div>
            <div class="stat-sub">ton client n'a jamais vu Prime</div>
          </div>
        </div>

        <div class="stat-card stat-card-accent">
          <div class="stat-icon stat-icon-green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13 8 8 13 1 6"/><polyline points="22 12 22 17 17 17"/></svg>
          </div>
          <div class="stat-body">
            <div class="stat-value">−<span class="stat-counter" data-to="70">0</span><span class="stat-unit">%</span></div>
            <div class="stat-label">ton coût vs agences</div>
            <div class="stat-sub">pure marge dans ta poche</div>
          </div>
        </div>
      </div>

      <!-- Scroll hint vers le catalogue -->
      <div class="scroll-hint" data-animate data-delay="0.44">
        <span class="scroll-hint-text">Scroll · Ton catalogue de 25 services défile</span>
        <svg class="scroll-hint-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
      </div>

    </div>
  </div>

  <!-- Croix diagonale (X) premium -->
  <div class="cross-stage">

    <!-- Spotlight multi-couches au centre -->
    <div class="spot spot-core" aria-hidden="true"></div>
    <div class="spot spot-halo" aria-hidden="true"></div>

    <!-- Bande 1 : diagonale /  -->
    <div class="band band-1">
      <div class="track track-1">
        {[...row1, ...row1, ...row1].map((file) => (
          <div class="tile" data-tilt data-cat={categories[file]}>
            <img class="tile-bg" src={`/images/services-cards/${file}`} alt="" aria-hidden="true" loading="lazy" />
            <div class="tile-bg-tint" aria-hidden="true"></div>
            <img class="tile-fg" src={`/images/services-cards/${file}`} alt="" loading="lazy" />
            <div class="tile-sheen" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bande 2 : diagonale \ -->
    <div class="band band-2">
      <div class="track track-2">
        {[...row2, ...row2, ...row2].map((file) => (
          <div class="tile" data-tilt data-cat={categories[file]}>
            <img class="tile-bg" src={`/images/services-cards/${file}`} alt="" aria-hidden="true" loading="lazy" />
            <div class="tile-bg-tint" aria-hidden="true"></div>
            <img class="tile-fg" src={`/images/services-cards/${file}`} alt="" loading="lazy" />
            <div class="tile-sheen" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ──────────── Section ──────────── */
  .prime-section {
    position: relative;
    padding: 80px 0 88px;
    background: radial-gradient(ellipse at 50% 0%, #120820 0%, #050309 60%, #000 100%);
    overflow: hidden;
    isolation: isolate;
    content-visibility: auto;
    contain-intrinsic-size: 1200px;
  }

  .prime-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  /* Pattern grille subtil */
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 55%, rgba(168, 85, 247, 0.12), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ──────────── Header premium ──────────── */
  .prime-header {
    text-align: center;
    margin-bottom: 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ─── LIVE STATUS ─── */
  .live-status {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 16px 8px 14px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.10);
    border: 1px solid rgba(168, 85, 247, 0.45);
    box-shadow: 0 4px 20px -6px rgba(168, 85, 247, 0.45), inset 0 0 0 1px rgba(192, 132, 252, 0.15);
    backdrop-filter: blur(12px);
    margin-bottom: 28px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #86efac;
  }
  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c084fc;
    box-shadow: 0 0 14px #a855f7;
    animation: live-pulse 1.4s ease-in-out infinite;
  }
  .live-label { color: #e9d5ff; }
  .live-sep { width: 1px; height: 14px; background: rgba(192, 132, 252, 0.45); }
  .live-detail { color: rgba(255, 255, 255, 0.9); letter-spacing: 0.04em; font-weight: 600; }
  .live-count { color: #fff; font-weight: 900; font-variant-numeric: tabular-nums; }
  @keyframes live-pulse {
    0%, 100% { transform: scale(1);   box-shadow: 0 0 14px #a855f7; }
    50%      { transform: scale(1.4); box-shadow: 0 0 22px #a855f7, 0 0 40px rgba(168, 85, 247, 0.5); }
  }

  /* ─── HEADLINE ─── */
  .headline {
    font-size: clamp(2.6rem, 8.5vw, 5.6rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.035em;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .headline-line-1 {
    color: rgba(255, 255, 255, 0.92);
    font-style: italic;
    font-weight: 800;
  }
  .headline-line-2 {
    display: inline-block;
    max-width: 100%;
    line-height: 1.25;
  }
  .headline-soft {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 900;
  }

  /* Highlight moderne : bloc violet incliné avec glow + gradient text blanc */
  .headline-mark {
    position: relative;
    display: inline-block;
    padding: 0.02em 0.28em 0.06em;
    margin: 0 0.04em;
    border-radius: clamp(6px, 0.8vw, 12px);
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 55%, #c084fc 100%);
    box-shadow:
      0 8px 28px rgba(168, 85, 247, 0.45),
      0 2px 6px rgba(168, 85, 247, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -2px 0 rgba(0, 0, 0, 0.18);
    transform: rotate(-1.2deg);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .headline-mark::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255,255,255,0.18) 0%, transparent 55%);
    pointer-events: none;
  }
  .headline-mark:hover { transform: rotate(0deg) scale(1.02); }
  .headline-mark-text {
    position: relative;
    color: #fff;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
  }

  /* ─── SOUS-TITRE ─── */
  .sub {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.65);
    max-width: 780px;
    margin: 0 auto 28px;
    line-height: 1.6;
    font-weight: 400;
  }
  .sub strong {
    color: #fff;
    font-weight: 700;
  }

  /* ─── PILLS CATEGORIES ─── */
  .cat-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    max-width: 820px;
    margin: 0 auto 40px;
  }
  .cat-pill {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(168, 85, 247, 0.25);
    color: rgba(216, 180, 254, 0.95);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    font-family: inherit;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
                background 0.3s ease,
                border-color 0.3s ease,
                color 0.3s ease,
                box-shadow 0.3s ease;
    cursor: pointer;
  }
  .cat-pill:hover {
    transform: translateY(-2px);
    background: rgba(168, 85, 247, 0.18);
    border-color: rgba(192, 132, 252, 0.6);
    color: #fff;
  }
  .cat-pill-active {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.35), rgba(124, 58, 237, 0.45));
    border-color: rgba(192, 132, 252, 0.85);
    color: #fff;
    box-shadow: 0 4px 18px -6px rgba(168, 85, 247, 0.55);
  }

  /* ─── STATS KPI CARDS ─── */
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 840px;
    margin: 0 auto;
    width: 100%;
  }

  .stat-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-radius: 18px;
    background:
      linear-gradient(135deg, rgba(30, 15, 55, 0.6), rgba(15, 8, 30, 0.7));
    border: 1px solid rgba(168, 85, 247, 0.25);
    backdrop-filter: blur(14px);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.35s ease,
                box-shadow 0.35s ease;
    text-align: left;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(192, 132, 252, 0.55);
    box-shadow:
      0 18px 40px rgba(168, 85, 247, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .stat-card-accent {
    background:
      linear-gradient(135deg, rgba(124, 58, 237, 0.22), rgba(168, 85, 247, 0.1));
    border-color: rgba(192, 132, 252, 0.45);
  }

  .stat-icon {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(124, 58, 237, 0.1));
    border: 1px solid rgba(168, 85, 247, 0.3);
    color: #C4B5FD;
  }
  .stat-icon svg { width: 22px; height: 22px; }
  .stat-icon-orange {
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.25), rgba(249, 115, 22, 0.1));
    border-color: rgba(251, 146, 60, 0.4);
    color: #fed7aa;
  }
  .stat-icon-green {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.25), rgba(22, 163, 74, 0.1));
    border-color: rgba(34, 197, 94, 0.4);
    color: #bbf7d0;
  }

  .stat-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }

  .stat-value {
    font-size: 1.7rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: baseline;
  }
  .stat-unit { font-size: 1.1rem; font-weight: 800; color: rgba(255, 255, 255, 0.7); }
  .stat-counter { display: inline-block; }

  .stat-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    letter-spacing: 0.01em;
  }
  .stat-sub {
    font-size: 0.68rem;
    color: rgba(216, 180, 254, 0.6);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-top: 1px;
  }

  /* ─── SCROLL HINT ─── */
  .scroll-hint {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
  }
  .scroll-hint-arrow {
    width: 14px;
    height: 14px;
    animation: scroll-bounce 1.6s ease-in-out infinite;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0);   }
    50%      { transform: translateY(4px); }
  }

  /* ──────────── Scene croix X ──────────── */
  .cross-stage {
    position: relative;
    width: 100%;
    height: 620px;
    perspective: 1600px;
    overflow: hidden;
    /* Fade horizontal uniquement - les tuiles ne sont plus coupees en haut/bas */
    mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }

  /* Spotlight multi-couches au croisement */
  .spot {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1;
  }

  .spot-core {
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(192, 132, 252, 0.55) 0%, rgba(168, 85, 247, 0.25) 35%, transparent 70%);
    filter: blur(30px);
    animation: pulse-core 4.5s ease-in-out infinite;
  }

  .spot-halo {
    width: 720px;
    height: 720px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.18) 0%, rgba(88, 28, 135, 0.1) 40%, transparent 75%);
    filter: blur(60px);
  }

  @keyframes pulse-core {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 1;    transform: translate(-50%, -50%) scale(1.15); }
  }

  /* Bande diagonale */
  .band {
    position: absolute;
    top: 50%;
    left: -20%;
    right: -20%;
    height: 220px;
    transform-origin: center center;
    overflow: visible;
    transform-style: preserve-3d;
  }

  .band-1 {
    transform: translateY(-50%) rotate(-10deg);
    z-index: 2;
  }

  .band-2 {
    transform: translateY(-50%) rotate(10deg);
    z-index: 3;
  }

  /* Track */
  .track {
    display: flex;
    flex-direction: row;
    gap: 20px;
    width: max-content;
    height: 100%;
    align-items: center;
    will-change: transform;
  }

  .track-1 {
    animation: slide-left 62s linear infinite;
  }

  .track-2 {
    animation: slide-left 70s linear infinite reverse;
  }

  @keyframes slide-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.3333%); }
  }

  .cross-stage:hover .track {
    animation-play-state: paused;
  }

  /* ──────────── Tuile premium (taille unifiee carree + BG blur auto) ──────────── */
  .tile {
    position: relative;
    flex: 0 0 auto;
    width: 220px;
    height: 220px;
    border-radius: 22px;
    overflow: hidden;
    background: #06030d;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
                box-shadow 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.9),
      0 8px 20px -8px rgba(88, 28, 135, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    isolation: isolate;
  }

  /* Bordure en gradient (technique mask-composite) */
  .tile::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg,
      rgba(192, 132, 252, 0.55) 0%,
      rgba(168, 85, 247, 0.15) 40%,
      rgba(168, 85, 247, 0) 60%,
      rgba(192, 132, 252, 0.35) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.4s;
  }

  /* Background : meme image, floutee + saturee, remplit toute la tuile */
  .tile-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: blur(30px) saturate(1.6) brightness(0.9);
    transform: scale(1.25); /* evite les bords transparents du blur */
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* Tint leger uniquement pour unifier + vignette subtile */
  .tile-bg-tint {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0) 30%, rgba(0,0,0,0.35) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Foreground : l'image entiere, centree avec contain, pas de crop */
  .tile-fg {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: 10px;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 2;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.4));
  }

  /* Reflet "sheen" diagonal qui balaie au hover */
  .tile-sheen {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.12) 50%,
