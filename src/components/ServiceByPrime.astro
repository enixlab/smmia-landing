---
const categories = ["Tout", "Réputation", "Créatif", "Web", "Publicité", "Automatisation", "Avancé"];

const services = [
  // RÉPUTATION
  { file: "09-avis-google-PORTRAIT.png",     cat: "réputation" },
  { file: "24-gmb-SQUARE.png",               cat: "réputation" },
  { file: "01-tiktok-certif-SQUARE.png",     cat: "réputation" },
  { file: "21-e-reputation-SQUARE.png",      cat: "réputation" },
  { file: "02-snapchat-certif-SQUARE.png",   cat: "réputation" },
  // CRÉATIF
  { file: "11-visuels-WIDE.jpeg",            cat: "créatif"    },
  { file: "14-ugc-ia-PORTRAIT.jpeg",         cat: "créatif"    },
  { file: "10-flyers-SQUARE.png",            cat: "créatif"    },
  { file: "06-videos-montages-WIDE.png",     cat: "créatif"    },
  // WEB
  { file: "12-sites-web-WIDE.png",           cat: "web"        },
  { file: "08-landing-pages-SQUARE.png",     cat: "web"        },
  { file: "19-seo-SQUARE.png",               cat: "web"        },
  // PUBLICITÉ
  { file: "15-campagnes-ads-WIDE.png",       cat: "publicité"  },
  { file: "20-audit-SQUARE.png",             cat: "publicité"  },
  { file: "05-generation-leads-WIDE.png",    cat: "publicité"  },
  // AUTOMATISATION
  { file: "07-apple-wallet-PORTRAIT.png",    cat: "automatisation" },
  { file: "04-chatbot-sav-SQUARE.png",       cat: "automatisation" },
  { file: "13-nfc-PORTRAIT.png",             cat: "automatisation" },
  { file: "03-sms-mail-SQUARE.png",          cat: "automatisation" },
  { file: "16-crm-PORTRAIT.png",             cat: "automatisation" },
  { file: "17-whatsapp-SQUARE.png",          cat: "automatisation" },
  { file: "18-scrapping-SQUARE.png",         cat: "automatisation" },
  // AVANCÉ
  { file: "25-underground-WIDE.png",         cat: "avancé"     },
  { file: "22-osint-PORTRAIT.png",           cat: "avancé"     },
  { file: "23-creation-societe-PORTRAIT.png",cat: "avancé"     },
];
---

<section id="prime" class="prime-section">
  <div class="prime-inner">

    <!-- Header -->
    <div class="prime-header">
      <div class="prime-logo-row">
        <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" class="prime-logo" />
        <span class="prime-times">&times;</span>
        <span class="prime-brand">PRIME</span>
      </div>
      <h2 class="prime-title" data-animate>Tu vends.<br>Prime livre.</h2>
      <p class="prime-sub" data-animate data-delay="0.1">
        En tant que membre SMMIA, tu accèdes aux services de l'agence Prime à des tarifs imbattables.
        Tu closes, on livre. Aucune excuse.
      </p>
    </div>

    <!-- Filtres -->
    <div class="tabs-wrap">
      <div class="tabs" id="prime-tabs">
        {categories.map((cat, i) => (
          <button class={`tab ${i === 0 ? 'active' : ''}`} data-filter={cat.toLowerCase()}>
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Grille masonry CSS columns -->
    <div class="masonry" id="prime-masonry">
      {services.map((s) => (
        <div class="card" data-cat={s.cat}>
          <img
            src={`/images/services-cards/${s.file}`}
            alt=""
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .prime-section {
    padding: 100px 0;
    background: #000;
  }

  .prime-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ── */
  .prime-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .prime-logo-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .prime-logo {
    height: 44px;
    width: auto;
    filter: drop-shadow(0 0 12px rgba(168,85,247,0.4));
  }

  .prime-times {
    font-size: 1.5rem;
    color: rgba(255,255,255,0.25);
    font-weight: 300;
  }

  .prime-brand {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    background: linear-gradient(135deg, #A855F7, #E8442A);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .prime-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 16px;
  }

  .prime-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Filtres ── */
  .tabs-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs-wrap::-webkit-scrollbar { display: none; }

  .tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tab {
    padding: 8px 20px;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.5);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .tab:hover {
    border-color: rgba(168,85,247,0.4);
    color: rgba(255,255,255,0.85);
  }

  .tab.active {
    background: rgba(168,85,247,0.15);
    border-color: rgba(168,85,247,0.6);
    color: #A855F7;
  }

  /* ── Masonry (CSS columns) ── */
  .masonry {
    column-count: 5;
    column-gap: 8px;
  }

  @media (max-width: 1100px) { .masonry { column-count: 4; } }
  @media (max-width: 800px)  { .masonry { column-count: 3; } }
  @media (max-width: 540px)  { .masonry { column-count: 2; } }

  .card {
    break-inside: avoid;
    margin-bottom: 10px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(168,85,247,0.1);
    background: #080510;
    transition: transform 0.2s, border-color 0.2s;
    line-height: 0;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: rgba(168,85,247,0.35);
  }

  .card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .card.hidden {
    display: none;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('#prime-tabs .tab');
  const cards = document.querySelectorAll<HTMLElement>('#prime-masonry .card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.dataset.filter ?? 'tout';
      cards.forEach(card => {
        const cat = card.dataset.cat ?? '';
        card.classList.toggle('hidden', filter !== 'tout' && cat !== filter);
      });
    });
  });
</script>
