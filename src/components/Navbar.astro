---

<nav id="navbar" style="position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(0,0,0,0.92);backdrop-filter:blur(20px);transition:border-bottom 0.3s ease;border-bottom:1px solid transparent;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:88px;">
    <!-- Logo -->
    <a href="#" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
      <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" class="nav-logo nav-logo-dark" style="height:64px;width:auto;display:block;" />
      <img src="/images/logos/DCC.png" alt="SMMIA" class="nav-logo nav-logo-light" style="height:64px;width:auto;display:none;" />
    </a>

    <!-- Liens desktop : retirés à la demande — on garde uniquement le CTA Rejoindre -->
    <div class="nav-links" style="display:flex;align-items:center;gap:32px;">
      <a href="https://wa.me/33766814280" target="_blank" rel="noopener" class="btn-pill" style="padding:10px 22px;font-size:0.875rem;">Rejoindre &rarr;</a>
    </div>

    <!-- Theme toggle — toujours visible (desktop + mobile) -->
    <button id="theme-toggle" aria-label="Basculer thème clair / sombre" class="theme-toggle">
      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <!-- Burger mobile -->
    <button id="burger" aria-label="Menu" style="display:none;background:none;border:none;cursor:pointer;padding:8px;color:#fff;">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;padding:16px 24px 24px;border-top:1px solid rgba(168,85,247,0.2);">
    <a href="https://wa.me/33766814280" target="_blank" rel="noopener" class="btn-pill" style="width:100%;justify-content:center;">Rejoindre &rarr;</a>
  </div>
</nav>

<style>
  /* Theme toggle button — toujours visible desktop + mobile */
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(168,85,247,0.12);
    border: 1.5px solid rgba(168,85,247,0.5);
    color: #fff;
    cursor: pointer;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
    margin-left: 12px;
    flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(168,85,247,0.25);
  }
  .theme-toggle:hover {
    transform: scale(1.08);
    background: rgba(168,85,247,0.22);
    border-color: rgba(168,85,247,0.8);
    box-shadow: 0 6px 20px rgba(168,85,247,0.4);
  }
  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon {
    position: absolute;
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .theme-toggle .icon-moon { opacity: 1; transform: rotate(0); }
  .theme-toggle .icon-sun { opacity: 0; transform: rotate(-90deg); }
  :root[data-theme="light"] .theme-toggle .icon-sun { opacity: 1; transform: rotate(0); }
  :root[data-theme="light"] .theme-toggle .icon-moon { opacity: 0; transform: rotate(90deg); }
  :root[data-theme="light"] .theme-toggle { color: #5B21B6; border-color: rgba(168,85,247,0.7); background: rgba(168,85,247,0.1); }
  :root[data-theme="light"] .theme-toggle:hover { background: rgba(168,85,247,0.18); }

  /* Logo swap : DCC en clair, SMMIA v2 en sombre */
  :root[data-theme="light"] .nav-logo-dark { display: none !important; }
  :root[data-theme="light"] .nav-logo-light { display: block !important; }

  @media (max-width: 768px) {
    /* On garde le bouton Rejoindre visible en mobile (seul item restant) */
    .nav-links { gap: 10px !important; }
    .nav-links .btn-pill { padding: 8px 16px !important; font-size: 0.8rem !important; }
    #burger { display: none !important; }
    .nav-logo { height: 52px !important; }
  }
  a:hover {
    color: #A855F7 !important;
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.style.display === 'block';
    if (mobileMenu) mobileMenu.style.display = isOpen ? 'none' : 'block';
  });
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      if (mobileMenu) mobileMenu.style.display = 'none';
    });
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch(e) {}
  });
</script>
