  { id: 't07', source: 'trustpilot', name: 'Jonathan B',        initials: 'JB', role: 'Avis vérifié Trustpilot', city: 'France',  rating: 5, quote: "Les lives de Sonny, c'est de la plus value de fou !!!!! À chaque apparition de Sonny, c'est une expérience incroyable !!! El Proffessor !!!",                                                                                                                              result: 'Plus value de fou',date: 'Avr. 2026', avatarHue: 220 },
  { id: 't08', source: 'trustpilot', name: 'Marco Rutigliano',  initials: 'MR', role: 'Avis vérifié Trustpilot', city: 'Italie',  rating: 5, quote: "Formation complète avec des lives toutes les semaines, ça m'a beaucoup fait progresser en tant que débutant.",                                                                                                                                                              result: 'Progrès débutant', date: 'Mars 2026', avatarHue: 225 },
  { id: 't09', source: 'trustpilot', name: 'Ilies Bourbouane',  initials: 'IB', role: 'Avis vérifié Trustpilot', city: 'Algérie', rating: 5, quote: "L'avancée de notre niveau est juste impressionnante ! J'ai jamais pu apprendre autant de choses en si peu de temps, merciii et je reste Focus ❤️",                                                                                                                         result: 'Progression express',date: 'Avr. 2026', avatarHue: 35 },
];

// Split : discord → ligne 1 (scroll gauche), trustpilot → ligne 2 (scroll droite)
const discordList = testimonials.filter(t => t.source === 'discord');
const trustList   = testimonials.filter(t => t.source === 'trustpilot');

// Stats
const totalCount = testimonials.length;
const avgRating = (testimonials.reduce((s, t) => s + t.rating, 0) / totalCount).toFixed(1).replace('.', ',');
---

<section id="temoignages" class="ta-section">

  <!-- Logos brand flottants subtils -->
  <FloatingBrandIcons variant="subtle" seed={2} />

  <!-- Halos violets de fond -->
  <div class="ta-halo ta-halo-l" aria-hidden="true"></div>
  <div class="ta-halo ta-halo-r" aria-hidden="true"></div>

  <div class="ta-inner">

    <!-- Header -->
    <div class="ta-head">
      <div class="ta-badge" data-animate>
        <span class="ta-badge-dot"></span>
        Avis vérifiés · Communauté Focus
      </div>
      <h2 class="ta-title" data-animate data-delay="0.08">
        Ils ont changé leur vie <br>
        <span class="ta-title-accent">avec SMMIA.</span>
      </h2>
      <p class="ta-sub" data-animate data-delay="0.16">
        Plus de {totalCount} témoignages certifiés Discord &amp; Trustpilot. Aucun filtre, aucune retouche.
      </p>

      <!-- Stats ribbon -->
      <div class="ta-stats" data-animate data-delay="0.24">
        <div class="ta-stat">
          <span class="ta-stat-val">{totalCount}+</span>
          <span class="ta-stat-lbl">Avis vérifiés</span>
        </div>
        <div class="ta-stat-sep" aria-hidden="true"></div>
        <div class="ta-stat">
          <span class="ta-stat-val">
            {avgRating}
            <span class="ta-stat-val-sub">/ 5</span>
          </span>
          <span class="ta-stat-lbl">Note moyenne</span>
        </div>
        <div class="ta-stat-sep" aria-hidden="true"></div>
        <div class="ta-stat">
          <span class="ta-stat-val">100<span class="ta-stat-val-sub">%</span></span>
          <span class="ta-stat-lbl">Clients satisfaits</span>
        </div>
      </div>

      <!-- Filter tabs -->
      <div class="ta-tabs" role="tablist" data-animate data-delay="0.32">
        <button class="ta-tab is-active" role="tab" data-filter="all">
          <span class="ta-tab-dot"></span>
          Tous
          <span class="ta-tab-count">{totalCount}</span>
        </button>
        <button class="ta-tab" role="tab" data-filter="discord">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
          Discord
          <span class="ta-tab-count">{discordList.length}</span>
        </button>
        <button class="ta-tab" role="tab" data-filter="trustpilot">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 1.5 15 9h7.5l-6 4.5 2.2 7L12 16l-6.7 4.5L7.5 13.5l-6-4.5H9z"/></svg>
          Trustpilot
          <span class="ta-tab-count">{trustList.length}</span>
        </button>
      </div>
    </div>

    <!-- Marquee ligne 1 : Discord → gauche -->
    <div class="ta-marquee-wrap" data-row="discord">
      <div class="ta-fade-l"></div>
      <div class="ta-fade-r"></div>
      <div class="ta-track ta-track-l">
        {[...discordList, ...discordList].map((t, i) => (
          <article class="ta-card" data-source={t.source} data-id={t.id} tabindex="0" role="button" aria-label={`Voir l'avis complet de ${t.name}`}>
            <header class="ta-card-head">
              <div class="ta-avatar" style={`--hue: ${t.avatarHue}`}>
                <span class="ta-avatar-ini">{t.initials}</span>
              </div>
              <div class="ta-who">
                <div class="ta-who-name">
                  {t.name}
                  <svg class="ta-who-check" viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-label="Vérifié"><path d="M12 2 14.6 4 18 3.2 18.8 6.6 22 8l-1.2 3.4L22 14.8 18.8 16 18 19.4 14.6 20 12 22 9.4 20 6 20.8 5.2 17.4 2 16l1.2-3.4L2 9.2 5.2 8 6 4.6 9.4 4z" opacity="0.2"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="ta-who-meta">{t.role} · {t.city}</div>
              </div>
              <span class="ta-source-pill" data-src={t.source}>
                {t.source === 'discord' ? (
                  <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
                ) : (
                  <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M12 1.5 15 9h7.5l-6 4.5 2.2 7L12 16l-6.7 4.5L7.5 13.5l-6-4.5H9z"/></svg>
                )}
                {t.source === 'discord' ? 'Discord' : 'Trustpilot'}
              </span>
            </header>

            <div class="ta-stars" aria-label={`Note : ${t.rating} sur 5`}>
              {Array.from({length: 5}).map(() => (
                <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 17.3 6.2 20.6l1.1-6.5-4.7-4.6 6.5-.9L12 3l2.9 5.6 6.5.9-4.7 4.6 1.1 6.5z"/></svg>
              ))}
            </div>

            <p class="ta-quote">{t.quote}</p>

            <footer class="ta-card-foot">
              <span class="ta-result">{t.result}</span>
              <span class="ta-date">{t.date}</span>
            </footer>
          </article>
        ))}
      </div>
    </div>

    <!-- Marquee ligne 2 : Trustpilot → droite -->
    <div class="ta-marquee-wrap" data-row="trustpilot">
      <div class="ta-fade-l"></div>
      <div class="ta-fade-r"></div>
      <div class="ta-track ta-track-r">
        {[...trustList, ...trustList, ...trustList].map((t, i) => (
          <article class="ta-card" data-source={t.source} data-id={t.id} tabindex="0" role="button" aria-label={`Voir l'avis complet de ${t.name}`}>
            <header class="ta-card-head">
              <div class="ta-avatar" style={`--hue: ${t.avatarHue}`}>
                <span class="ta-avatar-ini">{t.initials}</span>
              </div>
              <div class="ta-who">
                <div class="ta-who-name">
                  {t.name}
                  <svg class="ta-who-check" viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-label="Vérifié"><path d="M12 2 14.6 4 18 3.2 18.8 6.6 22 8l-1.2 3.4L22 14.8 18.8 16 18 19.4 14.6 20 12 22 9.4 20 6 20.8 5.2 17.4 2 16l1.2-3.4L2 9.2 5.2 8 6 4.6 9.4 4z" opacity="0.2"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="ta-who-meta">{t.role} · {t.city}</div>
              </div>
              <span class="ta-source-pill" data-src={t.source}>
                <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M12 1.5 15 9h7.5l-6 4.5 2.2 7L12 16l-6.7 4.5L7.5 13.5l-6-4.5H9z"/></svg>
                Trustpilot
              </span>
            </header>

            <div class="ta-stars" aria-label={`Note : ${t.rating} sur 5`}>
              {Array.from({length: 5}).map(() => (
                <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 17.3 6.2 20.6l1.1-6.5-4.7-4.6 6.5-.9L12 3l2.9 5.6 6.5.9-4.7 4.6 1.1 6.5z"/></svg>
              ))}
            </div>

            <p class="ta-quote">{t.quote}</p>

            <footer class="ta-card-foot">
              <span class="ta-result">{t.result}</span>
              <span class="ta-date">{t.date}</span>
            </footer>
          </article>
        ))}
      </div>
    </div>

    <!-- CTA conversion -->
    <div class="ta-cta-wrap" data-animate>
      <a href="#prix" class="ta-cta">
        <span class="ta-cta-text">Rejoindre les {totalCount}+ membres de SMMIA</span>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <p class="ta-cta-sub">Plus que 10 places · Session Mai 2026</p>
    </div>
  </div>

  <!-- Modal (lecture détaillée) -->
  <div class="ta-modal" id="ta-modal" aria-hidden="true" role="dialog">
    <div class="ta-modal-backdrop" data-close></div>
    <div class="ta-modal-card" role="document">
      <button class="ta-modal-close" data-close aria-label="Fermer">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <div class="ta-modal-body" id="ta-modal-body"><!-- injecté en JS --></div>
    </div>
  </div>
</section>

<script define:vars={{ testimonials }}>
  // ─────── Filter tabs ───────
  const tabs  = document.querySelectorAll('.ta-tab');
  const cards = document.querySelectorAll('.ta-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = tab.getAttribute('data-filter');
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');

      cards.forEach(card => {
        const src = card.getAttribute('data-source');
        const show = filter === 'all' || src === filter;
        card.style.display = show ? '' : 'none';
      });

      // Pause/resume rows selon le filtre
      const rowD = document.querySelector('[data-row="discord"] .ta-track');
      const rowT = document.querySelector('[data-row="trustpilot"] .ta-track');
      if (rowD && rowT) {
        rowD.style.animationPlayState = (filter === 'trustpilot') ? 'paused' : 'running';
        rowT.style.animationPlayState = (filter === 'discord')    ? 'paused' : 'running';
      }
    });
  });

  // ─────── Modal ───────
  const modal = document.getElementById('ta-modal');
  const body  = document.getElementById('ta-modal-body');

  const open = (id) => {
    const t = testimonials.find(x => x.id === id);
    if (!t || !body || !modal) return;
    const srcName = t.source === 'discord' ? 'Discord' : 'Trustpilot';
    body.innerHTML = `
      <div class="ta-modal-head">
        <div class="ta-avatar ta-avatar-xl" style="--hue:${t.avatarHue}">
          <span class="ta-avatar-ini">${t.initials}</span>
        </div>
        <div>
          <div class="ta-modal-name">${t.name}</div>
          <div class="ta-modal-meta">${t.role} · ${t.city}</div>
          <div class="ta-modal-src">
            <span class="ta-source-pill" data-src="${t.source}">
              ${t.source === 'discord' ? 'Discord' : 'Trustpilot'}
            </span>
            <span class="ta-modal-verified">✓ Avis vérifié · ${t.date}</span>
          </div>
        </div>
      </div>
      <div class="ta-modal-stars">
        ${'★'.repeat(5)}
      </div>
      <blockquote class="ta-modal-quote">« ${t.quote} »</blockquote>
      <div class="ta-modal-result">
        <span class="ta-modal-result-lbl">Résultat</span>
        <span class="ta-modal-result-val">${t.result}</span>
      </div>
      <a href="#prix" class="ta-modal-cta">
        Je veux les mêmes résultats
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    `;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-id');
      if (id) open(id);
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const id = card.getAttribute('data-id');
        if (id) open(id);
      }
    });
  });

  document.querySelectorAll('[data-close]').forEach(el => {
    el.addEventListener('click', close);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>

