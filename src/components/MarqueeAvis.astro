  { id: 'd04', source: 'discord', name: 'RM',             initials: 'RM', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Les gars, une amie à ma cousine est traiteur événementiel (mariage, cérémonie). Je l'ai travaillée toute la semaine : résultat vente de site avec automatisation de devis + campagne ADS. Closer 2 500€.",                                                                result: '+2 500€ traiteur', date: 'Avr. 2026', avatarHue: 245 },
  { id: 'd05', source: 'discord', name: 'Muhammed Ali',   initials: 'MA', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "700€ d'acompte récupérés ! On va tout réinvestir sur le Claude à 200 😂😂",                                                                                                                                                                                                     result: '+700€ d\'acompte',  date: 'Avr. 2026', avatarHue: 290 },
  { id: 'd06', source: 'discord', name: 'Jibril',         initials: 'JB', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Récap de la semaine : 3 sites Closer + abonnement. On lâche rien 🔥🔥",                                                                                                                                                                                                           result: '3 sites closés',    date: 'Avr. 2026', avatarHue: 255 },
  { id: 'd07', source: 'discord', name: 'Muhammed Ali',   initials: 'MA', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Salam aleykum, toute la louange est à Allah. Aujourd'hui : 2 ventes de services complets. Il y a d'autres clients potentiels, je vais commencer à déléguer. Qu'Allah vous enrichisse tous de manière halal.",                                                                result: '2 ventes complètes', date: 'Avr. 2026', avatarHue: 290 },
  { id: 'd08', source: 'discord', name: 'Grunchymaann',   initials: 'GR', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Après le live SMMA de Jamel, j'ai appliqué les méthodes qu'on nous a données. Dans la même semaine j'ai fait 350€ en facturant des flyers.",                                                                                                                                  result: '+350€ flyers',      date: 'Avr. 2026', avatarHue: 300 },
  { id: 'd09', source: 'discord', name: 'RS6',            initials: 'RS', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Salam à tous, voici quelques résultats : 2,5k en Infrastructure IA complète vendue à une entreprise. Lead qualifié direct dans l'agenda du client couplé à un BOT IA (même pas de Claude, dites vous).",                                                                 result: '+2 500€ infra IA',  date: 'Mars 2026', avatarHue: 270 },
