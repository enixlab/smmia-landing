---
import FloatingBrandIcons from './FloatingBrandIcons.astro';

type Source = 'discord' | 'trustpilot';
type Testimonial = {
  id: string;
  source: Source;
  name: string;
  initials: string;
  role: string;
  city: string;
  rating: 5 | 4.5;
  quote: string;
  result: string;
  date: string;
  avatarHue: number;
};

// ⚠️ TOUS LES AVIS CI-DESSOUS SONT DES TRANSCRIPTIONS FIDÈLES
// des screenshots réels présents dans /public/images/avis/
// (14 Discord #FOCUS + 9 Trustpilot — aucun avis inventé)
const testimonials: Testimonial[] = [
  // ─────────── DISCORD FOCUS (14 avis réels) ───────────
