  { id: 'd12', source: 'discord', name: 'Bene',           initials: 'BE', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Après le taf, ça part Closer les hôtels 🔥",                                                                                                                                                                                                                                       result: 'Prospect hôtels',   date: 'Avr. 2026', avatarHue: 285 },
  { id: 'd13', source: 'discord', name: 'Medjr19',        initials: 'MJ', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Un prototype à préparer pour vendredi pro et un RDV pour finaliser la semaine prochaine : 800€ pour une boutique ✅",                                                                                                                                                              result: '+800€ site boutique',date: 'Avr. 2026', avatarHue: 250 },
  { id: 'd14', source: 'discord', name: 'Tahirou773',     initials: 'TH', role: 'Membre Focus',       city: 'SMMIA',    rating: 5, quote: "Salam aleykoum, je sors de la salle, je vois un kiosque à pizza et au culot je vais le prospecter. Il a pris mon num pour la création de site, etc. pour ses futurs projets 💪",                                                                                                    result: 'Prospection réussie',date: 'Avr. 2026', avatarHue: 295 },

  // ─────────── TRUSTPILOT (9 avis réels) ───────────
  { id: 't01', source: 'trustpilot', name: 'Nora Gougane',      initials: 'NG', role: 'Avis vérifié Trustpilot', city: 'France',  rating: 5, quote: "Expérience qualitative : des lives de qualité, on peut poser toutes les questions, l'entraide est de mise… Des projets concrets qui donnent des résultats !!! Abonnement rentabilisé dès l'accès.",                                                                 result: 'Abo rentabilisé', date: 'Mars 2026', avatarHue: 320 },
  { id: 't02', source: 'trustpilot', name: 'Faina Hanidhi',     initials: 'FH', role: 'Avis vérifié Trustpilot', city: 'France',  rating: 5, quote: "Franchement, je recommande à 100% le groupe de FOCUS 🔥",                                                                                                                                                                                                                     result: 'Recommandé 100%', date: 'Avr. 2026', avatarHue: 310 },
  { id: 't03', source: 'trustpilot', name: 'Amadou',            initials: 'AM', role: 'Avis vérifié Trustpilot', city: 'France',  rating: 5, quote: "Contenu live ultra qualitatif et l'équipe au top !!!",                                                                                                                                                                                                                       result: 'Équipe au top',   date: 'Avr. 2026', avatarHue: 140 },
  { id: 't04', source: 'trustpilot', name: 'Gamelle Dog',       initials: 'GD', role: 'Avis vérifié Trustpilot', city: 'Suisse',  rating: 5, quote: "Des lives tous les soirs, une équipe solidaire. Si t'es dans le business et que tu cherches une communauté avec qui échanger et s'entraider, discord FOCUS est là pour toi !",                                                                                              result: 'Communauté ✓',    date: 'Avr. 2026', avatarHue: 215 },
  { id: 't05', source: 'trustpilot', name: 'Rimk',              initials: 'RI', role: 'Avis vérifié Trustpilot', city: 'France',  rating: 5, quote: "Sonny c'est pas du blabla, c'est concret. Chaque session t'apporte un truc que tu peux appliquer direct. Ce qui m'a le plus marqué : sa manière de faire voir les choses différemment, tu ressors avec une clarté que t'avais pas avant. Je recommande à 100%.", result: 'Clarté totale',   date: 'Avr. 2026', avatarHue: 125 },
