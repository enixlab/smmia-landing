---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Screenshots réels : 32 Discord + 18 Trustpilot = 50 avis
const discordImages = Array.from({length: 32}, (_, i) => {
  const num = String(i + 1).padStart(2, '0');
  return `/images/avis/discord/discord-${num}.webp`;
});
const trustpilotImages = Array.from({length: 18}, (_, i) => {
  const num = String(i + 1).padStart(2, '0');
  return `/images/avis/trustpilot/trustpilot-${num}.webp`;
});

const totalCount = discordImages.length + trustpilotImages.length;

// 2 marquees comme la référence : Discord → gauche, Trustpilot → droite

---

<section id="temoignages" class="av-section">

  <BrandFloatingIcons icons={["Facebook", "YouTube", "Sparkle", "Shopify"]} />

  <!-- Halos -->
  <div class="av-halo av-halo-l" aria-hidden="true"></div>
  <div class="av-halo av-halo-r" aria-hidden="true"></div>
  <div class="av-halo-c" aria-hidden="true"></div>

  <!-- Grille subtile -->
  <div class="av-grid" aria-hidden="true"></div>

  <div class="av-inner">

    <!-- Header -->
    <div class="av-head">
      <div class="av-badge">
        <span class="av-badge-dot"></span>
        <span class="av-badge-text">{totalCount} AVIS VÉRIFIÉS · COMMUNAUTÉ FOCUS</span>
        <span class="av-live">LIVE</span>
      </div>

      <h2 class="av-title">
        Ils ont changé leur vie <br/>
        <span class="av-title-accent">avec le SMMIA.</span>
      </h2>

      <!-- Stats ribbon avec counter -->
      <div class="av-stats" id="avStats">
        <div class="av-stat">
          <span class="av-stat-val"><span class="av-counter" data-to={totalCount}>0</span>+</span>
          <span class="av-stat-lbl">Avis vérifiés</span>
        </div>
        <div class="av-stat-sep" aria-hidden="true"></div>
        <div class="av-stat">
          <span class="av-stat-val">
            <span class="av-counter" data-to="50" data-format="comma">0</span><span class="av-stat-val-sub">/ 5</span>
          </span>
          <span class="av-stat-lbl">Note moyenne</span>
        </div>
        <div class="av-stat-sep" aria-hidden="true"></div>
        <div class="av-stat">
          <span class="av-stat-val"><span class="av-counter" data-to="100">0</span><span class="av-stat-val-sub">%</span></span>
          <span class="av-stat-lbl">Satisfaction</span>
        </div>
      </div>

      <!-- Filter tabs -->
      <div class="av-tabs" role="tablist">
        <button class="av-tab is-active" data-filter="all" role="tab">
          <span class="av-tab-dot"></span>
          Tous
          <span class="av-tab-count">{totalCount}</span>
        </button>
        <button class="av-tab" data-filter="discord" role="tab">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
          Discord
          <span class="av-tab-count">{discordImages.length}</span>
        </button>
        <button class="av-tab" data-filter="trustpilot" role="tab">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="#00B67A"><path d="M12 1.5 15 9h7.5l-6 4.5 2.2 7L12 16l-6.7 4.5L7.5 13.5l-6-4.5H9z"/></svg>
          Trustpilot
          <span class="av-tab-count">{trustpilotImages.length}</span>
        </button>
      </div>
    </div>

    <!-- 2 marquees : Discord ← / Trustpilot → -->
    <div class="av-rows">

      <div class="av-marquee">
        <div class="av-fade av-fade-l"></div>
        <div class="av-fade av-fade-r"></div>
        <div class="av-track av-track-l">
          {[...discordImages, ...discordImages].map((src, i) => (
            <figure class="av-card" data-src={src} data-source="discord" tabindex="0" role="button" aria-label="Agrandir avis Discord">
              <span class="av-pill av-pill-discord">
                <svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
                DISCORD
              </span>
              <div class="av-card-border" aria-hidden="true"></div>
              <img src={src} alt={`Avis Discord ${i + 1}`} loading="lazy" decoding="async" class="av-img"/>
            </figure>
          ))}
        </div>
      </div>

      <div class="av-marquee">
        <div class="av-fade av-fade-l"></div>
        <div class="av-fade av-fade-r"></div>
        <div class="av-track av-track-r">
          {[...trustpilotImages, ...trustpilotImages].map((src, i) => (
            <figure class="av-card av-card-trust" data-src={src} data-source="trustpilot" tabindex="0" role="button" aria-label="Agrandir avis Trustpilot">
              <span class="av-pill av-pill-trustpilot">
                <svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor"><path d="M12 1.5 15 9h7.5l-6 4.5 2.2 7L12 16l-6.7 4.5L7.5 13.5l-6-4.5H9z"/></svg>
                TRUSTPILOT
              </span>
              <div class="av-card-border" aria-hidden="true"></div>
              <img src={src} alt={`Avis Trustpilot ${i + 1}`} loading="lazy" decoding="async" class="av-img"/>
            </figure>
          ))}
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="av-cta-wrap">
      <a href="#prix" class="av-cta">
        <span class="av-cta-shine"></span>
        <span>Rejoindre la communauté SMMIA</span>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <!-- Lightbox avec navigation -->
  <div class="av-lightbox" id="avLightbox" aria-hidden="true" role="dialog">
    <div class="av-lb-backdrop" data-close></div>
    <button class="av-lb-close" data-close aria-label="Fermer">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
    <button class="av-lb-nav av-lb-prev" id="avLbPrev" aria-label="Précédent">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M15 6l-6 6 6 6"/></svg>
    </button>
    <button class="av-lb-nav av-lb-next" id="avLbNext" aria-label="Suivant">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg>
    </button>
    <div class="av-lb-content">
      <img class="av-lb-img" id="avLbImg" src="" alt="Avis agrandi"/>
      <div class="av-lb-counter" id="avLbCounter">1 / 50</div>
    </div>
  </div>
</section>

<script define:vars={{ discordImages, trustpilotImages }}>
  // ═══ Lightbox + navigation ═══
  const allImages = [...discordImages, ...trustpilotImages];
  const lb      = document.getElementById('avLightbox');
  const lbImg   = document.getElementById('avLbImg');
  const lbCnt   = document.getElementById('avLbCounter');
  const lbPrev  = document.getElementById('avLbPrev');
  const lbNext  = document.getElementById('avLbNext');
  let currentIdx = 0;

  const updateLb = () => {
    if (!lbImg || !lbCnt) return;
    lbImg.src = allImages[currentIdx];
    lbCnt.textContent = `${currentIdx + 1} / ${allImages.length}`;
  };

  const open = (src) => {
    if (!lb) return;
    const idx = allImages.indexOf(src);
    currentIdx = idx >= 0 ? idx : 0;
    updateLb();
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    if (!lb) return;
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };
  const prev = () => { currentIdx = (currentIdx - 1 + allImages.length) % allImages.length; updateLb(); };
  const next = () => { currentIdx = (currentIdx + 1) % allImages.length; updateLb(); };

  document.querySelectorAll('.av-card').forEach(c => {
    c.addEventListener('click', () => {
      const src = c.getAttribute('data-src');
      if (src) open(src);
    });
    c.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const src = c.getAttribute('data-src');
        if (src) open(src);
      }
    });
  });

  document.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', close));
  lbPrev?.addEventListener('click', prev);
  lbNext?.addEventListener('click', next);
  document.addEventListener('keydown', (e) => {
    if (lb?.getAttribute('aria-hidden') === 'true') return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  prev();
    if (e.key === 'ArrowRight') next();
  });

  // ═══ Filter tabs ═══
  const tabs  = document.querySelectorAll('.av-tab');
  const cards = document.querySelectorAll('.av-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = tab.getAttribute('data-filter');
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');

      cards.forEach(card => {
        const src = card.getAttribute('data-source');
        const show = filter === 'all' || src === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });

  // ═══ Counter animation on scroll ═══
  const counters = document.querySelectorAll('.av-counter');
  const animateCounter = (el) => {
    const to = parseFloat(el.getAttribute('data-to') || '0');
    const format = el.getAttribute('data-format');
    const duration = 1400;
    const start = performance.now();
    const step = (now) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      const val = to * eased;
      if (format === 'comma') {
        el.textContent = (val / 10).toFixed(1).replace('.', ',');
      } else {
        el.textContent = Math.round(val).toString();
      }
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        counters.forEach(animateCounter);
        io.disconnect();
      }
    });
  }, { threshold: 0.5 });

  const stats = document.getElementById('avStats');
  if (stats) io.observe(stats);
</script>

<style>
  /* ═══ SECTION ═══ */
  .av-section {
    position: relative;
    padding: 130px 0 110px;
    background:
      radial-gradient(ellipse at 50% 0%, #1a0d33 0%, #0a0413 50%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .av-halo {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    filter: blur(50px);
    pointer-events: none;
    z-index: 0;
  }
  .av-halo-l { top: 5%;    left: -180px;  background: radial-gradient(circle, rgba(34, 211, 238, 0.28), transparent 70%); }
  .av-halo-r { bottom: 8%; right: -180px; background: radial-gradient(circle, rgba(251, 146, 60, 0.25), transparent 70%); }

  .av-halo-c {
    position: absolute;
    top: 45%;
    left: 50%;
    width: 640px;
    height: 320px;
    background: radial-gradient(ellipse at center, rgba(168, 85, 247, 0.24), transparent 70%);
    filter: blur(45px);
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .av-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 211, 238, 0.035) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%);
    z-index: 1;
    pointer-events: none;
  }

  @keyframes avHaloFloat {
    0%, 100% { transform: translate(0, 0)       scale(1);   }
    50%      { transform: translate(40px, 30px) scale(1.1); }
  }
  @keyframes avHaloPulse {
    0%, 100% { opacity: 0.7; }
    50%      { opacity: 1;   }
  }

  .av-inner {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ═══ HEADER ═══ */
  .av-head {
    max-width: 960px;
    margin: 0 auto 64px;
    padding: 0 24px;
    text-align: center;
  }

  .av-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 8px 7px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    margin-bottom: 28px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: #C4B5FD;
    position: relative;
  }

  .av-badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 12px #A855F7;
    animation: avPulse 2s ease-in-out infinite;
  }

  .av-live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.15);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #E9D5FF;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    position: relative;
  }
  .av-live::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 8px #A855F7;
    animation: avPulse 1.2s ease-in-out infinite;
  }

  @keyframes avPulse {
    0%, 100% { transform: scale(1);   opacity: 1;   }
    50%      { transform: scale(1.3); opacity: 0.6; }
  }

  .av-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: #fff;
    margin: 0 0 20px;
  }

  .av-title-accent {
    background: linear-gradient(135deg, #22D3EE 0%, #A855F7 50%, #FB923C 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 4px 22px rgba(168,85,247,0.35));
    position: relative;
  }

  .av-sub {
    font-size: 1.04rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 640px;
    margin: 0 auto 34px;
    line-height: 1.55;
  }
  .av-sub-strong { color: #fff; font-weight: 600; }

  /* ═══ Stats ribbon ═══ */
  .av-stats {
    display: inline-flex;
    align-items: center;
    gap: 30px;
    padding: 18px 30px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(168, 85, 247, 0.25);
    backdrop-filter: blur(12px);
    box-shadow:
      0 8px 30px rgba(168, 85, 247, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    margin-bottom: 26px;
  }
  .av-stat { display: flex; flex-direction: column; align-items: flex-start; gap: 3px; }
  .av-stat-val {
    font-size: 1.7rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .av-stat-val-sub {
    font-size: 0.85rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.55);
    margin-left: 2px;
  }
  .av-stat-lbl {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }
  .av-stat-sep { width: 1px; height: 32px; background: rgba(255, 255, 255, 0.15); }

  /* ═══ Tabs ═══ */
  .av-tabs {
    display: inline-flex;
    gap: 6px;
    padding: 5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    margin-top: 12px;
  }
  .av-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.84rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: color 0.25s, background 0.25s;
  }
  .av-tab:hover { color: #fff; }
  .av-tab.is-active {
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 100%);
    color: #fff;
    box-shadow: 0 6px 20px rgba(168, 85, 247, 0.5);
  }
  .av-tab-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.9;
  }
  .av-tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 18px;
    padding: 0 7px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    font-size: 0.7rem;
    font-weight: 800;
  }
  .av-tab.is-active .av-tab-count { background: rgba(255, 255, 255, 0.24); }

  /* ═══ ROWS MARQUEES ═══ */
  .av-rows {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .av-marquee {
    position: relative;
    overflow: hidden;
    padding: 8px 0;
  }

  .av-fade {
    position: absolute;
    top: 0; bottom: 0;
    width: 160px;
    z-index: 3;
    pointer-events: none;
  }
  .av-fade-l { left: 0;  background: linear-gradient(to right, #000 0%, transparent 100%); }
  .av-fade-r { right: 0; background: linear-gradient(to left,  #000 0%, transparent 100%); }

  .av-track {
    display: flex;
    gap: 22px;
    width: max-content;
    will-change: transform;
  }
  .av-track-l      { animation: avScrollL 110s linear infinite; }
  .av-track-r      { animation: avScrollR 125s linear infinite; }
  .av-track-slow   { animation-duration: 150s; }

  .av-marquee:hover .av-track { animation-play-state: paused; }

  @keyframes avScrollL {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes avScrollR {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* ═══ CARD ═══ */
  .av-card {
    position: relative;
    flex: 0 0 auto;
    height: 260px;
    border-radius: 16px;
    overflow: hidden;
    background: #0d0618;
    cursor: pointer;
    margin: 0;
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Border via pseudo (conic gradient animé au hover) */
  .av-card-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1.5px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.45), rgba(168, 85, 247, 0.15) 50%, rgba(168, 85, 247, 0.45));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: opacity 0.4s ease, background 0.4s ease;
    z-index: 2;
    pointer-events: none;
  }

  .av-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    pointer-events: none;
    transition: box-shadow 0.45s ease;
    z-index: 1;
  }

  .av-card:hover,
  .av-card:focus-visible {
    transform: translateY(-8px) scale(1.03);
    outline: none;
    z-index: 4;
  }

  .av-card:hover::before,
  .av-card:focus-visible::before {
    box-shadow:
      0 26px 60px rgba(168, 85, 247, 0.45),
      0 6px 18px rgba(168, 85, 247, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .av-card:hover .av-card-border,
  .av-card:focus-visible .av-card-border {
    background: conic-gradient(from 0deg,
      #C084FC, #A855F7, #7C3AED, #A855F7, #C084FC);
