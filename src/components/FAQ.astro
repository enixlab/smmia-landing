---
const faqs = [
  {
    q: "C'est quoi SMMIA exactement ?",
    a: "SMMIA est un module de la communauté Focus créé par Val et son équipe. En 3 mois, tu apprends à vendre des services IA, à trouver des clients et à les livrer avec l'IA. Même si tu pars de zéro."
  },
  {
    q: "Je n'ai aucune compétence en IA, c'est fait pour moi ?",
    a: "C'est exactement pour ça qu'on l'a créé. Pas besoin de coder, pas besoin d'expérience. Les lives sont 100% pratiques — tu reproduis, tu vends."
  },
  {
    q: "Quand commence la prochaine session ?",
    a: "La prochaine session Focus démarre en Mai 2026. Les places sont limitées à 50 membres max pour garantir un suivi de qualité."
  },
  {
    q: "Quelle différence avec d'autres formations ?",
    a: "On est une communauté d'entrepreneurs actifs, pas des formateurs théoriques. Val et l'équipe vivent de ce qu'ils enseignent. Tu vois les résultats réels, pas des slides PowerPoint."
  },
];
---

<section style="padding:100px 0;">
  <div style="max-width:760px;margin:0 auto;padding:0 24px;">

    <div style="text-align:center;margin-bottom:60px;">
      <h2 data-animate style="font-size:clamp(1.8rem,4vw,3rem);font-weight:900;letter-spacing:-0.03em;margin-bottom:12px;">
        Questions fréquentes
      </h2>
      <p data-animate data-delay="0.1" style="color:rgba(255,255,255,0.5);font-size:1rem;">
        Tout ce que tu dois savoir avant de rejoindre.
      </p>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      {faqs.map((faq, i) => (
        <div
          class="faq-item glass-card"
          data-animate
          data-delay={String(i * 0.08)}
          style="overflow:hidden;"
        >
          <button
            class="faq-btn"
            style="width:100%;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:24px 28px;background:none;border:none;color:#fff;text-align:left;cursor:pointer;font-family:inherit;"
          >
            <span style="font-size:1rem;font-weight:700;line-height:1.3;">{faq.q}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 7.5L10 12.5L15 7.5" stroke="#A855F7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-answer">
            <p style="padding:0 28px 24px;color:rgba(255,255,255,0.6);font-size:0.95rem;line-height:1.7;">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
