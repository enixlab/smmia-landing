---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

type Cat = 'programme' | 'prix' | 'resultats' | 'support' | 'logistique';

type Faq = {
  q: string;
  a: string;
  cat: Cat;
  icon: 'spark' | 'lightning' | 'shield' | 'euro' | 'chart' | 'clock' | 'chat' | 'gift' | 'cal' | 'rocket';
  trust?: string;
};

const faqs: Faq[] = [
  {
    cat: 'programme', icon: 'spark',
    q: "C'est quoi SMMIA exactement ?",
    a: "SMMIA est le module signature de la communauté Focus, créé par Val et son équipe. En 3 mois, tu apprends à vendre des services IA (SMMA + automation), trouver des clients, et les livrer avec l'IA — même si tu pars totalement de zéro.",
    trust: "Module créé par Val — 10 ans d'expérience SMMA"
  },
  {
    cat: 'programme', icon: 'rocket',
    q: "Je n'ai aucune compétence en IA, c'est fait pour moi ?",
    a: "Exactement pour ça qu'on l'a créé. Pas besoin de coder, pas besoin d'expérience préalable. Les lives sont 100% pratiques — tu reproduis étape par étape, tu vends. Nos résultats les plus rapides viennent souvent de débutants qui appliquent à la lettre.",
    trust: "68% de nos membres débutaient à zéro"
  },
  {
    cat: 'logistique', icon: 'cal',
    q: "Quand commence la prochaine session ?",
    a: "La session Mai 2026 démarre le 2 mai. Places limitées à 50 membres max pour garantir un suivi qualitatif. À ce jour, il reste 10 places. Une fois fermé, la prochaine session n'ouvre qu'en Septembre 2026.",
    trust: "Plus que 10 places — Session Mai 2026"
  },
  {
    cat: 'programme', icon: 'lightning',
    q: "Quel est le rythme réel sur 3 mois ?",
    a: "2 lives par semaine (90 min chacun) animés par Val, Sonny, Jamel et le reste de l'équipe. Plus l'accès permanent au Discord VIP, aux templates Claude/Gemini/Lovart, aux scripts de closing, et aux replays à vie. Compte ≈ 5h/semaine pour tout consommer.",
    trust: "24+ lives programmés · Replays illimités"
  },
  {
    cat: 'resultats', icon: 'chart',
    q: "En combien de temps je signe mon 1er client ?",
    a: "Médiane actuelle : 28 jours après le début du module. Les plus rapides signent en moins de 7 jours (cf. témoignages Discord : khaldiii999, Medjr19, MC Ley). Ça dépend surtout de ton volume de prospection — mais le système marche.",
    trust: "Résultats certifiés via Discord Focus"
  },
  {
    cat: 'resultats', icon: 'euro',
    q: "Combien je peux réellement espérer gagner ?",
    a: "Fourchettes réelles observées : 1er mois 500-2 500€, 3e mois 3 000-14 000€/mois selon ton investissement. Certains membres dépassent 20k€/mois. Mais ça reste un business — aucune garantie de revenu, que de résultats tangibles si tu appliques.",
    trust: "Chiffres extraits des transactions partagées en Discord"
  },
  {
    cat: 'prix', icon: 'shield',
    q: "Le prix de 500€, c'est vraiment tout ?",
    a: "Paiement unique de 500€ ou 3× sans frais, aucun coût caché, aucune upsell. Tu as accès à 100% du module + communauté + templates + lives + replays pendant 3 mois. Le tarif public hors session est de 2 500€, c'est un prix membre exclusif.",
    trust: "Facture fournie · Paiement sécurisé Stripe"
  },
  {
    cat: 'prix', icon: 'gift',
    q: "Est-ce qu'il y a une garantie si ça ne me convient pas ?",
    a: "Oui — 7 jours satisfait ou remboursé sans justification. Tu rejoins, tu testes le Discord, les 2 premiers lives, les templates. Si tu n'es pas convaincu : 1 email et on te rembourse intégralement. 0% des 847 membres ont demandé un remboursement à ce jour.",
    trust: "7j remboursé — 0% de retour en 2025"
  },
  {
    cat: 'programme', icon: 'spark',
    q: "Quelle différence avec d'autres formations SMMA ?",
    a: "On n'est pas des formateurs. Val, Sonny, Jamel et les autres vivent du SMMA (millions de CA cumulés). Ils montrent leurs chiffres réels, leurs outils réels, leurs clients réels — pas des slides marketing. Communauté > formation.",
    trust: "Équipe active dans le business · Pas des théoriciens"
  },
  {
    cat: 'support', icon: 'chat',
    q: "Comment je te pose une question pendant le module ?",
    a: "Discord Focus VIP (réponse équipe en < 2h en semaine, < 12h le week-end), WhatsApp direct avec Val pour les questions structurantes, et chaque live se termine par un Q&A dédié. Tu ne resteras jamais bloqué plus de 24h.",
    trust: "Délai moyen de réponse : 1h42"
  },
];

const categories: Array<{ id: Cat | 'all'; label: string; icon: string }> = [
  { id: 'all',        label: 'Tout',              icon: '▦' },
  { id: 'programme',  label: 'Programme',         icon: '◐' },
  { id: 'prix',       label: 'Prix & garanties',  icon: '◊' },
  { id: 'resultats',  label: 'Résultats',         icon: '◈' },
  { id: 'support',    label: 'Support',           icon: '◎' },
  { id: 'logistique', label: 'Dates',             icon: '◉' },
];

const catLabels: Record<Cat, string> = {
  programme:  'Programme',
  prix:       'Prix & garanties',
  resultats:  'Résultats',
  support:    'Support',
  logistique: 'Dates',
};
---

<section id="faq" class="fq-section">

  <!-- Halos violets -->
  <div class="fq-halo fq-halo-l" aria-hidden="true"></div>
  <div class="fq-halo fq-halo-r" aria-hidden="true"></div>

  <BrandFloatingIcons icons={["Sparkle", "Claude", "Gemini", "Stripe"]} />

  <div class="fq-inner">

    <!-- Header -->
    <div class="fq-head">
      <div class="fq-badge" data-animate>
        <span class="fq-badge-dot"></span>
        Support 7j/7 · Réponse &lt; 2h
      </div>
      <h2 class="fq-title" data-animate data-delay="0.08">
        Tout ce que tu veux savoir.<br>
        <span class="fq-title-accent">Sans filtre.</span>
      </h2>
      <p class="fq-sub" data-animate data-delay="0.16">
        10 questions qu'on nous pose vraiment. Si la tienne n'y est pas, écris-nous — on répond toujours.
      </p>

      <!-- Trust strip -->
      <div class="fq-trust" data-animate data-delay="0.22">
        <div class="fq-trust-item">
          <div class="fq-trust-val">1&nbsp;247</div>
          <div class="fq-trust-lbl">Questions répondues en 2026</div>
        </div>
        <div class="fq-trust-sep" aria-hidden="true"></div>
        <div class="fq-trust-item">
          <div class="fq-trust-val">&lt; 2h</div>
          <div class="fq-trust-lbl">Délai moyen support</div>
        </div>
        <div class="fq-trust-sep" aria-hidden="true"></div>
        <div class="fq-trust-item">
          <div class="fq-trust-val">100<span class="fq-trust-val-sub">%</span></div>
          <div class="fq-trust-lbl">Satisfaits ou remboursés</div>
        </div>
      </div>
    </div>

    <!-- Barre de recherche + filtres -->
    <div class="fq-controls" data-animate data-delay="0.26">
      <div class="fq-search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
        <input type="search" id="fq-search-input" placeholder="Rechercher : prix, garantie, résultats…" aria-label="Rechercher une question" />
        <button class="fq-search-clear" id="fq-search-clear" aria-label="Effacer la recherche">×</button>
      </div>

      <div class="fq-tabs" role="tablist">
        {categories.map((c, i) => (
          <button class={`fq-tab ${i === 0 ? 'is-active' : ''}`} role="tab" data-filter={c.id}>
            <span class="fq-tab-ic" aria-hidden="true">{c.icon}</span>
            {c.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Liste FAQ -->
    <div class="fq-list">
      {faqs.map((f, i) => (
        <details class="fq-item" data-cat={f.cat} data-animate data-delay={String(0.08 + i * 0.04)}>
          <summary class="fq-q">
            <span class="fq-q-icon" aria-hidden="true">
              {f.icon === 'spark' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.9 6.1L20 10l-6.1 1.9L12 18l-1.9-6.1L4 10l6.1-1.9z"/></svg>}
              {f.icon === 'lightning' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>}
              {f.icon === 'shield' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 5v7c0 5 3.5 9 8 10 4.5-1 8-5 8-10V5z"/></svg>}
              {f.icon === 'euro' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M4 14h12M18 6a8 8 0 1 0 0 12"/></svg>}
              {f.icon === 'chart' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 20h18M6 17v-5M11 17V8M16 17v-3M21 17V5"/></svg>}
              {f.icon === 'clock' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>}
              {f.icon === 'chat' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>}
              {f.icon === 'gift' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v9H4v-9M2 8h20v4H2zM12 22V8M12 8a4 4 0 0 1-4-4 2 2 0 0 1 2-2c2 0 2 2 2 4 0-2 0-4 2-4a2 2 0 0 1 2 2 4 4 0 0 1-4 4z"/></svg>}
              {f.icon === 'cal' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>}
              {f.icon === 'rocket' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11 a6 6 0 0 1 6-6h5v5 a6 6 0 0 1-6 6M9 11 l-3 3 3 3M9 11l4 4M15 7a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/></svg>}
            </span>

            <span class="fq-q-text">
              <span class="fq-cat-pill">{catLabels[f.cat]}</span>
              <span class="fq-q-title">{f.q}</span>
            </span>

            <span class="fq-chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </summary>

          <div class="fq-a">
            <div class="fq-a-text">{f.a}</div>
            {f.trust && (
              <div class="fq-a-trust">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="m9 16.2-3.5-3.6L4 14l5 5L20 8l-1.4-1.4z"/></svg>
                <span>{f.trust}</span>
              </div>
            )}
          </div>
        </details>
      ))}

      <!-- Empty state -->
      <div class="fq-empty" id="fq-empty" hidden>
        <div class="fq-empty-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        </div>
        <div class="fq-empty-title">Aucune question ne correspond</div>
        <div class="fq-empty-sub">Pose-nous la tienne directement, on te répond sous 2h.</div>
      </div>
    </div>

    <!-- Bloc support premium -->
    <div class="fq-support" data-animate>
      <div class="fq-support-top">
        <div class="fq-support-avatars" aria-hidden="true">
          <span class="fq-avt" style="--hue:275">V</span>
          <span class="fq-avt" style="--hue:305">S</span>
          <span class="fq-avt" style="--hue:260">J</span>
        </div>
        <div class="fq-support-heading">
          <div class="fq-support-title">Ta question n'est pas ici ?</div>
          <div class="fq-support-sub">Val, Sonny et l'équipe répondent personnellement sous 2h.</div>
        </div>
      </div>

      <div class="fq-channels">
        <a href="https://wa.me/33600000000" class="fq-channel" target="_blank" rel="noopener">
          <div class="fq-channel-ic" data-type="whatsapp" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11.8 11.8 0 0 0 12.1 0C5.5 0 .1 5.4.1 12c0 2.1.5 4.1 1.6 5.9L0 24l6.3-1.7c1.7 1 3.7 1.5 5.8 1.5 6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.6-8.3zm-8.4 18.4c-1.9 0-3.7-.5-5.2-1.5l-.4-.2-3.7 1 1-3.6-.3-.4A10 10 0 0 1 2.1 12a10 10 0 0 1 17.1-7 10 10 0 0 1-7.1 16.9z"/></svg>
          </div>
          <div class="fq-channel-body">
            <div class="fq-channel-name">WhatsApp direct</div>
            <div class="fq-channel-meta">Val répond personnellement</div>
          </div>
          <svg class="fq-channel-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>

        <a href="#discord" class="fq-channel">
          <div class="fq-channel-ic" data-type="discord" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
          </div>
          <div class="fq-channel-body">
            <div class="fq-channel-name">Discord Focus</div>
            <div class="fq-channel-meta">847 membres actifs</div>
          </div>
          <svg class="fq-channel-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>

        <a href="mailto:contact@smmia.app" class="fq-channel">
          <div class="fq-channel-ic" data-type="mail" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          </div>
          <div class="fq-channel-body">
            <div class="fq-channel-name">Email équipe</div>
            <div class="fq-channel-meta">Réponse sous 2h</div>
          </div>
          <svg class="fq-channel-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

      <a href="#prix" class="fq-final-cta">
        Je rejoins SMMIA — 500€
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Accordéon exclusif + search + filtres
  const items  = Array.from(document.querySelectorAll<HTMLDetailsElement>('.fq-item'));
  const tabs   = Array.from(document.querySelectorAll<HTMLButtonElement>('.fq-tab'));
  const input  = document.getElementById('fq-search-input') as HTMLInputElement | null;
  const clear  = document.getElementById('fq-search-clear') as HTMLButtonElement | null;
  const empty  = document.getElementById('fq-empty');
  const search = document.querySelector('.fq-search');

  let activeCat = 'all';

  // Un seul ouvert à la fois
  items.forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        items.forEach(o => { if (o !== d) o.open = false; });
      }
    });
  });

  // Filtres catégories
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      tabs.forEach(x => x.classList.remove('is-active'));
      t.classList.add('is-active');
      activeCat = t.getAttribute('data-filter') || 'all';
      applyFilters();
    });
  });

  // Recherche
  const applyFilters = () => {
    const q = (input?.value || '').trim().toLowerCase();
    let visible = 0;
    items.forEach(d => {
      const cat = d.getAttribute('data-cat');
      const txt = d.textContent?.toLowerCase() || '';
      const matchCat = activeCat === 'all' || cat === activeCat;
      const matchQ   = !q || txt.includes(q);
      const show = matchCat && matchQ;
      d.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (empty) empty.hidden = visible > 0;
    if (search) search.classList.toggle('has-value', !!q);
  };

  input?.addEventListener('input', applyFilters);
  clear?.addEventListener('click', () => {
    if (input) { input.value = ''; applyFilters(); input.focus(); }
  });
</script>

<style>
  /* ═══════════════ SECTION ═══════════════ */
  .fq-section {
    position: relative;
    padding: 120px 0 128px;
    background: radial-gradient(ellipse at 50% 0%, #0f0622 0%, #070311 60%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .fq-halo {
    position: absolute;
    width: 520px; height: 520px;
    border-radius: 50%;
    filter: blur(110px);
    pointer-events: none;
    z-index: 0;
  }
  .fq-halo-l { top: 10%; left: -160px;  background: radial-gradient(circle, rgba(168, 85, 247, 0.25), transparent 70%); }
  .fq-halo-r { bottom: 8%; right: -160px; background: radial-gradient(circle, rgba(192, 132, 252, 0.20), transparent 70%); }

  .fq-inner {
    position: relative;
    z-index: 2;
    max-width: 920px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── Head ─── */
  .fq-head { text-align: center; margin-bottom: 44px; }

  .fq-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    font-size: 0.72rem;
    font-weight: 700;
    color: #C4B5FD;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }
  .fq-badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.85);
    animation: fq-pulse 2s ease-in-out infinite;
  }
  @keyframes fq-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.3); opacity: 0.65; }
  }

  .fq-title {
    font-size: clamp(1.9rem, 4.4vw, 3.2rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 14px;
  }
  .fq-title-accent {
    background: linear-gradient(135deg, #C084FC 0%, #A855F7 50%, #7C3AED 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .fq-sub {
    max-width: 620px;
    margin: 0 auto 28px;
    color: rgba(255, 255, 255, 0.58);
    font-size: 1rem;
    line-height: 1.55;
  }

  /* ─── Trust strip ─── */
  .fq-trust {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    padding: 14px 24px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(168, 85, 247, 0.22);
    backdrop-filter: blur(10px);
  }
  .fq-trust-item { display: flex; flex-direction: column; align-items: flex-start; gap: 3px; }
  .fq-trust-val {
    font-size: 1.25rem; font-weight: 900; color: #fff; line-height: 1; letter-spacing: -0.02em;
  }
  .fq-trust-val-sub { font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.55); }
  .fq-trust-lbl {
    font-size: 0.64rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.48);
  }
  .fq-trust-sep { width: 1px; height: 26px; background: rgba(255, 255, 255, 0.12); }

  /* ─── Controls : search + tabs ─── */
  .fq-controls {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 28px;
  }

  .fq-search {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px 0 18px;
    height: 52px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: border-color .2s, background .2s;
  }
  .fq-search:focus-within {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: 0 0 0 4px rgba(168, 85, 247, 0.12);
