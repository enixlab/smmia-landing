---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Videos d'avis : deposer les MP4 dans /public/videos/ avec le nom
// "avis-{slug}.mp4" pour qu'ils se chargent automatiquement. Si le fichier
// n'existe pas encore, la carte reste cliquable et montre le poster.

// hook = titre click-bait extrait du contenu réel de la vidéo (lecture des sous-titres incrustés)
const testimonials = [
  {
    slug: "sonny",
    hook: "\"Focus m'a vraiment aidé en e-com\"",
    sub: "Il raconte ce qu'il a appris jour après jour.",
    tag: "E-commerce",
    poster: "/images/portraits-video/sonny.webp",
    posterPos: "15%",
  },
  {
    slug: "jamel",
    hook: "\"L'effet 360, c'est la dinguerie\"",
    sub: "Pourquoi ceux qui testent Focus ne lâchent plus.",
    tag: "Expérience",
    poster: "/images/portraits-video/jamel.webp",
    posterPos: "37%",
  },
  {
    slug: "idriss",
    hook: "\"Ils transmettent comme aucune autre formation\"",
    sub: "Elle était sceptique. Maintenant elle parle sans filtre.",
    tag: "Transmission",
    poster: "/images/portraits-video/idriss.webp",
    posterPos: "32%",
  },
  {
    slug: "moubak",
    hook: "\"Ils m'ont aidé à me recentrer\"",
    sub: "Avant : il dispersait tout. Après : cap clair.",
    tag: "Clarté",
    poster: "/images/portraits-video/moubak.webp",
    posterPos: "46%",
  },
  {
    slug: "val",
    hook: "\"La communauté, l'équipe — c'est ça Focus\"",
    sub: "Le fondateur parle des vraies coulisses.",
    tag: "Fondateur",
    poster: "/images/portraits-video/val.webp",
    posterPos: "43%",
  },
  {
    slug: "lea",
    hook: "\"Plutôt Focus qu'une formation générique\"",
    sub: "Il hésitait. En 3 min, il donne la vraie raison.",
    tag: "Choix",
    poster: "/images/portraits-video/lea.webp",
    posterPos: "56%",
  },
];
---

<section id="video-avis" class="va-section">

  <!-- Pattern & halos de fond -->
  <div class="va-grid" aria-hidden="true"></div>
  <div class="va-halo va-halo-l" aria-hidden="true"></div>
  <div class="va-halo va-halo-r" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["TikTok", "Shopify", "Facebook", "n8n"]} />

  <div class="va-inner">

    <!-- Header -->
    <div class="va-header">
      <div class="va-badge" data-animate>
        <span class="va-badge-dot"></span>
        Ils racontent en vidéo
      </div>

      <h2 class="va-title" data-animate data-delay="0.08">
        La preuve, <span class="va-accent">en direct.</span>
      </h2>

      <p class="va-sub" data-animate data-delay="0.16">
        Pas de capture Trustpilot copiée. Des vraies têtes, des vrais chiffres, des vrais résultats.
      </p>

    </div>

    <!-- Grille de videos -->
    <div class="va-grid-cards" id="va-grid">
      {testimonials.map((t, i) => (
        <button
          class="va-card"
          data-animate
          data-delay={0.04 * i}
          data-video={`/videos/avis-${t.slug}.mp4`}
          data-name={t.hook}
          aria-label={`Lire le témoignage : ${t.hook}`}
        >
          <div class="va-card-media">
            <img
              src={t.poster}
              alt={t.hook}
              loading="lazy"
              class="va-poster"
              style={`object-position: center ${t.posterPos};`}
            />

            <!-- Overlay gradient léger (lisibilité play button) -->
            <div class="va-card-overlay" aria-hidden="true"></div>

            <!-- Bouton play (seul élément conservé sur l'image) -->
            <div class="va-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>

          <div class="va-card-body">
            <h3 class="va-hook">{t.hook}</h3>
            <div class="va-cta-watch">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              Regarder le témoignage
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- CTA bas de section -->
    <div class="va-cta-block" data-animate>
      <p class="va-cta-line">
        Tu as vu leurs résultats.
        <strong>Maintenant c'est à ton tour.</strong>
      </p>
      <a class="va-cta-btn" href="#prix">
        <span class="va-cta-btn-inner">
          Je veux ces résultats
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      <div class="va-cta-trust">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Réservation en moins de 3 min · 10 places restantes
      </div>
    </div>

  </div>

  <!-- Modal lecteur -->
  <div class="va-modal" id="va-modal" aria-hidden="true">
    <button class="va-modal-close" id="va-modal-close" aria-label="Fermer">&times;</button>
    <div class="va-modal-inner">
      <video
        id="va-modal-video"
        controls
        playsinline
        preload="none"
      ></video>
      <div class="va-modal-caption" id="va-modal-caption"></div>
    </div>
  </div>
</section>

<style>
  /* ────────── Section ────────── */
  .va-section {
    position: relative;
    padding: 120px 0 140px;
    background: radial-gradient(ellipse at 50% 0%, #140828 0%, #060211 55%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  @media (max-width: 768px) {
    .va-halo, .va-grid { display: none; }
    .va-card::after { display: none; }
  }

  .va-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    z-index: 2;
  }

  .va-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .va-halo {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .va-halo-l {
    top: 10%;
    left: -10%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 70%);
  }

  .va-halo-r {
    bottom: 10%;
    right: -10%;
    background: radial-gradient(circle, rgba(88, 28, 135, 0.25), transparent 70%);
  }

  /* ────────── Header ────────── */
  .va-header {
    text-align: center;
    margin-bottom: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 24px;
  }

  .va-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: va-dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes va-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .va-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 18px;
  }

  .va-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 6px 30px rgba(168, 85, 247, 0.45));
  }

  .va-sub {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  /* Stats ribbon */
  .va-stats {
    display: inline-flex;
    align-items: center;
    gap: clamp(20px, 4vw, 44px);
    padding: 18px 28px;
    border-radius: 20px;
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.18);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .va-stat {
    text-align: center;
    min-width: 72px;
  }

  .va-stat-value {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, #C084FC);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .va-star {
    color: #FACC15;
    display: inline-flex;
    -webkit-text-fill-color: #FACC15;
  }

  .va-star svg {
    width: 0.8em;
    height: 0.8em;
    filter: drop-shadow(0 0 8px rgba(250, 204, 21, 0.6));
  }

  .va-stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .va-stat-sep {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, rgba(168, 85, 247, 0.5), transparent);
  }

  /* ────────── Grille cards ────────── */
  .va-grid-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .va-card {
    position: relative;
    all: unset;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, rgba(23, 10, 42, 0.6), rgba(10, 6, 21, 0.8));
    border-radius: 22px;
    overflow: hidden;
    cursor: pointer;
    isolation: isolate;
    transition:
      transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.95),
      0 22px 44px -18px rgba(168, 85, 247, 0.55),
      0 10px 24px -8px rgba(124, 58, 237, 0.45),
      inset 0 1px 0 rgba(216, 180, 254, 0.12);
  }

  /* Glow violet qui entoure chaque card (pulse doux) */
  .va-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      120% 80% at 50% 0%,
      rgba(192, 132, 252, 0.22) 0%,
      rgba(168, 85, 247, 0.05) 35%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 2;
  }

  .va-card:hover::after { opacity: 1; }

  /* Bordure gradient */
  .va-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg,
      rgba(192, 132, 252, 0.55) 0%,
      rgba(168, 85, 247, 0.12) 40%,
      rgba(168, 85, 247, 0) 60%,
      rgba(192, 132, 252, 0.35) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
  }

  .va-card:hover {
    transform: translateY(-10px);
    box-shadow:
      0 36px 80px -20px rgba(0, 0, 0, 0.95),
      0 30px 60px -12px rgba(168, 85, 247, 0.7),
      0 14px 28px -6px rgba(124, 58, 237, 0.55),
      inset 0 1px 0 rgba(216, 180, 254, 0.22);
  }

  /* Media */
  .va-card-media {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }

  .va-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1),
                filter 0.6s ease;
    filter: brightness(0.82) saturate(1.08) hue-rotate(-4deg);
  }

  .va-card:hover .va-poster {
    transform: scale(1.06);
    filter: brightness(1) saturate(1.15) hue-rotate(-4deg);
  }

  /* Overlay violet branded léger (plus de texte, donc overlay plus subtil) */
  .va-card-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(100% 70% at 50% 100%, rgba(168, 85, 247, 0.22) 0%, transparent 60%),
      radial-gradient(70% 50% at 10% 0%, rgba(192, 132, 252, 0.16) 0%, transparent 60%),
      linear-gradient(180deg, rgba(14, 6, 26, 0) 0%, rgba(10, 4, 20, 0.18) 100%);
    z-index: 1;
    transition: opacity 0.6s ease;
  }

  /* Play button */
  .va-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 30%, #FFFFFF, #F5F0FF 60%, #E9D5FF 100%);
    color: #1a0627;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    backdrop-filter: blur(4px);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    box-shadow:
      0 14px 50px rgba(168, 85, 247, 0.75),
      0 6px 22px rgba(124, 58, 237, 0.55),
      0 0 0 0 rgba(192, 132, 252, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      transform 0.4s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.4s;
    animation: va-play-pulse 2.2s ease-out infinite;
  }

  .va-play svg {
    width: 28px;
    height: 28px;
    margin-left: 4px;
  }

  @keyframes va-play-pulse {
    0%   { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 0 rgba(192, 132, 252, 0.55); }
    70%  { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 22px rgba(192, 132, 252, 0); }
    100% { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 0 rgba(192, 132, 252, 0); }
  }

  .va-card:hover .va-play {
    transform: translate(-50%, -50%) scale(1.12);
  }

  /* Body — le hook vit ici (plus sur l'image) */
  .va-card-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .va-hook {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.3;
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.012em;
  }

  .va-cta-watch {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    align-self: flex-start;
    color: #C084FC;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: color 0.25s ease, transform 0.3s ease;
  }

  .va-card:hover .va-cta-watch {
    color: #E9D5FF;
    transform: translateX(3px);
  }

  .va-cta-watch svg {
    color: #C084FC;
    filter: drop-shadow(0 0 6px rgba(168, 85, 247, 0.6));
  }

  /* ────────── CTA block ────────── */
  .va-cta-block {
    margin-top: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    text-align: center;
  }

  .va-cta-line {
    margin: 0;
    font-size: clamp(1.1rem, 1.8vw, 1.45rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.4;
    max-width: 620px;
    letter-spacing: -0.01em;
  }

  .va-cta-line strong {
    color: #fff;
    font-weight: 900;
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 50%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .va-cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 20px 40px;
    border-radius: 18px;
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 50%, #6D28D9 100%);
    color: #fff;
    font-size: 1.12rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      0 24px 60px -14px rgba(168, 85, 247, 0.75),
      0 8px 22px -6px rgba(124, 58, 237, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1),
                box-shadow 0.3s;
  }

  .va-cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.32) 50%,
      transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-cta-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow:
      0 32px 80px -12px rgba(168, 85, 247, 0.9),
      0 12px 28px -6px rgba(124, 58, 237, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .va-cta-btn:hover::before { transform: translateX(120%); }

  .va-cta-btn-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .va-cta-trust {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .va-cta-trust svg { color: rgba(192, 132, 252, 0.85); }

  /* ────────── Modal ────────── */
  .va-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 10000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .va-modal.open {
    display: flex;
    opacity: 1;
  }

  .va-modal-inner {
    position: relative;
    width: 100%;
    max-width: 980px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .va-modal video {
    width: 100%;
    height: auto;
    max-height: 80vh;
    border-radius: 18px;
    background: #000;
    box-shadow: 0 40px 100px rgba(168, 85, 247, 0.3);
  }

  .va-modal-caption {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
  }

  .va-modal-close {
    position: absolute;
    top: -56px;
    right: -4px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: all 0.25s;
  }

  .va-modal-close:hover {
    background: rgba(168, 85, 247, 0.25);
    border-color: rgba(168, 85, 247, 0.6);
    transform: scale(1.08);
  }

  /* ────────── Tablette ────────── */
  @media (max-width: 1024px) {
    .va-section { padding: 96px 0 112px; }
    .va-header { margin-bottom: 56px; }
    .va-grid-cards { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .va-play { width: 64px; height: 64px; }
    .va-play svg { width: 24px; height: 24px; }
    .va-halo { width: 380px; height: 380px; filter: blur(80px); }
  }

  /* ────────── Mobile ────────── */
  @media (max-width: 640px) {
    .va-section { padding: 72px 0 88px; }
    .va-header { margin-bottom: 44px; }
    .va-stats { padding: 14px 18px; gap: 18px; border-radius: 16px; }
    .va-stat-sep { height: 28px; }
    .va-grid-cards { grid-template-columns: 1fr; gap: 18px; }
    .va-card-body { padding: 16px 18px 18px; gap: 10px; }
    .va-play { width: 58px; height: 58px; }
    .va-play svg { width: 22px; height: 22px; }
    .va-hook { font-size: 1rem; }
    .va-cta-block { margin-top: 56px; gap: 18px; }
    .va-cta-btn { padding: 17px 30px; font-size: 1.02rem; width: 100%; max-width: 340px; }
    .va-cta-trust { font-size: 0.76rem; text-align: center; }
    .va-modal-close { top: -48px; }
    .va-grid { background-size: 44px 44px; }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .va-play, .va-badge-dot { animation: none; }
    .va-card, .va-poster { transition: none; }
  }
</style>

<script>
  const modal = document.getElementById('va-modal') as HTMLDivElement | null;
  const modalVideo = document.getElementById('va-modal-video') as HTMLVideoElement | null;
  const modalCaption = document.getElementById('va-modal-caption') as HTMLDivElement | null;
  const modalClose = document.getElementById('va-modal-close');

  const cards = document.querySelectorAll<HTMLButtonElement>('.va-card');

  function closeModal() {
    if (!modal || !modalVideo) return;
    modalVideo.pause();
    modalVideo.removeAttribute('src');
    modalVideo.load();
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!modal || !modalVideo || !modalCaption) return;
      const src = card.dataset.video ?? '';
      const name = card.dataset.name ?? '';
      modalVideo.src = src;
      modalCaption.textContent = name;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Auto-play (muted fallback si autoplay bloque)
      modalVideo.play().catch(() => {
        modalVideo.muted = true;
        modalVideo.play().catch(() => {});
      });
    });
  });

  modalClose?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
