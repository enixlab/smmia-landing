---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Videos d'avis : deposer les MP4 dans /public/videos/ avec le nom
// "avis-{slug}.mp4" pour qu'ils se chargent automatiquement. Si le fichier
// n'existe pas encore, la carte reste cliquable et montre le poster.

// hook = titre click-bait extrait du contenu réel de la vidéo (lecture des sous-titres incrustés)
const testimonials = [
  {
    slug: "sonny",
    hook: "\"Focus m'a vraiment aidé en e-com\"",
    sub: "Il raconte ce qu'il a appris jour après jour.",
    tag: "E-commerce",
    poster: "/images/portraits-video/sonny.webp",
    posterPos: "15%",
  },
  {
    slug: "jamel",
    hook: "\"L'effet 360, c'est la dinguerie\"",
    sub: "Pourquoi ceux qui testent Focus ne lâchent plus.",
    tag: "Expérience",
    poster: "/images/portraits-video/jamel.webp",
    posterPos: "37%",
  },
  {
    slug: "idriss",
    hook: "\"Ils transmettent comme aucune autre formation\"",
    sub: "Elle était sceptique. Maintenant elle parle sans filtre.",
    tag: "Transmission",
    poster: "/images/portraits-video/idriss.webp",
    posterPos: "32%",
  },
  {
    slug: "moubak",
    hook: "\"Ils m'ont aidé à me recentrer\"",
    sub: "Avant : il dispersait tout. Après : cap clair.",
    tag: "Clarté",
    poster: "/images/portraits-video/moubak.webp",
    posterPos: "46%",
  },
  {
    slug: "val",
    hook: "\"La communauté, l'équipe — c'est ça Focus\"",
    sub: "Le fondateur parle des vraies coulisses.",
    tag: "Fondateur",
    poster: "/images/portraits-video/val.webp",
    posterPos: "43%",
  },
  {
    slug: "lea",
    hook: "\"Plutôt Focus qu'une formation générique\"",
    sub: "Il hésitait. En 3 min, il donne la vraie raison.",
    tag: "Choix",
    poster: "/images/portraits-video/lea.webp",
    posterPos: "56%",
  },
];
---

<section id="video-avis" class="va-section">

  <!-- Pattern & halos de fond -->
  <div class="va-grid" aria-hidden="true"></div>
  <div class="va-halo va-halo-l" aria-hidden="true"></div>
  <div class="va-halo va-halo-r" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["TikTok", "Shopify", "Facebook", "n8n"]} />

  <div class="va-inner">

    <!-- Header -->
    <div class="va-header">
      <div class="va-badge" data-animate>
        <span class="va-badge-dot"></span>
        Ils racontent en vidéo
      </div>

      <h2 class="va-title" data-animate data-delay="0.08">
        La preuve, <span class="va-accent">en direct.</span>
      </h2>

      <p class="va-sub" data-animate data-delay="0.16">
        Pas de capture Trustpilot copiée. Des vraies têtes, des vrais chiffres, des vrais résultats.
      </p>

    </div>

    <!-- Grille de videos -->
    <div class="va-grid-cards" id="va-grid">
      {testimonials.map((t, i) => (
        <button
          class="va-card"
          data-animate
          data-delay={0.04 * i}
          data-video={`/videos/avis-${t.slug}.mp4`}
          data-name={t.hook}
          aria-label={`Lire le témoignage : ${t.hook}`}
        >
          <div class="va-card-media">
            <img
              src={t.poster}
              alt={t.hook}
              loading="lazy"
              class="va-poster"
              style={`object-position: center ${t.posterPos};`}
            />

            <!-- Overlay gradient léger (lisibilité play button) -->
            <div class="va-card-overlay" aria-hidden="true"></div>

            <!-- Bouton play (seul élément conservé sur l'image) -->
            <div class="va-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>

          <div class="va-card-body">
            <h3 class="va-hook">{t.hook}</h3>
            <div class="va-cta-watch">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              Regarder le témoignage
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- CTA bas de section (card premium) -->
    <div class="va-cta-card" data-animate>

      <!-- Eyebrow scarcity -->
      <div class="va-cta-eyebrow">
        <span class="va-cta-eyebrow-dot"></span>
        Session Mai 2026 · <strong>10 places restantes</strong>
      </div>

      <!-- Headline -->
      <h3 class="va-cta-headline">
        Tu as vu leurs résultats.<br>
        <span class="va-cta-headline-accent">Maintenant c'est ton tour.</span>
      </h3>

      <!-- Sub -->
      <p class="va-cta-sub">
        Rejoins 847 membres déjà passés à l'action. 3 mois d'accès · lives en direct · garantie 14j.
      </p>

      <!-- CTA + secondary -->
      <div class="va-cta-actions">
        <a class="va-cta-btn" href="#prix">
          <span class="va-cta-btn-inner">
            Je veux ces résultats
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a class="va-cta-secondary" href="https://wa.me/33766814280" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11.8 11.8 0 0 0 12.1 0C5.5 0 .1 5.4.1 12c0 2.1.5 4.1 1.6 5.9L0 24l6.3-1.7c1.7 1 3.7 1.5 5.8 1.5 6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.6-8.3zm-5.6 13.5c-.3.7-1.6 1.4-2.2 1.4-.6 0-1.3.1-2.1-.1-.5-.2-1.1-.4-1.9-.7-3.3-1.4-5.5-4.7-5.6-4.9-.2-.2-1.4-1.9-1.4-3.6 0-1.7.9-2.6 1.2-2.9.3-.3.7-.4.9-.4h.7c.2 0 .5-.1.8.6.3.7.9 2.4 1 2.5.1.2.1.4 0 .6-.1.2-.2.3-.3.5-.2.2-.3.4-.5.6-.2.2-.3.4-.1.7.2.3.9 1.5 2 2.4 1.4 1.2 2.6 1.6 2.9 1.8.3.2.5.1.7-.1.2-.2.8-.9 1-1.2.2-.3.4-.3.7-.2.3.1 1.9.9 2.3 1 .3.2.5.2.6.4.1.1.1.8-.2 1.5z"/></svg>
          Parler à Val
        </a>
      </div>

      <!-- Trust row : 3 signals -->
      <div class="va-cta-signals">
        <div class="va-cta-signal">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Réservation en 3 min
        </div>
        <span class="va-cta-signal-sep" aria-hidden="true"></span>
        <div class="va-cta-signal">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 2l7 4v6c0 4-3 8-7 10-4-2-7-6-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
          Paiement sécurisé
        </div>
        <span class="va-cta-signal-sep" aria-hidden="true"></span>
        <div class="va-cta-signal">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          Remboursé 14j
        </div>
      </div>

    </div>

  </div>

  <!-- Modal lecteur -->
  <div class="va-modal" id="va-modal" aria-hidden="true">
    <button class="va-modal-close" id="va-modal-close" aria-label="Fermer">&times;</button>
    <div class="va-modal-inner">
      <video
        id="va-modal-video"
        controls
        playsinline
        preload="none"
      ></video>
      <div class="va-modal-caption" id="va-modal-caption"></div>
    </div>
  </div>
</section>

<style>
  /* ────────── Section ────────── */
  .va-section {
    position: relative;
    padding: 120px 0 140px;
    background: radial-gradient(ellipse at 50% 0%, #140828 0%, #060211 55%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  @media (max-width: 768px) {
    .va-halo, .va-grid { display: none; }
    .va-card::after { display: none; }
  }

  .va-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    z-index: 2;
  }

  .va-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .va-halo {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .va-halo-l {
    top: 10%;
    left: -10%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 70%);
  }

  .va-halo-r {
    bottom: 10%;
    right: -10%;
    background: radial-gradient(circle, rgba(88, 28, 135, 0.25), transparent 70%);
  }

  /* ────────── Header ────────── */
  .va-header {
    text-align: center;
    margin-bottom: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 24px;
  }

  .va-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: va-dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes va-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .va-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 18px;
  }

  .va-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 6px 30px rgba(168, 85, 247, 0.45));
  }

  .va-sub {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  /* Stats ribbon */
  .va-stats {
    display: inline-flex;
    align-items: center;
    gap: clamp(20px, 4vw, 44px);
    padding: 18px 28px;
    border-radius: 20px;
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.18);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .va-stat {
    text-align: center;
    min-width: 72px;
  }

  .va-stat-value {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, #C084FC);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .va-star {
    color: #FACC15;
    display: inline-flex;
    -webkit-text-fill-color: #FACC15;
  }

  .va-star svg {
    width: 0.8em;
    height: 0.8em;
    filter: drop-shadow(0 0 8px rgba(250, 204, 21, 0.6));
  }

  .va-stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .va-stat-sep {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, rgba(168, 85, 247, 0.5), transparent);
  }

  /* ────────── Grille cards ────────── */
  .va-grid-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .va-card {
    position: relative;
    all: unset;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, rgba(23, 10, 42, 0.6), rgba(10, 6, 21, 0.8));
    border-radius: 22px;
    overflow: hidden;
    cursor: pointer;
    isolation: isolate;
    transition:
      transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.95),
      0 22px 44px -18px rgba(168, 85, 247, 0.55),
      0 10px 24px -8px rgba(124, 58, 237, 0.45),
      inset 0 1px 0 rgba(216, 180, 254, 0.12);
  }

  /* Glow violet qui entoure chaque card (pulse doux) */
  .va-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      120% 80% at 50% 0%,
      rgba(192, 132, 252, 0.22) 0%,
      rgba(168, 85, 247, 0.05) 35%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 2;
  }

  .va-card:hover::after { opacity: 1; }

  /* Bordure gradient */
  .va-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg,
      rgba(192, 132, 252, 0.55) 0%,
      rgba(168, 85, 247, 0.12) 40%,
      rgba(168, 85, 247, 0) 60%,
      rgba(192, 132, 252, 0.35) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
  }

  .va-card:hover {
    transform: translateY(-10px);
    box-shadow:
      0 36px 80px -20px rgba(0, 0, 0, 0.95),
      0 30px 60px -12px rgba(168, 85, 247, 0.7),
      0 14px 28px -6px rgba(124, 58, 237, 0.55),
      inset 0 1px 0 rgba(216, 180, 254, 0.22);
  }

  /* Media */
  .va-card-media {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }

  .va-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1),
                filter 0.6s ease;
    filter: brightness(0.82) saturate(1.08) hue-rotate(-4deg);
  }

  .va-card:hover .va-poster {
    transform: scale(1.06);
    filter: brightness(1) saturate(1.15) hue-rotate(-4deg);
  }

  /* Overlay violet branded léger (plus de texte, donc overlay plus subtil) */
  .va-card-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(100% 70% at 50% 100%, rgba(168, 85, 247, 0.22) 0%, transparent 60%),
      radial-gradient(70% 50% at 10% 0%, rgba(192, 132, 252, 0.16) 0%, transparent 60%),
      linear-gradient(180deg, rgba(14, 6, 26, 0) 0%, rgba(10, 4, 20, 0.18) 100%);
    z-index: 1;
    transition: opacity 0.6s ease;
  }

  /* Play button */
  .va-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 30%, #FFFFFF, #F5F0FF 60%, #E9D5FF 100%);
    color: #1a0627;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    backdrop-filter: blur(4px);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    box-shadow:
      0 14px 50px rgba(168, 85, 247, 0.75),
      0 6px 22px rgba(124, 58, 237, 0.55),
      0 0 0 0 rgba(192, 132, 252, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      transform 0.4s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.4s;
    animation: va-play-pulse 2.2s ease-out infinite;
  }

  .va-play svg {
    width: 28px;
    height: 28px;
    margin-left: 4px;
  }

  @keyframes va-play-pulse {
    0%   { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 0 rgba(192, 132, 252, 0.55); }
    70%  { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 22px rgba(192, 132, 252, 0); }
    100% { box-shadow: 0 10px 40px rgba(168, 85, 247, 0.55), 0 0 0 0 rgba(192, 132, 252, 0); }
  }

  .va-card:hover .va-play {
    transform: translate(-50%, -50%) scale(1.12);
  }

  /* Body — le hook vit ici (plus sur l'image) */
  .va-card-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .va-hook {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.3;
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.012em;
  }

  .va-cta-watch {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    align-self: flex-start;
    color: #C084FC;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: color 0.25s ease, transform 0.3s ease;
  }

  .va-card:hover .va-cta-watch {
    color: #E9D5FF;
    transform: translateX(3px);
  }

  .va-cta-watch svg {
    color: #C084FC;
    filter: drop-shadow(0 0 6px rgba(168, 85, 247, 0.6));
  }

  /* ────────── CTA card premium ────────── */
  .va-cta-card {
    position: relative;
    margin: 80px auto 0;
    max-width: 760px;
    padding: 48px clamp(28px, 4vw, 56px);
    border-radius: 28px;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(168, 85, 247, 0.18) 0%, transparent 60%),
      linear-gradient(180deg, rgba(22, 10, 40, 0.85) 0%, rgba(10, 4, 20, 0.9) 100%);
    border: 1px solid rgba(168, 85, 247, 0.32);
    box-shadow:
      0 40px 100px -30px rgba(168, 85, 247, 0.45),
      0 16px 40px -12px rgba(88, 28, 135, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  /* Glow interne animé au top (halo violet) */
  .va-cta-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(192, 132, 252, 0.85), transparent);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.8);
  }

  /* Eyebrow scarcity */
  .va-cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(239, 68, 68, 0.14);
    border: 1px solid rgba(239, 68, 68, 0.4);
    color: #FECACA;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .va-cta-eyebrow strong { color: #FCA5A5; font-weight: 800; }

  .va-cta-eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #EF4444;
    box-shadow: 0 0 10px #EF4444;
    animation: va-scarcity-pulse 1.4s ease-in-out infinite;
  }

  @keyframes va-scarcity-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  /* Headline */
  .va-cta-headline {
    margin: 0 0 14px;
    font-size: clamp(1.7rem, 3.2vw, 2.6rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.88);
  }

  .va-cta-headline-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 45%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Sub */
  .va-cta-sub {
    margin: 0 auto 32px;
    max-width: 520px;
    font-size: 0.98rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  /* Actions row */
  .va-cta-actions {
