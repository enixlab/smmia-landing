  }
  .va-cta-signal svg { color: rgba(192, 132, 252, 0.85); }

  .va-cta-signal-sep {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.35);
  }

  /* ────────── Modal ────────── */
  .va-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 10000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .va-modal.open {
    display: flex;
    opacity: 1;
  }

  .va-modal-inner {
    position: relative;
    width: 100%;
    max-width: 980px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .va-modal video {
    width: 100%;
    height: auto;
    max-height: 80vh;
    border-radius: 18px;
    background: #000;
    box-shadow: 0 40px 100px rgba(168, 85, 247, 0.3);
  }

  .va-modal-caption {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
  }

  .va-modal-close {
    position: absolute;
    top: -56px;
    right: -4px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
