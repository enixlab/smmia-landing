---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Videos d'avis : deposer les MP4 dans /public/videos/ avec le nom
// "avis-{slug}.mp4" pour qu'ils se chargent automatiquement. Si le fichier
// n'existe pas encore, la carte reste cliquable et montre le poster.

// hook = titre click-bait extrait du contenu réel de la vidéo (lecture des sous-titres incrustés)
const testimonials = [
  {
    slug: "mohamed-ali",
    hook: "\"+3K€/mois en 5 semaines SMMIA\"",
    sub: "Ticket moyen ×3 après le module Offre IA.",
    tag: "+3K€/mois",
    poster: "/images/portraits-video/mohamed-ali.webp",
    posterPos: "30%",
  },
  {
    slug: "oumya",
    hook: "\"2 clients signés dès la 1ère semaine SMMIA\"",
    sub: "Scripts Closing appliqués, résultats immédiats.",
    tag: "2 clients",
    poster: "/images/portraits-video/oumya.webp",
    posterPos: "30%",
  },
  {
    slug: "rm",
    hook: "\"Ticket 350€ → 1 200€ avec SMMIA\"",
    sub: "Packaging refait, prospects signent sans négocier.",
    tag: "×3,4 ticket",
    poster: "/images/portraits-video/rm.webp",
    posterPos: "30%",
  },
  {
    slug: "awais",
    hook: "\"5 retainers signés en 3 semaines SMMIA\"",
    sub: "MRR sécurisé avant la fin du module.",
    tag: "5 retainers",
    poster: "/images/portraits-video/awais.webp",
    posterPos: "30%",
  },
  {
    slug: "velox",
    hook: "\"CA mensuel ×3 grâce au module SMMIA\"",
    sub: "Agents IA déployés, capacité +70%.",
    tag: "×3 CA",
    poster: "/images/portraits-video/velox.webp",
    posterPos: "30%",
  },
  {
    slug: "oussmane",
    hook: "\"Revenus ×2 en 60 jours grâce à SMMIA\"",
    sub: "Workflows IA : 3h gagnées par jour.",
    tag: "×2 revenus",
    poster: "/images/portraits-video/oussmane.webp",
    posterPos: "30%",
  },
];
const rowA = testimonials;
---

<section id="video-avis" class="va-section">

  <!-- Pattern -->
  <div class="va-grid" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["TikTok", "Shopify", "Facebook", "n8n"]} />

  <div class="va-inner">

    <!-- Header -->
    <div class="va-header">
      <div class="va-badge" data-animate>
        <span class="va-badge-dot"></span>
        Ils racontent en vidéo
      </div>

      <h2 class="va-title" data-animate data-delay="0.08">
        La preuve, <span class="va-accent">en direct.</span>
      </h2>

      <p class="va-sub" data-animate data-delay="0.16">
        Pas de capture Trustpilot copiée. Des vraies têtes, des vrais chiffres, des vrais résultats.
      </p>

    </div>

    <!-- Marquee vidéos : 1 seule ligne -->
    <div class="va-marquee-wrap" data-animate>

      <!-- Fade edges (masque pour effet "flottant") -->
      <div class="va-marquee-fade va-marquee-fade--l" aria-hidden="true"></div>
      <div class="va-marquee-fade va-marquee-fade--r" aria-hidden="true"></div>

      <!-- Ligne unique : défile vers la gauche -->
      <div class="va-marquee-track va-marquee-track--l">
        {[...rowA, ...rowA, ...rowA].map((t) => (
          <button
            class="va-card"
            data-video={`/videos/avis-${t.slug}.mp4`}
            data-name={t.hook}
            aria-label={`Lire le témoignage : ${t.hook}`}
          >
            <div class="va-card-media">
              <img
                src={t.poster}
                alt={t.hook}
                loading="lazy"
                class="va-poster"
                style={`object-position: center ${t.posterPos};`}
              />

              <!-- Overlay : un seul gradient bottom pour lisibilité du hook -->
              <div class="va-card-overlay" aria-hidden="true"></div>

              <!-- Badge métrique (top-left) — épuré -->
              <div class="va-metric-badge" aria-hidden="true">
                {t.tag}
              </div>

              <!-- Play button simple -->
              <div class="va-play" aria-hidden="true">
                <span class="va-play-core">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </span>
              </div>

              <!-- Bas de poster : hook propre -->
              <div class="va-card-footer">
                <h3 class="va-hook">{t.hook}</h3>
                <div class="va-cta-watch">Regarder le témoignage</div>
              </div>
            </div>
          </button>
        ))}
      </div>

    </div>

  </div>

  <!-- Modal lecteur -->
  <div class="va-modal" id="va-modal" aria-hidden="true">
    <button class="va-modal-close" id="va-modal-close" aria-label="Fermer">&times;</button>
    <div class="va-modal-inner">
      <video
        id="va-modal-video"
        controls
        playsinline
        preload="none"
      ></video>
      <div class="va-modal-caption" id="va-modal-caption"></div>
    </div>
  </div>
</section>

<!-- CTA hors-section : fond noir pur, zéro bordure violette -->
<div class="va-cta-outer">
    <div class="va-cta-card" data-animate>

      <!-- Eyebrow scarcity -->
      <div class="va-cta-eyebrow">
        <span class="va-cta-eyebrow-dot"></span>
        Session Mai 2026 · <strong>10 places restantes</strong>
      </div>

      <!-- Headline -->
      <h3 class="va-cta-headline">
        Tu as vu leurs résultats.<br>
        <span class="va-cta-headline-accent">Maintenant c'est ton tour.</span>
      </h3>

      <!-- Sub -->
      <p class="va-cta-sub">
        Rejoins 847 membres déjà passés à l'action. 3 mois d'accès · lives en direct · garantie 14j.
      </p>

      <!-- CTA principal -->
      <div class="va-cta-actions">
        <a class="va-cta-btn" href="#prix">
          <span class="va-cta-btn-inner">
            Je veux ces résultats
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>

    </div>
  </div>

<style>
  /* ────────── Section ────────── */
  .va-section {
    position: relative;
    padding: 120px 0 60px;
    background: radial-gradient(ellipse at 50% 0%, #140828 0%, #060211 55%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  /* Light mode section background */
  :global([data-theme="light"]) .va-section {
    background: radial-gradient(ellipse at 50% 0%, #F5F0FF 0%, #FAFAFC 55%, #FFFFFF 100%);
  }

  @media (max-width: 768px) {
    .va-grid { display: none; }
  }

  .va-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    z-index: 2;
  }

  .va-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="light"]) .va-grid {
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.08) 1px, transparent 1px);
  }

  /* ────────── Header ────────── */
  .va-header {
    text-align: center;
    margin-bottom: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 24px;
  }

  :global([data-theme="light"]) .va-badge {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.3);
    color: #7C3AED;
  }

  .va-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: va-dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes va-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .va-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 18px;
  }

  :global([data-theme="light"]) .va-title {
    color: #0A0418;
  }

  .va-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  :global([data-theme="light"]) .va-accent {
    background: linear-gradient(135deg, #7C3AED 0%, #A855F7 50%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .va-sub {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  :global([data-theme="light"]) .va-sub {
    color: rgba(10, 4, 24, 0.65);
  }

  /* ────────── Marquee vidéos — 1 ligne ────────── */
  .va-marquee-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    padding: 30px 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Fade edges — masques gauche/droite pour effet "cards flottent dans le fade" */
  .va-marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 14%;
    pointer-events: none;
    z-index: 5;
  }
  .va-marquee-fade--l {
    left: 0;
    background: linear-gradient(90deg, #060211 0%, rgba(6, 2, 17, 0.8) 40%, transparent 100%);
  }
  .va-marquee-fade--r {
    right: 0;
    background: linear-gradient(-90deg, #060211 0%, rgba(6, 2, 17, 0.8) 40%, transparent 100%);
  }

  :global([data-theme="light"]) .va-marquee-fade--l {
    background: linear-gradient(90deg, #FAFAFC 0%, rgba(250, 250, 252, 0.8) 40%, transparent 100%);
  }
  :global([data-theme="light"]) .va-marquee-fade--r {
    background: linear-gradient(-90deg, #FAFAFC 0%, rgba(250, 250, 252, 0.8) 40%, transparent 100%);
  }

  .va-marquee-track {
    display: flex;
    gap: 28px;
    width: max-content;
    will-change: transform;
  }
  .va-marquee-track--l {
    animation: va-marquee-l 30s linear infinite;
  }
  .va-marquee-track--r {
    animation: va-marquee-r 34s linear infinite;
    margin-left: -8%;
  }
  .va-marquee-wrap:hover .va-marquee-track,
  .va-marquee-wrap:focus-within .va-marquee-track {
    animation-play-state: paused;
  }
  @keyframes va-marquee-l {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes va-marquee-r {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .va-marquee-track { animation: none; }
  }

  /* ────────── CARD — format éditorial élancé 3:5 ────────── */
  .va-card {
    position: relative;
    all: unset;
    flex: 0 0 auto;
    width: 300px;
    aspect-ratio: 3 / 5;
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    isolation: isolate;
    transition:
      transform 0.5s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  :global([data-theme="light"]) .va-card {
    box-shadow: 0 12px 32px -12px rgba(24, 10, 48, 0.18);
    border: 1px solid rgba(10, 4, 24, 0.06);
  }

  .va-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 24px 56px -16px rgba(0, 0, 0, 0.7);
  }

  :global([data-theme="light"]) .va-card:hover {
    box-shadow: 0 20px 48px -16px rgba(24, 10, 48, 0.25);
  }

  /* Media : la card EST le poster, tout est en overlay */
  .va-card-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
  }

  .va-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-card:hover .va-poster {
    transform: scale(1.04);
  }

  /* Overlay simple : un seul gradient bottom pour lisibilité du hook */
  .va-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(8, 4, 20, 0) 0%,
      rgba(8, 4, 20, 0) 45%,
      rgba(8, 4, 20, 0.55) 75%,
      rgba(8, 4, 20, 0.9) 100%);
    z-index: 1;
  }

  /* ────────── Metric badge (top-left) — épuré ────────── */
  .va-metric-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    padding: 6px 11px;
    border-radius: 6px;
    background: #7C3AED;
    color: #fff;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: -0.005em;
    line-height: 1;
  }

  /* ────────── PLAY BUTTON — propre, rond, un seul shadow ────────── */
  .va-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68px;
    height: 68px;
    z-index: 3;
    pointer-events: none;
    transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-play-core {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.95);
    color: #1a0627;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1),
                background 0.3s ease;
  }

  .va-play-core svg {
    width: 24px;
    height: 24px;
    margin-left: 3px;
  }

  .va-card:hover .va-play {
    transform: translate(-50%, -50%) scale(1.06);
  }

  /* Pulse UNIQUEMENT au hover */
  .va-card:hover .va-play-core {
    animation: va-play-pulse 2s ease-in-out infinite;
  }
  @keyframes va-play-pulse {
    0%, 100% { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35); }
    50%      { box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45); }
  }

  /* ────────── Card footer (bas poster) — hook + CTA sobre ────────── */
  .va-card-footer {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    padding: 18px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .va-hook {
    font-size: 1rem;
    line-height: 1.3;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .va-cta-watch {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ────────── CTA hors-section (fond noir pur) ────────── */
  .va-cta-outer {
    background: #000;
    padding: 96px 24px 120px;
  }

  :global([data-theme="light"]) .va-cta-outer {
    background: #FFFFFF;
  }

  /* ────────── CTA card premium rectangulaire ────────── */
  .va-cta-card {
    position: relative;
    margin: 0 auto;
    max-width: 960px;
    padding: 44px clamp(32px, 5vw, 72px);
    border-radius: 24px;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(168, 85, 247, 0.18) 0%, transparent 60%),
      linear-gradient(180deg, rgba(22, 10, 40, 0.85) 0%, rgba(10, 4, 20, 0.9) 100%);
    border: 1px solid rgba(168, 85, 247, 0.32);
    box-shadow:
      0 40px 100px -30px rgba(168, 85, 247, 0.45),
      0 16px 40px -12px rgba(88, 28, 135, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  :global([data-theme="light"]) .va-cta-card {
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(168, 85, 247, 0.1) 0%, transparent 60%),
      linear-gradient(180deg, #FFFFFF 0%, #FAFAFC 100%);
    border: 1px solid rgba(168, 85, 247, 0.25);
    box-shadow:
      0 40px 100px -30px rgba(124, 58, 237, 0.3),
      0 16px 40px -12px rgba(168, 85, 247, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  /* Glow interne animé au top (halo violet) */
  .va-cta-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(192, 132, 252, 0.85), transparent);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.8);
  }

  /* Eyebrow scarcity (violet) */
  .va-cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.14);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #C4B5FD;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .va-cta-eyebrow strong { color: #E9D5FF; font-weight: 800; }

  :global([data-theme="light"]) .va-cta-eyebrow {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.3);
    color: #7C3AED;
  }
  :global([data-theme="light"]) .va-cta-eyebrow strong { color: #6D28D9; }

  .va-cta-eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 10px #A855F7;
    animation: va-scarcity-pulse 1.4s ease-in-out infinite;
  }

  @keyframes va-scarcity-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  /* Headline */
  .va-cta-headline {
    margin: 0 0 14px;
    font-size: clamp(1.7rem, 3.2vw, 2.6rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.88);
  }

  :global([data-theme="light"]) .va-cta-headline {
    color: #0A0418;
  }

  .va-cta-headline-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 45%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  :global([data-theme="light"]) .va-cta-headline-accent {
    background: linear-gradient(135deg, #7C3AED 0%, #A855F7 50%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Sub */
  .va-cta-sub {
    margin: 0 auto 32px;
    max-width: 520px;
    font-size: 0.98rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  :global([data-theme="light"]) .va-cta-sub {
    color: rgba(10, 4, 24, 0.65);
  }

  /* Actions row */
  .va-cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .va-cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 36px;
    border-radius: 16px;
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 50%, #6D28D9 100%);
    color: #fff;
    font-size: 1.06rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      0 22px 56px -14px rgba(168, 85, 247, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1), box-shadow 0.3s;
  }

  .va-cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgba(255, 255, 255, 0.3) 50%, transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-cta-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 32px 80px -10px rgba(168, 85, 247, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .va-cta-btn:hover::before { transform: translateX(120%); }

  .va-cta-btn-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  /* ────────── Modal ────────── */
  .va-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 10000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .va-modal.open {
    display: flex;
    opacity: 1;
  }

  .va-modal-inner {
    position: relative;
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .va-modal video {
    width: 100%;
    height: auto;
    max-height: 80vh;
    border-radius: 18px;
    background: #000;
    box-shadow: 0 40px 100px rgba(168, 85, 247, 0.3);
  }

  .va-modal-caption {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
  }

  .va-modal-close {
    position: absolute;
    top: -56px;
    right: -4px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: all 0.25s;
  }

  .va-modal-close:hover {
    background: rgba(168, 85, 247, 0.25);
    border-color: rgba(168, 85, 247, 0.6);
    transform: scale(1.08);
  }

  /* ────────── Tablette ────────── */
  @media (max-width: 1024px) {
    .va-section { padding: 96px 0 112px; }
    .va-header { margin-bottom: 56px; }
    .va-card { width: 260px; border-radius: 16px; }
    .va-marquee-wrap { gap: 22px; }
    .va-marquee-track { gap: 22px; }
    .va-marquee-track--l { animation-duration: 48s; }
    .va-marquee-track--r { animation-duration: 54s; }
    .va-play { width: 60px; height: 60px; }
    .va-play-core svg { width: 22px; height: 22px; }
    .va-metric-badge { font-size: 0.7rem; padding: 5px 10px; }
    .va-hook { font-size: 0.94rem; }
  }

  /* ────────── Mobile ────────── */
  @media (max-width: 640px) {
    .va-section { padding: 72px 0 88px; }
    .va-header { margin-bottom: 44px; }
    .va-card { width: 220px; border-radius: 14px; }
    .va-marquee-wrap { gap: 16px; padding: 20px 0; }
    .va-marquee-track { gap: 16px; }
    .va-marquee-track--l { animation-duration: 40s; }
    .va-marquee-track--r { animation-duration: 46s; }
    .va-play { width: 56px; height: 56px; }
    .va-play-core svg { width: 20px; height: 20px; margin-left: 2px; }
    .va-card-footer { padding: 14px 14px 14px; gap: 5px; }
    .va-hook { font-size: 0.88rem; }
    .va-cta-watch { font-size: 0.68rem; }
    .va-metric-badge { font-size: 0.66rem; padding: 5px 9px; top: 12px; left: 12px; }
    .va-cta-outer { padding: 64px 20px 80px; }
    .va-cta-card { padding: 32px 22px; border-radius: 20px; }
    .va-cta-headline { font-size: clamp(1.45rem, 5.5vw, 1.85rem); }
    .va-cta-sub { font-size: 0.92rem; margin-bottom: 24px; }
    .va-cta-actions { flex-direction: column; width: 100%; gap: 10px; }
    .va-cta-btn { padding: 16px 24px; font-size: 1rem; width: 100%; }
    .va-modal-close { top: -48px; }
    .va-grid { background-size: 44px 44px; }
    .va-marquee-fade { width: 8%; }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .va-badge-dot { animation: none; }
    .va-card, .va-poster { transition: none; }
  }
</style>

<script>
  const modal = document.getElementById('va-modal') as HTMLDivElement | null;
  const modalVideo = document.getElementById('va-modal-video') as HTMLVideoElement | null;
  const modalCaption = document.getElementById('va-modal-caption') as HTMLDivElement | null;
  const modalClose = document.getElementById('va-modal-close');

  const cards = document.querySelectorAll<HTMLButtonElement>('.va-card');

  function closeModal() {
    if (!modal || !modalVideo) return;
    modalVideo.pause();
    modalVideo.removeAttribute('src');
    modalVideo.load();
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!modal || !modalVideo || !modalCaption) return;
      const src = card.dataset.video ?? '';
      const name = card.dataset.name ?? '';
      modalVideo.src = src;
      modalCaption.textContent = name;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Auto-play (muted fallback si autoplay bloque)
      modalVideo.play().catch(() => {
        modalVideo.muted = true;
        modalVideo.play().catch(() => {});
      });
    });
  });

  modalClose?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
