    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 50%, #6D28D9 100%);
    color: #fff;
    font-size: 1.06rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      0 22px 56px -14px rgba(168, 85, 247, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1), box-shadow 0.3s;
  }

  .va-cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgba(255, 255, 255, 0.3) 50%, transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-cta-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 32px 80px -10px rgba(168, 85, 247, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .va-cta-btn:hover::before { transform: translateX(120%); }

  .va-cta-btn-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .va-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 18px 24px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.25s, border-color 0.25s, color 0.25s, transform 0.25s;
  }
  .va-cta-secondary:hover {
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(34, 197, 94, 0.5);
    color: #86EFAC;
    transform: translateY(-2px);
  }
  .va-cta-secondary svg { color: #22C55E; }

  /* Trust signals row */
  .va-cta-signals {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px 16px;
    padding-top: 22px;
