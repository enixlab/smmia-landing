    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: all 0.25s;
  }

  .va-modal-close:hover {
    background: rgba(168, 85, 247, 0.25);
    border-color: rgba(168, 85, 247, 0.6);
    transform: scale(1.08);
  }

  /* ────────── Tablette ────────── */
  @media (max-width: 1024px) {
    .va-section { padding: 96px 0 112px; }
    .va-header { margin-bottom: 56px; }
    .va-card { width: 320px; border-radius: 24px; }
    .va-marquee-wrap { gap: 22px; }
    .va-marquee-track { gap: 22px; }
    .va-marquee-track--l { animation-duration: 58s; }
    .va-marquee-track--r { animation-duration: 64s; }
    .va-play { width: 80px; height: 80px; }
    .va-play-core svg { width: 28px; height: 28px; }
    .va-halo { width: 380px; height: 380px; filter: blur(80px); }
    .va-metric-badge { font-size: 0.72rem; padding: 7px 11px; }
    .va-hook { font-size: 1rem; }
  }

  /* ────────── Mobile ────────── */
  @media (max-width: 640px) {
    .va-section { padding: 72px 0 88px; }
    .va-header { margin-bottom: 44px; }
    .va-card { width: 260px; border-radius: 20px; }
    .va-marquee-wrap { gap: 16px; padding: 20px 0; }
    .va-marquee-track { gap: 16px; }
    .va-marquee-track--l { animation-duration: 44s; }
    .va-marquee-track--r { animation-duration: 50s; }
    .va-play { width: 68px; height: 68px; }
    .va-play-core svg { width: 24px; height: 24px; margin-left: 4px; }
    .va-card-footer { padding: 16px 16px 16px; gap: 8px; }
    .va-hook { font-size: 0.92rem; }
    .va-cta-watch { font-size: 0.66rem; padding: 5px 10px; }
    .va-metric-badge { font-size: 0.68rem; padding: 6px 10px; top: 12px; left: 12px; }
    .va-live-badge { font-size: 0.6rem; padding: 5px 9px; top: 12px; right: 12px; }
    .va-cta-outer { padding: 64px 20px 80px; }
    .va-cta-card { padding: 32px 22px; border-radius: 20px; }
    .va-cta-headline { font-size: clamp(1.45rem, 5.5vw, 1.85rem); }
    .va-cta-sub { font-size: 0.92rem; margin-bottom: 24px; }
    .va-cta-actions { flex-direction: column; width: 100%; gap: 10px; }
    .va-cta-btn { padding: 16px 24px; font-size: 1rem; width: 100%; }
    .va-modal-close { top: -48px; }
    .va-grid { background-size: 44px 44px; }
    .va-marquee-fade { width: 8%; }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .va-play-ring, .va-badge-dot, .va-metric-spark, .va-live-dot { animation: none; }
    .va-card, .va-poster, .va-shine { transition: none; }
  }
</style>

<script>
  const modal = document.getElementById('va-modal') as HTMLDivElement | null;
  const modalVideo = document.getElementById('va-modal-video') as HTMLVideoElement | null;
  const modalCaption = document.getElementById('va-modal-caption') as HTMLDivElement | null;
  const modalClose = document.getElementById('va-modal-close');

  const cards = document.querySelectorAll<HTMLButtonElement>('.va-card');

  function closeModal() {
    if (!modal || !modalVideo) return;
    modalVideo.pause();
    modalVideo.removeAttribute('src');
    modalVideo.load();
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!modal || !modalVideo || !modalCaption) return;
      const src = card.dataset.video ?? '';
      const name = card.dataset.name ?? '';
      modalVideo.src = src;
      modalCaption.textContent = name;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Auto-play (muted fallback si autoplay bloque)
      modalVideo.play().catch(() => {
        modalVideo.muted = true;
        modalVideo.play().catch(() => {});
      });
    });
  });

  modalClose?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
