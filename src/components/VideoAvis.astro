  }

  /* ────────── Mobile ────────── */
  @media (max-width: 640px) {
    .va-section { padding: 72px 0 88px; }
    .va-header { margin-bottom: 44px; }
    .va-stats { padding: 14px 18px; gap: 18px; border-radius: 16px; }
    .va-stat-sep { height: 28px; }
    .va-grid-cards { grid-template-columns: 1fr; gap: 18px; }
    .va-card-body { padding: 16px 18px 18px; gap: 10px; }
    .va-play { width: 58px; height: 58px; }
    .va-play svg { width: 22px; height: 22px; }
    .va-hook { font-size: 1rem; }
    .va-cta-card { margin-top: 56px; padding: 36px 22px; border-radius: 22px; }
    .va-cta-headline { font-size: clamp(1.45rem, 5.5vw, 1.85rem); }
    .va-cta-sub { font-size: 0.92rem; margin-bottom: 24px; }
    .va-cta-actions { flex-direction: column; width: 100%; gap: 10px; }
    .va-cta-btn, .va-cta-secondary { padding: 16px 24px; font-size: 1rem; width: 100%; }
    .va-cta-signals { font-size: 0.74rem; gap: 8px 12px; }
    .va-cta-signal-sep { display: none; }
    .va-modal-close { top: -48px; }
    .va-grid { background-size: 44px 44px; }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .va-play, .va-badge-dot { animation: none; }
    .va-card, .va-poster { transition: none; }
  }
</style>

<script>
  const modal = document.getElementById('va-modal') as HTMLDivElement | null;
  const modalVideo = document.getElementById('va-modal-video') as HTMLVideoElement | null;
  const modalCaption = document.getElementById('va-modal-caption') as HTMLDivElement | null;
  const modalClose = document.getElementById('va-modal-close');

  const cards = document.querySelectorAll<HTMLButtonElement>('.va-card');

  function closeModal() {
    if (!modal || !modalVideo) return;
    modalVideo.pause();
    modalVideo.removeAttribute('src');
    modalVideo.load();
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!modal || !modalVideo || !modalCaption) return;
      const src = card.dataset.video ?? '';
      const name = card.dataset.name ?? '';
      modalVideo.src = src;
      modalCaption.textContent = name;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Auto-play (muted fallback si autoplay bloque)
      modalVideo.play().catch(() => {
        modalVideo.muted = true;
        modalVideo.play().catch(() => {});
      });
    });
  });

  modalClose?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
