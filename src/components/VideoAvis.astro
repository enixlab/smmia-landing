---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Videos d'avis : deposer les MP4 dans /public/videos/ avec le nom
// "avis-{slug}.mp4" pour qu'ils se chargent automatiquement. Si le fichier
// n'existe pas encore, la carte reste cliquable et montre le poster.

// hook = titre click-bait extrait du contenu réel de la vidéo (lecture des sous-titres incrustés)
const testimonials = [
  {
    slug: "mohamed-ali",
    hook: "\"+3K€/mois en 5 semaines SMMIA\"",
    sub: "Ticket moyen ×3 après le module Offre IA.",
    tag: "+3K€/mois",
    poster: "/images/portraits-video/mohamed-ali.webp",
    posterPos: "center",
  },
  {
    slug: "oumya",
    hook: "\"2 clients signés dès la 1ère semaine SMMIA\"",
    sub: "Scripts Closing appliqués, résultats immédiats.",
    tag: "2 clients",
    poster: "/images/portraits-video/oumya.webp",
    posterPos: "center",
  },
  {
    slug: "oussmane",
    hook: "\"Revenus ×2 en 60 jours grâce à SMMIA\"",
    sub: "Workflows IA : 3h gagnées par jour.",
    tag: "×2 revenus",
    poster: "/images/portraits-video/oussmane.webp",
    posterPos: "center",
  },
  {
    slug: "rm",
    hook: "\"Ticket 350€ → 1 200€ avec SMMIA\"",
    sub: "Packaging refait, prospects signent sans négocier.",
    tag: "×3,4 ticket",
    poster: "/images/portraits-video/rm.webp",
    posterPos: "center",
  },
  {
    slug: "awais",
    hook: "\"5 retainers signés en 3 semaines SMMIA\"",
    sub: "MRR sécurisé avant la fin du module.",
    tag: "5 retainers",
    poster: "/images/portraits-video/awais.webp",
    posterPos: "center",
  },
  {
    slug: "velox",
    hook: "\"CA mensuel ×3 grâce au module SMMIA\"",
    sub: "Agents IA déployés, capacité +70%.",
    tag: "×3 CA",
    poster: "/images/portraits-video/velox.webp",
    posterPos: "center",
  },
];
---

<section id="video-avis" class="va-section">

  <!-- Pattern -->
  <div class="va-grid" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["TikTok", "Shopify", "Facebook", "n8n"]} />

  <div class="va-inner">

    <!-- Header -->
    <div class="va-header">
      <div class="va-badge" data-animate>
        <span class="va-badge-dot"></span>
        Ils racontent en vidéo
      </div>

      <h2 class="va-title" data-animate data-delay="0.08">
        La preuve, <span class="va-accent">en direct.</span>
      </h2>

      <p class="va-sub" data-animate data-delay="0.16">
        Pas de capture Trustpilot copiée. Des vraies têtes, des vrais chiffres, des vrais résultats.
      </p>

    </div>

    <!-- Marquee vidéos défilant infini -->
    <div class="va-marquee-wrap" data-animate>
      <div class="va-marquee-track" id="va-marquee-track">
        {[...testimonials, ...testimonials].map((t, i) => (
          <button
            class="va-card"
            data-video={`/videos/avis-${t.slug}.mp4`}
            data-name={t.hook}
            aria-label={`Lire le témoignage : ${t.hook}`}
          >
            <!-- Badge métrique en top -->
            <span class="va-metric-badge">
              <span class="va-metric-badge-dot"></span>
              {t.tag}
            </span>

            <!-- Media portrait plein -->
            <div class="va-card-media">
              <img
                src={t.poster}
                alt={t.hook}
                loading="lazy"
                class="va-poster"
                style={`object-position: center ${t.posterPos};`}
              />
              <div class="va-card-overlay" aria-hidden="true"></div>
              <div class="va-play" aria-hidden="true">
                <span class="va-play-ring"></span>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>

            <!-- Hook overlay bottom -->
            <div class="va-card-body">
              <h3 class="va-hook">{t.hook}</h3>
              <div class="va-cta-watch">
                Regarder
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>

  </div>

  <!-- Modal lecteur -->
  <div class="va-modal" id="va-modal" aria-hidden="true">
    <button class="va-modal-close" id="va-modal-close" aria-label="Fermer">&times;</button>
    <div class="va-modal-inner">
      <video
        id="va-modal-video"
        controls
        playsinline
        preload="none"
      ></video>
      <div class="va-modal-caption" id="va-modal-caption"></div>
    </div>
  </div>
</section>

<!-- CTA hors-section : fond noir pur, zéro bordure violette -->
<div class="va-cta-outer">
    <div class="va-cta-card" data-animate>

      <!-- Eyebrow scarcity -->
      <div class="va-cta-eyebrow">
        <span class="va-cta-eyebrow-dot"></span>
        Session Mai 2026 · <strong>10 places restantes</strong>
      </div>

      <!-- Headline -->
      <h3 class="va-cta-headline">
        Tu as vu leurs résultats.<br>
        <span class="va-cta-headline-accent">Maintenant c'est ton tour.</span>
      </h3>

      <!-- Sub -->
      <p class="va-cta-sub">
        Rejoins 847 membres déjà passés à l'action. 3 mois d'accès · lives en direct · garantie 14j.
      </p>

      <!-- CTA principal -->
      <div class="va-cta-actions">
        <a class="va-cta-btn" href="#prix">
          <span class="va-cta-btn-inner">
            Je veux ces résultats
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>

    </div>
  </div>

<style>
  /* ────────── Section ────────── */
  .va-section {
    position: relative;
    padding: 120px 0 60px;
    background: radial-gradient(ellipse at 50% 0%, #140828 0%, #060211 55%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  @media (max-width: 768px) {
    .va-halo, .va-grid { display: none; }
    .va-card::after { display: none; }
  }

  .va-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    z-index: 2;
  }

  .va-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .va-halo {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .va-halo-l {
    top: 10%;
    left: -10%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 70%);
  }

  .va-halo-r {
    bottom: 10%;
    right: -10%;
    background: radial-gradient(circle, rgba(88, 28, 135, 0.25), transparent 70%);
  }

  /* ────────── Header ────────── */
  .va-header {
    text-align: center;
    margin-bottom: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 24px;
  }

  .va-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: va-dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes va-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .va-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 18px;
  }

  .va-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 6px 30px rgba(168, 85, 247, 0.45));
  }

  .va-sub {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  /* Stats ribbon */
  .va-stats {
    display: inline-flex;
    align-items: center;
    gap: clamp(20px, 4vw, 44px);
    padding: 18px 28px;
    border-radius: 20px;
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.18);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .va-stat {
    text-align: center;
    min-width: 72px;
  }

  .va-stat-value {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, #C084FC);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .va-star {
    color: #FACC15;
    display: inline-flex;
    -webkit-text-fill-color: #FACC15;
  }

  .va-star svg {
    width: 0.8em;
    height: 0.8em;
    filter: drop-shadow(0 0 8px rgba(250, 204, 21, 0.6));
  }

  .va-stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .va-stat-sep {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, rgba(168, 85, 247, 0.5), transparent);
  }

  /* ────────── Marquee vidéos ────────── */
  .va-marquee-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    padding: 20px 0;
  }
  .va-marquee-track {
    display: flex;
    gap: 22px;
    width: max-content;
    animation: va-marquee 65s linear infinite;
    will-change: transform;
  }
  .va-marquee-wrap:hover .va-marquee-track,
  .va-marquee-wrap:focus-within .va-marquee-track {
    animation-play-state: paused;
  }
  @keyframes va-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .va-marquee-track { animation: none; }
  }

  /* ═══════════════ VideoAvis CARD — Premium Portrait ═══════════════ */
  .va-card {
    position: relative;
    all: unset;
    flex: 0 0 auto;
    width: 320px;
    aspect-ratio: 4 / 5;
    display: block;
    background: #0a0413;
    border-radius: 32px;
    overflow: hidden;
    cursor: pointer;
    isolation: isolate;
    transition:
      transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow:
      0 24px 60px -20px rgba(0, 0, 0, 0.9),
      0 18px 44px -18px rgba(168, 85, 247, 0.45),
      0 0 0 1px rgba(168, 85, 247, 0.18);
  }

  .va-card:hover {
    transform: translateY(-12px) scale(1.02);
    box-shadow:
      0 38px 80px -20px rgba(0, 0, 0, 0.92),
      0 28px 60px -15px rgba(168, 85, 247, 0.7),
      0 0 0 1px rgba(192, 132, 252, 0.5),
      0 0 80px -20px rgba(168, 85, 247, 0.5);
  }

  /* Media plein — remplit toute la card */
  .va-card-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .va-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
                filter 0.6s ease;
    filter: brightness(0.92) saturate(1.05);
  }

  .va-card:hover .va-poster {
    transform: scale(1.06);
    filter: brightness(1.02) saturate(1.15);
  }

  /* Overlay gradient bottom pour lisibilité du hook */
  .va-card-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(10, 4, 20, 0) 40%,
        rgba(10, 4, 20, 0.55) 62%,
        rgba(10, 4, 20, 0.88) 82%,
        rgba(10, 4, 20, 0.96) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Badge métrique (chiffre/résultat) — top-left */
  .va-metric-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px 9px 11px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.95), rgba(124, 58, 237, 0.92));
    backdrop-filter: blur(14px);
    border: 1px solid rgba(216, 180, 254, 0.4);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    z-index: 3;
    box-shadow: 0 8px 24px rgba(168, 85, 247, 0.45);
  }
  .va-metric-badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 8px rgba(255, 255, 255, 0.9);
    animation: va-badge-pulse 1.8s ease-in-out infinite;
  }
  @keyframes va-badge-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.82); }
  }

  /* Play button premium — ring + glow */
  .va-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    color: #1a0627;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    backdrop-filter: blur(14px);
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.6),
      0 6px 20px rgba(168, 85, 247, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s ease;
  }
  .va-play-ring {
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    border: 2px solid rgba(216, 180, 254, 0.55);
    animation: va-ring-pulse 2.4s ease-out infinite;
    pointer-events: none;
  }
  @keyframes va-ring-pulse {
    0%   { transform: scale(1);    opacity: 0.85; }
    100% { transform: scale(1.25); opacity: 0; }
  }
  .va-play svg {
    width: 30px;
    height: 30px;
    margin-left: 4px;
  }
  .va-card:hover .va-play {
    transform: translate(-50%, -50%) scale(1.14);
    box-shadow:
      0 14px 50px rgba(0, 0, 0, 0.7),
      0 10px 32px rgba(168, 85, 247, 0.8),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  /* Body en overlay absolute bottom */
  .va-card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 2;
  }

  .va-hook {
    font-size: 1.18rem;
    line-height: 1.28;
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.012em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.6);
  }

  .va-cta-watch {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    transition: background 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .va-card:hover .va-cta-watch {
    background: rgba(168, 85, 247, 0.9);
    border-color: rgba(216, 180, 254, 0.5);
    transform: translateX(4px);
  }
  .va-cta-watch svg {
    transition: transform 0.3s ease;
  }
  .va-card:hover .va-cta-watch svg {
    transform: translateX(2px);
  }

  /* ────────── CTA hors-section (fond noir pur) ────────── */
  .va-cta-outer {
    background: #000;
    padding: 96px 24px 120px;
  }

  /* ────────── CTA card premium rectangulaire ────────── */
  .va-cta-card {
    position: relative;
    margin: 0 auto;
    max-width: 960px;
    padding: 44px clamp(32px, 5vw, 72px);
    border-radius: 24px;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(168, 85, 247, 0.18) 0%, transparent 60%),
      linear-gradient(180deg, rgba(22, 10, 40, 0.85) 0%, rgba(10, 4, 20, 0.9) 100%);
    border: 1px solid rgba(168, 85, 247, 0.32);
    box-shadow:
      0 40px 100px -30px rgba(168, 85, 247, 0.45),
      0 16px 40px -12px rgba(88, 28, 135, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  /* Glow interne animé au top (halo violet) */
  .va-cta-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(192, 132, 252, 0.85), transparent);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.8);
  }

  /* Eyebrow scarcity (violet) */
  .va-cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.14);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #C4B5FD;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .va-cta-eyebrow strong { color: #E9D5FF; font-weight: 800; }

  .va-cta-eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 10px #A855F7;
    animation: va-scarcity-pulse 1.4s ease-in-out infinite;
  }

  @keyframes va-scarcity-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  /* Headline */
  .va-cta-headline {
    margin: 0 0 14px;
    font-size: clamp(1.7rem, 3.2vw, 2.6rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.88);
  }

  .va-cta-headline-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 45%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Sub */
  .va-cta-sub {
    margin: 0 auto 32px;
    max-width: 520px;
    font-size: 0.98rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  /* Actions row */
  .va-cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .va-cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 36px;
    border-radius: 16px;
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 50%, #6D28D9 100%);
    color: #fff;
    font-size: 1.06rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      0 22px 56px -14px rgba(168, 85, 247, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1), box-shadow 0.3s;
  }

  .va-cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgba(255, 255, 255, 0.3) 50%, transparent 70%);
    transform: translateX(-120%);
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .va-cta-btn:hover {
    transform: translateY(-3px) scale(1.02);
