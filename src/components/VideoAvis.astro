---
import BrandFloatingIcons from './BrandFloatingIcons.astro';

// Videos d'avis : deposer les MP4 dans /public/videos/ avec le nom
// "avis-{slug}.mp4" pour qu'ils se chargent automatiquement. Si le fichier
// n'existe pas encore, la carte reste cliquable et montre le poster.

// hook = titre click-bait extrait du contenu réel de la vidéo (lecture des sous-titres incrustés)
const testimonials = [
  {
    slug: "mohamed-ali",
    hook: "\"+3K€/mois en 5 semaines SMMIA\"",
    sub: "Ticket moyen ×3 après le module Offre IA.",
    tag: "+3K€/mois",
    poster: "/images/portraits-video/mohamed-ali.webp",
    posterPos: "30%",
  },
  {
    slug: "oumya",
    hook: "\"2 clients signés dès la 1ère semaine SMMIA\"",
    sub: "Scripts Closing appliqués, résultats immédiats.",
    tag: "2 clients",
    poster: "/images/portraits-video/oumya.webp",
    posterPos: "30%",
  },
  {
    slug: "rm",
    hook: "\"Ticket 350€ → 1 200€ avec SMMIA\"",
    sub: "Packaging refait, prospects signent sans négocier.",
    tag: "×3,4 ticket",
    poster: "/images/portraits-video/rm.webp",
    posterPos: "30%",
  },
  {
    slug: "awais",
    hook: "\"5 retainers signés en 3 semaines SMMIA\"",
    sub: "MRR sécurisé avant la fin du module.",
    tag: "5 retainers",
    poster: "/images/portraits-video/awais.webp",
    posterPos: "30%",
  },
  {
    slug: "velox",
    hook: "\"CA mensuel ×3 grâce au module SMMIA\"",
    sub: "Agents IA déployés, capacité +70%.",
    tag: "×3 CA",
    poster: "/images/portraits-video/velox.webp",
    posterPos: "30%",
  },
  {
    slug: "oussmane",
    hook: "\"Revenus ×2 en 60 jours grâce à SMMIA\"",
    sub: "Workflows IA : 3h gagnées par jour.",
    tag: "×2 revenus",
    poster: "/images/portraits-video/oussmane.webp",
    posterPos: "30%",
  },
];
const rowA = testimonials.slice(0, 3);
const rowB = testimonials.slice(3);
---

<section id="video-avis" class="va-section">

  <!-- Pattern -->
  <div class="va-grid" aria-hidden="true"></div>

  <!-- Logos brand flottants -->
  <BrandFloatingIcons icons={["TikTok", "Shopify", "Facebook", "n8n"]} />

  <div class="va-inner">

    <!-- Header -->
    <div class="va-header">
      <div class="va-badge" data-animate>
        <span class="va-badge-dot"></span>
        Ils racontent en vidéo
      </div>

      <h2 class="va-title" data-animate data-delay="0.08">
        La preuve, <span class="va-accent">en direct.</span>
      </h2>

      <p class="va-sub" data-animate data-delay="0.16">
        Pas de capture Trustpilot copiée. Des vraies têtes, des vrais chiffres, des vrais résultats.
      </p>

    </div>

    <!-- Marquee vidéos : 2 lignes qui défilent en sens opposés -->
    <div class="va-marquee-wrap" data-animate>

      <!-- Fade edges (masque pour effet "flottant") -->
      <div class="va-marquee-fade va-marquee-fade--l" aria-hidden="true"></div>
      <div class="va-marquee-fade va-marquee-fade--r" aria-hidden="true"></div>

      <!-- Ligne 1 : défile vers la gauche -->
      <div class="va-marquee-track va-marquee-track--l">
        {[...rowA, ...rowA].map((t) => (
          <button
            class="va-card"
            data-video={`/videos/avis-${t.slug}.mp4`}
            data-name={t.hook}
            aria-label={`Lire le témoignage : ${t.hook}`}
          >
            <div class="va-card-media">
              <img
                src={t.poster}
                alt={t.hook}
                loading="lazy"
                class="va-poster"
                style={`object-position: center ${t.posterPos};`}
              />

              <!-- Overlay cinéma (dégradé bas + spotlight haut) -->
              <div class="va-card-overlay" aria-hidden="true"></div>

              <!-- Badge métrique (top-left) -->
              <div class="va-metric-badge" aria-hidden="true">
                <span class="va-metric-spark"></span>
                {t.tag}
              </div>

              <!-- Badge LIVE (top-right) -->
              <div class="va-live-badge" aria-hidden="true">
                <span class="va-live-dot"></span>
                TÉMOIGNAGE
              </div>

              <!-- Play button signature : violet aurora + ring animé -->
              <div class="va-play" aria-hidden="true">
                <span class="va-play-ring"></span>
                <span class="va-play-ring va-play-ring--2"></span>
                <span class="va-play-core">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </span>
              </div>

              <!-- Bas de poster : hook incrusté + CTA subtil (hiérarchie cinéma) -->
              <div class="va-card-footer">
                <h3 class="va-hook">{t.hook}</h3>
                <div class="va-cta-watch">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  Regarder le témoignage
                  <svg class="va-cta-arrow" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </div>
              </div>

              <!-- Shine sweep au hover -->
              <div class="va-shine" aria-hidden="true"></div>
            </div>
          </button>
        ))}
      </div>

      <!-- Ligne 2 : défile vers la droite -->
      <div class="va-marquee-track va-marquee-track--r">
        {[...rowB, ...rowB].map((t) => (
          <button
            class="va-card"
            data-video={`/videos/avis-${t.slug}.mp4`}
            data-name={t.hook}
            aria-label={`Lire le témoignage : ${t.hook}`}
          >
            <div class="va-card-media">
              <img
                src={t.poster}
                alt={t.hook}
                loading="lazy"
                class="va-poster"
                style={`object-position: center ${t.posterPos};`}
              />

              <div class="va-card-overlay" aria-hidden="true"></div>

              <div class="va-metric-badge" aria-hidden="true">
                <span class="va-metric-spark"></span>
                {t.tag}
              </div>

              <div class="va-live-badge" aria-hidden="true">
                <span class="va-live-dot"></span>
                TÉMOIGNAGE
              </div>

              <div class="va-play" aria-hidden="true">
                <span class="va-play-ring"></span>
                <span class="va-play-ring va-play-ring--2"></span>
                <span class="va-play-core">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </span>
              </div>

              <div class="va-card-footer">
                <h3 class="va-hook">{t.hook}</h3>
                <div class="va-cta-watch">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  Regarder le témoignage
                  <svg class="va-cta-arrow" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </div>
              </div>

              <div class="va-shine" aria-hidden="true"></div>
            </div>
          </button>
        ))}
      </div>

    </div>

  </div>

  <!-- Modal lecteur -->
  <div class="va-modal" id="va-modal" aria-hidden="true">
    <button class="va-modal-close" id="va-modal-close" aria-label="Fermer">&times;</button>
    <div class="va-modal-inner">
      <video
        id="va-modal-video"
        controls
        playsinline
        preload="none"
      ></video>
      <div class="va-modal-caption" id="va-modal-caption"></div>
    </div>
  </div>
</section>

<!-- CTA hors-section : fond noir pur, zéro bordure violette -->
<div class="va-cta-outer">
    <div class="va-cta-card" data-animate>

      <!-- Eyebrow scarcity -->
      <div class="va-cta-eyebrow">
        <span class="va-cta-eyebrow-dot"></span>
        Session Mai 2026 · <strong>10 places restantes</strong>
      </div>

      <!-- Headline -->
      <h3 class="va-cta-headline">
        Tu as vu leurs résultats.<br>
        <span class="va-cta-headline-accent">Maintenant c'est ton tour.</span>
      </h3>

      <!-- Sub -->
      <p class="va-cta-sub">
        Rejoins 847 membres déjà passés à l'action. 3 mois d'accès · lives en direct · garantie 14j.
      </p>

      <!-- CTA principal -->
      <div class="va-cta-actions">
        <a class="va-cta-btn" href="#prix">
          <span class="va-cta-btn-inner">
            Je veux ces résultats
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>

    </div>
  </div>

<style>
  /* ────────── Section ────────── */
  .va-section {
    position: relative;
    padding: 120px 0 60px;
    background: radial-gradient(ellipse at 50% 0%, #140828 0%, #060211 55%, #000 100%);
    overflow: hidden;
    isolation: isolate;
  }

  /* Light mode section background */
  :global([data-theme="light"]) .va-section {
    background: radial-gradient(ellipse at 50% 0%, #F5F0FF 0%, #FAFAFC 55%, #FFFFFF 100%);
  }

  @media (max-width: 768px) {
    .va-halo, .va-grid { display: none; }
  }

  .va-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    z-index: 2;
  }

  .va-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="light"]) .va-grid {
    background-image:
      linear-gradient(rgba(168, 85, 247, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.08) 1px, transparent 1px);
  }

  .va-halo {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .va-halo-l {
    top: 10%;
    left: -10%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 70%);
  }

  .va-halo-r {
    bottom: 10%;
    right: -10%;
    background: radial-gradient(circle, rgba(88, 28, 135, 0.25), transparent 70%);
  }

  /* ────────── Header ────────── */
  .va-header {
    text-align: center;
    margin-bottom: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .va-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #C4B5FD;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 24px;
  }

  :global([data-theme="light"]) .va-badge {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.3);
    color: #7C3AED;
  }

  .va-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 12px #A855F7, 0 0 4px #fff;
    animation: va-dot-pulse 1.6s ease-in-out infinite;
  }

  @keyframes va-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .va-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 18px;
  }

  :global([data-theme="light"]) .va-title {
    color: #0A0418;
  }

  .va-accent {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 40%, #C084FC 80%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 6px 30px rgba(168, 85, 247, 0.45));
  }

  :global([data-theme="light"]) .va-accent {
    background: linear-gradient(135deg, #7C3AED 0%, #A855F7 50%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .va-sub {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  :global([data-theme="light"]) .va-sub {
    color: rgba(10, 4, 24, 0.65);
  }

  /* ────────── Marquee vidéos — 2 lignes sens opposés ────────── */
  .va-marquee-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    padding: 30px 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Fade edges — masques gauche/droite pour effet "cards flottent dans le fade" */
  .va-marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 14%;
    pointer-events: none;
    z-index: 5;
  }
  .va-marquee-fade--l {
    left: 0;
    background: linear-gradient(90deg, #060211 0%, rgba(6, 2, 17, 0.8) 40%, transparent 100%);
  }
  .va-marquee-fade--r {
    right: 0;
    background: linear-gradient(-90deg, #060211 0%, rgba(6, 2, 17, 0.8) 40%, transparent 100%);
  }

  :global([data-theme="light"]) .va-marquee-fade--l {
    background: linear-gradient(90deg, #FAFAFC 0%, rgba(250, 250, 252, 0.8) 40%, transparent 100%);
  }
  :global([data-theme="light"]) .va-marquee-fade--r {
    background: linear-gradient(-90deg, #FAFAFC 0%, rgba(250, 250, 252, 0.8) 40%, transparent 100%);
  }

  .va-marquee-track {
    display: flex;
    gap: 28px;
    width: max-content;
    will-change: transform;
  }
  .va-marquee-track--l {
    animation: va-marquee-l 32s linear infinite;
  }
  .va-marquee-track--r {
    animation: va-marquee-r 38s linear infinite;
    margin-left: -8%;
  }
  .va-marquee-wrap:hover .va-marquee-track,
  .va-marquee-wrap:focus-within .va-marquee-track {
    animation-play-state: paused;
  }
  @keyframes va-marquee-l {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes va-marquee-r {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .va-marquee-track { animation: none; }
  }

  /* ────────── CARD PREMIUM — format portrait cinéma ────────── */
  .va-card {
    position: relative;
    all: unset;
    flex: 0 0 auto;
    width: 380px;
    aspect-ratio: 9 / 14;
    border-radius: 28px;
    overflow: hidden;
    cursor: pointer;
    isolation: isolate;
    transition:
      transform 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      box-shadow 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow:
      0 30px 60px -20px rgba(0, 0, 0, 0.8),
      0 20px 40px -16px rgba(168, 85, 247, 0.45),
      0 8px 20px -6px rgba(124, 58, 237, 0.35),
      inset 0 1px 0 rgba(216, 180, 254, 0.14);
  }

  :global([data-theme="light"]) .va-card {
    box-shadow:
      0 30px 70px -24px rgba(124, 58, 237, 0.35),
      0 16px 36px -14px rgba(168, 85, 247, 0.28),
      0 4px 12px -4px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .va-card:hover {
    transform: translateY(-14px) scale(1.025);
    box-shadow:
      0 50px 100px -24px rgba(0, 0, 0, 0.85),
      0 34px 70px -18px rgba(168, 85, 247, 0.85),
      0 18px 40px -10px rgba(124, 58, 237, 0.7),
      inset 0 1px 0 rgba(216, 180, 254, 0.3);
  }

  :global([data-theme="light"]) .va-card:hover {
    box-shadow:
      0 48px 100px -24px rgba(124, 58, 237, 0.55),
      0 28px 60px -18px rgba(168, 85, 247, 0.45),
      0 8px 20px -6px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  /* Glow radial autour de la card au hover */
  .va-card::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: radial-gradient(
      120% 80% at 50% 0%,
      rgba(192, 132, 252, 0.28) 0%,
      rgba(168, 85, 247, 0.06) 40%,
      transparent 75%
    );
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 4;
  }
  .va-card:hover::after { opacity: 1; }

  /* Bordure gradient aurora */
  .va-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg,
      rgba(192, 132, 252, 0.65) 0%,
      rgba(168, 85, 247, 0.15) 35%,
      rgba(0, 200, 255, 0.25) 60%,
      rgba(192, 132, 252, 0.55) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 5;
    transition: opacity 0.4s ease;
  }

  :global([data-theme="light"]) .va-card::before {
    background: linear-gradient(135deg,
      rgba(168, 85, 247, 0.55) 0%,
      rgba(192, 132, 252, 0.2) 35%,
      rgba(0, 200, 255, 0.3) 60%,
      rgba(124, 58, 237, 0.5) 100%);
  }

  /* Media : la card EST le poster, tout est en overlay */
  .va-card-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
  }

  .va-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1),
                filter 0.8s ease;
    filter: brightness(0.88) saturate(1.1) contrast(1.05);
  }

  :global([data-theme="light"]) .va-poster {
    filter: brightness(0.95) saturate(1.12) contrast(1.03);
  }

  .va-card:hover .va-poster {
    transform: scale(1.09);
    filter: brightness(1) saturate(1.2) contrast(1.08);
  }

  /* Overlay cinéma : dark bas lisibilité + spotlight haut */
  .va-card-overlay {
    position: absolute;
    inset: 0;
    background:
      /* spotlight violet haut (derrière le play) */
      radial-gradient(70% 50% at 50% 38%, rgba(168, 85, 247, 0.32) 0%, transparent 55%),
      /* gradient bas pour le texte */
      linear-gradient(180deg,
        rgba(8, 4, 20, 0) 0%,
        rgba(8, 4, 20, 0) 45%,
        rgba(8, 4, 20, 0.55) 72%,
        rgba(8, 4, 20, 0.92) 100%),
      /* teinte violette globale subtile */
      linear-gradient(145deg, rgba(124, 58, 237, 0.1) 0%, transparent 50%);
    z-index: 1;
    transition: opacity 0.6s ease;
  }

  .va-card:hover .va-card-overlay {
    background:
      radial-gradient(70% 50% at 50% 38%, rgba(168, 85, 247, 0.42) 0%, transparent 55%),
      linear-gradient(180deg,
        rgba(8, 4, 20, 0) 0%,
        rgba(8, 4, 20, 0) 40%,
        rgba(8, 4, 20, 0.6) 70%,
        rgba(8, 4, 20, 0.95) 100%),
      linear-gradient(145deg, rgba(124, 58, 237, 0.12) 0%, transparent 50%);
  }

  /* Shine sweep diagonal au hover */
  .va-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg,
      transparent 35%,
      rgba(255, 255, 255, 0.15) 50%,
      transparent 65%);
    transform: translateX(-120%);
    transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    pointer-events: none;
    z-index: 3;
    mix-blend-mode: overlay;
  }
  .va-card:hover .va-shine {
    transform: translateX(120%);
  }

  /* ────────── Metric badge (top-left) ────────── */
  .va-metric-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 13px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.95), rgba(124, 58, 237, 0.9));
    border: 1px solid rgba(216, 180, 254, 0.45);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: -0.005em;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      0 8px 22px rgba(124, 58, 237, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .va-metric-spark {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00C8FF;
    box-shadow: 0 0 10px #00C8FF, 0 0 4px #fff;
    animation: va-spark 1.8s ease-in-out infinite;
  }
  @keyframes va-spark {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.6; transform: scale(0.8); }
  }

  /* ────────── Live badge (top-right) ────────── */
  .va-live-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 11px;
    border-radius: 8px;
    background: rgba(10, 4, 20, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .va-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #EF4444;
    box-shadow: 0 0 8px #EF4444;
    animation: va-live-pulse 1.4s ease-in-out infinite;
  }
  @keyframes va-live-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }

  /* ────────── PLAY BUTTON SIGNATURE (violet aurora + double ring animé) ────────── */
  .va-play {
    position: absolute;
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 96px;
    height: 96px;
    z-index: 3;
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  /* Rings (halos qui pulsent vers l'extérieur) */
  .va-play-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(192, 132, 252, 0.7);
    animation: va-ring-pulse 2.4s ease-out infinite;
    pointer-events: none;
  }
  .va-play-ring--2 {
    animation-delay: 1.2s;
  }
  @keyframes va-ring-pulse {
    0% {
      transform: scale(1);
      opacity: 0.85;
      border-color: rgba(192, 132, 252, 0.85);
    }
    100% {
      transform: scale(1.9);
      opacity: 0;
      border-color: rgba(192, 132, 252, 0);
    }
  }

  /* Core du play button — aurora gradient + ring solide + inner shadow blanc */
  .va-play-core {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 35% 30%, #FFFFFF 0%, #F5F0FF 20%, #C084FC 55%, #A855F7 80%, #7C3AED 100%);
    color: #1a0627;
    border: 2px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      /* halo externe fort (visible même light mode) */
      0 0 0 4px rgba(168, 85, 247, 0.3),
