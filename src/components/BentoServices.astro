---

<section class="bento-section">
  <div class="bento-header">
    <h2>Nos <span>Services</span></h2>
    <p>Tout ce qu'une agence peut vendre — généré, automatisé, livré.</p>
  </div>

  <div class="bento-grid">
    {services.map((s) => (
      <div class={`bento-card bento-${s.size}`} data-id={s.id}>
        <img
          src={`/images/services/bento/${s.file}`}
          alt={s.label}
          loading="lazy"
        />
        <div class="bento-label">
          <span>{s.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .bento-section {
    background: #000;
    padding: 80px 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .bento-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .bento-header h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .bento-header h2 span {
    color: #A855F7;
  }

  .bento-header p {
    color: #888;
    font-size: 1.1rem;
  }

  /* ─── GRID ─── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 300px;
    grid-auto-flow: dense;
    gap: 12px;
  }

  /* ─── CARD BASE ─── */
  .bento-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    background: #111;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bento-card:hover {
    transform: scale(1.02);
    box-shadow: 0 0 40px rgba(168, 85, 247, 0.25);
    z-index: 2;
  }

  .bento-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── LABEL OVERLAY ─── */
  .bento-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .bento-card:hover .bento-label {
    opacity: 1;
  }

  .bento-label span {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ─── SIZES ─── */
  .bento-wide {
    grid-column: span 2;
  }

  .bento-portrait {
    grid-row: span 2;
  }

  .bento-square {
    /* default: 1x1 */
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
  }

  @media (max-width: 560px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 240px;
    }

    .bento-wide,
    .bento-portrait {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
