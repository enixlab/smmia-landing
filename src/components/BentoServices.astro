  { id: "04-chatbot-sav",          file: "04-chatbot-sav-SQUARE.png",          size: "square",   label: "Chatbot SAV" },
  // WIDE
  { id: "05-generation-leads",     file: "05-generation-leads-WIDE.png",       size: "wide",     label: "Génération de Leads" },
  // PORTRAIT
  { id: "07-apple-wallet",         file: "07-apple-wallet-PORTRAIT.png",       size: "portrait", label: "Cartes Push Apple Wallet" },
  // SQUARE
  { id: "08-landing-pages",        file: "08-landing-pages-SQUARE.png",        size: "square",   label: "Landing Pages" },
  { id: "10-flyers",               file: "10-flyers-SQUARE.png",               size: "square",   label: "Flyers" },
  // PORTRAIT
  { id: "09-avis-google",          file: "09-avis-google-PORTRAIT.png",        size: "portrait", label: "Avis Google / Trustpilot" },
  { id: "13-nfc",                  file: "13-nfc-PORTRAIT.png",                size: "portrait", label: "Cartes NFC" },
  // WIDE
  { id: "15-campagnes-ads",        file: "15-campagnes-ads-WIDE.png",          size: "wide",     label: "Campagnes Ads" },
  // SQUARE
  { id: "17-whatsapp",             file: "17-whatsapp-SQUARE.png",             size: "square",   label: "Automatisation WhatsApp" },
  { id: "18-scrapping",            file: "18-scrapping-SQUARE.png",            size: "square",   label: "Scrapping" },
  // WIDE
  { id: "06-videos-montages",      file: "06-videos-montages-WIDE.png",        size: "wide",     label: "Vidéos IA / Montages" },
  // SQUARE
  { id: "19-seo",                  file: "19-seo-SQUARE.png",                  size: "square",   label: "SEO" },
  // PORTRAIT
  { id: "16-crm",                  file: "16-crm-PORTRAIT.png",                size: "portrait", label: "CRM / Logiciel / Automatisations" },
  // SQUARE
  { id: "20-audit",                file: "20-audit-SQUARE.png",                size: "square",   label: "Stratégie & Audit" },
  { id: "21-e-reputation",         file: "21-e-reputation-SQUARE.png",         size: "square",   label: "Supprimer Avis / E-réputation" },
  // PORTRAIT
