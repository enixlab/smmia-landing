  { id: "02-snapchat-certif",      file: "02-snapchat-certif-SQUARE.png",      size: "square",   label: "Certification Snapchat" },
  // WIDE 2x1
  { id: "11-visuels",              file: "11-visuels-WIDE.png",                size: "wide",     label: "Visuels" },
  // PORTRAIT 1x2
  { id: "14-ugc-ia",               file: "14-ugc-ia-PORTRAIT.png",             size: "portrait", label: "UGC IA" },
  // WIDE
  { id: "12-sites-web",            file: "12-sites-web-WIDE.png",              size: "wide",     label: "Sites Web" },
  // SQUARE
