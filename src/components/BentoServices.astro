---
const services = [
  { id: "01-tiktok-certif",        file: "01-tiktok-certif-SQUARE.webp",        label: "Certification TikTok" },
  { id: "02-snapchat-certif",      file: "02-snapchat-certif-SQUARE.webp",      label: "Certification Snapchat" },
  { id: "11-visuels",              file: "11-visuels-SQUARE.webp",              label: "Visuels" },
  { id: "14-ugc-ia",               file: "14-ugc-ia-SQUARE.webp",               label: "UGC IA" },
  { id: "12-sites-web",            file: "12-sites-web-SQUARE.webp",            label: "Sites Web" },
  { id: "03-sms-mail",             file: "03-sms-mail-SQUARE.webp",             label: "SMS / Mail Automatisé" },
  { id: "04-chatbot-sav",          file: "04-chatbot-sav-SQUARE.webp",          label: "Chatbot SAV" },
  { id: "05-generation-leads",     file: "05-generation-leads-SQUARE.webp",     label: "Génération de Leads" },
  { id: "07-apple-wallet",         file: "07-apple-wallet-SQUARE.webp",         label: "Cartes Push Apple Wallet" },
  { id: "08-landing-pages",        file: "08-landing-pages-SQUARE.webp",        label: "Landing Pages" },
  { id: "10-flyers",               file: "10-flyers-SQUARE.webp",               label: "Flyers" },
  { id: "09-avis-google",          file: "09-avis-google-SQUARE.webp",          label: "Avis Google / Trustpilot" },
  { id: "13-nfc",                  file: "13-nfc-SQUARE.webp",                  label: "Cartes NFC" },
  { id: "15-campagnes-ads",        file: "15-campagnes-ads-SQUARE.webp",        label: "Campagnes Ads" },
  { id: "17-whatsapp",             file: "17-whatsapp-SQUARE.webp",             label: "Automatisation WhatsApp" },
  { id: "18-scrapping",            file: "18-scrapping-SQUARE.webp",            label: "Scrapping" },
  { id: "06-videos-montages",      file: "06-videos-montages-SQUARE.webp",      label: "Vidéos IA / Montages" },
  { id: "19-seo",                  file: "19-seo-SQUARE.webp",                  label: "SEO" },
  { id: "16-crm",                  file: "16-crm-SQUARE.webp",                  label: "CRM / Logiciel / Automatisations" },
  { id: "20-audit",                file: "20-audit-SQUARE.webp",                label: "Stratégie & Audit" },
  { id: "21-e-reputation",         file: "21-e-reputation-SQUARE.webp",         label: "Supprimer Avis / E-réputation" },
  { id: "22-osint",                file: "22-osint-SQUARE.webp",                label: "OSINT" },
  { id: "24-gmb",                  file: "24-gmb-SQUARE.webp",                  label: "Google My Business" },
  { id: "23-creation-societe",     file: "23-creation-societe-SQUARE.webp",     label: "Création de Société" },
  { id: "25-underground",          file: "25-underground-SQUARE.webp",          label: "Service Underground / BlackHat" },
];
---

<section class="bento-section">
  <div class="bento-header">
    <h2>Nos <span>Services</span></h2>
    <p>Tout ce qu'une agence peut vendre — généré, automatisé, livré.</p>
  </div>

  <div class="bento-grid">
    {services.map((s) => (
      <div class="bento-card" data-id={s.id}>
        <img
          src={`/images/services/bento/${s.file}`}
          alt={s.label}
          loading="lazy"
        />
        <div class="bento-label">
          <span>{s.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .bento-section {
    background: #000;
    padding: 80px 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .bento-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .bento-header h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .bento-header h2 span {
    background: linear-gradient(135deg, #22D3EE 0%, #A855F7 50%, #FB923C 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 4px 20px rgba(168,85,247,0.4));
  }

  .bento-header p {
    color: rgba(255,255,255,0.65);
    font-size: 1.1rem;
  }

  /* ─── GRID ─── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }

  /* ─── CARD BASE ─── */
  .bento-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    background: #0D0720;
    aspect-ratio: 1 / 1;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Chaque card dans une rangée de 5 prend une teinte différente au hover (cyclique) */
  .bento-card:nth-child(5n+1):hover { box-shadow: 0 0 44px rgba(34, 211, 238, 0.35);  }
  .bento-card:nth-child(5n+2):hover { box-shadow: 0 0 44px rgba(168, 85, 247, 0.4);   }
  .bento-card:nth-child(5n+3):hover { box-shadow: 0 0 44px rgba(124, 58, 237, 0.4);   }
  .bento-card:nth-child(5n+4):hover { box-shadow: 0 0 44px rgba(251, 146, 60, 0.35);  }
  .bento-card:nth-child(5n+5):hover { box-shadow: 0 0 44px rgba(252, 211, 77, 0.35);  }

  .bento-card:hover {
    transform: scale(1.02);
    z-index: 2;
  }

  .bento-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── LABEL OVERLAY ─── */
  .bento-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .bento-card:hover .bento-label {
    opacity: 1;
  }

  .bento-label span {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1100px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
