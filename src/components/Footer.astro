---
const year = new Date().getFullYear();
const DISCORD_URL = 'https://discord.com/invite/focus-1398487214215659612';
const WA_URL = 'https://wa.me/33766814280';
const EMAIL = 'contact@smmia.app';
---

<footer class="ft">

  <!-- Décors de fond -->
  <div class="ft-halo ft-halo-l" aria-hidden="true"></div>
  <div class="ft-halo ft-halo-r" aria-hidden="true"></div>

  <!-- Grille principale 3 colonnes -->
  <div class="ft-main">

    <!-- Col 1 — Brand + Newsletter -->
    <div class="ft-col ft-col-brand">
      <a href="#hero" class="ft-logo">
        <img src="/images/logos/SMMIA-logo-transparent-v2.png" alt="SMMIA" class="ft-logo-dark" />
        <img src="/images/logos/SMMIA-logo-transparent-light.png" alt="SMMIA" class="ft-logo-light" />
      </a>
      <p class="ft-tagline">
        Le module IA business de la communauté Focus. Close des clients, livre avec Prime.
      </p>
    </div>

    <!-- Col 2 — Navigation -->
    <div class="ft-col">
      <h4 class="ft-col-title">Navigation</h4>
      <nav class="ft-links">
        <a href="#programme">Programme</a>
        <a href="#temoignages">Témoignages</a>
        <a href="#prime">Services Prime</a>
        <a href="#prix">Tarif</a>
        <a href="#faq">FAQ</a>
      </nav>
    </div>

    <!-- Col 3 — Communauté live -->
    <div class="ft-col">
      <h4 class="ft-col-title">Communauté</h4>
      <a href={DISCORD_URL} target="_blank" rel="noopener" class="ft-community">
        <div class="ft-community-head">
          <svg class="ft-community-ic" viewBox="0 0 24 24" fill="currentColor"><path d="M20.3 4.4A19 19 0 0 0 15.7 3l-.2.4a17.4 17.4 0 0 0-6.9 0L8.3 3a19 19 0 0 0-4.6 1.4A19.8 19.8 0 0 0 .4 15.3a19.1 19.1 0 0 0 5.8 2.9l1.2-1.6a12.5 12.5 0 0 1-2-.9l.5-.4a13.7 13.7 0 0 0 12.3 0l.5.4a12.5 12.5 0 0 1-2 .9l1.2 1.6a19.1 19.1 0 0 0 5.8-2.9 19.8 19.8 0 0 0-3.4-10.9zM8 13.6c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4zm8 0c-1.2 0-2.1-1.1-2.1-2.4 0-1.3 1-2.4 2.1-2.4 1.2 0 2.1 1.1 2.1 2.4 0 1.3-1 2.4-2.1 2.4z"/></svg>
          <div>
            <div class="ft-community-name">Discord Focus</div>
            <div class="ft-community-meta"><span class="ft-online-dot"></span> <span id="ft-online">128</span> en ligne · 847 membres</div>
          </div>
        </div>
        <span class="ft-community-cta">Rejoindre →</span>
      </a>

      <a href={WA_URL} target="_blank" rel="noopener" class="ft-contact-row">
        <span class="ft-contact-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        </span>
        <span class="ft-contact-label">WhatsApp direct</span>
      </a>

      <a href={`mailto:${EMAIL}`} class="ft-contact-row">
        <span class="ft-contact-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </span>
        <span class="ft-contact-label">{EMAIL}</span>
      </a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="ft-bottom">
    <div class="ft-bottom-inner">
      <div class="ft-copyright">
        © {year} <strong>SMMIA</strong> · Un module Focus · Tous droits réservés
      </div>
      <div class="ft-trust">
        <span class="ft-trust-item">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2l7 4v6c0 4-3 8-7 10-4-2-7-6-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
          Paiement sécurisé Stripe
        </span>
        <span class="ft-trust-sep">·</span>
        <span class="ft-trust-item">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          Satisfait ou remboursé 14j
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ═══════════════ FOOTER ═══════════════ */
  .ft {
    position: relative;
    background: linear-gradient(180deg, #07030f 0%, #050208 100%);
    color: rgba(255, 255, 255, 0.75);
    padding: 96px 0 0;
    overflow: hidden;
    isolation: isolate;
    font-family: 'Inter', sans-serif;
  }

  .ft-halo {
    position: absolute;
    width: 480px; height: 480px;
    border-radius: 50%;
    filter: blur(70px);
    pointer-events: none;
    z-index: 0;
  }
  .ft-halo-l { top: -8%; left: -140px; background: radial-gradient(circle, rgba(168, 85, 247, 0.18), transparent 70%); }
  .ft-halo-r { bottom: -20%; right: -120px; background: radial-gradient(circle, rgba(124, 58, 237, 0.14), transparent 70%); }

  /* ─── Pre-CTA strip ─── */
  .ft-precta {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto 80px;
    padding: 40px clamp(24px, 5vw, 64px);
    border-radius: 28px;
    background:
      radial-gradient(140% 100% at 0% 0%, rgba(168, 85, 247, 0.22) 0%, transparent 55%),
      linear-gradient(135deg, rgba(22, 10, 40, 0.85) 0%, rgba(10, 4, 20, 0.9) 100%);
    border: 1px solid rgba(168, 85, 247, 0.28);
    box-shadow:
      0 30px 80px -30px rgba(168, 85, 247, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .ft-precta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  .ft-precta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.15);
    border: 1px solid rgba(168, 85, 247, 0.35);
    font-size: 0.72rem;
    font-weight: 700;
    color: #C4B5FD;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .ft-live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #C084FC;
    box-shadow: 0 0 8px #A855F7;
  }

  .ft-precta-title {
    font-size: clamp(1.6rem, 3.2vw, 2.25rem);
    font-weight: 900;
    line-height: 1.12;
    color: #fff;
    margin: 0 0 10px;
    letter-spacing: -0.025em;
  }

  .ft-gradient {
    background: linear-gradient(135deg, #FFFFFF 0%, #E9D5FF 45%, #C084FC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .ft-precta-sub {
    font-size: 0.94rem;
    color: rgba(255, 255, 255, 0.58);
    margin: 0;
    max-width: 520px;
  }

  .ft-precta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ft-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 14px;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s, border-color 0.25s;
    white-space: nowrap;
  }

  .ft-btn-primary {
    background: linear-gradient(135deg, #A855F7 0%, #7C3AED 100%);
    color: #fff;
    box-shadow: 0 14px 40px -12px rgba(168, 85, 247, 0.65), inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }
  .ft-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 20px 50px -10px rgba(168, 85, 247, 0.85); }

  .ft-btn-ghost {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(168, 85, 247, 0.4);
  }
  .ft-btn-ghost:hover { background: rgba(168, 85, 247, 0.14); border-color: rgba(168, 85, 247, 0.7); }

  /* ─── Divider ─── */
  .ft-divider {
    max-width: 1200px;
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.35), transparent);
  }

  /* ─── Main grid ─── */
  .ft-main {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 24px 56px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.3fr;
    gap: 56px;
  }

  .ft-col-brand { min-width: 0; }

  .ft-logo {
    display: inline-block;
    margin-bottom: 20px;
  }
  .ft-logo img {
    height: 52px;
    width: auto;
    display: block;
  }
  .ft-logo-light { display: none !important; }
  :root[data-theme="light"] .ft-logo-dark  { display: none !important; }
  :root[data-theme="light"] .ft-logo-light { display: block !important; }

  .ft-tagline {
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 26px;
    max-width: 340px;
  }


  /* ─── Columns ─── */
  .ft-col-title {
    font-size: 0.78rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.18);
  }

  .ft-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ft-links a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
    width: fit-content;
  }
  .ft-links a:hover { color: #C4B5FD; transform: translateX(3px); }

  /* ─── Community card ─── */
  .ft-community {
    display: block;
    text-decoration: none;
    padding: 14px 16px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(88, 101, 242, 0.16) 0%, rgba(168, 85, 247, 0.1) 100%);
    border: 1px solid rgba(88, 101, 242, 0.3);
    margin-bottom: 14px;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  }
  .ft-community:hover {
    transform: translateY(-2px);
    border-color: rgba(88, 101, 242, 0.65);
    box-shadow: 0 12px 30px -10px rgba(88, 101, 242, 0.4);
  }

  .ft-community-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ft-community-ic {
    flex-shrink: 0;
    width: 32px; height: 32px;
    color: #5865F2;
  }

  .ft-community-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .ft-community-meta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .ft-online-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #A855F7;
    box-shadow: 0 0 8px #A855F7;
    animation: ft-online-pulse 2s ease-in-out infinite;
  }

  @keyframes ft-online-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.55; }
  }

  .ft-community-cta {
    display: inline-block;
    margin-top: 10px;
    font-size: 0.78rem;
    font-weight: 700;
    color: #C4B5FD;
  }

  /* ─── Contact rows (pills premium avec icône circulaire propre) ─── */
  .ft-contact-row {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 20px 8px 8px;
    margin: 10px 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    border-radius: 9999px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.22);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
    width: fit-content;
    max-width: 100%;
    line-height: 1;
    overflow: visible;
  }
  .ft-contact-row:hover {
    color: #FFFFFF;
    background: rgba(168, 85, 247, 0.18);
    border-color: rgba(168, 85, 247, 0.55);
    transform: translateX(4px);
    box-shadow: 0 8px 24px -10px rgba(124, 58, 237, 0.4);
  }
  .ft-contact-ic {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(135deg, #A855F7, #7C3AED);
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .ft-contact-ic svg {
    width: 16px;
    height: 16px;
    color: #FFFFFF;
    display: block;
  }
  .ft-contact-row:hover .ft-contact-ic {
    transform: scale(1.06);
    box-shadow: 0 6px 18px rgba(124, 58, 237, 0.55);
  }
  .ft-contact-label {
    display: inline-block;
    line-height: 1.15;
    padding: 2px 0;
  }

  /* LIGHT MODE : icônes WhatsApp/email plus CLAIRES (violet trop foncé) */
  :root[data-theme="light"] .ft-contact-ic {
    background: linear-gradient(135deg, #C084FC, #A855F7) !important;
    box-shadow: 0 4px 14px rgba(192, 132, 252, 0.5) !important;
  }
  :root[data-theme="light"] .ft-contact-row:hover .ft-contact-ic {
    background: linear-gradient(135deg, #D8B4FE, #C084FC) !important;
    box-shadow: 0 6px 20px rgba(192, 132, 252, 0.65) !important;
  }

  /* ─── Socials ─── */
  .ft-socials {
    display: flex;
    gap: 10px;
    margin-top: 22px;
  }

  .ft-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: transform 0.2s, background 0.2s, border-color 0.2s, color 0.2s;
  }
  .ft-socials a:hover {
    transform: translateY(-2px);
    background: rgba(168, 85, 247, 0.15);
    border-color: rgba(168, 85, 247, 0.5);
    color: #E9D5FF;
  }

  /* ─── Bottom bar ─── */
  .ft-bottom {
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(168, 85, 247, 0.14);
    padding: 20px 24px;
    background: rgba(0, 0, 0, 0.2);
  }

  .ft-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  .ft-copyright {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }
  .ft-copyright strong { color: #C4B5FD; font-weight: 700; }

  .ft-trust {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .ft-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .ft-trust-item svg { color: rgba(192, 132, 252, 0.85); }
  .ft-trust-sep { opacity: 0.35; }

  /* ═══════════════ RESPONSIVE ═══════════════ */
  @media (max-width: 1024px) {
    .ft-main { grid-template-columns: 1fr 1fr; gap: 44px 40px; padding-top: 8px; }
    .ft-col-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .ft { padding-top: 72px; }
    .ft-precta { margin-bottom: 56px; padding: 28px 22px; border-radius: 22px; }
    .ft-precta-inner { flex-direction: column; align-items: flex-start; gap: 22px; }
    .ft-precta-actions { width: 100%; }
    .ft-btn { width: 100%; justify-content: center; }
    .ft-main { grid-template-columns: 1fr; gap: 36px; padding: 52px 20px 44px; }
    .ft-col-brand { grid-column: auto; }
    .ft-logo img { height: 44px; }
    .ft-bottom-inner { flex-direction: column; align-items: flex-start; }
    .ft-trust { flex-wrap: wrap; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-online-dot { animation: none; }
  }
</style>

<script>
  // Compteur "en ligne" qui fluctue subtilement (réaliste)
  const onlineEl = document.getElementById('ft-online');
  if (onlineEl) {
    let n = 128;
    setInterval(() => {
      const d = Math.floor(Math.random() * 5) - 2; // -2 à +2
      n = Math.max(98, Math.min(162, n + d));
      onlineEl.textContent = n.toString();
    }, 6000);
  }

</script>
