<footer style="padding:64px 0 40px;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;text-align:center;">

    <!-- Logo -->
    <img
      src="/images/logos/SMMIA-logo-transparent-v2.png"
      alt="SMMIA"
      style="height:70px;width:auto;margin:0 auto 16px;display:block;opacity:0.9;"
    />

    <p style="font-size:0.85rem;color:rgba(255,255,255,0.4);margin-bottom:28px;">
      Un module de la communauté Focus
